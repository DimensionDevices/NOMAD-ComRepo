<style>
*{box-sizing:border-box}body{background:#f0f4f8;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;margin:0;padding:0}.chat-container{max-width:700px;margin:0 auto;padding:15px}.chat-status{padding:10px 16px;border-radius:8px;margin-bottom:12px;font-size:14px;text-align:center;font-weight:500}.chat-status.connected{background:#d4edda;color:#155724;border:1px solid #c3e6cb}.chat-status.disconnected{background:#f8d7da;color:#721c24;border:1px solid #f5c6cb}.chat-status.connecting{background:#fff3cd;color:#856404;border:1px solid #ffc107}.chat-messages{background:#fff;border-radius:12px;border:1px solid #dce4ec;height:400px;overflow-y:auto;padding:16px;margin-bottom:12px;box-shadow:0 2px 8px rgba(0,0,0,.06);font-size:14px;line-height:1.6}.message{margin-bottom:6px;padding:6px 10px;word-wrap:break-word;animation:fadeIn .2s ease;border-radius:6px}.message.self{background:#e3f2fd;color:#1565c0;margin-left:20%}.message.other{background:#f5f5f5;color:#333;margin-right:20%}.message.system{background:#fff3cd;color:#856404;text-align:center;font-style:italic;margin:4px 0;padding:4px 10px}.message.join{background:#d4edda;color:#155724;text-align:center;margin:4px 0;padding:4px 10px}.message.part{background:#f8d7da;color:#721c24;text-align:center;margin:4px 0;padding:4px 10px}.message .sender{font-weight:600;margin-right:8px}@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}.chat-input-area{display:flex;gap:10px;align-items:center}.chat-input-area input[type=text]{flex:1;padding:12px 16px;border:2px solid #dce4ec;border-radius:25px;font-size:15px;font-family:inherit;transition:border-color .2s;background:#fff}.chat-input-area input[type=text]:focus{border-color:#6c5ce7;outline:0;box-shadow:0 0 0 3px rgba(108,92,231,.15)}.chat-input-area input[type=text]:disabled{background:#e9ecef;cursor:not-allowed}.chat-input-area button{padding:12px 24px;background:#6c5ce7;color:#fff;border:0;border-radius:25px;font-size:15px;font-weight:600;cursor:pointer;transition:background .2s;white-space:nowrap}.chat-input-area button:hover:not(:disabled){background:#5a4bd1}.chat-input-area button:disabled{background:#b2c9d6;cursor:not-allowed}.user-controls{display:flex;gap:10px;margin-bottom:12px;flex-wrap:wrap}.user-controls input{flex:1;padding:10px 14px;border:2px solid #dce4ec;border-radius:8px;font-size:14px;font-family:inherit;min-width:120px;background:#fff}.user-controls input:focus{border-color:#6c5ce7;outline:0}.user-controls button{padding:10px 20px;color:#fff;border:0;border-radius:8px;font-weight:600;cursor:pointer;transition:background .2s;font-size:14px}.user-controls button.join{background:#2ecc71}.user-controls button.join:hover{background:#27ae60}.user-controls button.danger{background:#e74c3c}.user-controls button.danger:hover{background:#c0392b}.user-controls button.copy{background:#6c5ce7}.user-controls button.copy:hover{background:#5a4bd1}.signaling-box{background:#f8f9fa;border:2px dashed #dce4ec;border-radius:8px;padding:12px;margin-bottom:12px;font-family:monospace;font-size:12px;word-wrap:break-word;max-height:120px;overflow-y:auto}.signaling-box .label{font-weight:600;color:#6c757d;font-size:11px;margin-bottom:4px}.signaling-input{display:flex;gap:8px;margin-bottom:12px}.signaling-input input{flex:1;padding:10px 14px;border:2px solid #dce4ec;border-radius:8px;font-size:13px;font-family:monospace;background:#fff}.signaling-input input:focus{border-color:#6c5ce7;outline:0}.signaling-input button{padding:10px 20px;background:#3498db;color:#fff;border:0;border-radius:8px;font-weight:600;cursor:pointer;transition:background .2s;white-space:nowrap}.signaling-input button:hover{background:#2980b9}.user-count{text-align:center;font-size:13px;color:#7f8c8d;margin-top:8px}.peers{text-align:center;font-size:12px;color:#6c757d;margin:4px 0 8px;padding:4px;background:#f8f9fa;border-radius:4px}.toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);background:#333;color:#fff;padding:12px 24px;border-radius:8px;font-size:14px;z-index:9999;animation:slideUp .3s ease;max-width:90%;text-align:center;box-shadow:0 4px 12px rgba(0,0,0,.3)}.toast.success{background:#2ecc71}.toast.error{background:#e74c3c}.toast.info{background:#3498db}@keyframes slideUp{from{opacity:0;transform:translateX(-50%) translateY(20px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}@media(max-width:600px){.chat-messages{height:350px;padding:12px}.message.self{margin-left:10%}.message.other{margin-right:10%}.chat-input-area{flex-wrap:wrap}.chat-input-area input[type=text]{min-width:100%}.chat-input-area button{width:100%}.user-controls{flex-direction:column}.user-controls input{min-width:100%}.signaling-input{flex-direction:column}.signaling-input input{min-width:100%}}</style>
<div class=chat-container><div id=status class="chat-status connecting">Initializing...</div><div class=user-controls><input type=text id=usernameInput placeholder="Your name..." value="User"><button class=join onclick=createRoom()>Create Room</button><button class=copy onclick=copySignaling()>Copy</button><button class=danger onclick=leaveChat()>Leave</button></div><div class=signaling-box><div class=label>Your Signaling Data (share this with others)</div><div id=signalingData style=font-size:11px;word-break:break-all;color:#333>Create a room first</div></div><div class=signaling-input><input type=text id=signalInput placeholder="Paste signaling data here to join a room..."><button onclick=pasteAndJoin()>Join Room</button></div><div id=messages class=chat-messages><div class="message system">Create a room or paste signaling data to join</div></div><div class=chat-input-area><input type=text id=messageInput placeholder="Type a message..." disabled><button id=sendBtn onclick=sendMessage() disabled>Send</button></div><div id=userCount class=user-count>0 peers</div><div class=peers id=peerStatus>No peers connected</div></div>
<script>
let username="User",peerConnection=null,dataChannel=null,isConnected=!1,isInitiator=!1,localDescription=null,pendingCandidates=[],answerReceived=!1,gatheringComplete=!1;
