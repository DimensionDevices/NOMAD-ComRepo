{
  "html": "<div id='launcher-overlay'><style>#launcher-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:var(--bg);z-index:9998;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;padding:40px 20px;overflow-y:auto;box-sizing:border-box}.launcher-header{display:flex;flex-direction:column;align-items:center;margin-bottom:40px;width:100%;position:relative}.launcher-header h1{font-size:2.5rem;margin:0;color:var(--text);display:flex;align-items:center;gap:10px}.launcher-header h1 sup{font-size:.5rem;font-weight:400;opacity:.7}.launcher-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;width:100%;max-width:600px}.launcher-item{display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--surface);border-radius:20px;padding:16px 8px;aspect-ratio:1/1;cursor:pointer;transition:all .2s ease;border:1px solid var(--border);color:var(--text);text-decoration:none;gap:4px;position:relative}.launcher-item:hover{transform:scale(1.05);background:var(--accent);color:#fff;border-color:var(--accent)}.launcher-item.disabled{opacity:0.4;cursor:default;pointer-events:none}.launcher-item.disabled:hover{transform:none;background:var(--surface);color:var(--text);border-color:var(--border)}.launcher-icon{font-size:36px;line-height:1}.launcher-item span{font-size:.7rem;text-align:center;opacity:.8;font-weight:500}.launcher-page{display:none;width:100%;max-width:600px}.launcher-page.active{display:block}.launcher-back{position:absolute;top:0;left:0;background:transparent;border:none;font-size:28px;cursor:pointer;color:var(--text);padding:4px 12px}.launcher-back:hover{opacity:0.7}.bookmark-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;width:100%}.bookmark-item{display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--surface);border-radius:20px;padding:16px 8px;aspect-ratio:1/1;cursor:pointer;transition:all .2s ease;border:1px solid var(--border);color:var(--text);text-decoration:none;gap:4px;position:relative}.bookmark-item:hover{transform:scale(1.05);background:var(--accent);color:#fff;border-color:var(--accent)}.bookmark-icon{font-size:32px;line-height:1}.bookmark-item span{font-size:.65rem;text-align:center;opacity:.8;font-weight:500;word-break:break-all}</style><div class=launcher-header><button class=launcher-back id=launcherBack style=display:none>‹</button><h1>NOMAD<sup>v1.0</sup></h1></div><div class=launcher-page id=mainPage><div class=launcher-grid id=launcherGrid></div></div><div class=launcher-page id=bookmarkPage><div class=bookmark-grid id=bookmarkGrid></div></div></div>",
  "css": "",
  "js": "(function(){var overlay=document.getElementById('launcher-overlay');if(!overlay){overlay=document.createElement('div');overlay.id='launcher-overlay';document.body.appendChild(overlay);var style=document.createElement('style');style.textContent='#launcher-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:var(--bg);z-index:9998;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;padding:40px 20px;overflow-y:auto;box-sizing:border-box}.launcher-header{display:flex;flex-direction:column;align-items:center;margin-bottom:40px;width:100%;position:relative}.launcher-header h1{font-size:2.5rem;margin:0;color:var(--text);display:flex;align-items:center;gap:10px}.launcher-header h1 sup{font-size:.5rem;font-weight:400;opacity:.7}.launcher-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;width:100%;max-width:600px}.launcher-item{display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--surface);border-radius:20px;padding:16px 8px;aspect-ratio:1/1;cursor:pointer;transition:all .2s ease;border:1px solid var(--border);color:var(--text);text-decoration:none;gap:4px;position:relative}.launcher-item:hover{transform:scale(1.05);background:var(--accent);color:#fff;border-color:var(--accent)}.launcher-item.disabled{opacity:0.4;cursor:default;pointer-events:none}.launcher-item.disabled:hover{transform:none;background:var(--surface);color:var(--text);border-color:var(--border)}.launcher-icon{font-size:36px;line-height:1}.launcher-item span{font-size:.7rem;text-align:center;opacity:.8;font-weight:500}.launcher-page{display:none;width:100%;max-width:600px}.launcher-page.active{display:block}.launcher-back{position:absolute;top:0;left:0;background:transparent;border:none;font-size:28px;cursor:pointer;color:var(--text);padding:4px 12px}.launcher-back:hover{opacity:0.7}.bookmark-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;width:100%}.bookmark-item{display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--surface);border-radius:20px;padding:16px 8px;aspect-ratio:1/1;cursor:pointer;transition:all .2s ease;border:1px solid var(--border);color:var(--text);text-decoration:none;gap:4px;position:relative}.bookmark-item:hover{transform:scale(1.05);background:var(--accent);color:#fff;border-color:var(--accent)}.bookmark-icon{font-size:32px;line-height:1}.bookmark-item span{font-size:.65rem;text-align:center;opacity:.8;font-weight:500;word-break:break-all}';document.head.appendChild(style);overlay.innerHTML='<div class=launcher-header><button class=launcher-back id=launcherBack style=display:none>‹</button><h1>NOMAD<sup>v1.0</sup></h1></div><div class=launcher-page id=mainPage><div class=launcher-grid id=launcherGrid></div></div><div class=launcher-page id=bookmarkPage><div class=bookmark-grid id=bookmarkGrid></div></div>';}function openModal(title,content){var existing=document.getElementById('launcherModal');if(existing)existing.remove();var modal=document.createElement('div');modal.id='launcherModal';modal.style.cssText='position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);z-index:10001;display:flex;align-items:center;justify-content:center;padding:0px;box-sizing:border-box;';var container=document.createElement('div');container.style.cssText='background:var(--bg);border-radius:20px;max-width:90%;max-height:90%;width:600px;padding:10px;overflow-y:auto;border:1px solid var(--border);position:relative;';var close=document.createElement('button');close.textContent='✕';close.style.cssText='position:absolute;top:10px;right:15px;background:transparent;border:none;font-size:24px;cursor:pointer;color:var(--text);';close.onclick=function(){modal.remove();};var titleEl=document.createElement('h2');titleEl.textContent=title;titleEl.style.cssText='margin-top:0;margin-bottom:20px;color:var(--text);';var contentEl=document.createElement('div');contentEl.innerHTML=content;container.appendChild(close);container.appendChild(titleEl);container.appendChild(contentEl);modal.appendChild(container);document.body.appendChild(modal);}function showBookmarks(){document.getElementById('mainPage').classList.remove('active');document.getElementById('bookmarkPage').classList.add('active');document.getElementById('launcherBack').style.display='block';}function showMain(){document.getElementById('bookmarkPage').classList.remove('active');document.getElementById('mainPage').classList.add('active');document.getElementById('launcherBack').style.display='none';}document.getElementById('launcherBack').onclick=showMain;var grid=document.getElementById('launcherGrid');var bookmarkGrid=document.getElementById('bookmarkGrid');function stripCategoryBadges(html){var temp=document.createElement('div');temp.innerHTML=html;temp.querySelectorAll('.category-badge').forEach(function(el){el.remove();});return temp.innerHTML;}function renderGrid(){grid.innerHTML='';bookmarkGrid.innerHTML='';var baseItems=[{id:'headerDetails',label:'Status',icon:'📊'},{id:'filesDetails',label:'Files',icon:'📁'},{id:'nodesDetails',label:'Nodes',icon:'📡'},{id:'loraMessengerDetails',label:'Chat',icon:'💬'},{id:'createFile',label:'Create',icon:'➕'},{id:'fileInput',label:'Upload',icon:'📤'},{id:'helpModalBtn',label:'Settings',icon:'⚙️'}];var favList=document.getElementById('favoritesList');var favs=favList?favList.querySelectorAll('.file-item'):[];var extList=document.getElementById('extFileList');var extCount=extList?extList.querySelectorAll('.file-item').length:0;baseItems.forEach(function(item){var div=document.createElement('div');div.className='launcher-item';div.innerHTML='<div class=launcher-icon>'+item.icon+'</div><span>'+item.label+'</span>';if(item.id==='createFile'){div.onclick=function(e){e.stopPropagation();if(typeof openCreateFileModal==='function'){openCreateFileModal();}else if(window.openCreateFileModal){window.openCreateFileModal();}else{var btn=document.getElementById('createFileBtn');if(btn)btn.click();}};}else if(item.id==='fileInput'){div.onclick=function(e){e.stopPropagation();var input=document.getElementById('fileInput');if(input)input.click();};}else if(item.id==='helpModalBtn'){div.onclick=function(e){e.stopPropagation();var btn=document.getElementById('helpModalBtn');if(btn)btn.click();};}else if(item.id==='filesDetails'){div.onclick=function(e){e.stopPropagation();var list=document.getElementById('fileList');if(list){var content=list.cloneNode(true);openModal('Files',stripCategoryBadges(content.innerHTML));}};}else if(item.id==='nodesDetails'){div.onclick=function(e){e.stopPropagation();var nodes=document.getElementById('nodeList');if(nodes){var content=nodes.cloneNode(true);openModal('Nodes',stripCategoryBadges(content.innerHTML));}};}else if(item.id==='loraMessengerDetails'){div.onclick=function(e){e.stopPropagation();var chat=document.getElementById('chatWindow');if(chat){var parent=chat.parentNode;var clone=parent.cloneNode(true);openModal('Chat',stripCategoryBadges(clone.innerHTML));}};}else if(item.id==='headerDetails'){div.onclick=function(e){e.stopPropagation();var status=document.querySelector('.status-bar');if(status){var content=status.cloneNode(true);openModal('Status',stripCategoryBadges(content.innerHTML));}};}grid.appendChild(div);});var extDiv=document.createElement('div');extDiv.className='launcher-item'+(extCount===0?' disabled':'');extDiv.innerHTML='<div class=launcher-icon>🧩</div><span>Extensions'+(extCount>0?' ('+extCount+')':'')+'</span>';if(extCount>0){extDiv.onclick=function(e){e.stopPropagation();var extList=document.getElementById('extFileList');if(extList){var content=extList.cloneNode(true);openModal('Extensions',stripCategoryBadges(content.innerHTML));}};}grid.appendChild(extDiv);var bookmarksDiv=document.createElement('div');bookmarksDiv.className='launcher-item';bookmarksDiv.innerHTML='<div class=launcher-icon>⭐</div><span>Bookmarks'+(favs.length>0?' ('+favs.length+')':'')+'</span>';bookmarksDiv.onclick=function(e){e.stopPropagation();if(favs.length===0){openModal('Bookmarks','<div style=text-align:center;padding:40px;color:var(--text-dim);>No bookmarks yet</div>');}else{showBookmarks();}};grid.appendChild(bookmarksDiv);favs.forEach(function(li){var nameEl=li.querySelector('.file-name strong');if(nameEl){var name=nameEl.textContent.trim();var div=document.createElement('div');div.className='bookmark-item';div.innerHTML='<div class=bookmark-icon>⭐</div><span>'+name+'</span>';div.onclick=function(e){e.stopPropagation();if(typeof viewFile==='function'){viewFile(name);}else if(window.viewFile){window.viewFile(name);}else{var favs=document.getElementById('favoritesList');if(favs){var items=favs.querySelectorAll('.file-item');items.forEach(function(li){var nameEl=li.querySelector('.file-name strong');if(nameEl&&nameEl.textContent.trim()===name){var viewBtn=li.querySelector('.btn-success');if(viewBtn)viewBtn.click();}});}}};bookmarkGrid.appendChild(div);}});if(favs.length===0){var empty=document.createElement('div');empty.style.cssText='grid-column:1/-1;text-align:center;padding:40px;color:var(--text-dim);font-size:0.9rem;';empty.textContent='No bookmarks yet. Star files to add them here.';bookmarkGrid.appendChild(empty);}}renderGrid();var favObserver=new MutationObserver(function(){renderGrid();});var favList=document.getElementById('favoritesList');if(favList){favObserver.observe(favList,{childList:true,subtree:true});}var extObserver=new MutationObserver(function(){renderGrid();});var extList=document.getElementById('extFileList');if(extList){extObserver.observe(extList,{childList:true,subtree:true});}var header=document.querySelector('.header summary');if(header){var newHeader=header.cloneNode(true);header.parentNode.replaceChild(newHeader,header);newHeader.onclick=function(e){e.preventDefault();e.stopPropagation();var overlay=document.getElementById('launcher-overlay');if(overlay.style.display==='none'||overlay.style.display===''){overlay.style.display='flex';showMain();}else{overlay.style.display='none';}};}showMain();overlay.style.display='flex';})();",
  "target": "header"
}