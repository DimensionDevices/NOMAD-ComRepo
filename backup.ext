{
  "description":"A zipped file backup/archive button, added to the options menu.",
  "html": "<style>.backup-btn{background:var(--accent);color:#fff;border:none;padding:6px 12px;border-radius:6px;cursor:pointer;font-size:.85em;transition:all .2s ease;display:inline-flex;align-items:center;gap:4px;}.backup-btn:hover{opacity:.85;transform:scale(1.02);}.backup-btn:disabled{opacity:.5;cursor:not-allowed;transform:none;}</style><div id=backupControls style=display:none;><div style=padding:12px 0;><div style=display:flex;gap:8px;flex-wrap:wrap;align-items:center;><button class=backup-btn id=backupBtn>💾 Backup All Files</button></div><div style=margin-top:8px;font-size:.7em;color:var(--text-dim);><span id=backupStatus>Ready</span></div></div></div>",
  "css": "",
  "js": "var BACKUP_KEY='nomad_backup_data';console.log('[Backup] Extension loaded');function getBackupMeta(){try{var data=localStorage.getItem(BACKUP_KEY);if(data){console.log('[Backup] Found backup meta');return JSON.parse(data)}console.log('[Backup] No backup meta found');return null}catch(e){console.error('[Backup] Error reading backup meta:',e);return null}}function setBackupMeta(meta){try{localStorage.setItem(BACKUP_KEY,JSON.stringify(meta));console.log('[Backup] Backup meta saved:',meta)}catch(e){console.error('[Backup] Error saving backup meta:',e)}}function updateStatus(msg,isError){console.log('[Backup] Status update:',msg,isError?'(ERROR)':'');var el=document.getElementById('backupStatus');if(el){el.textContent=msg;el.style.color=isError?'#f44336':'var(--text-dim)';setTimeout(function(){if(!isError)el.textContent='Ready'},3000)}}function sanitizeFilename(name){console.log('[Backup] Sanitizing filename:',name);var original=name;name=name.replace(/[\\x00-\\x1F]/g,'');name=name.replace(/[<>:\"/\\\\|?*]/g,'');name=name.replace(/[^\\x20-\\x7E]/g,'_');name=name.replace(/\\s+/g,'_');name=name.replace(/_+/g,'_');name=name.replace(/^_+|_+$/g,'');if(!name||name==='_'){console.log('[Backup] Filename sanitized to empty, using \"file\"');name='file'}console.log('[Backup] Sanitized:',original,'->',name);return name}function getAllFiles(){console.log('[Backup] Fetching file list from /api/files...');return fetch('/api/files').then(function(r){if(!r.ok){throw new Error('HTTP '+r.status)}return r.json()}).then(function(data){console.log('[Backup] Found',data.files.length,'files from API');var files=[];data.files.forEach(function(file){var name=file.name;var sanitized=sanitizeFilename(name);if(sanitized){files.push({original:name,sanitized:sanitized,size:file.size})}});console.log('[Backup] Total files to backup:',files.length);return files}).catch(function(err){console.error('[Backup] Error fetching file list:',err);updateStatus('Failed to fetch file list',true);return []})}function getFileContent(filename){console.log('[Backup] Fetching file:',filename);return fetch('/api/view-file?filename='+encodeURIComponent(filename)).then(function(r){if(!r.ok){console.error('[Backup] Failed to fetch',filename,'HTTP',r.status);throw new Error('HTTP '+r.status)}console.log('[Backup] Successfully fetched',filename);return r.text()}).then(function(data){console.log('[Backup] Received content for',filename,'length:',data.length);return data}).catch(function(err){console.error('[Backup] Error fetching',filename,':',err);return null})}function stringToUint8Array(str){var len=str.length;var bytes=new Uint8Array(len);for(var i=0;i<len;i++){bytes[i]=str.charCodeAt(i)&255}return bytes}function crc32(b){var c=-1;for(var i=0;i<b.length;i++){c^=b[i];for(var j=0;j<8;j++)c=(c&1)?(c>>>1)^0xEDB88320:c>>>1}return(c^-1)>>>0}function createZip(F){function w16(b,p,v){b[p]=v&255;b[p+1]=v>>>8&255}function w32(b,p,v){b[p]=v&255;b[p+1]=v>>>8&255;b[p+2]=v>>>16&255;b[p+3]=v>>>24&255}var L=[],C=[],O=0;F.forEach(function(f){var n=f.sanitized,c=stringToUint8Array(f.content),cl=c.length,crc=crc32(c),nb=stringToUint8Array(n),nl=nb.length,mt=0,md=0,lh=new Uint8Array(30+nl),p=0;w32(lh,p,0x04034b50);p+=4;w16(lh,p,20);p+=2;w16(lh,p,0);p+=2;w16(lh,p,0);p+=2;w16(lh,p,mt);p+=2;w16(lh,p,md);p+=2;w32(lh,p,crc);p+=4;w32(lh,p,cl);p+=4;w32(lh,p,cl);p+=4;w16(lh,p,nl);p+=2;w16(lh,p,0);p+=2;lh.set(nb,p);L.push(lh,c);var ch=new Uint8Array(46+nl);p=0;w32(ch,p,0x02014b50);p+=4;w16(ch,p,20);p+=2;w16(ch,p,20);p+=2;w16(ch,p,0);p+=2;w16(ch,p,0);p+=2;w16(ch,p,mt);p+=2;w16(ch,p,md);p+=2;w32(ch,p,crc);p+=4;w32(ch,p,cl);p+=4;w32(ch,p,cl);p+=4;w16(ch,p,nl);p+=2;w16(ch,p,0);p+=2;w16(ch,p,0);p+=2;w16(ch,p,0);p+=2;w16(ch,p,0);p+=2;w32(ch,p,0x20);p+=4;w32(ch,p,O);p+=4;ch.set(nb,p);C.push(ch);O+=lh.length+cl});var CS=C.reduce((a,b)=>a+b.length,0),end=new Uint8Array(22),p=0;w32(end,p,0x06054b50);p+=4;w16(end,p,0);p+=2;w16(end,p,0);p+=2;w16(end,p,F.length);p+=2;w16(end,p,F.length);p+=2;w32(end,p,CS);p+=4;w32(end,p,O);p+=4;w16(end,p,0);p+=2;var TL=L.reduce((a,b)=>a+b.length,0)+CS+end.length,final=new Uint8Array(TL),pos=0;L.forEach(function(x){final.set(x,pos);pos+=x.length});C.forEach(function(x){final.set(x,pos);pos+=x.length});final.set(end,pos);return final;}
function createZip(F){function w16(b,p,v){b[p]=v&255;b[p+1]=v>>>8&255}function w32(b,p,v){b[p]=v&255;b[p+1]=v>>>8&255;b[p+2]=v>>>16&255;b[p+3]=v>>>24&255}var L=[],C=[],O=0;F.forEach(function(f){var n=f.sanitized,c=stringToUint8Array(f.content),cl=c.length,crc=crc32(c),nb=stringToUint8Array(n),nl=nb.length,mt=0,md=0,lh=new Uint8Array(30+nl),p=0;w32(lh,p,0x04034b50);p+=4;w16(lh,p,20);p+=2;w16(lh,p,0);p+=2;w16(lh,p,0);p+=2;w16(lh,p,mt);p+=2;w16(lh,p,md);p+=2;w32(lh,p,crc);p+=4;w32(lh,p,cl);p+=4;w32(lh,p,cl);p+=4;w16(lh,p,nl);p+=2;w16(lh,p,0);p+=2;lh.set(nb,p);L.push(lh,c);var ch=new Uint8Array(46+nl);p=0;w32(ch,p,0x02014b50);p+=4;w16(ch,p,20);p+=2;w16(ch,p,20);p+=2;w16(ch,p,0);p+=2;w16(ch,p,0);p+=2;w16(ch,p,mt);p+=2;w16(ch,p,md);p+=2;w32(ch,p,crc);p+=4;w32(ch,p,cl);p+=4;w32(ch,p,cl);p+=4;w16(ch,p,nl);p+=2;w16(ch,p,0);p+=2;w16(ch,p,0);p+=2;w16(ch,p,0);p+=2;w16(ch,p,0);p+=2;w32(ch,p,0x20);p+=4;w32(ch,p,O);p+=4;ch.set(nb,p);C.push(ch);O+=lh.length+cl});var CS=C.reduce((a,b)=>a+b.length,0),end=new Uint8Array(22),p=0;w32(end,p,0x06054b50);p+=4;w16(end,p,0);p+=2;w16(end,p,0);p+=2;w16(end,p,F.length);p+=2;w16(end,p,F.length);p+=2;w32(end,p,CS);p+=4;w32(end,p,O);p+=4;w16(end,p,0);p+=2;var TL=L.reduce((a,b)=>a+b.length,0)+CS+end.length,final=new Uint8Array(TL),pos=0;L.forEach(function(x){final.set(x,pos);pos+=x.length});C.forEach(function(x){final.set(x,pos);pos+=x.length});final.set(end,pos);return final;}function downloadZip(data,filename){console.log('[Backup] Downloading ZIP:',filename,'size:',data.length,'bytes');var blob=new Blob([data],{type:'application/zip'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=filename||'nomad_backup_'+new Date().toISOString().slice(0,10)+'.zip';document.body.appendChild(a);a.click();document.body.removeChild(a);console.log('[Backup] Download triggered');setTimeout(function(){URL.revokeObjectURL(a.href);console.log('[Backup] Object URL revoked')},5000)}function performBackup(){console.log('[Backup] ====== BACKUP STARTED ======');var btn=document.getElementById('backupBtn');if(btn){btn.disabled=true;btn.textContent='⏳ Scanning...';console.log('[Backup] Button disabled')}updateStatus('Fetching file list...');getAllFiles().then(function(fileList){if(fileList.length===0){console.warn('[Backup] No files found');updateStatus('No files found to backup',true);if(btn){btn.disabled=false;btn.textContent='💾 Backup All Files'}return}updateStatus('Found '+fileList.length+' files. Downloading...');var files=[];var total=fileList.length;var loaded=0;var errors=[];fileList.forEach(function(fileInfo,index){console.log('[Backup] Downloading',index+1,'of',total,':',fileInfo.original);getFileContent(fileInfo.original).then(function(content){if(content!==null){files.push({sanitized:fileInfo.sanitized,content:content});console.log('[Backup] Downloaded',fileInfo.original,'successfully')}else{errors.push(fileInfo.original);console.warn('[Backup] Failed to download',fileInfo.original)}loaded++;updateStatus('Downloading '+fileInfo.original+' ('+loaded+'/'+total+')');console.log('[Backup] Progress:',loaded,'/',total);if(loaded===total){console.log('[Backup] All files downloaded. Files:',files.length,'Errors:',errors.length);if(errors.length>0){console.warn('[Backup] Failed to download',errors.length,'files:',errors);updateStatus('Failed to download '+errors.length+' files',true)}else{console.log('[Backup] All files downloaded successfully');updateStatus('Creating ZIP archive...')}console.log('[Backup] Creating ZIP...');var zipData=createZip(files);var meta={date:new Date().toISOString(),fileCount:total,size:zipData.length};setBackupMeta(meta);var sizeKB=Math.round(zipData.length/1024);console.log('[Backup] Backup complete!',total,'files,',sizeKB,'KB');updateStatus('Backup complete! '+total+' files, '+sizeKB+'KB');downloadZip(zipData,'nomad_backup_'+new Date().toISOString().slice(0,10)+'.zip');if(btn){btn.disabled=false;btn.textContent='💾 Backup All Files';console.log('[Backup] Button re-enabled')}}})})})}function injectBackupControls(){console.log('[Backup] Injecting backup controls');var extOptions=document.getElementById('extOptions');if(!extOptions){console.warn('[Backup] extOptions not found');return}if(extOptions.querySelector('.backup-controls-injected')){console.log('[Backup] Controls already injected');return}var controls=document.getElementById('backupControls');if(!controls){console.warn('[Backup] backupControls not found');return}var clone=controls.cloneNode(true);clone.id='backupControlsInjected';clone.className='backup-controls-injected';clone.style.display='block';clone.style.marginBottom='20px';var title=document.createElement('div');title.style.cssText='font-weight:600;font-size:1em;margin-bottom:8px;color:var(--text);';title.textContent='💾 Backup';clone.insertBefore(title,clone.firstChild);extOptions.insertBefore(clone,extOptions.firstChild);console.log('[Backup] Controls injected');var backupBtn=document.getElementById('backupBtn');if(backupBtn){backupBtn.addEventListener('click',function(){console.log('[Backup] Backup button clicked');performBackup()});console.log('[Backup] Backup button listener attached')}else{console.warn('[Backup] backupBtn not found')}var meta=getBackupMeta();if(meta){var sizeKB=Math.round(meta.size/1024);console.log('[Backup] Existing backup found:',meta.fileCount,'files,',sizeKB,'KB from',meta.date);updateStatus('Backup exists: '+meta.fileCount+' files, '+sizeKB+'KB from '+new Date(meta.date).toLocaleDateString())}else{console.log('[Backup] No existing backup found');updateStatus('No backup saved')}}document.addEventListener('DOMContentLoaded',function(){console.log('[Backup] DOM Content Loaded');var origOpenHelp=window.openHelpModal;window.openHelpModal=function(){console.log('[Backup] openHelpModal called');if(origOpenHelp)origOpenHelp();setTimeout(injectBackupControls,150)};var origInitHelp=window.initHelpModal;window.initHelpModal=function(){console.log('[Backup] initHelpModal called');if(origInitHelp)origInitHelp();setTimeout(injectBackupControls,150)};setTimeout(injectBackupControls,500)})",
  "target": "options"
}