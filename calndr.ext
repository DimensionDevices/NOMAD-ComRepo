{
  "description": "Personal Calendar with local storage - Add and manage entries",
  "html": "<details class='section' id='calendarSection'><summary><h2><svg style='position:relative;top:6px' width='24px' height='24px' viewBox='0 0 24 24' fill='none' stroke='var(--text)' stroke-width='2'><rect x='3' y='4' width='18' height='18' rx='2' ry='2'></rect><line x1='16' y1='2' x2='16' y2='6'></line><line x1='8' y1='2' x2='8' y2='6'></line><line x1='3' y1='10' x2='21' y2='10'></line></svg>&nbsp;Calendar &amp; Notes</h2></summary><div style='padding:15px;'><div id='calendarDisplay' style='margin-bottom:15px;'></div><button onclick='window.openModal()' class='btn btn-primary' style='width:100%;padding:10px;background:var(--accent);color:var(--bg);border:none;border-radius:4px;cursor:pointer;font-weight:bold;margin-bottom:15px;'>➕ Add New Entry</button><div id='entriesList' style='max-height:400px;overflow-y:auto;'></div></div></details><div id='entryModal' style='display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:9999;justify-content:center;align-items:center;'><div style='background:var(--bg);border-radius:12px;padding:25px;max-width:400px;width:90%;box-shadow:0 10px 40px rgba(0,0,0,0.3);border:1px solid var(--border);'><h3 style='margin-top:0;color:var(--text);'>📝 Add Calendar Entry</h3><div style='display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;'><input type='date' id='entryDate' style='background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:8px;'><input type='time' id='entryTime' style='background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:8px;'></div><input type='text' id='entryTitle' placeholder='Entry title...' style='width:100%;background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:8px;margin-bottom:10px;'><textarea id='entryNote' placeholder='Note (optional)' style='width:100%;background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:8px;margin-bottom:15px;resize:vertical;min-height:60px;'></textarea><div style='display:flex;gap:10px;'><button onclick='window.addCalendarEntry()' class='btn btn-primary' style='flex:1;padding:10px;background:var(--accent);color:var(--bg);border:none;border-radius:4px;cursor:pointer;font-weight:bold;'>Save Entry</button><button onclick='window.closeModal()' style='padding:10px 20px;background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:4px;cursor:pointer;'>Cancel</button></div></div></div>",
  "css": ".calendar-grid { display:grid; grid-template-columns:repeat(7,1fr); gap:4px; margin-bottom:15px; } .calendar-grid .day-header { font-weight:bold; text-align:center; padding:5px; color:var(--text-dim); font-size:12px; } .calendar-grid .day { text-align:center; padding:8px; border-radius:4px; cursor:pointer; background:var(--bg); border:1px solid var(--border); } .calendar-grid .day:hover { background:var(--accent); color:var(--bg); } .calendar-grid .day.has-entry { background:var(--accent-light); border-color:var(--accent); } .calendar-grid .day.empty { background:transparent; border:1px solid transparent; cursor:default; } .calendar-grid .day.today { border-color:var(--accent); font-weight:bold; } .entry-item { background:var(--surface); padding:10px; margin-bottom:8px; border-radius:4px; border-left:3px solid var(--accent); display:flex; justify-content:space-between; align-items:center; } .entry-item .entry-info { flex:1; } .entry-item .entry-time { color:var(--text-dim); font-size:12px; margin-right:10px; } .entry-item .entry-title { font-weight:bold; } .entry-item .entry-note { color:var(--text-dim); font-size:13px; margin-top:4px; } .entry-item .delete-btn { background:transparent; border:none; color:var(--text-dim); cursor:pointer; font-size:18px; padding:0 5px; } .entry-item .delete-btn:hover { color:#ff4444; } .month-nav { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; } .month-nav button { background:var(--surface); border:1px solid var(--border); border-radius:4px; padding:5px 15px; cursor:pointer; color:var(--text); } .month-nav button:hover { background:var(--accent); color:var(--bg); } .month-nav .month-year { font-weight:bold; font-size:16px; } .no-entries { color:var(--text-dim); text-align:center; padding:20px; }",
  "js": "var calendarData = JSON.parse(localStorage.getItem('calendarEntries') || '{}');var currentDate = new Date();var currentMonth = currentDate.getMonth();var currentYear = currentDate.getFullYear();function saveCalendarData() { localStorage.setItem('calendarEntries', JSON.stringify(calendarData)); }function getDateKey(year, month, day) { return year + '-' + String(month + 1).padStart(2, '0') + '-' + String(day).padStart(2, '0'); }function getEntriesForDate(dateKey) { return calendarData[dateKey] || []; }window.openModal = function() { var today = new Date(); var dateInput = document.getElementById('entryDate'); var timeInput = document.getElementById('entryTime'); if (dateInput) { dateInput.value = getDateKey(today.getFullYear(), today.getMonth(), today.getDate()); } if (timeInput) { timeInput.value = String(today.getHours()).padStart(2,'0') + ':' + String(today.getMinutes()).padStart(2,'0'); } document.getElementById('entryTitle').value = ''; document.getElementById('entryNote').value = ''; document.getElementById('entryModal').style.display = 'flex'; };window.closeModal = function() { document.getElementById('entryModal').style.display = 'none'; };function renderCalendar() { var display = document.getElementById('calendarDisplay'); if (!display) return; var firstDay = new Date(currentYear, currentMonth, 1).getDay(); var daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate(); var today = new Date(); var todayKey = getDateKey(today.getFullYear(), today.getMonth(), today.getDate()); var html = '<div class=\"month-nav\">'; html += '<button onclick=\"window.changeMonth(-1)\">‹</button>'; html += '<span class=\"month-year\">' + new Date(currentYear, currentMonth).toLocaleString('default', {month:'long', year:'numeric'}) + '</span>'; html += '<button onclick=\"window.changeMonth(1)\">›</button>'; html += '</div>'; html += '<div class=\"calendar-grid\">'; ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].forEach(function(d) { html += '<div class=\"day-header\">' + d + '</div>'; }); for (var i = 0; i < firstDay; i++) { html += '<div class=\"day empty\"></div>'; } for (var day = 1; day <= daysInMonth; day++) { var dateKey = getDateKey(currentYear, currentMonth, day); var hasEntry = calendarData[dateKey] && calendarData[dateKey].length > 0; var isToday = dateKey === todayKey; var classNames = 'day' + (hasEntry ? ' has-entry' : '') + (isToday ? ' today' : ''); html += '<div class=\"' + classNames + '\" onclick=\"window.showEntriesForDate(\\'' + dateKey + '\\')\">' + day + '</div>'; } html += '</div>'; display.innerHTML = html; if (calendarData[todayKey]) { window.showEntriesForDate(todayKey); } else { var keys = Object.keys(calendarData); if (keys.length > 0) { window.showEntriesForDate(keys[0]); } else { var list = document.getElementById('entriesList'); if (list) list.innerHTML = '<div class=\"no-entries\">No entries yet. Click \"Add New Entry\" to get started!</div>'; } } }window.showEntriesForDate = function(dateKey) { var entries = getEntriesForDate(dateKey); var list = document.getElementById('entriesList'); if (!list) return; if (entries.length === 0) { list.innerHTML = '<div class=\"no-entries\">No entries for this date.</div>'; return; } entries.sort(function(a, b) { return a.time.localeCompare(b.time); }); var html = '<div style=\"margin-bottom:8px;font-weight:bold;color:var(--text-dim);\">📅 ' + dateKey + '</div>'; entries.forEach(function(entry, index) { html += '<div class=\"entry-item\">'; html += '<div class=\"entry-info\">'; html += '<span class=\"entry-time\">' + entry.time + '</span>'; html += '<span class=\"entry-title\">' + entry.title + '</span>'; if (entry.note) { html += '<div class=\"entry-note\">' + entry.note + '</div>'; } html += '</div>'; html += '<button class=\"delete-btn\" onclick=\"window.deleteEntry(\\'' + dateKey + '\\',' + index + ')\">✕</button>'; html += '</div>'; }); list.innerHTML = html; };window.changeMonth = function(delta) { currentMonth += delta; if (currentMonth > 11) { currentMonth = 0; currentYear++; } if (currentMonth < 0) { currentMonth = 11; currentYear--; } renderCalendar(); };window.addCalendarEntry = function() { var dateInput = document.getElementById('entryDate'); var timeInput = document.getElementById('entryTime'); var titleInput = document.getElementById('entryTitle'); var noteInput = document.getElementById('entryNote'); if (!dateInput.value) { alert('Please select a date.'); return; } if (!titleInput.value.trim()) { alert('Please enter a title.'); return; } var dateKey = dateInput.value; var time = timeInput.value || '00:00'; var title = titleInput.value.trim(); var note = noteInput.value.trim(); if (!calendarData[dateKey]) { calendarData[dateKey] = []; } calendarData[dateKey].push({ time: time, title: title, note: note }); saveCalendarData(); window.closeModal(); renderCalendar(); };window.deleteEntry = function(dateKey, index) { if (confirm('Delete this entry?')) { calendarData[dateKey].splice(index, 1); if (calendarData[dateKey].length === 0) { delete calendarData[dateKey]; } saveCalendarData(); renderCalendar(); } };function initCalendar() { renderCalendar(); }if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', initCalendar); } else { initCalendar(); }document.addEventListener('click', function(e) { var modal = document.getElementById('entryModal'); if (e.target === modal) { window.closeModal(); } });",
  "target": "footer"
}