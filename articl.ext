{
  "html": "<button id='url2md_btn'>web2md</button><div id='url2md_url_modal' style='display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:10000;justify-content:center;align-items:center'><div style='background:var(--bg);border-radius:8px;padding:25px;max-width:500px;width:90%;box-shadow:0 4px 20px rgba(0,0,0,0.3)'><div style='display:flex;justify-content:space-between;margin-bottom:16px'><h3 style='margin:0'>Enter Article URL</h3><button onclick='document.getElementById(\"url2md_url_modal\").style.display=\"none\"' style='background:none;border:none;font-size:20px;cursor:pointer'>✕</button></div><div style='margin-bottom:12px'><input id='url2md_url_input' type='url' placeholder='https://example.com/article' style='width:100%;padding:10px;border:1px solid var(--border);border-radius:4px;background:var(--surface);color:var(--text);font-size:14px;box-sizing:border-box'/><div id='url2md_url_error' style='color:#c00;font-size:12px;margin-top:4px;display:none'></div></div><div style='display:flex;gap:8px;justify-content:flex-end'><button onclick='document.getElementById(\"url2md_url_modal\").style.display=\"none\"' style='padding:8px 20px;background:var(--surface);border:1px solid var(--border);border-radius:4px;cursor:pointer;color:var(--text)'>Cancel</button><button id='url2md_url_submit' onclick='window.url2md.submitURL()' style='padding:8px 20px;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer'>Convert</button></div></div></div><div id='url2md_modal' style='display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:9999;justify-content:center;align-items:center'><div style='background:var(--bg);border-radius:8px;padding:20px;max-width:800px;width:90%;max-height:90vh;display:flex;flex-direction:column;box-shadow:0 4px 20px rgba(0,0,0,0.3)'><div style='display:flex;justify-content:space-between;margin-bottom:12px'><h3 style='margin:0'>Markdown Output</h3><button onclick='document.getElementById(\"url2md_modal\").style.display=\"none\"' style='background:none;border:none;font-size:20px;cursor:pointer'>✕</button></div><div style='display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px'><button onclick='window.url2md.downloadMarkdown()' style='padding:4px 12px;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px'>⬇ MD</button></div><div style='display:flex;gap:8px;flex-wrap:wrap;margin-bottom:6px'><label style='font-size:12px;color:var(--text-dim);display:flex;align-items:center;gap:4px'><input type='checkbox' id='url2md_truncate' onchange='window.url2md.updateCompression()'/>Truncate</label><label style='font-size:12px;color:var(--text-dim);display:flex;align-items:center;gap:4px'><input type='checkbox' id='url2md_noimg' onchange='window.url2md.updateCompression()'/>No images</label><label style='font-size:12px;color:var(--text-dim);display:flex;align-items:center;gap:4px'><input type='checkbox' id='url2md_nolink' onchange='window.url2md.updateCompression()'/>No links</label><label style='font-size:12px;color:var(--text-dim);display:flex;align-items:center;gap:4px'><input type='checkbox' id='url2md_noformat' onchange='window.url2md.updateCompression()'/>No format</label><label style='font-size:12px;color:var(--text-dim);display:flex;align-items:center;gap:4px'><input type='checkbox' id='url2md_compresslines' onchange='window.url2md.updateCompression()'/>Compress</label></div><div id='url2md_sliderwrap' style='display:none;margin-bottom:6px'><label style='font-size:12px;color:var(--text-dim)'>Keep <span id='url2md_percent'>100</span>%</label><input type='range' id='url2md_slider' min='10' max='100' value='100' step='5' oninput='window.url2md.updateSlider()' style='width:100%'/></div><div style='font-size:12px;color:var(--text-dim);margin-bottom:6px'>Size: <strong id='url2md_size' style='color:var(--text)'>0 KB</strong></div><div id='url2md_preview' style='background:var(--surface);border:1px solid var(--border);border-radius:4px;padding:8px;flex:1;overflow-y:auto;font-family:monospace;font-size:11px;line-height:1.4;white-space:pre-wrap;word-wrap:break-word;color:var(--text);min-height:200px'></div><div id='url2md_status' style='padding:6px;border-radius:4px;margin-top:6px;display:none;font-size:12px'></div></div></div>",
  "css": "#url2md_status.error{background:rgba(255,0,0,0.1);color:#c00;border:1px solid rgba(255,0,0,0.2)}#url2md_status.success{background:rgba(0,200,0,0.1);color:#060;border:1px solid rgba(0,200,0,0.2)}#url2md_status.info{background:rgba(0,0,200,0.1);color:#006;border:1px solid rgba(0,0,200,0.2)}#url2md_preview::-webkit-scrollbar{width:6px}#url2md_preview::-webkit-scrollbar-track{background:var(--surface)}#url2md_preview::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}#url2md_btn{padding:10px;border-radius:6px;border:1px solid var(--border);background:#c6bbac;color:var(--bg);position:fixed;bottom:10px;left:10px;}",
  "js": "window.url2md={mdContent:'',origMd:'',pageTitle:'',urlInput:'',showStatus:function(m,t){var s=document.getElementById('url2md_status');s.textContent=m;s.className=t;s.style.display='block'},hideStatus:function(){document.getElementById('url2md_status').style.display='none'},showModal:function(){document.getElementById('url2md_modal').style.display='flex'},showURLModal:function(){document.getElementById('url2md_url_modal').style.display='flex';document.getElementById('url2md_url_input').focus();document.getElementById('url2md_url_error').style.display='none'},hideURLModal:function(){document.getElementById('url2md_url_modal').style.display='none'},submitURL:function(){var self=this;var input=document.getElementById('url2md_url_input');var url=input.value.trim();var errorEl=document.getElementById('url2md_url_error');if(!url){errorEl.textContent='Please enter a URL';errorEl.style.display='block';return}try{var urlObj=new URL(url);if(!['http:','https:'].includes(urlObj.protocol)){errorEl.textContent='URL must use http:// or https://';errorEl.style.display='block';return}}catch(e){errorEl.textContent='Invalid URL format';errorEl.style.display='block';return}errorEl.style.display='none';self.hideURLModal();self.urlInput=url;self.fetchAndConvert()},updateSlider:function(){var s=document.getElementById('url2md_slider');document.getElementById('url2md_percent').textContent=s.value;this.updateCompression()},updateCompression:function(){var t=document.getElementById('url2md_truncate').checked;var wrap=document.getElementById('url2md_sliderwrap');wrap.style.display=t?'block':'none';if(!this.origMd)return;var c=this.origMd;if(t){var p=parseInt(document.getElementById('url2md_slider').value);var a=c.split(/\\n\\n+/);var k=Math.ceil(a.length*(p/100));c=a.slice(0,k).join('\\n\\n')}if(document.getElementById('url2md_noimg').checked)c=c.replace(/!\\[([^\\]]*)\\]\\([^\\)]+\\)\\n*/g,'');if(document.getElementById('url2md_nolink').checked)c=c.replace(/\\[([^\\]]*)\\]\\([^\\)]+\\)/g,function(match,text){return text||''});if(document.getElementById('url2md_noformat').checked)c=c.replace(/\\*\\*([^\\*]+)\\*\\*/g,'$1').replace(/\\*([^\\*]+)\\*/g,'$1').replace(/__([^_]+)__/g,'$1').replace(/_([^_]+)_/g,'$1');if(document.getElementById('url2md_compresslines').checked)c=c.replace(/\\n{3,}/g,'\\n\\n');this.mdContent=c;this.updateResults()},fetchWithTimeout:function(url,options,timeout){return Promise.race([fetch(url,options),new Promise(function(_,reject){setTimeout(function(){reject(new Error('Timeout'))},timeout)})])},fetchAndConvert:function(){var self=this;var u=self.urlInput;if(!u){self.showURLModal();return}var b=document.getElementById('url2md_btn');b.disabled=true;b.textContent='⏳';self.showStatus('Fetching...','info');var timeoutId=setTimeout(function(){self.showStatus('Timeout','error');b.disabled=false;b.textContent='web2md'},60000);var proxies=['https://r.jina.ai/','https://api.allorigins.win/raw?url=','https://corsproxy.io/?','https://api.codetabs.com/v1/proxy?quest=','https://thingproxy.freeboard.io/fetch/','https://cors-anywhere.herokuapp.com/','https://proxy.cors.sh/'];function tryFetch(i){if(i>=proxies.length)return Promise.reject(new Error('All fetch methods failed.'));var fetchUrl=proxies[i]+encodeURIComponent(u);var headers={'User-Agent':'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36','Accept':'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8','Accept-Language':'en-US,en;q=0.9'};self.showStatus('Attempt '+(i+1)+'/'+proxies.length,'info');return self.fetchWithTimeout(fetchUrl,{method:'GET',headers:headers,mode:'cors',credentials:'omit'},30000).then(function(r){if(!r.ok)throw new Error('HTTP '+r.status);var ct=r.headers.get('content-type')||'';if(!ct.includes('text/html')&&!ct.includes('text/plain')&&!ct.includes('application/json'))throw new Error('Not HTML');return r.text()}).then(function(html){if(html.length<100)throw new Error('Too short');if(html.includes('<html')||html.includes('<!DOCTYPE'))return html;try{var parsed=JSON.parse(html);if(parsed.contents)return parsed.contents;if(parsed.data)return parsed.data;if(parsed.response)return parsed.response;if(parsed.content)return parsed.content;throw new Error('Invalid JSON')}catch(e){if(html.trim().startsWith('{')||html.trim().startsWith('['))throw new Error('Invalid JSON');return html}}).catch(function(e){return tryFetch(i+1)})}tryFetch(0).then(function(html){var p=new DOMParser();var doc=p.parseFromString(html,'text/html');var remove=['script','style','noscript','iframe','svg','nav','footer','header','aside','form','button','[role=\"navigation\"]','[role=\"banner\"]','[role=\"contentinfo\"]','.nav','.navigation','.navbar','.menu','.sidebar','.footer','.header','.ads','.advertisement','.social','.share','.comments','.related','.recommended','.popular','#nav','#navigation','#footer','#header','#sidebar','.cookie','.consent','.gdpr','.popup','[class*=\"nav\"]','[class*=\"menu\"]','[class*=\"sidebar\"]','[class*=\"share\"]','[id*=\"nav\"]','[id*=\"menu\"]','[id*=\"sidebar\"]','[id*=\"share\"]','[class*=\"comments\"]','[id*=\"comments\"]','.widget','.promo'];remove.forEach(function(s){try{doc.querySelectorAll(s).forEach(function(e){if(e&&e.parentNode)e.parentNode.removeChild(e)})}catch(e){}});var cands=[];function getCand(el){for(var i=0;i<cands.length;i++){if(cands[i].el===el)return cands[i]}var c={el:el,score:0};cands.push(c);return c}var nodes=doc.querySelectorAll('p, td, pre, h1, h2, h3, article');nodes.forEach(function(node){var text=node.textContent.trim();if(text.length<25&&node.tagName!=='ARTICLE')return;var score=1+text.split(',').length+Math.min(Math.floor(text.length/100),3);if(node.tagName==='ARTICLE')score+=20;var parent=node.parentNode;var grandParent=parent?parent.parentNode:null;if(parent&&parent.tagName!=='BODY')getCand(parent).score+=score;if(grandParent&&grandParent.tagName!=='BODY')getCand(grandParent).score+=score/2});var bestEl=null;var bestScore=-1;cands.forEach(function(c){var cls=(c.el.className+' '+c.el.id).toLowerCase();if(cls.match(/(article|content|main|post|story|body)/))c.score+=25;if(cls.match(/(sidebar|menu|nav|footer|header|comment|share|widget)/))c.score-=25;var a=c.el.querySelectorAll('a');var aLen=0;a.forEach(function(x){aLen+=(x.textContent||'').length});var tLen=(c.el.textContent||'').length;if(tLen>0&&(aLen/tLen)>0.3)c.score-=30;if(c.score>bestScore){bestScore=c.score;bestEl=c.el}});if(!bestEl||bestScore<10){var fallback=['article','[role=\"main\"]','main'];for(var i=0;i<fallback.length;i++){var el=doc.querySelector(fallback[i]);if(el){bestEl=el;break}}}var main=bestEl||doc.body;if(main){var allElements=main.querySelectorAll('*');allElements.forEach(function(child){var text=child.textContent||'';var isHidden=child.style&&(child.style.display==='none'||child.style.visibility==='hidden');if((text.trim().length===0&&child.children.length===0)||isHidden||child.getAttribute('aria-hidden')==='true'){if(child.parentNode)child.parentNode.removeChild(child)}})}self.showStatus('Converting...','info');var md='';var imageCounter=0;function processNode(n){if(n.nodeType===Node.TEXT_NODE)return n.textContent.trim()||'';if(n.nodeType!==Node.ELEMENT_NODE)return '';var tag=n.tagName.toLowerCase();if(['script','style','noscript','iframe'].includes(tag))return '';var text='';for(var i=0;i<n.childNodes.length;i++)text+=processNode(n.childNodes[i]);text=text.replace(/\\s+/g,' ').trim();var r='';switch(tag){case'h1':r='\\n\\n# '+text+'\\n\\n';break;case'h2':r='\\n\\n## '+text+'\\n\\n';break;case'h3':r='\\n\\n### '+text+'\\n\\n';break;case'h4':r='\\n\\n#### '+text+'\\n\\n';break;case'h5':r='\\n\\n##### '+text+'\\n\\n';break;case'h6':r='\\n\\n###### '+text+'\\n\\n';break;case'p':r='\\n\\n'+text+'\\n\\n';break;case'br':r='\\n';break;case'strong':case'b':r='**'+text+'**';break;case'em':case'i':r='*'+text+'*';break;case'code':if(n.parentElement&&n.parentElement.tagName.toLowerCase()==='pre')return text;r='`'+text+'`';break;case'pre':r='\\n\\n```\\n'+text+'\\n```\\n\\n';break;case'a':var href=n.getAttribute('href');var txt=text||'';if(href&&txt){try{var url=new URL(href,u);r='['+txt+']('+url.href+')'}catch(e){r=txt}}else if(href&&!txt)r='';else r=txt;break;case'img':var src=n.getAttribute('src');var alt=n.getAttribute('alt')||'image-'+(++imageCounter);if(src){try{var url=new URL(src,u);r='\\n\\n!['+alt+']('+url.href+')\\n\\n'}catch(e){r=''}}break;case'ul':case'ol':var ordered=tag==='ol';var idx2=1;var listText='';var items=n.querySelectorAll(':scope > li');for(var liIdx=0;liIdx<items.length;liIdx++){var li=items[liIdx];var liText='';var liChildren=li.childNodes;for(var j=0;j<liChildren.length;j++)liText+=processNode(liChildren[j]);liText=liText.trim();if(ordered)listText+=(idx2++)+'. '+liText+'\\n';else listText+='- '+liText+'\\n'}r='\\n\\n'+listText+'\\n\\n';break;case'li':r=text;break;case'blockquote':r='\\n\\n> '+text.replace(/\\n/g,'\\n> ')+'\\n\\n';break;case'hr':r='\\n\\n---\\n\\n';break;default:var defaultText='';for(var k=0;k<n.childNodes.length;k++)defaultText+=processNode(n.childNodes[k]);r=defaultText}return r}md=processNode(main);md=md.replace(/\\n{4,}/g,'\\n\\n\\n');md=md.replace(/[ \\t]+$/gm,'');md=md.replace(/^[ \\t]+/gm,'');self.mdContent=md.trim();self.origMd=self.mdContent;self.pageTitle=doc.title||'converted-page';self.updateCompression();self.showModal();self.showStatus('✅ Done!','success');setTimeout(function(){self.hideStatus()},3000);b.disabled=false;b.textContent='web2md';clearTimeout(timeoutId)}).catch(function(e){var msg=e.message;if(msg.includes('fetch')||msg.includes('network'))msg='Network error';else if(msg.includes('CORS'))msg='CORS error';else if(msg.includes('timeout'))msg='Timeout';self.showStatus('❌ '+msg,'error');b.disabled=false;b.textContent='Convert Article to MD';clearTimeout(timeoutId)})},updateResults:function(){var chars=this.mdContent.length;var kb=(chars/1024).toFixed(2);document.getElementById('url2md_size').textContent=kb+' KB';document.getElementById('url2md_preview').textContent=this.mdContent},downloadMarkdown:function(){var content=this.mdContent;var fn=this.pageTitle.replace(/[^a-z0-9]/gi,'').toLowerCase().substring(0,6)+'.md';var dataUrl='data:text/markdown;charset=utf-8,'+encodeURIComponent(content);var link=document.createElement('a');link.href=dataUrl;link.download=fn;document.body.appendChild(link);link.click();document.body.removeChild(link);this.showStatus('Downloaded!','success');setTimeout(function(){this.hideStatus()}.bind(this),2000)}};document.getElementById('url2md_btn').addEventListener('click',function(){window.url2md.showURLModal()});document.getElementById('url2md_url_input').addEventListener('keydown',function(e){if(e.key==='Enter'){window.url2md.submitURL()}})"
}