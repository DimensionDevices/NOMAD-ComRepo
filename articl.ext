{
  "description": "URL to Markdown converter - fetch web pages and convert to Markdown",
  "html": "<details class='section'><summary><h2><svg style='position:relative;top:6px' width='24px' height='24px' viewBox='0 0 24 24' fill='none' stroke='var(--text)' stroke-width='2'><path d='M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z'/><polyline points='14 2 14 8 20 8'/><line x1='16' y1='13' x2='8' y2='13'/><line x1='16' y1='17' x2='8' y2='17'/><polyline points='10 9 9 9 8 9'/></svg>&nbsp;Article to .md</h2></summary><div style='padding:8px 0'><div style='display:flex;gap:8px;margin-bottom:8px'><input type='text' id='url2md_input' placeholder='https://example.com/article' style='flex:1;padding:6px 10px;border:1px solid var(--border);border-radius:6px;background:var(--bg);color:var(--text);font-size:13px'/><button id='url2md_btn' onclick='window.url2md.fetchAndConvert()' style='padding:6px 16px;background:var(--accent);color:#fff;border:none;border-radius:6px;cursor:pointer;font-weight:600'>Convert</button></div><div id='url2md_status' style='padding:6px;border-radius:4px;margin-bottom:6px;display:none;font-size:12px'></div><div id='url2md_results' style='display:none'><div style='display:flex;gap:6px;flex-wrap:wrap;margin-bottom:6px'><button onclick='window.url2md.downloadMarkdown()' style='padding:4px 12px;background:var(--accent);color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:12px'>⬇ Download .md</button></div><div style='display:flex;gap:8px;flex-wrap:wrap;margin-bottom:6px'><label style='font-size:12px;color:var(--text-dim);display:flex;align-items:center;gap:4px'><input type='checkbox' id='url2md_truncate' onchange='window.url2md.updateCompression()'/>Truncate paragraphs</label><label style='font-size:12px;color:var(--text-dim);display:flex;align-items:center;gap:4px'><input type='checkbox' id='url2md_noimg' onchange='window.url2md.updateCompression()'/>Remove images</label><label style='font-size:12px;color:var(--text-dim);display:flex;align-items:center;gap:4px'><input type='checkbox' id='url2md_nolink' onchange='window.url2md.updateCompression()'/>Remove links</label><label style='font-size:12px;color:var(--text-dim);display:flex;align-items:center;gap:4px'><input type='checkbox' id='url2md_noformat' onchange='window.url2md.updateCompression()'/>Remove formatting</label><label style='font-size:12px;color:var(--text-dim);display:flex;align-items:center;gap:4px'><input type='checkbox' id='url2md_compresslines' onchange='window.url2md.updateCompression()'/>Compress line breaks</label><label style='font-size:12px;color:var(--text-dim);display:flex;align-items:center;gap:4px'><input type='checkbox' id='url2md_removeorphans' onchange='window.url2md.updateCompression()'/>Remove orphan words</label></div><div id='url2md_sliderwrap' style='display:none;margin-bottom:6px'><label style='font-size:12px;color:var(--text-dim)'>Keep <span id='url2md_percent'>100</span>% of paragraphs</label><input type='range' id='url2md_slider' min='10' max='100' value='100' step='5' oninput='window.url2md.updateCompressionSlider()' style='width:100%'/></div><div style='font-size:12px;color:var(--text-dim);margin-bottom:6px'>Size: <strong id='url2md_size' style='color:var(--text)'>0 KB</strong></div><div id='url2md_preview' style='background:var(--surface);border:1px solid var(--border);border-radius:4px;padding:8px;max-height:300px;overflow-y:auto;font-family:monospace;font-size:11px;line-height:1.4;white-space:pre-wrap;word-wrap:break-word;color:var(--text)'></div></div></div></details>",
  "css": "#url2md_input:focus{outline:2px solid var(--accent);outline-offset:1px}#url2md_status.error{background:rgba(255,0,0,0.1);color:#c00;border:1px solid rgba(255,0,0,0.2)}#url2md_status.success{background:rgba(0,200,0,0.1);color:#060;border:1px solid rgba(0,200,0,0.2)}#url2md_status.info{background:rgba(0,0,200,0.1);color:#006;border:1px solid rgba(0,0,200,0.2)}#url2md_preview::-webkit-scrollbar{width:6px}#url2md_preview::-webkit-scrollbar-track{background:var(--surface)}#url2md_preview::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}",
  "js": "window.url2md={mdContent:'',origMd:'',pageTitle:'',DEBUG:true,log:function(m){if(this.DEBUG)console.log('[URL2MD]',m)},showStatus:function(m,t){var s=document.getElementById('url2md_status');s.textContent=m;s.className=t;s.style.display='block';this.log('Status: '+m)},hideStatus:function(){document.getElementById('url2md_status').style.display='none'},updateCompressionSlider:function(){var s=document.getElementById('url2md_slider');document.getElementById('url2md_percent').textContent=s.value;this.updateCompression()},updateCompression:function(){var t=document.getElementById('url2md_truncate').checked;var wrap=document.getElementById('url2md_sliderwrap');wrap.style.display=t?'block':'none';if(!this.origMd)return;var c=this.origMd;if(t){var p=parseInt(document.getElementById('url2md_slider').value);c=this.truncateParagraphs(c,p)}if(document.getElementById('url2md_noimg').checked)c=this.removeImages(c);if(document.getElementById('url2md_nolink').checked)c=this.removeLinks(c);if(document.getElementById('url2md_noformat').checked)c=this.removeFormatting(c);if(document.getElementById('url2md_compresslines').checked)c=this.compressLineBreaks(c);if(document.getElementById('url2md_removeorphans').checked)c=this.removeOrphanWords(c);this.mdContent=c;this.updateResults()},truncateParagraphs:function(c,p){var a=c.split(/\\n\\n+/);var k=Math.ceil(a.length*(p/100));return a.slice(0,k).join('\\n\\n')},removeImages:function(c){return c.replace(/!\\[([^\\]]*)\\]\\([^\\)]+\\)\\n*/g,'')},removeLinks:function(c){return c.replace(/\\[([^\\]]*)\\]\\([^\\)]+\\)/g,function(match,text){return text||''})},removeFormatting:function(c){return c.replace(/\\*\\*([^\\*]+)\\*\\*/g,'$1').replace(/\\*([^\\*]+)\\*/g,'$1').replace(/__([^_]+)__/g,'$1').replace(/_([^_]+)_/g,'$1')},compressLineBreaks:function(c){return c.replace(/\\n{3,}/g,'\\n\\n')},removeOrphanWords:function(c){var lines=c.split('\\n');var result=[];for(var i=0;i<lines.length;i++){var line=lines[i].trim();var words=line.split(/\\s+/).filter(function(w){return w.length>0});if(words.length===1&&line.length<30){continue}result.push(lines[i])}return result.join('\\n')},fetchWithTimeout:function(url,options,timeout){return Promise.race([fetch(url,options),new Promise(function(_,reject){setTimeout(function(){reject(new Error('Timeout'))},timeout)})])},fetchAndConvert:function(){var self=this;var u=document.getElementById('url2md_input').value.trim();if(!u){self.showStatus('Please enter a URL','error');return}try{var urlObj=new URL(u);if(!['http:','https:'].includes(urlObj.protocol)){self.showStatus('URL must use http:// or https://','error');return}}catch(e){self.showStatus('Invalid URL format','error');return}var b=document.getElementById('url2md_btn');b.disabled=true;b.textContent='⏳';self.showStatus('Fetching article...','info');var timeoutId=setTimeout(function(){self.showStatus('Operation timed out after 60 seconds','error');b.disabled=false;b.textContent='Convert'},60000);self.fetchWithFallback(u).then(function(html){return self.processHTML(html,u)}).then(function(){self.showStatus('✅ Conversion successful!','success');setTimeout(function(){self.hideStatus()},3000)}).catch(function(e){var msg=e.message;if(msg.includes('fetch')||msg.includes('network')){msg='Network error. Check your connection.'}else if(msg.includes('CORS')){msg='CORS error. The website may be blocking requests.'}else if(msg.includes('timeout')){msg='Request timed out.'}self.showStatus('❌ Error: '+msg,'error')}).finally(function(){clearTimeout(timeoutId);b.disabled=false;b.textContent='Convert'})},fetchWithFallback:function(url){var self=this;var proxies=['https://r.jina.ai/','https://api.allorigins.win/raw?url=','https://corsproxy.io/?','https://api.codetabs.com/v1/proxy?quest=','https://thingproxy.freeboard.io/fetch/','https://cors-anywhere.herokuapp.com/','https://proxy.cors.sh/'];function tryFetch(i){if(i>=proxies.length){return Promise.reject(new Error('All fetch methods failed.'))}var proxy=proxies[i];var fetchUrl=proxy+encodeURIComponent(url);var headers={'User-Agent':'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36','Accept':'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8','Accept-Language':'en-US,en;q=0.9','Accept-Encoding':'gzip, deflate, br'};self.showStatus('Attempt '+(i+1)+'/'+proxies.length+'...','info');return self.fetchWithTimeout(fetchUrl,{method:'GET',headers:headers,mode:'cors',credentials:'omit'},30000).then(function(r){if(!r.ok)throw new Error('HTTP '+r.status+' '+r.statusText);var ct=r.headers.get('content-type')||'';if(!ct.includes('text/html')&&!ct.includes('text/plain')&&!ct.includes('application/json')){throw new Error('Not HTML content')}return r.text()}).then(function(html){if(html.length<100)throw new Error('Response too short');if(html.includes('<html')||html.includes('<!DOCTYPE')){return html}try{var parsed=JSON.parse(html);if(parsed.contents)return parsed.contents;if(parsed.data)return parsed.data;if(parsed.response)return parsed.response;if(parsed.content)return parsed.content;throw new Error('Invalid response format')}catch(e){if(html.trim().startsWith('{')||html.trim().startsWith('[')){throw new Error('Invalid JSON response')}return html}}).catch(function(e){self.log('Proxy '+i+' failed: '+e.message);return tryFetch(i+1)})}return tryFetch(0)},processHTML:function(html,baseUrl){var self=this;self.showStatus('Extracting content...','info');var p=new DOMParser();var doc=p.parseFromString(html,'text/html');var main=self.extractMainContent(doc);if(!main||main.textContent.trim().length<50){self.log('Primary extraction failed, trying fallback');main=doc.body}self.showStatus('Converting to Markdown...','info');self.mdContent=self.htmlToMarkdown(main,baseUrl);self.origMd=self.mdContent;self.pageTitle=doc.title||'converted-page';self.updateCompression();return Promise.resolve()},extractMainContent:function(doc){var self=this;var remove=['script','style','noscript','iframe','svg','nav','footer','header','aside','[role=\"navigation\"]','[role=\"banner\"]','[role=\"contentinfo\"]','.nav','.navigation','.navbar','.menu','.sidebar','.footer','.header','.ads','.advertisement','.social','.share','.comments','.related','.recommended','.popular','#nav','#navigation','#footer','#header','#sidebar','.cookie','.consent','.gdpr','.popup'];remove.forEach(function(s){doc.querySelectorAll(s).forEach(function(e){if(e&&e.parentNode){e.parentNode.removeChild(e)}})});var selectors=['article','[role=\"main\"]','main','.article','.post','.content','.main-content','.entry-content','.post-content','.story-content','.article-content','.blog-post','.single-post','.page-content','#content','#main','#article','#post','.body-text','.prose','.rich-text'];var bestCandidate=null;var bestScore=0;for(var i=0;i<selectors.length;i++){var elements=doc.querySelectorAll(selectors[i]);for(var j=0;j<elements.length;j++){var el=elements[j];var score=self.scoreElement(el);if(score>bestScore){bestScore=score;bestCandidate=el}}}if(!bestCandidate||bestScore<10){bestCandidate=self.findReadableContent(doc)}if(bestCandidate){self.cleanElement(bestCandidate)}return bestCandidate||doc.body},scoreElement:function(el){var text=el.textContent||'';var textLength=text.trim().length;var score=0;if(textLength>1000)score+=20;else if(textLength>500)score+=15;else if(textLength>200)score+=10;else if(textLength>50)score+=5;var pCount=el.querySelectorAll('p').length;if(pCount>10)score+=15;else if(pCount>5)score+=10;else if(pCount>2)score+=5;var hCount=el.querySelectorAll('h1,h2,h3').length;if(hCount>0)score+=5;var imgCount=el.querySelectorAll('img').length;if(imgCount>0&&imgCount<10)score+=5;var links=el.querySelectorAll('a');var linkText=0;links.forEach(function(a){linkText+=(a.textContent||'').length});var totalText=text.length;if(totalText>0){var linkRatio=linkText/totalText;if(linkRatio<0.1)score+=10;else if(linkRatio<0.2)score+=5;else if(linkRatio>0.5)score-=10}var className=el.className||'';var id=el.id||'';if(className.match(/article|post|content|story|entry|blog/i))score+=10;if(id.match(/article|post|content|story|entry|blog/i))score+=10;return score},findReadableContent:function(doc){var candidates=[];var body=doc.body;var elements=body.querySelectorAll('div, section, main, article');elements.forEach(function(el){var text=el.textContent||'';var textLength=text.trim().length;var score=0;if(textLength>2000)score+=30;else if(textLength>1000)score+=20;else if(textLength>500)score+=10;var pCount=el.querySelectorAll('p').length;score+=pCount*2;var hCount=el.querySelectorAll('h1,h2,h3').length;score+=hCount*3;var depth=0;var parent=el;while(parent.parentNode&&parent.parentNode!==doc){depth++;parent=parent.parentNode}if(depth>5)score-=depth;candidates.push({element:el,score:score})});candidates.sort(function(a,b){return b.score-a.score});if(candidates.length>0&&candidates[0].score>20){return candidates[0].element}return body},cleanElement:function(el){var allElements=el.querySelectorAll('*');allElements.forEach(function(child){var text=child.textContent||'';if(text.trim().length===0&&child.children.length===0){if(child.parentNode){child.parentNode.removeChild(child)}}})},htmlToMarkdown:function(el,baseUrl){var md='';var imageCounter=0;function getTextContent(n){var t='';for(var i=0;i<n.childNodes.length;i++){var c=n.childNodes[i];if(c.nodeType===Node.TEXT_NODE){t+=c.textContent}else if(c.nodeType===Node.ELEMENT_NODE){var tag=c.tagName.toLowerCase();if(tag==='br'){t+='\\n'}else if(['script','style','noscript'].includes(tag)){}else{t+=processNode(c)}}}return t.replace(/[ \\t]+/g,' ').trim()}function processNode(n){if(n.nodeType===Node.TEXT_NODE){return n.textContent.trim()||''}if(n.nodeType!==Node.ELEMENT_NODE)return '';var tag=n.tagName.toLowerCase();if(['script','style','noscript','iframe'].includes(tag)){return ''}var text='';for(var i=0;i<n.childNodes.length;i++){text+=processNode(n.childNodes[i])}text=text.replace(/\\s+/g,' ').trim();var r='';switch(tag){case'h1':r='\\n\\n# '+text+'\\n\\n';break;case'h2':r='\\n\\n## '+text+'\\n\\n';break;case'h3':r='\\n\\n### '+text+'\\n\\n';break;case'h4':r='\\n\\n#### '+text+'\\n\\n';break;case'h5':r='\\n\\n##### '+text+'\\n\\n';break;case'h6':r='\\n\\n###### '+text+'\\n\\n';break;case'p':r='\\n\\n'+text+'\\n\\n';break;case'br':r='\\n';break;case'strong':case'b':r='**'+text+'**';break;case'em':case'i':r='*'+text+'*';break;case'code':if(n.parentElement&&n.parentElement.tagName.toLowerCase()==='pre'){return text}r='`'+text+'`';break;case'pre':r='\\n\\n```\\n'+text+'\\n```\\n\\n';break;case'a':var href=n.getAttribute('href');var txt=text||'';if(href&&txt){try{var url=new URL(href,baseUrl);r='['+txt+']('+url.href+')'}catch(e){r=txt}}else if(href&&!txt){r=''}else{r=txt}break;case'img':var src=n.getAttribute('src');var alt=n.getAttribute('alt')||'image-'+(++imageCounter);if(src){try{var url=new URL(src,baseUrl);r='\\n\\n!['+alt+']('+url.href+')\\n\\n'}catch(e){r=''}}break;case'ul':case'ol':r='\\n\\n'+processList(n,tag==='ol')+'\\n\\n';break;case'li':r=text;break;case'blockquote':r='\\n\\n> '+text.replace(/\\n/g,'\\n> ')+'\\n\\n';break;case'hr':r='\\n\\n---\\n\\n';break;case'div':case'section':case'article':case'header':case'footer':case'main':var childText='';for(var j=0;j<n.childNodes.length;j++){childText+=processNode(n.childNodes[j])}r=childText;break;default:var defaultText='';for(var k=0;k<n.childNodes.length;k++){defaultText+=processNode(n.childNodes[k])}r=defaultText}return r}function processList(n,ordered){var r='';var idx=1;var items=n.querySelectorAll(':scope > li');for(var i=0;i<items.length;i++){var li=items[i];var liText='';var liChildren=li.childNodes;for(var j=0;j<liChildren.length;j++){liText+=processNode(liChildren[j])}liText=liText.trim();if(ordered){r+=(idx++)+'. '+liText+'\\n'}else{r+='- '+liText+'\\n'}}return r}md=processNode(el);md=md.replace(/\\n{4,}/g,'\\n\\n\\n');md=md.replace(/[ \\t]+$/gm,'');md=md.replace(/^[ \\t]+/gm,'');return md.trim()},updateResults:function(){var chars=this.mdContent.length;var kb=(chars/1024).toFixed(2);var est=document.getElementById('url2md_size');est.textContent=kb+' KB';est.style.color='var(--text)';document.getElementById('url2md_preview').textContent=this.mdContent;document.getElementById('url2md_results').style.display='block'},downloadMarkdown:function(){var content=this.mdContent;var fn=this.pageTitle.replace(/[^a-z0-9]/gi,'').toLowerCase().substring(0,6)+'.md';var dataUrl='data:text/markdown;charset=utf-8,'+encodeURIComponent(content);var link=document.createElement('a');link.href=dataUrl;link.download=fn;document.body.appendChild(link);link.click();document.body.removeChild(link);this.showStatus('Download started!','success');setTimeout(function(){this.hideStatus()}.bind(this),2000)},copyToClipboard:function(){var self=this;navigator.clipboard.writeText(this.mdContent).then(function(){self.showStatus('Copied!','success');setTimeout(function(){self.hideStatus()},2000)}).catch(function(){self.showStatus('Copy failed','error')})}};document.getElementById('url2md_input').addEventListener('keypress',function(e){if(e.key==='Enter')window.url2md.fetchAndConvert()});"
}