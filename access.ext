{
  "description": "Extra accessibility options",
  "target": "options",
  "html": "<style>.acc-group{padding:8px 0;border-bottom:1px solid var(--border);}.acc-group:last-child{border-bottom:0;}.acc-row{display:flex;align-items:center;justify-content:space-between;}.acc-label strong{display:block;font-size:13px;}.acc-label span{font-size:11px;opacity:0.6;}.acc-slider{width:100%;margin:4px 0 2px;}.acc-range-labels{display:flex;justify-content:space-between;font-size:10px;opacity:0.5;}.acc-select{width:100%;padding:6px 10px;border-radius:6px;border:1px solid var(--border);background:var(--surface-solid);color:var(--text);font-size:13px;}.acc-section h3{margin:0 0 12px;font-size:15px;}.acc-section hr{margin:12px 0;border-color:var(--border);}.acc-reset{width:100%;padding:8px;background:var(--danger);color:#fff;border:0;border-radius:6px;cursor:pointer;font-size:12px;font-weight:600;margin-top:8px;}.acc-reset:active{opacity:0.7;}</style><div class='acc-section'><h3>♿ Accessibility</h3><div class='acc-group'><div class='acc-row'><div class='acc-label'><strong>High Contrast</strong><span>Enhanced readability + bolder fonts</span></div><label class='switch'><input type='checkbox' id='accHighContrast'><span class='slider'></span></label></div></div><div class='acc-group'><div class='acc-row'><div class='acc-label'><strong>Grayscale</strong><span>Remove all color</span></div><label class='switch'><input type='checkbox' id='accGrayscale'><span class='slider'></span></label></div></div><div class='acc-group'><div class='acc-row'><div class='acc-label'><strong>Reduced Motion</strong><span>Disable animations</span></div><label class='switch'><input type='checkbox' id='accReducedMotion'><span class='slider'></span></label></div></div><div class='acc-group'><div class='acc-row'><div class='acc-label'><strong>Focus Indicators</strong><span>Visible keyboard focus</span></div><label class='switch'><input type='checkbox' id='accFocusIndicators'><span class='slider'></span></label></div></div><hr><div class='acc-group'><div class='acc-row'><div class='acc-label'><strong>Protanopia</strong><span>Red-green (red-blind)</span></div><label class='switch'><input type='checkbox' id='accProtanopia'><span class='slider'></span></label></div></div><div class='acc-group'><div class='acc-row'><div class='acc-label'><strong>Deuteranopia</strong><span>Red-green (green-blind)</span></div><label class='switch'><input type='checkbox' id='accDeuteranopia'><span class='slider'></span></label></div></div><div class='acc-group'><div class='acc-row'><div class='acc-label'><strong>Tritanopia</strong><span>Blue-yellow</span></div><label class='switch'><input type='checkbox' id='accTritanopia'><span class='slider'></span></label></div></div><hr><div class='acc-group'><div class='acc-label'><strong>Font Size</strong><span>Adjust text size</span></div><input class='acc-slider' type='range' id='accFontSize' min='70' max='200' value='100'><div class='acc-range-labels'><span>70%</span><span id='accFontSizeLabel'>100%</span><span>200%</span></div></div><div class='acc-group'><div class='acc-label'><strong>Line Height</strong><span>Text spacing</span></div><input class='acc-slider' type='range' id='accLineHeight' min='1.2' max='2.8' step='0.1' value='1.6'><div class='acc-range-labels'><span>1.2</span><span id='accLineHeightLabel'>1.6</span><span>2.8</span></div></div><div class='acc-group'><div class='acc-label'><strong>Letter Spacing</strong><span>Character spacing</span></div><input class='acc-slider' type='range' id='accLetterSpacing' min='0' max='5' step='0.5' value='0'><div class='acc-range-labels'><span>0px</span><span id='accLetterSpacingLabel'>0px</span><span>5px</span></div></div><div class='acc-group'><div class='acc-label'><strong>Font Family</strong><span>Choose a typeface</span></div><select class='acc-select' id='accFontFamily'><option value='system-ui'>System Default</option><option value='Arial,Helvetica,sans-serif'>Arial</option><option value='Verdana,Geneva,sans-serif'>Verdana</option><option value='Georgia,serif'>Georgia</option><option value='\"Courier New\",monospace'>Courier New</option><option value='\"Comic Sans MS\",cursive'>Comic Sans</option><option value='\"OpenDyslexic\",\"Comic Sans MS\",cursive'>OpenDyslexic</option></select></div><hr><button class='acc-reset' id='accResetBtn'>Reset All Accessibility Settings</button><br><br></div>",
  "css": "",
  "js": "function accLoad(){var s=localStorage;var apply=function(){var root=document.documentElement;var hc=s.getItem('accHighContrast')==='true';var gs=s.getItem('accGrayscale')==='true';var rm=s.getItem('accReducedMotion')==='true';var fi=s.getItem('accFocusIndicators')==='true';var pt=s.getItem('accProtanopia')==='true';var dt=s.getItem('accDeuteranopia')==='true';var tr=s.getItem('accTritanopia')==='true';var fs=s.getItem('accFontSize')||100;var lh=s.getItem('accLineHeight')||1.6;var ls=s.getItem('accLetterSpacing')||0;var ff=s.getItem('accFontFamily')||'system-ui';var filters=[];if(hc){filters.push('contrast(1.2)','brightness(1.05)');}if(gs){filters.push('grayscale(1)');}if(pt){filters.push('hue-rotate(320deg)','saturate(0.7)');}if(dt){filters.push('hue-rotate(340deg)','saturate(0.7)');}if(tr){filters.push('hue-rotate(280deg)','saturate(0.6)');}var filterStr=filters.length?filters.join(' '):'none';root.style.filter=filterStr;root.style.fontSize=fs+'%';root.style.lineHeight=lh;root.style.letterSpacing=ls+'px';root.style.fontFamily=ff;var fsTag=document.getElementById('accFontStyle');if(ff!=='system-ui'){if(!fsTag){fsTag=document.createElement('style');fsTag.id='accFontStyle';document.head.appendChild(fsTag);}fsTag.textContent='*{font-family:'+ff+'!important;}';}else{if(fsTag)fsTag.remove();}var boldTag=document.getElementById('accBoldStyle');if(hc){if(!boldTag){boldTag=document.createElement('style');boldTag.id='accBoldStyle';document.head.appendChild(boldTag);}boldTag.textContent='*{font-weight:600!important;}';}else{if(boldTag)boldTag.remove();}if(rm){root.style.setProperty('--transition','none');root.style.setProperty('--animation','none');document.querySelectorAll('*').forEach(function(el){el.style.transition='none';el.style.animation='none';});}else{root.style.setProperty('--transition','');root.style.setProperty('--animation','');document.querySelectorAll('*').forEach(function(el){el.style.transition='';el.style.animation='';});}if(fi){var style=document.getElementById('accFocusStyle');if(!style){style=document.createElement('style');style.id='accFocusStyle';document.head.appendChild(style);}style.textContent='*:focus-visible{outline:3px solid #ff6b00!important;outline-offset:2px!important;box-shadow:0 0 0 4px rgba(255,107,0,0.3)!important;}';}else{var s2=document.getElementById('accFocusStyle');if(s2)s2.remove();}};var syncUI=function(){var el=function(id){return document.getElementById(id);};if(el('accHighContrast'))el('accHighContrast').checked=s.getItem('accHighContrast')==='true';if(el('accGrayscale'))el('accGrayscale').checked=s.getItem('accGrayscale')==='true';if(el('accReducedMotion'))el('accReducedMotion').checked=s.getItem('accReducedMotion')==='true';if(el('accFocusIndicators'))el('accFocusIndicators').checked=s.getItem('accFocusIndicators')==='true';if(el('accProtanopia'))el('accProtanopia').checked=s.getItem('accProtanopia')==='true';if(el('accDeuteranopia'))el('accDeuteranopia').checked=s.getItem('accDeuteranopia')==='true';if(el('accTritanopia'))el('accTritanopia').checked=s.getItem('accTritanopia')==='true';if(el('accFontSize')){var fs=s.getItem('accFontSize')||100;el('accFontSize').value=fs;el('accFontSizeLabel').textContent=fs+'%';}if(el('accLineHeight')){var lh=s.getItem('accLineHeight')||1.6;el('accLineHeight').value=lh;el('accLineHeightLabel').textContent=lh;}if(el('accLetterSpacing')){var ls=s.getItem('accLetterSpacing')||0;el('accLetterSpacing').value=ls;el('accLetterSpacingLabel').textContent=ls+'px';}if(el('accFontFamily')){el('accFontFamily').value=s.getItem('accFontFamily')||'system-ui';}if(el('accProtanopia')&&el('accProtanopia').checked){if(el('accDeuteranopia'))el('accDeuteranopia').checked=false;if(el('accTritanopia'))el('accTritanopia').checked=false;}if(el('accDeuteranopia')&&el('accDeuteranopia').checked){if(el('accProtanopia'))el('accProtanopia').checked=false;if(el('accTritanopia'))el('accTritanopia').checked=false;}if(el('accTritanopia')&&el('accTritanopia').checked){if(el('accProtanopia'))el('accProtanopia').checked=false;if(el('accDeuteranopia'))el('accDeuteranopia').checked=false;}};var handler=function(id,cb){var el=document.getElementById(id);if(el){el.addEventListener('change',function(){cb(el);});}};handler('accHighContrast',function(el){s.setItem('accHighContrast',el.checked);apply();});handler('accGrayscale',function(el){s.setItem('accGrayscale',el.checked);apply();});handler('accReducedMotion',function(el){s.setItem('accReducedMotion',el.checked);apply();});handler('accFocusIndicators',function(el){s.setItem('accFocusIndicators',el.checked);apply();});var colorBlindHandler=function(id){var el=document.getElementById(id);if(el){el.addEventListener('change',function(){if(el.checked){if(id==='accProtanopia'){s.setItem('accProtanopia','true');s.removeItem('accDeuteranopia');s.removeItem('accTritanopia');var d=document.getElementById('accDeuteranopia');if(d)d.checked=false;var t=document.getElementById('accTritanopia');if(t)t.checked=false;}else if(id==='accDeuteranopia'){s.setItem('accDeuteranopia','true');s.removeItem('accProtanopia');s.removeItem('accTritanopia');var p=document.getElementById('accProtanopia');if(p)p.checked=false;var t2=document.getElementById('accTritanopia');if(t2)t2.checked=false;}else if(id==='accTritanopia'){s.setItem('accTritanopia','true');s.removeItem('accProtanopia');s.removeItem('accDeuteranopia');var p2=document.getElementById('accProtanopia');if(p2)p2.checked=false;var d2=document.getElementById('accDeuteranopia');if(d2)d2.checked=false;}}else{s.removeItem(id);}apply();});}};colorBlindHandler('accProtanopia');colorBlindHandler('accDeuteranopia');colorBlindHandler('accTritanopia');var rangeHandler=function(id,labelId,key){var el=document.getElementById(id);if(el){el.addEventListener('input',function(){var val=el.value;var label=document.getElementById(labelId);if(label){if(key==='accFontSize'){label.textContent=val+'%';}else if(key==='accLineHeight'){label.textContent=val;}else if(key==='accLetterSpacing'){label.textContent=val+'px';}}s.setItem(key,val);apply();});}};rangeHandler('accFontSize','accFontSizeLabel','accFontSize');rangeHandler('accLineHeight','accLineHeightLabel','accLineHeight');rangeHandler('accLetterSpacing','accLetterSpacingLabel','accLetterSpacing');var ff=document.getElementById('accFontFamily');if(ff){ff.addEventListener('change',function(){s.setItem('accFontFamily',ff.value);apply();});}var reset=document.getElementById('accResetBtn');if(reset){reset.addEventListener('click',function(){if(confirm('Reset all accessibility settings?')){s.removeItem('accHighContrast');s.removeItem('accGrayscale');s.removeItem('accReducedMotion');s.removeItem('accFocusIndicators');s.removeItem('accProtanopia');s.removeItem('accDeuteranopia');s.removeItem('accTritanopia');s.removeItem('accFontSize');s.removeItem('accLineHeight');s.removeItem('accLetterSpacing');s.removeItem('accFontFamily');var sf=document.getElementById('accFontStyle');if(sf)sf.remove();var sf2=document.getElementById('accFocusStyle');if(sf2)sf2.remove();var sf3=document.getElementById('accBoldStyle');if(sf3)sf3.remove();syncUI();apply();}});}syncUI();apply();}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',accLoad);}else{accLoad();}"
}