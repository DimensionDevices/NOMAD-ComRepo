{
  "html": "<details class='section' id='particleVizSection' open>\n  <summary>\n    <h2>\n      <svg style='position:relative;top:6px' width='24px' height='24px' viewBox='0 0 24 24' fill='none' stroke='var(--text)' stroke-width='2'>\n        <circle cx='12' cy='12' r='10'/>\n        <circle cx='12' cy='12' r='4' fill='var(--text)'/>\n        <line x1='12' y1='2' x2='12' y2='6'/>\n        <line x1='12' y1='18' x2='12' y2='22'/>\n        <line x1='2' y1='12' x2='6' y2='12'/>\n        <line x1='18' y1='12' x2='22' y2='12'/>\n        <line x1='4.93' y1='4.93' x2='7.76' y2='7.76'/>\n        <line x1='16.24' y1='16.24' x2='19.07' y2='19.07'/>\n      </svg>\n      &nbsp;Particle Galaxy\n    </h2>\n  </summary>\n  <div style='padding:10px 0;'>\n    <canvas id='particleCanvas' style='width:100%;height:300px;border-radius:12px;display:block;background:var(--bg);'></canvas>\n    <div style='display:flex;justify-content:space-between;margin-top:8px;font-size:0.8em;opacity:0.6;'>\n      <span>✨ Particles: <span id='particleCount'>0</span></span>\n    </div>\n  </div>\n</details>",
  "css": "#particleCanvas { border: 1px solid var(--border); transition: all 0.3s ease; }\n#particleCanvas:hover { border-color: var(--accent); }\n#particleVizSection .section { margin-bottom: 12px; }\n#particleVizSection summary h2 { display: flex; align-items: center; gap: 8px; }\n#particleVizSection summary h2 svg { flex-shrink: 0; }",
  "js": "(function() {\n  'use strict';\n  \n  let canvas, ctx;\n  let particles = [];\n  let mouseX = -1000, mouseY = -1000;\n  let frameCount = 0;\n  let lastFpsUpdate = 0;\n  let fps = 0;\n  let animationId = null;\n  let isVisible = true;\n  \n  // Configuration\n  const CONFIG = {\n    particleCount: 150,\n    maxSpeed: 1.2,\n    connectionDistance: 120,\n    colorPalette: [\n      '#ff6b6b', '#ffd93d', '#6bcb77', '#4d96ff', \n      '#9b59b6', '#f39c12', '#1abc9c', '#e74c3c',\n      '#3498db', '#2ecc71', '#f1c40f', '#e67e22'\n    ],\n    baseSize: 2,\n    glowIntensity: 0.4,\n  };\n  \n  function init() {\n    canvas = document.getElementById('particleCanvas');\n    if (!canvas) return;\n    \n    ctx = canvas.getContext('2d');\n    resizeCanvas();\n    \n    // Generate particles\n    createParticles(CONFIG.particleCount);\n    \n    // Event listeners\n    canvas.addEventListener('click', handleClick);\n    canvas.addEventListener('mousemove', handleMouseMove);\n    canvas.addEventListener('mouseleave', handleMouseLeave);\n    \n    // Resize handler\n    window.addEventListener('resize', resizeCanvas);\n    \n    // Visibility API - pause animation when tab is hidden\n    document.addEventListener('visibilitychange', () => {\n      isVisible = !document.hidden;\n      if (isVisible) {\n        animate();\n      } else if (animationId) {\n        cancelAnimationFrame(animationId);\n        animationId = null;\n      }\n    });\n    \n    // Start animation\n    animate();\n    updateParticleCount();\n  }\n  \n  function resizeCanvas() {\n    if (!canvas) return;\n    const rect = canvas.parentElement.getBoundingClientRect();\n    const dpr = window.devicePixelRatio || 1;\n    const width = canvas.clientWidth || rect.width || 600;\n    const height = 300;\n    \n    canvas.width = width * dpr;\n    canvas.height = height * dpr;\n    canvas.style.width = width + 'px';\n    canvas.style.height = height + 'px';\n    \n    if (ctx) {\n      ctx.scale(dpr, dpr);\n    }\n  }\n  \n  function createParticles(count) {\n    particles = [];\n    const width = canvas.width / (window.devicePixelRatio || 1);\n    const height = canvas.height / (window.devicePixelRatio || 1);\n    \n    for (let i = 0; i < count; i++) {\n      particles.push(createParticle(width, height));\n    }\n  }\n  \n  function createParticle(width, height) {\n    return {\n      x: Math.random() * width,\n      y: Math.random() * height,\n      vx: (Math.random() - 0.5) * CONFIG.maxSpeed * 1.5,\n      vy: (Math.random() - 0.5) * CONFIG.maxSpeed * 1.5,\n      size: CONFIG.baseSize + Math.random() * 2,\n      color: CONFIG.colorPalette[Math.floor(Math.random() * CONFIG.colorPalette.length)],\n      opacity: 0.6 + Math.random() * 0.4,\n      phase: Math.random() * Math.PI * 2,\n      pulseSpeed: 0.02 + Math.random() * 0.03,\n    };\n  }\n  \n  function updateParticles() {\n    const width = canvas.width / (window.devicePixelRatio || 1);\n    const height = canvas.height / (window.devicePixelRatio || 1);\n    \n    particles.forEach(p => {\n      // Update position with slight sinusoidal variation\n      p.x += p.vx + Math.sin(frameCount * 0.01 + p.phase) * 0.1;\n      p.y += p.vy + Math.cos(frameCount * 0.01 + p.phase) * 0.1;\n      \n      // Gentle attraction to center for a galaxy effect\n      const cx = width / 2;\n      const cy = height / 2;\n      const dx = cx - p.x;\n      const dy = cy - p.y;\n      const dist = Math.sqrt(dx * dx + dy * dy);\n      const maxDist = Math.max(width, height) * 0.6;\n      \n      if (dist < maxDist) {\n        const force = 0.0008 * (1 - dist / maxDist);\n        p.vx += dx * force;\n        p.vy += dy * force;\n      }\n      \n      // Damping to prevent runaway\n      p.vx *= 0.999;\n      p.vy *= 0.999;\n      \n      // Limit speed\n      const speed = Math.sqrt(p.vx * p.vx + p.vy * p.vy);\n      const maxSpeed = CONFIG.maxSpeed * 1.5;\n      if (speed > maxSpeed) {\n        p.vx = (p.vx / speed) * maxSpeed;\n        p.vy = (p.vy / speed) * maxSpeed;\n      }\n      \n      // Bounce off edges with some randomness\n      if (p.x < 0) { p.x = 0; p.vx = Math.abs(p.vx) * 0.8; }\n      if (p.x > width) { p.x = width; p.vx = -Math.abs(p.vx) * 0.8; }\n      if (p.y < 0) { p.y = 0; p.vy = Math.abs(p.vy) * 0.8; }\n      if (p.y > height) { p.y = height; p.vy = -Math.abs(p.vy) * 0.8; }\n    });\n  }\n  \n  function drawParticles() {\n    const width = canvas.width / (window.devicePixelRatio || 1);\n    const height = canvas.height / (window.devicePixelRatio || 1);\n    \n    // Clear canvas with subtle trail effect\n    ctx.fillStyle = 'rgba(0, 0, 0, 0.05)';\n    ctx.fillRect(0, 0, width, height);\n    \n    // Draw connections\n    ctx.lineWidth = 0.5;\n    for (let i = 0; i < particles.length; i++) {\n      for (let j = i + 1; j < particles.length; j++) {\n        const a = particles[i];\n        const b = particles[j];\n        const dx = a.x - b.x;\n        const dy = a.y - b.y;\n        const dist = Math.sqrt(dx * dx + dy * dy);\n        \n        if (dist < CONFIG.connectionDistance) {\n          const alpha = (1 - dist / CONFIG.connectionDistance) * 0.4;\n          ctx.beginPath();\n          ctx.moveTo(a.x, a.y);\n          ctx.lineTo(b.x, b.y);\n          ctx.strokeStyle = `rgba(255, 255, 255, ${alpha})`;\n          ctx.stroke();\n        }\n      }\n    }\n    \n    // Draw particles\n    particles.forEach(p => {\n      const pulse = 0.8 + Math.sin(frameCount * p.pulseSpeed + p.phase) * 0.2;\n      const size = p.size * pulse;\n      \n      // Glow\n      const gradient = ctx.createRadialGradient(\n        p.x, p.y, 0,\n        p.x, p.y, size * 3\n      );\n      gradient.addColorStop(0, p.color);\n      gradient.addColorStop(0.3, p.color + '80');\n      gradient.addColorStop(1, 'rgba(0,0,0,0)');\n      \n      ctx.beginPath();\n      ctx.arc(p.x, p.y, size * 3, 0, Math.PI * 2);\n      ctx.fillStyle = gradient;\n      ctx.fill();\n      \n      // Core\n      ctx.beginPath();\n      ctx.arc(p.x, p.y, size, 0, Math.PI * 2);\n      ctx.fillStyle = p.color;\n      ctx.shadowColor = p.color;\n      ctx.shadowBlur = 10;\n      ctx.fill();\n      ctx.shadowBlur = 0;\n    });\n    \n    // Mouse interaction - draw repulsion/attraction indicator\n    if (mouseX > 0 && mouseX < width && mouseY > 0 && mouseY < height) {\n      ctx.beginPath();\n      ctx.arc(mouseX, mouseY, 30, 0, Math.PI * 2);\n      ctx.strokeStyle = 'rgba(255,255,255,0.2)';\n      ctx.lineWidth = 1;\n      ctx.setLineDash([5, 5]);\n      ctx.stroke();\n      ctx.setLineDash([]);\n    }\n  }\n  \n  function animate() {\n    if (!isVisible) {\n      animationId = null;\n      return;\n    }\n    \n    frameCount++;\n    \n    // FPS counter\n    const now = performance.now();\n    if (now - lastFpsUpdate > 1000) {\n      fps = Math.round(frameCount / ((now - lastFpsUpdate) / 1000));\n      lastFpsUpdate = now;\n      frameCount = 0;\n    // Mouse interaction - repulsion\n    if (mouseX > 0 && mouseY > 0) {\n      const width = canvas.width / (window.devicePixelRatio || 1);\n      const height = canvas.height / (window.devicePixelRatio || 1);\n      \n      particles.forEach(p => {\n        const dx = p.x - mouseX;\n        const dy = p.y - mouseY;\n        const dist = Math.sqrt(dx * dx + dy * dy);\n        const maxDist = 80;\n        \n        if (dist < maxDist && dist > 0) {\n          const force = (1 - dist / maxDist) * 0.8;\n          p.vx += (dx / dist) * force;\n          p.vy += (dy / dist) * force;\n        }\n      });\n    }\n    \n    updateParticles();\n    drawParticles();\n    \n    animationId = requestAnimationFrame(animate);\n  }\n  \n  function handleClick(e) {\n    const rect = canvas.getBoundingClientRect();\n    const x = (e.clientX - rect.left) * (canvas.width / rect.width / (window.devicePixelRatio || 1));\n    const y = (e.clientY - rect.top) * (canvas.height / rect.height / (window.devicePixelRatio || 1));\n    \n    // Create explosion\n    const count = 30;\n    const width = canvas.width / (window.devicePixelRatio || 1);\n    const height = canvas.height / (window.devicePixelRatio || 1);\n    \n    for (let i = 0; i < count; i++) {\n      const angle = Math.random() * Math.PI * 2;\n      const speed = 2 + Math.random() * 4;\n      const p = createParticle(width, height);\n      p.x = x;\n      p.y = y;\n      p.vx = Math.cos(angle) * speed;\n      p.vy = Math.sin(angle) * speed;\n      p.size = 1 + Math.random() * 3;\n      p.color = CONFIG.colorPalette[Math.floor(Math.random() * CONFIG.colorPalette.length)];\n      particles.push(p);\n    }\n    \n    // Limit particle count to prevent slowdown\n    if (particles.length > 300) {\n      particles.splice(0, particles.length - 300);\n    }\n    \n    updateParticleCount();\n  }\n  \n  function handleMouseMove(e) {\n    const rect = canvas.getBoundingClientRect();\n    const dpr = window.devicePixelRatio || 1;\n    mouseX = (e.clientX - rect.left) * (canvas.width / rect.width / dpr);\n    mouseY = (e.clientY - rect.top) * (canvas.height / rect.height / dpr);\n  }\n  \n  function handleMouseLeave() {\n    mouseX = -1000;\n    mouseY = -1000;\n  }\n  \n  function updateParticleCount() {\n    const el = document.getElementById('particleCount');\n    if (el) el.textContent = particles.length;\n  }\n  \n  // Initialize when DOM is ready\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', init);\n  } else {\n    init();\n  }\n  \n  // Cleanup on page unload\n  window.addEventListener('beforeunload', () => {\n    if (animationId) {\n      cancelAnimationFrame(animationId);\n      animationId = null;\n    }\n  });\n})();",
  "target": "footer"
}