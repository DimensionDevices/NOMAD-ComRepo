{
  "description": "Desktop-style launcher with icon grid opening sections as windows",
  "css": "#desktopLauncher{padding:12px 20px}#desktopLauncher .launcher-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(80px,1fr));gap:12px;margin:6px 0 10px 0}#desktopLauncher .launcher-item{display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:12px 6px 10px 6px;cursor:pointer;transition:all .2s ease;text-align:center;user-select:none}#desktopLauncher .launcher-item:hover{transform:translateY(-3px);box-shadow:0 6px 18px rgba(0,0,0,.10);border-color:var(--accent)}#desktopLauncher .launcher-item:active{transform:scale(.95)}#desktopLauncher .launcher-icon{font-size:28px;line-height:1.2;margin-bottom:4px}#desktopLauncher .launcher-label{font-size:.7rem;font-weight:600;color:var(--text);line-height:1.2;word-break:break-word;max-width:100%}#desktopLauncher .launcher-badge{font-size:.55rem;background:var(--accent);color:#fff;border-radius:10px;padding:1px 7px;margin-top:4px;display:inline-block}#desktopLauncher .desktop-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px}#desktopLauncher .desktop-header h3{font-size:.9rem;font-weight:700;margin:0;color:var(--text)}#desktopLauncher .desktop-header .desktop-toggle{background:0 0;border:1px solid var(--border);border-radius:6px;padding:2px 10px;font-size:.7rem;cursor:pointer;color:var(--text-dim)}#desktopLauncher .desktop-header .desktop-toggle:hover{background:var(--surface)}.section{border: 0 !important;background:transparent !important;}.window-body .section h2{opacity:0!important;height:0!important;padding:0!important;margin:0!important;overflow:hidden!important;pointer-events:none!important;border: 0 !important;background: transparent !important;}.desktop-window{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(0.95);background:var(--bg);border:1px solid var(--border);border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,0.4);z-index:9999;width:92%;max-width:800px;max-height:85vh;display:flex;flex-direction:column;opacity:0;transition:all .2s cubic-bezier(.34,1.56,.64,1);pointer-events:none}.desktop-window.open{opacity:1;transform:translate(-50%,-50%) scale(1);pointer-events:auto}.desktop-window .window-header{display:flex;justify-content:space-between;align-items:center;padding:14px 20px;border-bottom:1px solid var(--border);flex-shrink:0}.desktop-window .window-header h2{margin:0;font-size:1.1rem}.desktop-window .window-close{background:0 0;border:none;font-size:28px;cursor:pointer;color:var(--text);padding:0 8px;line-height:1;opacity:.6;transition:opacity .2s}.desktop-window .window-close:hover{opacity:1}.desktop-window .window-body{overflow-y:auto;padding:16px 20px 20px 20px;flex:1}.desktop-window .window-body .section{opacity:1!important;height:auto!important;padding:0!important;margin:0!important;overflow:visible!important;pointer-events:auto!important}.desktop-window .window-body .section details>summary{display:none}.desktop-window .window-body .section details[open]>:not(summary){opacity:1;transform:translateY(0);visibility:visible;height:auto}.desktop-window .window-body .empty-state{padding:20px;text-align:center;color:var(--text-dim)}.window-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);z-index:9998;opacity:0;transition:opacity .2s ease;pointer-events:none}.window-overlay.open{opacity:1;pointer-events:auto}",
  "html": "<div id=desktopLauncher><div class=desktop-header><h3>&nbsp;</h3></div><div class=launcher-grid id=launcherGrid></div></div>",
  "js": "var sectionIds=['filesDetails','nodesDetails','loraMessengerDetails','transfersDetails','bookmarkDetails','extFilesDetails'];var labels={'filesDetails':'📁 Directory','nodesDetails':'📡 Nodes','loraMessengerDetails':'💬 Messenger','transfersDetails':'📦 Transfers','bookmarkDetails':'⭐ Bookmarks','extFilesDetails':'🧩 Extensions'};var icons={'filesDetails':'📂','nodesDetails':'📡','loraMessengerDetails':'💬','transfersDetails':'📦','bookmarkDetails':'⭐','extFilesDetails':'🧩'};var activeWindows=[];function getLabel(id){return labels[id]||id}function getIcon(id){return icons[id]||'📄'}function getCount(id){var el=document.getElementById(id);if(!el)return 0;if(id==='filesDetails')return el.querySelectorAll('.file-item,.file-card').length;if(id==='nodesDetails')return el.querySelectorAll('.node-card').length;if(id==='loraMessengerDetails')return el.querySelectorAll('div[style*=\"max-width:82%\"]').length;if(id==='transfersDetails')return el.querySelectorAll('.transfer-item').length;if(id==='bookmarkDetails')return el.querySelectorAll('.file-item').length;if(id==='extFilesDetails')return el.querySelectorAll('.file-item').length;return 0}window.closeWindow=function(id){var overlay=document.getElementById('windowOverlay_'+id);var win=document.getElementById('desktopWindow_'+id);if(overlay){overlay.classList.remove('open');setTimeout(function(){if(overlay.parentNode)overlay.remove()},250)}if(win){win.classList.remove('open');setTimeout(function(){if(win.parentNode)win.remove()},250)}activeWindows=activeWindows.filter(function(w){return w!==id});setTimeout(function(){if(activeWindows.length===0)document.body.style.overflow=''},300)};window.openWindow=function(id){var section=document.getElementById(id);if(!section)return;var existing=document.getElementById('desktopWindow_'+id);if(existing){window.closeWindow(id);setTimeout(function(){window.openWindow(id)},300);return}var content=section.cloneNode(true);content.className='section';content.style.cssText='opacity:1!important;height:auto!important;padding:0!important;margin:0!important;overflow:visible!important;pointer-events:auto!important';content.setAttribute('open','open');var overlay=document.createElement('div');overlay.className='window-overlay';overlay.id='windowOverlay_'+id;var win=document.createElement('div');win.className='desktop-window';win.id='desktopWindow_'+id;win.innerHTML='<div class=window-header><h2>'+getLabel(id)+'</h2><button class=window-close onclick=window.closeWindow(\"'+id+'\")>×</button></div><div class=window-body></div>';win.querySelector('.window-body').appendChild(content);document.body.appendChild(overlay);document.body.appendChild(win);document.body.style.overflow='hidden';activeWindows.push(id);setTimeout(function(){overlay.classList.add('open');win.classList.add('open')},10);setTimeout(function(){var items=content.querySelectorAll('.file-item,.node-card,.transfer-item');if(items.length===0){var empty=document.createElement('div');empty.className='empty-state';empty.innerHTML='<p>Nothing here yet...</p>';content.appendChild(empty)}},50);var escHandler=function(e){if(e.key==='Escape'){window.closeWindow(id);document.removeEventListener('keydown',escHandler)}};document.addEventListener('keydown',escHandler);overlay.onclick=function(){window.closeWindow(id)}};window.toggleAllSections=function(){var allHidden=true;for(var i=0;i<sectionIds.length;i++){var el=document.getElementById(sectionIds[i]);if(el&&el.style.opacity!=='0'&&el.style.height!=='0px'){allHidden=false;break}}for(var i=0;i<sectionIds.length;i++){var el=document.getElementById(sectionIds[i]);if(!el)continue;if(allHidden){el.style.opacity='1';el.style.height='auto';el.style.padding='';el.style.margin='';el.style.overflow='';el.style.pointerEvents='auto'}else{el.style.opacity='0';el.style.height='0';el.style.padding='0';el.style.margin='0';el.style.overflow='hidden';el.style.pointerEvents='none'}}var btn=document.querySelector('#desktopLauncher .desktop-toggle');if(btn){btn.textContent=allHidden?'Hide All':'Show All'}};function renderLauncher(){var grid=document.getElementById('launcherGrid');if(!grid)return;grid.innerHTML='';for(var i=0;i<sectionIds.length;i++){var id=sectionIds[i];var div=document.createElement('div');div.className='launcher-item';div.dataset.sectionId=id;div.onclick=function(i){return function(){window.openWindow(i)}}(id);var icon=document.createElement('div');icon.className='launcher-icon';icon.textContent=getIcon(id);var label=document.createElement('div');label.className='launcher-label';label.textContent=getLabel(id);var badge=document.createElement('span');badge.className='launcher-badge';badge.textContent='0';badge.style.display='none';div.appendChild(icon);div.appendChild(label);div.appendChild(badge);grid.appendChild(div)}setTimeout(updateBadges,300);var observer=new MutationObserver(function(){updateBadges()});observer.observe(document.getElementById('fileList')||document.body,{childList:true,subtree:true});observer.observe(document.getElementById('nodeList')||document.body,{childList:true,subtree:true});observer.observe(document.getElementById('chatWindow')||document.body,{childList:true,subtree:true});observer.observe(document.getElementById('transferList')||document.body,{childList:true,subtree:true});observer.observe(document.getElementById('favoritesList')||document.body,{childList:true,subtree:true});observer.observe(document.getElementById('extFileList')||document.body,{childList:true,subtree:true});window.__launcherObserver=observer}function updateBadges(){var items=document.querySelectorAll('#desktopLauncher .launcher-item');for(var i=0;i<items.length;i++){var id=items[i].dataset.sectionId;if(id){var count=getCount(id);var badge=items[i].querySelector('.launcher-badge');if(badge){badge.textContent=count;badge.style.display=count>0?'inline-block':'none'}}}}function init(){for(var i=0;i<sectionIds.length;i++){var el=document.getElementById(sectionIds[i]);if(el){el.style.opacity='0';el.style.height='0';el.style.padding='0';el.style.margin='0';el.style.overflow='hidden';el.style.pointerEvents='none'}}renderLauncher()}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',init)}else{init()}var oldRefreshFiles=window.refreshFiles;if(oldRefreshFiles){window.refreshFiles=function(){oldRefreshFiles.apply(this,arguments);setTimeout(updateBadges,500)}}var oldRefreshNodes=window.refreshNodes;if(oldRefreshNodes){window.refreshNodes=function(){oldRefreshNodes.apply(this,arguments);setTimeout(updateBadges,500)}}setInterval(updateBadges,5000)",
  "target": "footer"
}