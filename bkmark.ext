{
  "description": "Full-featured bookmark manager with icon dropdown.",
  "target": "header",
  "css": "#bookmarkDetails{display:none !important;} .nmdbm-toolbar{display:flex;gap:8px;padding:10px 10px 0 10px;flex-wrap:wrap;} .nmdbm-search{flex:1;padding:8px 10px;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:0.9em;min-width:120px;} .nmdbm-list{display:flex;flex-direction:column;gap:8px;padding:10px;} .nmdbm-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:10px 12px;display:flex;align-items:center;gap:10px;cursor:grab;} .nmdbm-card.nmdbm-dragging{opacity:0.4;} .nmdbm-card.nmdbm-dragover{border-color:var(--accent);} .nmdbm-handle{color:var(--text-dim);font-size:1.1em;user-select:none;} .nmdbm-icon{font-size:1.2em;flex-shrink:0;width:24px;text-align:center;} .nmdbm-info{flex:1;min-width:0;} .nmdbm-alias{font-weight:600;color:var(--text);word-break:break-word;} .nmdbm-realname{font-size:0.78em;color:var(--text-dim);word-break:break-all;} .nmdbm-actions{display:flex;gap:6px;flex-shrink:0;flex-wrap:wrap;} .nmdbm-empty{padding:20px;text-align:center;color:var(--text-dim);} .nmdbm-rename-input{width:100%;padding:4px 6px;border-radius:6px;border:1px solid var(--accent);background:var(--bg);color:var(--text);font-size:0.9em;} .nmdbm-refresh-btn{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:8px 12px;color:var(--text);cursor:pointer;font-size:0.9em;} .nmdbm-refresh-btn:hover{background:var(--bg);} .nmdbm-icon-select{font-size:1.1em;padding:4px 6px;border-radius:6px;border:1px solid var(--accent);background:var(--bg);color:var(--text);cursor:pointer;max-width:80px;} .nmdbm-icon-select option{font-size:1.1em;padding:2px;} .nmdbm-rename-container{display:flex;align-items:center;gap:8px;width:100%;}",
  "html": "<details class='section' id='nmdbmDetails' open><summary><h2><svg style='top:6px;position:relative' width='24px' height='24px' fill='none' viewBox='0 0 16 16' xmlns='http://www.w3.org/2000/svg'><path d='M14 0H2V16H4L8 12L12 16H14V0ZM7 3V5H5V7H7V9H9V7H11V5H9V3H7Z' clip-rule='evenodd' fill='var(--text)' fill-rule='evenodd'></path></svg>&nbsp;Bookmarks</h2></summary><div class='nmdbm-toolbar'><input type='text' id='nmdbmSearch' class='nmdbm-search' placeholder='Search bookmarks...' oninput='nmdbmRender()'><button class='nmdbm-refresh-btn' onclick='nmdbmRender()'>вҹі Refresh</button></div><div id='nmdbmList' class='nmdbm-list'><div class='nmdbm-empty'>Loading bookmarks...</div></div></details>",
  "js": "var STORE_KEY='nmdbm_bookmarks_v1';var ICON_SET=['рҹ“„','рҹ“ғ','рҹ“‘','рҹ“Ҡ','рҹ“Ҳ','рҹ“ү','рҹ“Ӣ','рҹ“Ң','рҹ“Қ','рҹ“Һ','рҹ–ҮпёҸ','рҹ“қ','рҹ“…','рҹ“Ҷ','рҹ—ӮпёҸ','рҹ“Ӯ','рҹ“Ғ','рҹ—ғпёҸ','рҹ—„пёҸ','рҹ—‘пёҸ','рҹ”–','рҹ“ҡ','рҹ“–','рҹ“•','рҹ“—','рҹ“ҳ','рҹ“ҷ','рҹҢҗ','рҹҢҚ','рҹҢҺ','рҹҢҸ','рҹ–ҘпёҸ','рҹ’»','вҢЁпёҸ','рҹ–ұпёҸ','рҹ–ЁпёҸ','рҹ“ұ','рҹ“І','вҳҺпёҸ','рҹ“һ','рҹ“ ','рҹ“Ў','рҹ“¶','рҹ”—','рҹ”’','рҹ”“','рҹ”җ','рҹ”‘','рҹӣЎпёҸ','рҹ“§','вңүпёҸ','рҹ“©','рҹ“Ё','рҹ“Ә','рҹ“«','рҹ“¬','рҹ“ӯ','рҹ“®','рҹҸ·пёҸ','рҹҺө','рҹҺ¶','рҹҺӨ','рҹҺ§','рҹ“·','рҹ“ё','рҹҺҘ','рҹҺ¬','рҹ“ә','рҹ“»','рҹҺҷпёҸ','рҹҺҡпёҸ','рҹҺӣпёҸ','рҹ“ҪпёҸ','рҹҺһпёҸ','рҹ“ҹ','рҹ”ў','рҹ” ','рҹ”Ў','рҹ”Ө','рҹ”Қ','рҹ”Һ','рҹ”ӯ','рҹ§ӯ','рҹ—әпёҸ','рҹҺҜ','рҹҸҒ','рҹҡ©','рҹҸҙ','рҹҸіпёҸ','вӯҗ','рҹҢҹ','вңЁ','рҹ’«','рҹ”Ҙ','вҡЎ','рҹ’Ў','рҹ””','рҹ”•','рҹ’Ҝ','рҹҶ•','рҹ”ҙ','рҹҹ ','рҹҹЎ','рҹҹў','рҹ”ө','рҹҹЈ','рҹҹӨ','вҡ«','вҡӘ','вң…','вң”пёҸ','вҳ‘пёҸ','вқҢ','вқҺ','вӯ•','вһЎпёҸ','в¬…пёҸ','в¬ҶпёҸ','в¬ҮпёҸ','рҹ”„','рҹ”ғ','рҹ”Җ','рҹ”Ғ','рҹ”Ӯ','рҹ‘Ө','рҹ‘Ҙ','рҹ§‘','рҹ‘Ё','рҹ‘©','рҹ§’','рҹ‘Ұ','рҹ‘§','рҹ‘ЁвҖҚрҹ’»','рҹ‘©вҖҚрҹ’»','рҹ‘ЁвҖҚрҹҸ«','рҹ‘©вҖҚрҹҸ«','рҹ‘ЁвҖҚрҹҺ“','рҹ‘©вҖҚрҹҺ“','рҹ§‘вҖҚрҹ’»','рҹҸ ','рҹҸЎ','рҹҸў','рҹҸЈ','рҹҸӨ','рҹҸҘ','рҹҸҰ','рҹҸЁ','рҹҸ©','рҹҸӘ','рҹҸ«','рҹҸ¬','рҹҸӯ','рҹҸҜ','рҹҸ°','рҹ’’','рҹ—ј','рҹ—Ҫ','рҹҸ”пёҸ','рҹҢӢ','рҹ—»','рҹҸқпёҸ','рҹҸңпёҸ','рҹҺ®','рҹ•№пёҸ','рҹҺІ','вҷ пёҸ','вҷҘпёҸ','вҷҰпёҸ','вҷЈпёҸ','рҹғҸ','рҹҺі','рҹҺҝ','рҹҸӮ','рҹҸ„','рҹҸҠ','рҹ•җ','рҹ•‘','рҹ•’','рҹ•“','рҹ•”','рҹ••','рҹ•–','рҹ•—','рҹ•ҳ','рҹ•ҷ','рҹ•ҡ','рҹ•ӣ','вҸ°','вҢҡ','вҸі','вҢӣ','рҹ”§','рҹ”Ё','вҡ’пёҸ','рҹӣ пёҸ','вӣҸпёҸ','рҹ”©','вҡҷпёҸ','рҹ§°','рҹ§ұ','рҹ”«','рҹ”Ә','вҡ”пёҸ','рҹӣЎпёҸ','рҹ”¬','рҹ”ӯ','рҹ’ү','рҹ’Ҡ','рҹҺЁ','рҹ–ҢпёҸ','рҹ–ҚпёҸ','вңҸпёҸ','вң’пёҸ','рҹ–ҠпёҸ','рҹ–ӢпёҸ','рҹ“җ','рҹ“Ҹ','рҹӣ’','рҹӣҚпёҸ','рҹ’°','рҹ’ө','рҹ’¶','рҹ’·','рҹ’ҙ','рҹ’і','рҹ“Ұ','рҹ’¬','рҹ’ӯ','рҹ—ЁпёҸ','рҹ—ҜпёҸ','рҹ’Ң','рҹ“Ө','рҹ“Ҙ','рҹ”®','рҹ§ҝ','рҹ’Һ','рҹ”ұ','вҡңпёҸ','рҹ”°','вҷ»пёҸ','вҡ•пёҸ','рҹ”Ҝ','вңЎпёҸ','вҳҜпёҸ','вҳ®пёҸ','рҹ•үпёҸ','рҹҶ”','вҡӣпёҸ','вҳўпёҸ','вҳЈпёҸ','рҹӣҗ','рҹ•Ӣ','рҹ•Ң','рҹ•Қ','вӣӘ','рҹ’ҫ','рҹ’ҝ','рҹ“Җ'];function loadStore(){try{var raw=localStorage.getItem(STORE_KEY);if(raw)return JSON.parse(raw);}catch(e){}return null;}function saveStore(list){localStorage.setItem(STORE_KEY,JSON.stringify(list));}function migrateFromLegacy(){var legacy=(typeof getFavorites==='function')?getFavorites():[];var list=loadStore();if(!list){list=legacy.map(function(name,i){return{name:name,alias:name,icon:'рҹ“„',order:i};});saveStore(list);return list;}var existingNames=list.map(function(b){return b.name;});var maxOrder=list.reduce(function(m,b){return Math.max(m,b.order);},-1);legacy.forEach(function(name){if(existingNames.indexOf(name)===-1){maxOrder++;list.push({name:name,alias:name,icon:'рҹ“„',order:maxOrder});}});list=list.filter(function(b){return legacy.indexOf(b.name)!==-1;});saveStore(list);return list;}function getList(){return migrateFromLegacy().sort(function(a,b){return a.order-b.order;});}function setList(list){list.forEach(function(b,i){b.order=i;});saveStore(list);if(typeof setFavorites==='function'){setFavorites(list.map(function(b){return b.name;}));}}window.nmdbmDelete=function(name){var list=getList().filter(function(b){return b.name!==name;});setList(list);nmdbmRender();};window.nmdbmStartRename=function(name){var list=getList();var item=list.find(function(b){return b.name===name;});if(!item)return;var container=document.querySelector('[data-nmdbm-name=\"'+CSS.escape(name)+'\"] .nmdbm-info');if(!container)return;var div=document.createElement('div');div.className='nmdbm-rename-container';var select=document.createElement('select');select.className='nmdbm-icon-select';ICON_SET.forEach(function(icon){var option=document.createElement('option');option.value=icon;option.textContent=icon;if(icon===item.icon){option.selected=true;}select.appendChild(option);});var nameInput=document.createElement('input');nameInput.type='text';nameInput.className='nmdbm-rename-input';nameInput.value=item.alias;nameInput.style.flex='1';div.appendChild(select);div.appendChild(nameInput);container.innerHTML='';container.appendChild(div);nameInput.focus();nameInput.select();var isCommitting=false;function commit(){if(isCommitting)return;isCommitting=true;var iconVal=select.value||'рҹ“„';var nameVal=nameInput.value.trim();if(nameVal.length>0){item.alias=nameVal;item.icon=iconVal;}setList(list);nmdbmRender();isCommitting=false;}function handleKeydown(e){if(e.key==='Enter'){e.preventDefault();commit();}else if(e.key==='Escape'){nmdbmRender();}}select.addEventListener('change',function(){commit();});nameInput.addEventListener('keydown',handleKeydown);nameInput.addEventListener('blur',function(e){setTimeout(function(){if(!select.matches(':focus')&&!nameInput.matches(':focus')){commit();}},100);});};var dragSrcName=null;window.nmdbmDragStart=function(e,name){dragSrcName=name;e.currentTarget.classList.add('nmdbm-dragging');e.dataTransfer.effectAllowed='move';};window.nmdbmDragEnd=function(e){e.currentTarget.classList.remove('nmdbm-dragging');document.querySelectorAll('.nmdbm-dragover').forEach(function(el){el.classList.remove('nmdbm-dragover');});};window.nmdbmDragOver=function(e,name){e.preventDefault();if(name!==dragSrcName){e.currentTarget.classList.add('nmdbm-dragover');}};window.nmdbmDragLeave=function(e){e.currentTarget.classList.remove('nmdbm-dragover');};window.nmdbmDrop=function(e,targetName){e.preventDefault();e.currentTarget.classList.remove('nmdbm-dragover');if(!dragSrcName||dragSrcName===targetName)return;var list=getList();var fromIdx=list.findIndex(function(b){return b.name===dragSrcName;});var toIdx=list.findIndex(function(b){return b.name===targetName;});if(fromIdx===-1||toIdx===-1)return;var moved=list.splice(fromIdx,1)[0];list.splice(toIdx,0,moved);setList(list);dragSrcName=null;nmdbmRender();};window.nmdbmRender=function(){var listEl=document.getElementById('nmdbmList');if(!listEl)return;var searchEl=document.getElementById('nmdbmSearch');var query=searchEl?searchEl.value.trim().toLowerCase():'';var list=getList();if(query){list=list.filter(function(b){return b.alias.toLowerCase().indexOf(query)>-1||b.name.toLowerCase().indexOf(query)>-1;});}if(list.length===0){listEl.innerHTML='<div class=\"nmdbm-empty\">'+(query?'No bookmarks match your search.':'No bookmarks yet :(')+'</div>';return;}var html='';list.forEach(function(b){var safeName=b.name.replace(/'/g,\"\\\\'\");var showRealName=b.alias!==b.name;var icon=b.icon||'рҹ“„';html+='<div class=\"nmdbm-card\" draggable=\"true\" data-nmdbm-name=\"'+b.name.replace(/\"/g,'&quot;')+'\" '+'ondragstart=\"nmdbmDragStart(event,\\''+safeName+'\\')\" ondragend=\"nmdbmDragEnd(event)\" '+'ondragover=\"nmdbmDragOver(event,\\''+safeName+'\\')\" ondragleave=\"nmdbmDragLeave(event)\" ondrop=\"nmdbmDrop(event,\\''+safeName+'\\')\">'+'<span class=\"nmdbm-handle\">в ҝ</span>'+'<span class=\"nmdbm-icon\">'+icon+'</span>'+'<div class=\"nmdbm-info\"><div class=\"nmdbm-alias\">'+b.alias+'</div>'+(showRealName?'<div class=\"nmdbm-realname\">'+b.name+'</div>':'')+'</div>'+'<div class=\"nmdbm-actions\">'+'<button class=\"btn btn-small\" title=\"Rename\" onclick=\"nmdbmStartRename(\\''+safeName+'\\')\">вңҺ</button>'+'<button class=\"btn btn-success btn-small\" title=\"Open\" onclick=\"viewFile(\\''+safeName+'\\')\"><svg fill=\"#ffffff\" width=\"16px\" height=\"16px\" viewBox=\"0 0 16 16\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M12.027 9.92L16 13.95 14 16l-4.075-3.976A6.465 6.465 0 0 1 6.5 13C2.91 13 0 10.083 0 6.5 0 2.91 2.917 0 6.5 0 10.09 0 13 2.917 13 6.5a6.463 6.463 0 0 1-.973 3.42zM1.997 6.452c0 2.48 2.014 4.5 4.5 4.5 2.48 0 4.5-2.015 4.5-4.5 0-2.48-2.015-4.5-4.5-4.5-2.48 0-4.5 2.014-4.5 4.5z\" fill-rule=\"evenodd\"></path></svg></button>'+'<button class=\"btn btn-danger btn-small\" title=\"Remove bookmark\" onclick=\"nmdbmDelete(\\''+safeName+'\\')\">вң•</button>'+'</div></div>';});listEl.innerHTML=html;};var origToggle=window.toggleFavorite;if(typeof origToggle==='function'){window.toggleFavorite=function(e,name){origToggle(e,name);nmdbmRender();};}nmdbmRender();"
}