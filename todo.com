PAGE: Todo List
COLOR: #10b981
AUTHOR: NOMAD
DATE: 2025-01-15
DESCRIPTION: Simple offline todo list with save
CATEGORY: app
BIGHEADER: Todo List
CUSTOMHTML-START
<style>.todo-container{background:#f0fdf4;border-radius:16px;padding:16px;}.add-area{display:flex;gap:8px;margin-bottom:20px;}.todo-input{flex:1;padding:12px;border:1px solid #d1fae5;border-radius:12px;font-size:14px;outline:none;}.todo-input:focus{border-color:#10b981;}.add-btn{background:#10b981;color:white;border:none;padding:12px 20px;border-radius:12px;font-weight:bold;cursor:pointer;}.stats{font-size:12px;color:#6b7280;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid #d1fae5;}.todo-list{list-style:none;padding:0;margin:0;}.todo-item{display:flex;align-items:center;padding:10px;background:white;border-radius:10px;margin-bottom:8px;border:1px solid #d1fae5;}.todo-check{width:22px;height:22px;margin-right:12px;cursor:pointer;accent-color:#10b981;}.todo-text{flex:1;font-size:14px;word-break:break-word;}.todo-text.done{text-decoration:line-through;color:#9ca3af;}.delete-btn{background:none;border:none;color:#ef4444;font-size:18px;cursor:pointer;padding:0 8px;opacity:0.6;}.delete-btn:hover{opacity:1;}.empty-msg{text-align:center;color:#9ca3af;padding:30px;font-size:14px;}.clear-btn{background:#fee2e2;color:#dc2626;border:none;padding:8px 16px;border-radius:10px;font-size:12px;cursor:pointer;margin-top:12px;width:100%;}</style> <div class="todo-container"> <div class="add-area"> <input type="text" id="todoInput" class="todo-input" placeholder="Write a task..." onkeypress="if(event.key==='Enter') addTodo()"> <button class="add-btn" onclick="addTodo()">Add</button> </div> <div class="stats" id="stats">0 tasks, 0 completed</div> <ul class="todo-list" id="todoList"> <li class="empty-msg">No tasks yet. Add one above!</li> </ul> <button class="clear-btn" onclick="clearCompleted()">Clear Completed</button> </div> <script>let todos=[];function loadTodos(){let saved=localStorage.getItem('nomad_todos');if(saved){todos=JSON.parse(saved);}renderTodos();}function saveTodos(){localStorage.setItem('nomad_todos',JSON.stringify(todos));renderTodos();}function addTodo(){let input=document.getElementById('todoInput');let text=input.value.trim();if(text==='')return;todos.push({id: Date.now(),text: text,done: false});input.value='';saveTodos();}function toggleTodo(id){let todo=todos.find(t=>t.id===id);if(todo){todo.done=!todo.done;saveTodos();}}function deleteTodo(id){todos=todos.filter(t=>t.id!==id);saveTodos();}function clearCompleted(){todos=todos.filter(t=>!t.done);saveTodos();}function renderTodos(){let list=document.getElementById('todoList');let stats=document.getElementById('stats');let total=todos.length;let completed=todos.filter(t=>t.done).length;stats.innerText=total+' task'+(total!==1 ? 's' : '')+','+completed+' completed';if(total===0){list.innerHTML='<li class="empty-msg">No tasks yet. Add one above!</li>';return;}list.innerHTML='';for(let todo of todos){let li=document.createElement('li');li.className='todo-item';let check=document.createElement('input');check.type='checkbox';check.className='todo-check';check.checked=todo.done;check.onclick=(function(id){return function(){toggleTodo(id);};})(todo.id);let span=document.createElement('span');span.className='todo-text'+(todo.done ? ' done' : '');span.innerText=todo.text;let delBtn=document.createElement('button');delBtn.innerHTML='✕';delBtn.className='delete-btn';delBtn.onclick=(function(id){return function(){deleteTodo(id);};})(todo.id);li.appendChild(check);li.appendChild(span);li.appendChild(delBtn);list.appendChild(li);}}loadTodos();</script>
CUSTOMHTML-END