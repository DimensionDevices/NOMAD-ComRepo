{
  "html": "<div id='overlayDiv' style='position:fixed;top:0;left:0;width:100%;height:100%;z-index:999999;pointer-events:none;mix-blend-mode:multiply;filter:contrast(0.4) brightness(1.3);background:url(none);background-size:cover;background-position:center;'></div><div id='overlayControls' style='display:none;'><div style='padding:12px 0;'><div style='display:flex;gap:8px;flex-wrap:wrap;align-items:center;'><input type='url' id='overlayUrlInput' placeholder='Enter image URL...' style='flex:1;min-width:200px;background:var(--bg);border:1px solid var(--border);color:var(--text);padding:8px 12px;border-radius:6px;font-size:.85em;'><button class='btn' id='overlayApplyBtn' style='background:var(--accent);color:#fff;border:none;padding:8px 20px;border-radius:6px;cursor:pointer;'>Apply</button><button class='btn btn-secondary' id='overlayResetBtn' style='background:var(--border);color:var(--text);border:none;padding:8px 20px;border-radius:6px;cursor:pointer;'>Reset</button></div><div style='margin-top:8px;wrap;align-items:center;'><label style='font-size:.75em;color:var(--text-dim);'>Blend Mode:</label><select id='overlayBlendMode' style='background:var(--bg);border:1px solid var(--border);color:var(--text);padding:4px 8px;border-radius:4px;font-size:.85em;'><option value='multiply' selected>Multiply</option><option value='screen'>Screen</option><option value='overlay'>Overlay</option><option value='darken'>Darken</option><option value='lighten'>Lighten</option><option value='color-dodge'>Color Dodge</option><option value='color-burn'>Color Burn</option><option value='hard-light'>Hard Light</option><option value='soft-light'>Soft Light</option><option value='difference'>Difference</option><option value='exclusion'>Exclusion</option><option value='hue'>Hue</option><option value='saturation'>Saturation</option><option value='color'>Color</option></select></div><div style='margin-top:6px;display:flex;gap:16px;flex-wrap:wrap;align-items:center;'><div style='display:flex;align-items:center;gap:8px;flex:1;min-width:120px;'><label style='font-size:.7em;color:var(--text-dim);min-width:60px;'>Contrast:</label><input type='range' id='overlayContrast' min='0' max='2' step='0.01' value='0.4' style='flex:1;min-width:80px;'><span id='overlayContrastVal' style='font-size:.7em;color:var(--text-dim);min-width:40px;text-align:right;'>0.40</span></div><div style='display:flex;align-items:center;gap:8px;flex:1;min-width:120px;margin-top:0.25em;'><label style='font-size:.7em;color:var(--text-dim);min-width:60px;'>Brightness:</label><input type='range' id='overlayBrightness' min='0' max='3' step='0.01' value='1.3' style='flex:1;min-width:80px;'><span id='overlayBrightnessVal' style='font-size:.7em;color:var(--text-dim);min-width:40px;text-align:right;'>1.30</span></div></div><div style='margin-top:8px;font-size:.7em;color:var(--text-dim);'><span id='overlayStatus'>No overlay set</span></div></div></div>",
  "css": "#overlayControls { display: none; }",
  "js": "(function(){'use strict';var STORAGE_KEY='overlay_image_url';var BLEND_KEY='overlay_blend_mode';var CONTRAST_KEY='overlay_contrast';var BRIGHTNESS_KEY='overlay_brightness';var overlay=document.getElementById('overlayDiv');function updateFilter(){var contrast=parseFloat(localStorage.getItem(CONTRAST_KEY)||'0.4');var brightness=parseFloat(localStorage.getItem(BRIGHTNESS_KEY)||'1.3');overlay.style.filter='contrast('+contrast+') brightness('+brightness+')';var cEl=document.getElementById('overlayContrastVal');var bEl=document.getElementById('overlayBrightnessVal');if(cEl)cEl.textContent=contrast.toFixed(2);if(bEl)bEl.textContent=brightness.toFixed(2);var cRange=document.getElementById('overlayContrast');var bRange=document.getElementById('overlayBrightness');if(cRange)cRange.value=contrast;if(bRange)bRange.value=brightness}function applyOverlay(url){if(!url||url.trim()===''){overlay.style.background='';overlay.style.backgroundSize='';overlay.style.backgroundPosition='';var s=document.getElementById('overlayStatus');if(s)s.textContent='No overlay set';localStorage.removeItem(STORAGE_KEY);return}overlay.style.background='url(\"'+url+'\")';overlay.style.backgroundSize='cover';overlay.style.backgroundPosition='center';var s=document.getElementById('overlayStatus');if(s)s.textContent='Overlay: '+url.substring(0,50)+(url.length>50?'...':'');localStorage.setItem(STORAGE_KEY,url)}function applyBlendMode(mode){if(!mode||mode==='')mode='normal';overlay.style.mixBlendMode=mode;var sel=document.getElementById('overlayBlendMode');if(sel)sel.value=mode;localStorage.setItem(BLEND_KEY,mode)}function applyContrast(val){val=parseFloat(val)||0.4;localStorage.setItem(CONTRAST_KEY,val);updateFilter()}function applyBrightness(val){val=parseFloat(val)||1.3;localStorage.setItem(BRIGHTNESS_KEY,val);updateFilter()}function loadSavedSettings(){var saved=localStorage.getItem(STORAGE_KEY);if(saved){var input=document.getElementById('overlayUrlInput');if(input)input.value=saved;applyOverlay(saved)}var savedBlend=localStorage.getItem(BLEND_KEY);if(savedBlend){applyBlendMode(savedBlend)}var savedContrast=localStorage.getItem(CONTRAST_KEY);if(savedContrast){var cRange=document.getElementById('overlayContrast');if(cRange)cRange.value=savedContrast}var savedBrightness=localStorage.getItem(BRIGHTNESS_KEY);if(savedBrightness){var bRange=document.getElementById('overlayBrightness');if(bRange)bRange.value=savedBrightness}updateFilter()}function loadSettingsOnStart(){loadSavedSettings();setTimeout(function(){loadSavedSettings()},100)}function injectOverlayControls(){var extOptions=document.getElementById('extOptions');if(!extOptions)return;if(extOptions.querySelector('.overlay-controls-injected'))return;var controls=document.getElementById('overlayControls');if(!controls)return;var clone=controls.cloneNode(true);clone.id='overlayControlsInjected';clone.className='overlay-controls-injected';clone.style.display='block';clone.style.marginBottom='20px';var title=document.createElement('div');title.style.cssText='font-weight:600;font-size:1em;margin-bottom:8px;color:var(--text);';title.textContent='Overlay Settings';clone.insertBefore(title,clone.firstChild);extOptions.insertBefore(clone,extOptions.firstChild);var input=document.getElementById('overlayUrlInput');var applyBtn=document.getElementById('overlayApplyBtn');var resetBtn=document.getElementById('overlayResetBtn');var blendSelect=document.getElementById('overlayBlendMode');var contrastRange=document.getElementById('overlayContrast');var brightnessRange=document.getElementById('overlayBrightness');if(applyBtn){applyBtn.addEventListener('click',function(){var url=input?input.value.trim():'';if(url){applyOverlay(url)}else{var s=document.getElementById('overlayStatus');if(s)s.textContent='Enter a valid URL'}})}if(input){input.addEventListener('keypress',function(e){if(e.key==='Enter'){var url=input.value.trim();if(url){applyOverlay(url)}}})}if(resetBtn){resetBtn.addEventListener('click',function(){if(input)input.value='';applyOverlay('');if(input)input.focus()})}if(blendSelect){blendSelect.addEventListener('change',function(){applyBlendMode(this.value)});var savedBlend=localStorage.getItem(BLEND_KEY);if(savedBlend)blendSelect.value=savedBlend}if(contrastRange){contrastRange.addEventListener('input',function(){applyContrast(this.value)});var savedContrast=localStorage.getItem(CONTRAST_KEY);if(savedContrast)contrastRange.value=savedContrast}if(brightnessRange){brightnessRange.addEventListener('input',function(){applyBrightness(this.value)});var savedBrightness=localStorage.getItem(BRIGHTNESS_KEY);if(savedBrightness)brightnessRange.value=savedBrightness}loadSavedSettings()}function init(){loadSettingsOnStart();var origOpenHelp=window.openHelpModal;window.openHelpModal=function(){if(origOpenHelp)origOpenHelp();setTimeout(injectOverlayControls,150)};var origInitHelp=window.initHelpModal;window.initHelpModal=function(){if(origInitHelp)origInitHelp();setTimeout(injectOverlayControls,150)};setTimeout(injectOverlayControls,500)}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',init)}else{init()}})();",
  "target": "footer"
}