{
  "description": "Storage usage pie chart",
  "target": "footer",
  "html": "<style>.pies-section{margin-top:16px;background:var(--surface);border-radius:12px;border:1px solid var(--border);overflow:hidden;}.pies-header{padding:12px 16px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);}.pies-header h4{margin:0;font-size:14px;font-weight:600;}.pies-body{padding:16px;display:flex;flex-wrap:wrap;gap:24px;justify-content:center;}.pie-item{flex:1;min-width:120px;max-width:200px;text-align:center;}.pie-item canvas{width:100%;height:auto;aspect-ratio:1;display:block;}.pie-label{font-size:12px;font-weight:500;margin-top:6px;}.pie-value{font-size:11px;opacity:0.6;}.pies-empty{text-align:center;padding:20px;opacity:0.6;font-size:13px;}</style><details class='section' id='piesDetails'><summary><h2>◑&nbsp;&nbsp;Charts</h2></summary><div class='pies-section'><div class='pies-header'><h4>Storage Usage</h4><span class='storage-total' id='storageTotal'>0 KB total</span></div><div class='pies-body'><div class='pie-item'><canvas id='storageChart' width='200' height='200'></canvas><div class='pie-label'>Storage</div><div class='pie-value' id='storageLabel'>0 / 0 KB</div></div><div class='pie-item'><canvas id='dutyChart' width='200' height='200'></canvas><div class='pie-label'>Duty Cycle</div><div class='pie-value' id='dutyLabel'>0% used</div></div><div class='pie-item'><canvas id='heapChart' width='200' height='200'></canvas><div class='pie-label'>Free Heap</div><div class='pie-value' id='heapLabel'>0 / 0 KB</div></div></div></div></details>",
  "css": "",
  "js": "(function(){var storageCanvas=document.getElementById('storageChart');var dutyCanvas=document.getElementById('dutyChart');var heapCanvas=document.getElementById('heapChart');var storageTotalEl=document.getElementById('storageTotal');var storageLabelEl=document.getElementById('storageLabel');var dutyLabelEl=document.getElementById('dutyLabel');var heapLabelEl=document.getElementById('heapLabel');var colors=['#547540','#3a6ea5','#a55c3a','#8b3aa5','#abb3a5','#6b6b6b','#c62828','#f57c00','#2e7d32','#6a1b9a'];function drawPie(canvas,used,total,color,label){if(!canvas)return;var ctx=canvas.getContext('2d');var w=canvas.width;var h=canvas.height;var cx=w/2;var cy=h/2;var r=Math.min(w,h)/2-10;ctx.clearRect(0,0,w,h);var percent=total>0?Math.min(used/total,1):0;var startAngle=-Math.PI/2;var slice=percent*Math.PI*2;ctx.beginPath();ctx.moveTo(cx,cy);ctx.arc(cx,cy,r,startAngle,startAngle+slice);ctx.closePath();ctx.fillStyle=color||'#547540';ctx.fill();ctx.beginPath();ctx.moveTo(cx,cy);ctx.arc(cx,cy,r,startAngle+slice,startAngle+Math.PI*2);ctx.closePath();ctx.fillStyle='rgba(255,255,255,0.12)';ctx.fill();ctx.beginPath();ctx.arc(cx,cy,r*0.5,0,Math.PI*2);ctx.fillStyle='var(--surface)';ctx.fill();ctx.fillStyle='var(--text)';ctx.font='bold 14px sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(Math.round(percent*100)+'%',cx,cy);}function getFileExtension(name){var ext=name.substring(name.lastIndexOf('.')).toLowerCase();return ext||'other';}function getCategory(ext){var map={'.txt':'Text','.md':'Markdown','.com':'Web','.img':'Images','.avif':'Images','.ext':'Extensions','.bin':'Binary'};return map[ext]||'Other';}function renderStorageChart(files){if(!storageCanvas)return;var total=files.reduce(function(sum,f){return sum+f.size;},0);if(total===0){drawPie(storageCanvas,0,1,'#6b6b6b');storageTotalEl.textContent='0 KB total';storageLabelEl.textContent='No files';return;}var categories={};files.forEach(function(file){var ext=getFileExtension(file.name);var cat=getCategory(ext);var label=cat;if(ext==='.txt')label='Text (.txt)';else if(ext==='.md')label='Markdown (.md)';else if(ext==='.com')label='Web (.com)';else if(ext==='.img')label='Images (.img)';else if(ext==='.avif')label='Images (.avif)';else if(ext==='.ext')label='Extensions (.ext)';else label=cat+' ('+ext+')';if(!categories[label]){categories[label]={label:label,size:0,color:colors[Object.keys(categories).length%colors.length]};}categories[label].size+=file.size;});var data=Object.values(categories);data.sort(function(a,b){return b.size-a.size;});if(data.length>6){var other={label:'Other',size:0,color:'#6b6b6b'};data.slice(6).forEach(function(item){other.size+=item.size;});data=data.slice(0,6);if(other.size>0)data.push(other);}var ctx=storageCanvas.getContext('2d');var w=storageCanvas.width;var h=storageCanvas.height;var cx=w/2;var cy=h/2;var r=Math.min(w,h)/2-10;ctx.clearRect(0,0,w,h);var startAngle=-Math.PI/2;data.forEach(function(item,index){var slice=(item.size/total)*Math.PI*2;var endAngle=startAngle+slice;ctx.beginPath();ctx.moveTo(cx,cy);ctx.arc(cx,cy,r,startAngle,endAngle);ctx.closePath();ctx.fillStyle=item.color||colors[index%colors.length];ctx.fill();startAngle=endAngle;});ctx.beginPath();ctx.arc(cx,cy,r*0.5,0,Math.PI*2);ctx.fillStyle='var(--surface)';ctx.fill();ctx.fillStyle='var(--text)';ctx.font='bold 14px sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(Math.round((total/1024)*10)/10+'K',cx,cy);storageTotalEl.textContent=Math.round((total/1024)*10)/10+' KB total';storageLabelEl.textContent=files.length+' files, '+Math.round((total/1024)*10)/10+' KB';}function renderDutyChart(){if(!dutyCanvas)return;var dutyEl=document.getElementById('dutyCycle');if(!dutyEl){drawPie(dutyCanvas,0,1,'#f57c00');dutyLabelEl.textContent='0% used';return;}var dutyText=dutyEl.textContent.trim();var percent=parseFloat(dutyText)||0;drawPie(dutyCanvas,percent,100,'#f57c00');dutyLabelEl.textContent=percent.toFixed(1)+'% used';}function renderHeapChart(){if(!heapCanvas)return;var heapEl=document.getElementById('freeHeap');if(!heapEl){drawPie(heapCanvas,0,1,'#3a6ea5');heapLabelEl.textContent='0 / 0 KB';return;}var text=heapEl.textContent.trim().replace('kB','').trim();var used=parseFloat(text)||0;var total=320;drawPie(heapCanvas,used,total,'#3a6ea5');heapLabelEl.textContent=Math.round(used)+' / '+total+' KB free ('+Math.round((used/total)*100)+'%)';}function updateAll(){fetch('/api/files').then(function(r){if(!r.ok)throw new Error('Failed');return r.json();}).then(function(data){var files=data.files||[];renderStorageChart(files);renderDutyChart();renderHeapChart();}).catch(function(e){console.warn('Pies error:',e);if(storageCanvas)drawPie(storageCanvas,0,1,'#6b6b6b');if(dutyCanvas)drawPie(dutyCanvas,0,1,'#f57c00');if(heapCanvas)drawPie(heapCanvas,0,1,'#3a6ea5');});}function updateHeapAndDutyOnly(){renderDutyChart();renderHeapChart();}updateAll();var refreshInterval=setInterval(updateAll,30000);var fastInterval=setInterval(updateHeapAndDutyOnly,3000);var observer=new MutationObserver(function(){if(!document.getElementById('piesDetails')){clearInterval(refreshInterval);clearInterval(fastInterval);observer.disconnect();}});observer.observe(document.body,{childList:true,subtree:true});})();",
  "target": "footer"
}