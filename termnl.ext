{
  "description": "Retro Terminal Interface with Stats and Command Console",
  "html": "<style>#terminal-overlay{position:fixed;top:0;left:0;width:100vw;height:100vh;background:#0a0a0a;z-index:9999;display:flex;flex-direction:column;font-family:'Courier New',monospace}#terminal-container{flex-direction:column;display:flex;flex:1;min-height:0;padding:10px;gap:10px;background:#0a0a0a}.terminal-panel{flex:1;background:#0d0d0d;border:1px solid #33ff33;border-radius:5px;padding:10px;display:flex;flex-direction:column;overflow:hidden;min-height:0}#stats-terminal{flex:1;overflow-y:auto;color:#33ff33;font-size:11px;line-height:1.6;padding:5px;font-family:'Courier New',monospace;min-height:0}#stats-terminal .stat-line{display:flex;justify-content:space-between;padding:2px 0;border-bottom:1px solid rgba(51,255,51,0.05)}#stats-terminal .stat-label{color:#33ff33;opacity:0.7}#stats-terminal .stat-value{color:#33ff33;font-weight:bold;}.stat-value{font-size:0.85em}#stats-terminal .stat-value.warning{color:#ffaa00}#stats-terminal .stat-value.critical{color:#ff3333}#command-terminal{flex:1;display:flex;flex-direction:column;overflow:hidden;min-height:0}#command-output{flex:1;overflow-y:auto;color:#33ff33;font-size:11px;line-height:1.6;padding:5px;font-family:'Courier New',monospace;white-space:pre-wrap;word-wrap:break-word;min-height:0}#command-output .prompt{color:#33ff33;opacity:0.8}#command-output .error{color:#ff3333}#command-output .success{color:#33ff33}#command-output .info{color:#66ff66}#command-input-line{display:flex;align-items:center;padding:8px 5px;border-top:1px solid #33ff33;margin-top:5px;gap:8px;flex-shrink:0}#command-input-line .prompt-symbol{color:#33ff33;font-weight:bold;font-size:14px}#command-input{flex:1;background:#0d0d0d;border:1px solid #33ff33;color:#33ff33;padding:6px 10px;font-family:'Courier New',monospace;font-size:11px;outline:none;border-radius:3px}#command-input:focus{border-color:#66ff66;box-shadow:0 0 10px rgba(51,255,51,0.1)}#command-input::placeholder{color:#33ff33;opacity:0.3}#terminal-toggle{position:fixed;bottom:75px;right:20px;z-index:10000;background:#0d0d0d;border:1px solid #33ff33;color:#33ff33;padding:10px 20px;font-family:'Courier New',monospace;cursor:pointer;border-radius:5px;font-size:14px}#terminal-toggle:hover{background:#33ff33;color:#0a0a0a}</style><div id=terminal-overlay><div id=terminal-container><div class=terminal-panel><div id=stats-terminal></div></div><div class=terminal-panel><div id=command-terminal><div id=command-output>NOMAD Terminal v1.0<br>Type help for available commands<br></div><div id=command-input-line><span class=prompt-symbol>$</span><input id=command-input type=text placeholder='enter command...' autofocus></div></div></div></div></div><button id=terminal-toggle>⏣</button>",
  "css": "",
  "js": "var terminalVisible = true;var commandHistory = [];var historyIndex = -1;var currentFileContent = '';function toggleTerminal(){terminalVisible = !terminalVisible;document.getElementById('terminal-overlay').style.display = terminalVisible ? 'flex' : 'none';document.getElementById('terminal-toggle').textContent = terminalVisible ? '⏣' : '⏣'}document.getElementById('terminal-toggle').addEventListener('click', toggleTerminal);document.getElementById('command-input').addEventListener('keydown', function(e){if(e.key === 'Enter'){var cmd = this.value.trim();if(cmd){commandHistory.push(cmd);historyIndex = commandHistory.length;processCommand(cmd);this.value = ''}}if(e.key === 'ArrowUp'){e.preventDefault();if(historyIndex > 0){historyIndex--;this.value = commandHistory[historyIndex]}}if(e.key === 'ArrowDown'){e.preventDefault();if(historyIndex < commandHistory.length - 1){historyIndex++;this.value = commandHistory[historyIndex]}else{historyIndex = commandHistory.length;this.value = ''}}});function typeText(element, text, color, speed, callback) {if (!element) return;var i = 0;var container = document.createElement('div');if (color) {container.style.color = color;}element.appendChild(container);function typeChar() {if (i < text.length) {var ch = text.charAt(i);if (ch === '<') {var tagEnd = text.indexOf('>', i);if (tagEnd !== -1) {container.innerHTML += text.substring(i, tagEnd + 1);i = tagEnd + 1;} else {container.innerHTML += ch;i++;}} else {container.innerHTML += ch;i++;}element.scrollTop = element.scrollHeight;setTimeout(typeChar, speed || 15);} else {if (callback) callback();}}typeChar();}function appendOutput(text, type){var output = document.getElementById('command-output');var color = '';if(type === 'error'){color = '#ff3333'}else if(type === 'success'){color = '#33ff33'}else if(type === 'info'){color = '#66ff66'}else if(type === 'prompt'){color = '#33ff33';text = '$ ' + text;}var speed = 12;if (type === 'prompt') speed = 20;typeText(output, text, color, speed);}function processCommand(cmd){appendOutput(cmd, 'prompt');var parts = cmd.split(' ');var command = parts[0].toLowerCase();var args = parts.slice(1);switch(command){case 'help':appendOutput('Available commands:<br>  help - Show this help<br>  status - Show system status<br>  files, ls, dir - List all files<br>  open &lt;filename&gt; - View file content<br>  clear - Clear console<br>  stats - Show detailed stats<br>  uptime - Show uptime<br>  temp - Show temperature<br>  memory - Show memory usage<br>  nodecount - Show node count<br>  duty - Show duty cycle<br>  refresh - Refresh stats panel', 'info');break;case 'status':fetchStatus();break;case 'files':case 'ls':case 'dir':listFiles();break;case 'open':if(args.length > 0){openFile(args.join(' '))}else{appendOutput('Error: Please specify a filename', 'error')}break;case 'clear':document.getElementById('command-output').innerHTML = '';break;case 'stats':fetch('/api/status').then(function(r){return r.json()}).then(function(data){appendOutput('=== SYSTEM STATS ===', 'info');appendOutput('Node ID: ' + data.nodeId, '');appendOutput('Node Count: ' + data.nodeCount, '');appendOutput('File Count: ' + data.fileCount, '');appendOutput('Uptime: ' + data.uptime + ' seconds', '');appendOutput('Temperature: ' + data.temperature.toFixed(1) + '°C', '');appendOutput('Free Heap: ' + data.freeHeapKB + ' KB', '');appendOutput('Storage: ' + data.storage.usedKB + '/' + data.storage.totalKB + ' KB', '');appendOutput('Duty Cycle: ' + (data.dutyCycle * 100).toFixed(1) + '%', '');appendOutput('AP IP: ' + data.apIP, '');appendOutput('STA IP: ' + data.staIP, '')}).catch(function(){appendOutput('Error fetching stats', 'error')});break;case 'uptime':fetch('/api/status').then(function(r){return r.json()}).then(function(data){var days = Math.floor(data.uptime / 86400);var hours = Math.floor((data.uptime % 86400) / 3600);var mins = Math.floor((data.uptime % 3600) / 60);var secs = Math.floor(data.uptime % 60);appendOutput('Uptime: ' + days + 'd ' + hours + 'h ' + mins + 'm ' + secs + 's', 'info')}).catch(function(){appendOutput('Error fetching uptime', 'error')});break;case 'temp':fetch('/api/status').then(function(r){return r.json()}).then(function(data){appendOutput('Temperature: ' + data.temperature.toFixed(1) + '°C', 'info')}).catch(function(){appendOutput('Error fetching temperature', 'error')});break;case 'memory':fetch('/api/status').then(function(r){return r.json()}).then(function(data){appendOutput('Free Heap: ' + data.freeHeapKB + ' KB / ' + data.maxHeapKB + ' KB', 'info');appendOutput('Used: ' + (data.maxHeapKB - data.freeHeapKB) + ' KB', '')}).catch(function(){appendOutput('Error fetching memory', 'error')});break;case 'nodecount':fetch('/api/status').then(function(r){return r.json()}).then(function(data){appendOutput('Nodes discovered: ' + data.nodeCount, 'info')}).catch(function(){appendOutput('Error fetching node count', 'error')});break;case 'duty':fetch('/api/status').then(function(r){return r.json()}).then(function(data){appendOutput('Duty Cycle: ' + (data.dutyCycle * 100).toFixed(2) + '%', 'info')}).catch(function(){appendOutput('Error fetching duty cycle', 'error')});break;case 'refresh':updateStats();appendOutput('Stats refreshed', 'success');break;default:appendOutput('Unknown command: ' + command + '. Type help for available commands', 'error')}}function fetchStatus(){fetch('/api/status').then(function(r){return r.json()}).then(function(data){appendOutput('=== STATUS ===', 'info');appendOutput('Node: ' + data.nodeId, '');appendOutput('Nodes: ' + data.nodeCount, '');appendOutput('Files: ' + data.fileCount, '');appendOutput('Uptime: ' + data.uptime + 's', '');appendOutput('Temp: ' + data.temperature.toFixed(1) + '°C', '');appendOutput('Free Mem: ' + data.freeHeapKB + ' KB', '')}).catch(function(){appendOutput('Error fetching status', 'error')})}function listFiles(){fetch('/api/files').then(function(r){return r.json()}).then(function(data){if(data.files && data.files.length > 0){appendOutput('=== FILES (' + data.files.length + ') ===', 'info');data.files.forEach(function(f){appendOutput('  📄 ' + f.name + ' (' + f.size + ' bytes)', '')})}else{appendOutput('No files found', '')}}).catch(function(){appendOutput('Error listing files', 'error')})}function openFile(filename){if(typeof viewFile === 'function'){try{appendOutput('Opening ' + filename + '...', 'info');viewFile(filename);return;}catch(e){appendOutput('Error calling viewFile: ' + e.message, 'error');}}appendOutput('Fetching ' + filename + ' from API...', 'info');fetch('/api/view-file?filename=' + encodeURIComponent(filename)).then(function(r){if(!r.ok)throw new Error('File not found');return r.text()}).then(function(content){currentFileContent = content;var lines = content.split('\\n').slice(0, 50);appendOutput('=== ' + filename + ' ===', 'info');lines.forEach(function(line){appendOutput(line, '')});if(content.split('\\n').length > 50){appendOutput('... (truncated, ' + content.split('\\n').length + ' lines total)', 'info')}}).catch(function(){appendOutput('Error: File ' + filename + ' not found or cannot be read', 'error')})}function updateStats(){fetch('/api/status').then(function(r){return r.json()}).then(function(data){var html = '';var uptimeStr = '';var days = Math.floor(data.uptime / 86400);var hours = Math.floor((data.uptime % 86400) / 3600);var mins = Math.floor((data.uptime % 3600) / 60);var secs = Math.floor(data.uptime % 60);if(days > 0) uptimeStr += days + 'd ';if(hours > 0 || days > 0) uptimeStr += hours + 'h ';uptimeStr += mins + 'm ' + secs + 's';var tempClass = '';if(data.temperature > 60) tempClass = 'critical';else if(data.temperature > 50) tempClass = 'warning';var storagePercent = (data.storage.usedKB / data.storage.totalKB * 100).toFixed(1);var storageClass = '';if(storagePercent > 90) storageClass = 'critical';else if(storagePercent > 70) storageClass = 'warning';html += '<div class=stat-line><span class=stat-label>📡 NODE</span><span class=stat-value>' + data.nodeId + '</span></div>';html += '<div class=stat-line><span class=stat-label>📶 NODES</span><span class=stat-value>' + data.nodeCount + '</span></div>';html += '<div class=stat-line><span class=stat-label>📁 FILES</span><span class=stat-value>' + data.fileCount + '</span></div>';html += '<div class=stat-line><span class=stat-label>⏱ UPTIME</span><span class=stat-value>' + uptimeStr + '</span></div>';html += '<div class=stat-line><span class=stat-label>🌡 TEMP</span><span class=stat-value class=' + tempClass + '>' + data.temperature.toFixed(1) + '°C</span></div>';html += '<div class=stat-line><span class=stat-label>💾 MEMORY</span><span class=stat-value>' + (data.maxHeapKB - data.freeHeapKB) + '/' + data.maxHeapKB + ' KB</span></div>';html += '<div class=stat-line><span class=stat-label>💿 STORAGE</span><span class=stat-value class=' + storageClass + '>' + data.storage.usedKB + '/' + data.storage.totalKB + ' KB (' + storagePercent + '%)</span></div>';html += '<div class=stat-line><span class=stat-label>🔄 DUTY</span><span class=stat-value>' + (data.dutyCycle * 100).toFixed(1) + '%</span></div>';html += '<div class=stat-line><span class=stat-label>🌐 AP IP</span><span class=stat-value>' + data.apIP + '</span></div>';if(data.staIP && data.staIP != '0.0.0.0'){html += '<div class=stat-line><span class=stat-label>🌐 STA IP</span><span class=stat-value>' + data.staIP + '</span></div>'}if(data.transfers && data.transfers.length > 0){html += '<div class=stat-line style=border-top:1px solid #33ff33;margin-top:5px;padding-top:5px><span class=stat-label>📤 ACTIVE TRANSFERS</span><span class=stat-value>' + data.transfers.length + '</span></div>'}document.getElementById('stats-terminal').innerHTML = html}).catch(function(){document.getElementById('stats-terminal').innerHTML = '<div style=color:#ff3333>⚠ ERROR loading stats</div>'})}updateStats();setInterval(updateStats, 5000);document.getElementById('command-input').focus();document.addEventListener('click', function(){document.getElementById('command-input').focus()})",
  "target": "header"
}