{
  "description": "Retro Terminal Interface with Stats and Command Console",
  "html": "<style>#terminal-overlay{position:fixed;top:0;left:0;width:100vw;height:100vh;background:#0a0a0a;z-index:9999;display:flex;flex-direction:column;font-family:'Courier New',monospace}#terminal-container{flex-direction:column;display:flex;flex:1;min-height:0;padding:10px;gap:10px;background:#0a0a0a}.terminal-panel{flex:1;background:#0d0d0d;border:1px solid #33ff33;border-radius:5px;padding:10px;display:flex;flex-direction:column;overflow:hidden;min-height:0}#stats-terminal{flex:1;overflow-y:auto;color:#33ff33;font-size:11px;line-height:1.6;padding:5px;font-family:'Courier New',monospace;min-height:0}#stats-terminal .stat-line{display:flex;justify-content:space-between;padding:2px 0;border-bottom:1px solid rgba(51,255,51,0.05)}#stats-terminal .stat-label{color:#33ff33;opacity:0.7}#stats-terminal .stat-value{color:#33ff33;font-weight:bold;}.stat-value{font-size:0.85em}#stats-terminal .stat-value.warning{color:#ffaa00}#stats-terminal .stat-value.critical{color:#ff3333}#command-terminal{flex:1;display:flex;flex-direction:column;overflow:hidden;min-height:0}#command-output{flex:1;overflow-y:auto;color:#33ff33;font-size:11px;line-height:1.6;padding:5px;font-family:'Courier New',monospace;white-space:pre-wrap;word-wrap:break-word;min-height:0}#command-output .prompt{color:#33ff33;opacity:0.8}#command-output .error{color:#ff3333}#command-output .success{color:#33ff33}#command-output .info{color:#66ff66}#command-input-line{display:flex;align-items:center;padding:8px 5px;border-top:1px solid #33ff33;margin-top:5px;gap:8px;flex-shrink:0}#command-input-line .prompt-symbol{color:#33ff33;font-weight:bold;font-size:14px}#command-input{flex:1;background:#0d0d0d;border:1px solid #33ff33;color:#33ff33;padding:6px 10px;font-family:'Courier New',monospace;font-size:11px;outline:none;border-radius:3px}#command-input:focus{border-color:#66ff66;box-shadow:0 0 10px rgba(51,255,51,0.1)}#command-input::placeholder{color:#33ff33;opacity:0.3}#terminal-toggle{position: fixed;bottom: 4px;left: 5px;z-index: 10000;background: var(--text);border: 0;color: #fff;padding: 5px 8px;font-family: 'Courier New', monospace;cursor: pointer;border-radius: 50%;font-size: 14px;}#terminal-toggle:hover{background:#33ff33;color:#0a0a0a}#terminal-container .terminal-panel:first-child {flex: 0 0 25%;min-height: 0;}#terminal-container .terminal-panel:last-child {flex: 1;min-height: 0;}</style><div id=terminal-overlay><div id=terminal-container><div class=terminal-panel><div id=stats-terminal></div></div><div class=terminal-panel><div id=command-terminal><div id=command-output>NOMAD Terminal v1.0<br>Type help for available commands<br></div><div id=command-input-line><span class=prompt-symbol>$</span><input id=command-input type=text placeholder='enter command...' autofocus></div></div></div></div></div><button id=terminal-toggle>⏣</button>",
  "css": "",
  "js": "var terminalVisible=!0,commandHistory=[],historyIndex=-1,currentFileContent='';function toggleTerminal(){terminalVisible=!terminalVisible,document.getElementById('terminal-overlay').style.display=terminalVisible?'flex':'none',document.getElementById('terminal-toggle').textContent='⏣'}function typeText(t,e,n,a,s){if(t){var p=0,o=document.createElement('div');n&&(o.style.color=n),t.appendChild(o),function n(){if(p<e.length){var r=e.charAt(p);if('<'===r){var i=e.indexOf('>',p);-1!==i?(o.innerHTML+=e.substring(p,i+1),p=i+1):(o.innerHTML+=r,p++)}else o.innerHTML+=r,p++;t.scrollTop=t.scrollHeight,setTimeout(n,a||15)}else s&&s()}()}}function appendOutput(t,e){var n='';'error'===e?n='#ff3333':'success'===e?n='#33ff33':'info'===e?n='#66ff66':'prompt'===e&&(n='#33ff33',t='$ '+t);var a=12;'prompt'===e&&(a=20),typeText(document.getElementById('command-output'),t,n,a)}function processCommand(t){appendOutput(t,'prompt');var e=t.split(' '),n=e[0].toLowerCase(),a=e.slice(1);switch(n){case'help':appendOutput('Available commands:<br>  help - Show this help<br>  status - Show system status<br>  files, ls, dir - List all files<br>  open filename - View file content<br>  clear - Clear console<br>  stats - Show detailed stats<br>  uptime - Show uptime<br>  temp - Show temperature<br>  memory - Show memory usage<br>  nodecount - Show node count<br>  duty - Show duty cycle<br>  refresh - Refresh stats panel<br>  studio - Open .com studio<br>  create - Open create file dialog<br>  repo - Open official NOMAD file repository<br>  upload - Open file upload dialog<br>  options - Open the options dialog','info');break;case'status':fetchStatus();break;case'studio':openStudioModal();break;case'create':openCreateFileModal();break;case'repo':openAppRepo();break;case'upload':document.getElementById('fileInput').click();break;case'options':openHelpModal();break;case'files':case'ls':case'dir':listFiles();break;case'open':a.length>0?openFile(a.join(' ')):appendOutput('Error: Please specify a filename','error');break;case'clear':document.getElementById('command-output').innerHTML='';break;case'stats':fetch('/api/status').then(function(t){return t.json()}).then(function(t){appendOutput('=== SYSTEM STATS ===','info'),appendOutput('Node ID: '+t.nodeId,''),appendOutput('Node Count: '+t.nodeCount,''),appendOutput('File Count: '+t.fileCount,''),appendOutput('Uptime: '+t.uptime+' seconds',''),appendOutput('Temperature: '+t.temperature.toFixed(1)+'°C',''),appendOutput('Free Heap: '+t.freeHeapKB+' KB',''),appendOutput('Storage: '+t.storage.usedKB+'/'+t.storage.totalKB+' KB',''),appendOutput('Duty Cycle: '+(100*t.dutyCycle).toFixed(1)+'%',''),appendOutput('AP IP: '+t.apIP,''),appendOutput('STA IP: '+t.staIP,'')}).catch(function(){appendOutput('Error fetching stats','error')});break;case'uptime':fetch('/api/status').then(function(t){return t.json()}).then(function(t){appendOutput('Uptime: '+Math.floor(t.uptime/86400)+'d '+Math.floor(t.uptime%86400/3600)+'h '+Math.floor(t.uptime%3600/60)+'m '+Math.floor(t.uptime%60)+'s','info')}).catch(function(){appendOutput('Error fetching uptime','error')});break;case'temp':fetch('/api/status').then(function(t){return t.json()}).then(function(t){appendOutput('Temperature: '+t.temperature.toFixed(1)+'°C','info')}).catch(function(){appendOutput('Error fetching temperature','error')});break;case'memory':fetch('/api/status').then(function(t){return t.json()}).then(function(t){appendOutput('Free Heap: '+t.freeHeapKB+' KB / '+t.maxHeapKB+' KB','info'),appendOutput('Used: '+(t.maxHeapKB-t.freeHeapKB)+' KB','')}).catch(function(){appendOutput('Error fetching memory','error')});break;case'nodecount':fetch('/api/status').then(function(t){return t.json()}).then(function(t){appendOutput('Nodes discovered: '+t.nodeCount,'info')}).catch(function(){appendOutput('Error fetching node count','error')});break;case'duty':fetch('/api/status').then(function(t){return t.json()}).then(function(t){appendOutput('Duty Cycle: '+(100*t.dutyCycle).toFixed(2)+'%','info')}).catch(function(){appendOutput('Error fetching duty cycle','error')});break;case'refresh':updateStats(),appendOutput('Stats refreshed','success');break;default:appendOutput('Unknown command: '+n+'. Type help for available commands','error')}}function fetchStatus(){fetch('/api/status').then(function(t){return t.json()}).then(function(t){appendOutput('=== STATUS ===','info'),appendOutput('Node: '+t.nodeId,''),appendOutput('Nodes: '+t.nodeCount,''),appendOutput('Files: '+t.fileCount,''),appendOutput('Uptime: '+t.uptime+'s',''),appendOutput('Temp: '+t.temperature.toFixed(1)+'°C',''),appendOutput('Free Mem: '+t.freeHeapKB+' KB','')}).catch(function(){appendOutput('Error fetching status','error')})}function listFiles(){fetch('/api/files').then(function(t){return t.json()}).then(function(t){t.files&&t.files.length>0?(appendOutput('=== FILES ('+t.files.length+') ===','info'),t.files.forEach(function(t){appendOutput('  📄 '+t.name+' ('+t.size+' bytes)','')})):appendOutput('No files found','')}).catch(function(){appendOutput('Error listing files','error')})}function openFile(t){if('function'==typeof viewFile)try{return appendOutput('Opening '+t+'...','info'),void viewFile(t)}catch(t){appendOutput('Error calling viewFile: '+t.message,'error')}appendOutput('Fetching '+t+' from API...','info'),fetch('/api/view-file?filename='+encodeURIComponent(t)).then(function(t){if(!t.ok)throw new Error('File not found');return t.text()}).then(function(e){currentFileContent=e;var n=e.split('\\n').slice(0,50);appendOutput('=== '+t+' ===','info'),n.forEach(function(t){appendOutput(t,'')}),e.split('\\n').length>50&&appendOutput('... (truncated, '+e.split('\\n').length+' lines total)','info')}).catch(function(){appendOutput('Error: File '+t+' not found or cannot be read','error')})}function updateStats(){fetch('/api/status').then(function(t){return t.json()}).then(function(t){var e='',n='',a=Math.floor(t.uptime/86400),s=Math.floor(t.uptime%86400/3600);a>0&&(n+=a+'d '),(s>0||a>0)&&(n+=s+'h '),n+=Math.floor(t.uptime%3600/60)+'m '+Math.floor(t.uptime%60)+'s';var p='';t.temperature>60?p='critical':t.temperature>50&&(p='warning');var o=(t.storage.usedKB/t.storage.totalKB*100).toFixed(1),r='';o>90?r='critical':o>70&&(r='warning'),e+='<div class=stat-line><span class=stat-label>📡 NODE</span><span class=stat-value>'+t.nodeId+'</span></div>',e+='<div class=stat-line><span class=stat-label>📶 NODES</span><span class=stat-value>'+t.nodeCount+'</span></div>',e+='<div class=stat-line><span class=stat-label>📁 FILES</span><span class=stat-value>'+t.fileCount+'</span></div>',e+='<div class=stat-line><span class=stat-label>⏱ UPTIME</span><span class=stat-value>'+n+'</span></div>',e+='<div class=stat-line><span class=stat-label>🌡 TEMP</span><span class=stat-value class='+p+'>'+t.temperature.toFixed(1)+'°C</span></div>',e+='<div class=stat-line><span class=stat-label>💾 MEMORY</span><span class=stat-value>'+(t.maxHeapKB-t.freeHeapKB)+'/'+t.maxHeapKB+' KB</span></div>',e+='<div class=stat-line><span class=stat-label>💿 STORAGE</span><span class=stat-value class='+r+'>'+t.storage.usedKB+'/'+t.storage.totalKB+' KB ('+o+'%)</span></div>',e+='<div class=stat-line><span class=stat-label>🔄 DUTY</span><span class=stat-value>'+(100*t.dutyCycle).toFixed(1)+'%</span></div>',e+='<div class=stat-line><span class=stat-label>🌐 AP IP</span><span class=stat-value>'+t.apIP+'</span></div>',t.staIP&&'0.0.0.0'!=t.staIP&&(e+='<div class=stat-line><span class=stat-label>🌐 STA IP</span><span class=stat-value>'+t.staIP+'</span></div>'),t.transfers&&t.transfers.length>0&&(e+='<div class=stat-line style=border-top:1px solid #33ff33;margin-top:5px;padding-top:5px><span class=stat-label>📤 ACTIVE TRANSFERS</span><span class=stat-value>'+t.transfers.length+'</span></div>'),document.getElementById('stats-terminal').innerHTML=e}).catch(function(){document.getElementById('stats-terminal').innerHTML='<div style=color:#ff3333>⚠ ERROR loading stats</div>'})}document.getElementById('terminal-toggle').addEventListener('click',toggleTerminal),document.getElementById('command-input').addEventListener('keydown',function(t){if('Enter'===t.key){var e=this.value.trim();e&&(commandHistory.push(e),historyIndex=commandHistory.length,processCommand(e),this.value='')}'ArrowUp'===t.key&&(t.preventDefault(),historyIndex>0&&(historyIndex--,this.value=commandHistory[historyIndex])),'ArrowDown'===t.key&&(t.preventDefault(),historyIndex<commandHistory.length-1?(historyIndex++,this.value=commandHistory[historyIndex]):(historyIndex=commandHistory.length,this.value=''))}),updateStats(),setInterval(updateStats,5e3),document.getElementById('command-input').focus(),document.addEventListener('click',function(){document.getElementById('command-input').focus()});",
  "target": "header"
}