{
  "html": "<details class='section' id='logDetails'>\n  <summary>\n    <h2>\n      <svg style='position:relative;top:6px' width='24px' height='24px' viewBox='0 0 24 24' fill='none' stroke='var(--text)' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>\n        <path d='M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z'></path>\n        <polyline points='14 2 14 8 20 8'></polyline>\n        <line x1='16' y1='13' x2='8' y2='13'></line>\n        <line x1='16' y1='17' x2='8' y2='17'></line>\n        <polyline points='10 9 9 9 8 9'></polyline>\n      </svg>\n      &nbsp;Activity Log\n      <span style='font-size:0.7rem;font-weight:normal;opacity:0.5;margin-left:8px;' id='logCount'>0</span>\n    </h2>\n  </summary>\n  <div style='display:flex;gap:8px;padding:4px 0 8px 0;'>\n    <button class='btn btn-small btn-outline' onclick='clearLog()' style='padding:2px 12px;font-size:0.7rem;'>Clear</button>\n    <button class='btn btn-small btn-outline' onclick='toggleLogTracking()' style='padding:2px 12px;font-size:0.7rem;' id='logTrackBtn'>⏸️ Pause</button>\n  </div>\n  <div id='logEntries' style='padding:4px 0;max-height:300px;overflow-y:auto;font-size:0.8rem;font-family:monospace;'>\n    <div style='text-align:center;opacity:0.4;padding:20px 0;'>No activity logged yet</div>\n  </div>\n</details>",

  "css": ".log-entry { padding: 3px 6px; border-bottom: 1px solid var(--border); font-size: 0.75rem; display: flex; align-items: baseline; gap: 6px; }\n.log-entry:hover { background: var(--accent-light); }\n.log-time { color: var(--text-dim); flex-shrink: 0; font-size: 0.65rem; }\n.log-icon { flex-shrink: 0; font-size: 0.85rem; }\n.log-text { word-break: break-word; flex: 1; }\n.log-entry.click { border-left: 2px solid #547540; }\n.log-entry.api { border-left: 2px solid #1565c0; }\n.log-entry.system { border-left: 2px solid #f57c00; }\n.log-entry.error { border-left: 2px solid #f44336; }",

  "js": "var logEntries=[];var logMax=100;var logTracking=true;var logInterceptInstalled=false;function addLogEntry(e,t,n){if(!logTracking)return;var o=new Date();var l=o.getHours().toString().padStart(2,'0')+':'+o.getMinutes().toString().padStart(2,'0')+':'+o.getSeconds().toString().padStart(2,'0');logEntries.unshift({time:l,message:e,icon:t||'📌',type:n||'system'});if(logEntries.length>logMax){logEntries.pop()}renderLog()}function renderLog(){var e=document.getElementById('logEntries');var t=document.getElementById('logCount');if(!e)return;if(t){t.textContent=logEntries.length}if(logEntries.length===0){e.innerHTML='<div style=\"text-align:center;opacity:0.4;padding:20px 0;\">No activity logged yet</div>';return}var n='';logEntries.forEach(function(o){var l='';if(o.type==='click'){l='click'}else if(o.type==='api'){l='api'}else if(o.type==='error'){l='error'}n+='<div class=\"log-entry '+l+'\"><span class=\"log-time\">'+o.time+'</span><span class=\"log-icon\">'+o.icon+'</span><span class=\"log-text\">'+o.message+'</span></div>'});e.innerHTML=n;e.scrollTop=0}function clearLog(){logEntries=[];renderLog();addLogEntry('🗑️ Log cleared','🗑️')}function toggleLogTracking(){logTracking=!logTracking;var e=document.getElementById('logTrackBtn');if(e){e.textContent=logTracking?'⏸️ Pause':'▶️ Resume'}}function installClickInterceptor(){if(logInterceptInstalled)return;logInterceptInstalled=true;document.addEventListener('click',function(e){var t=e.target;var n=t.closest('button')||t.closest('a')||t.closest('[onclick]');if(n){var o='';if(n.tagName==='BUTTON'){o=n.textContent.trim().slice(0,30)}else if(n.tagName==='A'){o=n.textContent.trim().slice(0,30)||n.href||'link'}else{o='element'}var l=o||'click';var a='🖱️';if(n.classList.contains('btn-danger')){a='⚠️'}else if(n.classList.contains('btn-primary')){a='✅'}else if(n.classList.contains('btn-success')){a='✔️'}else if(n.classList.contains('refresh-btn')){a='🔄'}addLogEntry('Clicked: '+l,a,'click')}},true);document.addEventListener('DOMContentLoaded',function(){addLogEntry('🚀 Activity logging started','🚀','system')});var originalFetch=window.fetch;window.fetch=function(){var e=arguments[0];if(typeof e==='string'&&e.startsWith('/api/')){var t=e.split('?')[0];var n=t.replace('/api/','');var o='📡';if(n==='status'){o='📊'}else if(n==='nodes'){o='📡'}else if(n==='files'){o='📁'}else if(n==='upload'||n==='delete'){o='📤'}addLogEntry('API: '+n,o,'api')}return originalFetch.apply(this,arguments)}}function logSystemEvents(){fetch('/api/status').then(function(e){return e.json()}).then(function(e){if(e.nodeCount>0){var t='📡 '+e.nodeCount+' nodes';var n=logEntries.length>0&&logEntries[0].message===t;if(!n){addLogEntry(t,'📡','system')}}})}setInterval(logSystemEvents,60000);if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',function(){installClickInterceptor();addLogEntry('📋 Activity log ready','📋','system')})}else{installClickInterceptor();addLogEntry('📋 Activity log ready','📋','system')}",

  "target": "footer"
}