{
  "description": "Chat Encryption Extension",
  "html": "",
  "css": "#modalPromptInput{margin-bottom:1em !important;outline: none !important;}#loraMessengerDetails.section div .btn.btn-primary{height:53px;}.encrypt-btn{background:#6c5ce7;color:#fff;border:0;border-radius:6px;cursor:pointer;transition:all .2s;height:53px;width:41px;display:flex;align-items:center;justify-content:center;padding:0}.encrypt-btn:hover{background:#5a4bd1;transform:scale(1.02)}.encrypt-btn.active{background:#00b894}.encrypt-btn.active:hover{background:#00a381}.encrypt-btn svg{width:24px;height:24px}.decrypt-btn{padding:2px 10px;font-size:.7em;background:#6c5ce7;color:#fff;border:0;border-radius:4px;cursor:pointer;margin-left:6px;transition:all .2s;white-space:nowrap}.decrypt-btn:hover{background:#5a4bd1;transform:scale(1.05)}",
  "js": "var E={enabled:!1,password:''};var unlockIcon='<svg width=\"24\" height=\"24\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M11.5 2C10.6716 2 10 2.67157 10 3.5V6H13V16H1V6H8V3.5C8 1.567 9.567 0 11.5 0C13.433 0 15 1.567 15 3.5V4H13V3.5C13 2.67157 12.3284 2 11.5 2ZM9 10H5V12H9V10Z\" fill=\"#fff\"/></svg>';var lockIcon='<svg width=\"24\" height=\"24\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path fill-rule=\"evenodd\" clip-rule=\"evenodd\" d=\"M4 6V4C4 1.79086 5.79086 0 8 0C10.2091 0 12 1.79086 12 4V6H14V16H2V6H4ZM6 4C6 2.89543 6.89543 2 8 2C9.10457 2 10 2.89543 10 4V6H6V4ZM7 13V9H9V13H7Z\" fill=\"#fff\"/></svg>';function encryptMsg(t,e){if(!e||0===e.length)return t;var n='';for(var r=0;r<t.length;r++){var s=t.charCodeAt(r),o=e.charCodeAt(r%e.length);n+=String.fromCharCode(s^o)}return 'enc:'+btoa(n)}function decryptMsg(t,e){try{if(!t||!e||0===e.length)return t;var n=t;if(n.startsWith('enc:')){n=n.substring(4)}var r=atob(n);var s='';for(var o=0;o<r.length;o++){var i=r.charCodeAt(o),a=e.charCodeAt(o%e.length);s+=String.fromCharCode(i^a)}return s}catch(n){console.error('Decrypt error:',n);return t}}function showPasswordModal(title, callback){var modal=document.getElementById('customModal');var msg=document.getElementById('modalMessage');var input=document.getElementById('modalPromptInput');var okBtn=document.getElementById('modalOk');var cancelBtn=document.getElementById('modalCancel');if(!modal||!msg||!input||!okBtn||!cancelBtn){callback(null);return}msg.textContent=title||'Enter password:';input.style.display='block';input.value='';input.placeholder='Enter 3-word password (e.g. red fox sun)';input.type='text';okBtn.textContent='OK';cancelBtn.style.display='inline-block';modal.style.display='block';input.focus();input.select();function cleanup(){modal.style.display='none';input.style.display='none';input.value='';okBtn.removeEventListener('click',onOk);cancelBtn.removeEventListener('click',onCancel);input.removeEventListener('keydown',onKeydown);document.removeEventListener('keydown',onEscape)}function onOk(){var val=input.value.trim();cleanup();callback(val)}function onCancel(){cleanup();callback(null)}function onKeydown(e){if(e.key==='Enter'){e.preventDefault();onOk()}}function onEscape(e){if(e.key==='Escape'){onCancel()}}okBtn.addEventListener('click',onOk);cancelBtn.addEventListener('click',onCancel);input.addEventListener('keydown',onKeydown);document.addEventListener('keydown',onEscape)}function toggleEncryption(){var btn=document.querySelector('.encrypt-btn');if(E.enabled){E.enabled=!1;E.password='';btn.classList.remove('active');btn.innerHTML=unlockIcon;return}showPasswordModal('Enter encryption password (3+ words):',function(pw){if(pw&&pw.length>0){E.password=pw;E.enabled=!0;btn.classList.add('active');btn.innerHTML=lockIcon;var input=document.getElementById('chatInput');if(input)input.focus()}else{if(pw!==null){alert('Password cannot be empty')}}})}function addDecryptButtons(){var chatWindow=document.getElementById('chatWindow');if(!chatWindow)return;var msgs=chatWindow.querySelectorAll('.chat-broadcast-mine,.chat-broadcast');for(var i=0;i<msgs.length;i++){var msgEl=msgs[i];if(msgEl.querySelector('.decrypt-btn'))continue;var textDivs=msgEl.querySelectorAll('div');var textEl=null;for(var j=0;j<textDivs.length;j++){var d=textDivs[j];if(!d.querySelector('button')&&d.textContent&&d.textContent.startsWith('enc:')){textEl=d;break}}if(!textEl){var allDivs=msgEl.querySelectorAll('div:last-child');if(allDivs.length>0&&allDivs[0].textContent&&allDivs[0].textContent.startsWith('enc:')){textEl=allDivs[0]}}if(textEl){var content=textEl.textContent;if(content&&content.startsWith('enc:')){msgEl.style.borderLeft='3px solid #6c5ce7';msgEl.style.paddingLeft='8px';var decBtn=document.createElement('button');decBtn.className='decrypt-btn';decBtn.textContent='🔓 Decrypt';var encryptedContent=content;var targetEl=textEl;decBtn.onclick=function(e){e.stopPropagation();showPasswordModal('Enter password to decrypt:',function(pw){if(pw&&pw.length>0){try{var decrypted=decryptMsg(encryptedContent,pw);if(decrypted&&decrypted!==encryptedContent){targetEl.textContent=decrypted;this.remove()}else{alert('Wrong password or not encrypted')}}catch(err){alert('Decryption failed: '+err.message)}}}.bind(this))};msgEl.appendChild(decBtn)}}}}function initEncryption(){var input=document.getElementById('chatInput');if(input&&!input._encryptListener){input._encryptListener=!0;var wrapper=input.parentElement;if(wrapper){var container=document.createElement('span');container.id='encryptExtension';var btn=document.createElement('button');btn.className='encrypt-btn';btn.innerHTML=unlockIcon;btn.title='Toggle encryption';btn.onclick=toggleEncryption;container.appendChild(btn);var sendBtn=wrapper.querySelector('.btn-primary');if(sendBtn){wrapper.insertBefore(container,sendBtn)}else{wrapper.appendChild(container)}}var origSend=window.sendChatMessage;window.sendChatMessage=function(){if(E.enabled&&E.password){var msg=input.value;if(msg&&msg.trim().length>0){input.value=encryptMsg(msg,E.password);setTimeout(function(){var status=document.getElementById('chatStatus');if(status)status.textContent='🔒 Encrypted!'},100)}}origSend.apply(this,arguments)}}var chatWindow=document.getElementById('chatWindow');if(chatWindow){var observer=new MutationObserver(function(){addDecryptButtons()});observer.observe(chatWindow,{childList:!0,subtree:!0});setTimeout(addDecryptButtons,100)}}function startEncryption(){var btn=document.querySelector('.encrypt-btn');if(!btn)initEncryption()}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',startEncryption)}else{startEncryption()}setTimeout(startEncryption,500);setInterval(function(){if(!document.querySelector('.encrypt-btn'))initEncryption()},1000)"
}