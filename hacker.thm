{
  "description": "Hacker Style Terminal Overlay - Command interface for NOMAD",
  "css": "#hacker-terminal-overlay{position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:500001;background:#000000;color:#00ff00;font-family:'Courier New',monospace;flex-direction:column;padding:9px;box-sizing:border-box;overflow:hidden}#hacker-terminal-overlay.active{display:flex!important}.terminal-header{color:#00ff00;font-size:14px;padding:10px 0;border-bottom:1px solid rgba(0,255,0,0.2);margin-bottom:15px;display:flex;justify-content:space-between;align-items:center;flex-shrink:0}.terminal-header .close-btn{background:none;border:1px solid rgba(0,255,0,0.3);color:#00ff00;padding:5px 15px;cursor:pointer;border-radius:4px;font-family:'Courier New',monospace;font-size:12px}.terminal-header .close-btn:hover{background:rgba(0,255,0,0.1)}.terminal-body{flex:1;display:flex;flex-direction:column;overflow:hidden;min-height:0}.terminal-output-area{overflow-y:auto;padding:10px;margin-bottom:10px;background:rgba(0,255,0,0.02);height:72vh}.terminal-output-area::-webkit-scrollbar{width:6px}.terminal-output-area::-webkit-scrollbar-track{background:rgba(0,0,0,0.3)}.terminal-output-area::-webkit-scrollbar-thumb{background:rgba(0,255,0,0.3);border-radius:3px}.terminal-line{padding:2px 0;font-size:13px;line-height:1.6;font-family:'Courier New',monospace;white-space:pre-wrap;word-break:break-word}.terminal-line .prompt{color:#00aa00}.terminal-line .command{color:#00ff00;font-weight:bold}.terminal-line .output{color:#33ff33;display:block}.terminal-line .output .error{color:#ff4444}.terminal-line .output .info{color:#66ccff}.terminal-line .output .success{color:#00ff00}.terminal-line .output .warning{color:#ff8800}.terminal-line .separator{color:rgba(0,255,0,0.2);margin:8px 0;display:block;margin-top:0;}.terminal-line .file-item{display:flex;justify-content:space-between;padding:2px 0;border:0;background:transparent !important;cursor:pointer}.terminal-line .file-item:hover{background:rgba(0,255,0,0.05)}.terminal-line .file-item .size{color:#00aa00}.terminal-line .node-item{display:flex;justify-content:space-between;padding:2px 0;border:0;background:transparent !important}.terminal-line .node-item .signal-strong{color:#00ff00}.terminal-line .node-item .signal-weak{color:#ff8800}.terminal-line .node-item .signal-dead{color:#ff4444}.terminal-input-row{display:flex;gap:10px;align-items:center;border-top:1px solid rgba(0,255,0,0.2);padding-top:2vh;flex-shrink:0}.terminal-input-row .prompt-label{color:#00aa00;font-size:14px;font-family:'Courier New',monospace;white-space:nowrap}.terminal-input-row input{flex:1;background:rgba(0,0,0,0.8);border:1px solid rgba(0,255,0,0.3);color:#00ff00;padding:8px 12px;border-radius:4px;font-family:'Courier New',monospace;font-size:14px;outline:none}.terminal-input-row input:focus{border-color:#00ff00;box-shadow:0 0 10px rgba(0,255,0,0.1)}.terminal-input-row input::placeholder{color:#005500}.terminal-input-row .send-btn{background:rgba(0,255,0,0.1);border:1px solid rgba(0,255,0,0.3);color:#00ff00;padding:8px 20px;cursor:pointer;border-radius:4px;font-family:'Courier New',monospace;font-size:14px;transition:all 0.2s;flex-shrink:0}.terminal-input-row .send-btn:hover{background:rgba(0,255,0,0.2);border-color:#00ff00}.terminal-status{color:#00aa00;font-size:11px;opacity:0.5;padding:5px 0;border-top:1px solid rgba(0,255,0,0.05);margin-top:5px;flex-shrink:0}.terminal-status .dot{display:inline-block;width:8px;height:8px;background:#00ff00;border-radius:50%;margin-right:6px;animation:blink-dot 1.5s ease-in-out infinite}@keyframes blink-dot{0%,100%{opacity:1}50%{opacity:0.2}}@keyframes blink-cursor{0%,100%{opacity:1}50%{opacity:0}}.terminal-line .stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:5px 0}.terminal-line .stat-item{background:rgba(0,255,0,0.03);border:1px solid rgba(0,255,0,0.1);padding:10px;border-radius:4px;text-align:center}.terminal-line .stat-item .label{color:#00aa00;font-size:10px;text-transform:uppercase}.terminal-line .stat-item .value{color:#00ff00;font-size:16px;margin-top:2px}.terminal-line .chat-message{padding:4px 8px;margin:2px 0;border-left:2px solid rgba(0,255,0,0.2)}.terminal-line .chat-message .from{color:#00aa00}.terminal-line .chat-message .time{color:#005500;font-size:11px}.terminal-line .chat-message .text{color:#00ff00;margin-top:2px}.help-grid{max-width:450px;margin:5px 0}.help-grid .help-item{background:rgba(0,255,0,0.03);border:1px solid rgba(0,255,0,0.1);padding:6px 10px;border-radius:4px;display:flex;justify-content:space-between;margin-bottom:0.5em;}.help-grid .help-item .cmd{color:#00ff00;font-weight:bold}.help-grid .help-item .desc{color:#00aa00}.status-bar{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;padding:10px 0;width:100%}.status-bar .stat-card{background:rgba(0,255,0,0.03);border:1px solid rgba(0,255,0,0.1);border-radius:6px;padding:12px;text-align:center}.status-bar .stat-card .stat-label{color:#00aa00;font-size:10px;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px}.status-bar .stat-card .stat-value{color:#00ff00;font-size:14px;font-weight:bold}.status-bar .stat-card .stat-value .unit{color:#00aa00;font-size:10px;font-weight:normal}",
  "js": "document.addEventListener('DOMContentLoaded',function(){if(document.getElementById('hacker-terminal-overlay')){return}var overlay=document.createElement('div');overlay.id='hacker-terminal-overlay';overlay.innerHTML='<div class=terminal-header><span>NOMAD@NODE:~$</span><button class=close-btn onclick=closeTerminal()>✕</button></div><div class=terminal-body><div class=terminal-output-area id=termOutput><div class=terminal-line><span class=prompt>$ </span><span class=command>init</span><br><span class=output>NOMAD NODE TERMINAL v1.0</span><br><span class=output>Type a command or use the input below</span><br><span class=output>Available: files, nodes, status, chat, upload, help</span><br><span class=output>Also: open filename (e.g. open example.txt)</span><br><span class=separator>─────────────────────────────────────────</span></div></div><div class=terminal-input-row><span class=prompt-label>$ </span><input id=termInput type=text placeholder=\"Enter command...\" autofocus><button class=send-btn onclick=executeCommand()>⏎</button></div><div class=terminal-status><span class=dot></span> SYSTEM ONLINE</div></div>';document.body.appendChild(overlay);window.termOutput=document.getElementById('termOutput');window.termInput=document.getElementById('termInput');window.termInput.addEventListener('keydown',function(e){if(e.key==='Enter')executeCommand()});window.scrollToBottom=function(){var output=document.getElementById('termOutput');if(output){output.scrollTop=output.scrollHeight}};window.toggleTerminal=function(){var t=document.getElementById('hacker-terminal-overlay');if(t.classList.contains('active')){t.classList.remove('active');t.style.display='none'}else{t.style.display='flex';t.classList.add('active');setTimeout(function(){document.getElementById('termInput').focus();window.scrollToBottom()},100)}};window.closeTerminal=function(){var t=document.getElementById('hacker-terminal-overlay');t.classList.remove('active');t.style.display='none'};window.executeCommand=function(){var input=document.getElementById('termInput');if(!input){return}var cmd=input.value.trim();if(!cmd){return}input.value='';input.focus();var output=document.getElementById('termOutput');var promptLine='<div class=terminal-line><span class=prompt>$ </span><span class=command>'+escapeHtml(cmd)+'</span></div>';output.innerHTML+=promptLine;runCommand(cmd);window.scrollToBottom()};window.runCommand=function(cmd){var output=document.getElementById('termOutput');var lower=cmd.toLowerCase();if(lower.startsWith('open ')){var filename=cmd.substring(5).trim();if(filename){output.innerHTML+='<div class=terminal-line><span class=output class=info>📂 Opening '+escapeHtml(filename)+'...</span></div>';if(typeof viewFile==='function'){viewFile(filename)}else{output.innerHTML+='<div class=terminal-line><span class=output class=error>❌ viewFile() not available</span></div>'}window.scrollToBottom();return}else{output.innerHTML+='<div class=terminal-line><span class=output class=error>❌ Usage: open filename</span></div>';window.scrollToBottom();return}}switch(lower){case'files':case'ls':output.innerHTML+='<div class=terminal-line><span class=output class=info>📁 Loading files...</span></div>';fetch('/api/files').then(function(r){return r.json()}).then(function(data){var html='<div class=terminal-line><span class=output>';if(data.files&&data.files.length>0){data.files.forEach(function(f){var size=f.size||0;html+='<div class=file-item onclick=\"if(typeof viewFile===\\'function\\'){viewFile(\\''+escapeHtml(f.name)+'\\');closeTerminal()}\"><span>&gt;&nbsp;'+escapeHtml(f.name)+'</span><span class=size>'+size+'B</span></div>'})}else{html+='<span class=info>No files found</span>'}html+='</span></div>';output.innerHTML+=html;window.scrollToBottom()}).catch(function(){output.innerHTML+='<div class=terminal-line><span class=output class=error>❌ Failed to load files</span></div>';window.scrollToBottom()});break;case'nodes':case'node':output.innerHTML+='<div class=terminal-line><span class=output class=info>📡 Scanning for nodes...</span></div>';fetch('/api/nodes').then(function(r){return r.json()}).then(function(data){var html='<div class=terminal-line><span class=output>';if(data.nodes&&data.nodes.length>0){data.nodes.forEach(function(n){var signalClass='signal-'+((n.signal&&n.signal>-70)?'strong':(n.signal&&n.signal>-90)?'weak':'dead');html+='<div class=node-item><span class=id>'+escapeHtml(n.id)+'</span><span class='+signalClass+'>'+n.signal+'dBm</span></div>'})}else{html+='<span class=info>No nodes found</span>'}html+='</span></div>';output.innerHTML+=html;window.scrollToBottom()}).catch(function(){output.innerHTML+='<div class=terminal-line><span class=output class=error>❌ Failed to scan nodes</span></div>';window.scrollToBottom()});break;case'status':case'stats':output.innerHTML+='<div class=terminal-line><span class=output class=info>📊 Fetching status...</span></div>';fetch('/api/status').then(function(r){return r.json()}).then(function(data){var html='<div class=terminal-line><span class=output><div class=status-bar><div class=stat-card><div class=stat-label>Device ID</div><div class=stat-value id=nodeId>'+(data.nodeId||'NMD0740668')+'</div></div><div class=stat-card><div class=stat-label>Router IP</div><div class=stat-value id=routerIP style=\"font-size:0.85em;cursor:pointer;\" title=\"Click to open in browser\">'+(data.routerIP||'192.168.1.29')+'</div><div class=stat-value id=deviceDNS style=\"font-size:0.85em;cursor:pointer;\" title=\"Click to copy address\">'+(data.deviceDNS||'NMD740668.local')+'</div></div><div class=stat-card><div class=stat-label>Nearby Nodes</div><div class=stat-value id=nodeCount>'+(data.nodeCount||0)+'</div></div><div class=stat-card><div class=stat-label>Local Files</div><div class=stat-value id=fileCount>'+(data.fileCount||3)+'</div></div><div class=stat-card><div class=stat-label>Duty Cycle</div><div class=stat-value id=dutyCycle>'+(data.dutyCycle||'0.0')+'%</div><div style=\"background:#2a2a2a;height:8px;border-radius:4px;margin-top:4px;overflow:hidden;\"><div id=dutyCycleIndicator style=\"height:100%;width:'+(data.dutyCycle||0)+'%;transition:width 0.3s;background:linear-gradient(90deg,rgb(76,175,80),rgb(139,195,74));\"></div></div></div><div class=stat-card><div class=stat-label>Free Memory</div><div class=stat-value id=freeHeap>'+(data.freeHeap||'177')+'kB</div><div style=\"background:#2a2a2a;height:8px;border-radius:4px;margin-top:4px;overflow:hidden;\"><div id=heapIndicator style=\"height:100%;width:'+(data.heapPercent||65.4)+'%;transition:width 0.3s;background:linear-gradient(90deg,rgb(255,235,59),rgb(255,193,7));\"></div></div></div><div class=stat-card><div class=stat-label>Temperature</div><div class=stat-value id=theTemp><span style=\"border-radius:6px;width:100%;text-align:center;display:inline-block;background-color:#fff3cd;color:#856404;padding:6px;border-radius:3px;\">'+(data.temp||'59.3')+'°C</span></div></div><div class=stat-card><div class=stat-label>Storage Space</div><div class=stat-value id=storageText>'+(data.storageUsed||72)+' / '+(data.storageTotal||6392)+' kB</div><div style=\"background:#2a2a2a;height:8px;border-radius:4px;margin-top:4px;overflow:hidden;\"><div id=storageIndicator style=\"height:100%;width:'+(data.storagePercent||1.1)+'%;transition:width 0.3s;background:linear-gradient(90deg,rgb(76,175,80),rgb(139,195,74));\"></div></div></div><div class=stat-card><div class=stat-label>LoRa Frequency</div><div class=stat-value>'+(data.loraFreq||'868.1')+' <span class=unit>MHz</span></div></div><div class=stat-card><div class=stat-label>Spreading Factor</div><div class=stat-value>'+(data.spreadingFactor||'SF9')+'</div></div><div class=stat-card><div class=stat-label>Child-Safe Filter</div><div class=stat-value>'+(data.childSafe||'DISABLED')+'</div></div></div></span></div>';output.innerHTML+=html;window.scrollToBottom()}).catch(function(){output.innerHTML+='<div class=terminal-line><span class=output class=error>❌ Failed to get status</span></div>';window.scrollToBottom()});break;case'chat':case'messages':output.innerHTML+='<div class=terminal-line><span class=output class=info>💬 Loading messages...</span></div>';fetch('/api/chat/messages').then(function(r){return r.json()}).then(function(data){var html='<div class=terminal-line><span class=output>';if(data.messages&&data.messages.length>0){data.messages.forEach(function(m){html+='<div class=chat-message><div><span class=from>'+escapeHtml(m.from)+'</span> <span class=time>['+m.time+']</span></div><div class=text>'+escapeHtml(m.text)+'</div></div>'})}else{html+='<span class=info>No messages</span>'}html+='</span></div>';output.innerHTML+=html;window.scrollToBottom()}).catch(function(){output.innerHTML+='<div class=terminal-line><span class=output class=error>❌ Failed to load messages</span></div>';window.scrollToBottom()});break;case'upload':case'up':output.innerHTML+='<div class=terminal-line><span class=output class=info>📤 Opening file upload...</span></div>';var fileInput=document.getElementById('fileInput');if(fileInput){fileInput.click()}else{output.innerHTML+='<div class=terminal-line><span class=output class=error>❌ File input not found</span></div>';window.scrollToBottom()};break;case'help':case'?':var helpHtml='<div class=terminal-line><span class=output><div class=help-grid><div class=help-item><span class=cmd>files</span><span class=desc>List all files</span></div><div class=help-item><span class=cmd>nodes</span><span class=desc>Scan for nodes</span></div><div class=help-item><span class=cmd>status</span><span class=desc>Device status</span></div><div class=help-item><span class=cmd>chat</span><span class=desc>View messages</span></div><div class=help-item><span class=cmd>upload</span><span class=desc>Open file upload</span></div><div class=help-item><span class=cmd>open</span><span class=desc>open filename</span></div><div class=help-item><span class=cmd>help</span><span class=desc>Show this help</span></div></div></span></div>';output.innerHTML+=helpHtml;window.scrollToBottom();break;case'clear':case'cls':output.innerHTML='';break;case'exit':case'close':closeTerminal();break;default:output.innerHTML+='<div class=terminal-line><span class=output class=error>❌ Unknown command: '+escapeHtml(cmd)+'</span></div><div class=terminal-line><span class=output class=info>Type \"help\" for available commands</span></div>';window.scrollToBottom()}};function escapeHtml(str){if(!str)return'';return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;').replace(/'/g,'&#39;')}window.showTerminal=function(){var t=document.getElementById('hacker-terminal-overlay');t.style.display='flex';t.classList.add('active');setTimeout(function(){document.getElementById('termInput').focus();window.scrollToBottom()},100)};var menuBtn=document.querySelector('.floating-btn');if(menuBtn){var origClick=menuBtn.onclick;menuBtn.onclick=function(e){var overlay=document.getElementById('hacker-terminal-overlay');if(overlay&&overlay.classList.contains('active')){closeTerminal();return}origClick&&origClick(e)}};var uploadBtn=document.getElementById('uploadBtn');if(uploadBtn){uploadBtn.onclick=function(e){e.preventDefault();e.stopPropagation();var overlay=document.getElementById('hacker-terminal-overlay');if(overlay&&overlay.classList.contains('active')){closeTerminal()}setTimeout(function(){document.getElementById('fileInput').click()},100);document.getElementById('circularMenu').classList.remove('active')}};var terminalTrigger=document.createElement('a');terminalTrigger.href='#';terminalTrigger.className='menu-item';terminalTrigger.id='terminalToggleBtn';terminalTrigger.innerHTML='<svg style=position:relative width=24px height=24px viewBox=\"0 0 24 24\" fill=none stroke=#fff stroke-width=2 stroke-linecap=round stroke-linejoin=round><polyline points=\"4 17 10 11 4 5\"></polyline><line x1=\"12\" y1=\"19\" x2=\"20\" y2=\"19\"></line></svg>';terminalTrigger.onclick=function(e){e.preventDefault();e.stopPropagation();document.getElementById('circularMenu').classList.remove('active');showTerminal()};var wrapper=document.querySelector('.circular-menu .items-wrapper');if(wrapper){var studioBtn=document.getElementById('studioBtn');if(studioBtn){wrapper.insertBefore(terminalTrigger,studioBtn)}else{wrapper.appendChild(terminalTrigger)}}console.log('NOMAD HACKER TERMINAL READY - Click the terminal icon in the menu')});",
  "target": "footer"
}