PAGE: A fully working Chip8 console emulator
COLOR: #000
AUTHOR: NOMAD
DATE: 2026-06-30
CUSTOMHTML-START
<style>*{box-sizing:border-box;user-select:none;-webkit-tap-highlight-color:transparent}body{margin:0;min-height:100vh;background:#0a0a12;display:flex;justify-content:center;align-items:center;font-family:system-ui,-apple-system,sans-serif}.container{display:flex;flex-direction:column;align-items:center;gap:10px;padding:10px;width:100%;max-width:480px}canvas{width:100%;aspect-ratio:64/32;background:#000;display:block;border:3px solid #1a1a2e;border-radius:8px;image-rendering:pixelated;image-rendering:crisp-edges;background-color:#000}.controls{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;width:100%;max-width:400px}.controls button{background:#1a1a2e;border:none;border-radius:8px;color:#aab;font-size:1.4rem;font-weight:bold;padding:14px 0;cursor:pointer;touch-action:manipulation;box-shadow:0 3px 0 #0a0a12;transition:all .05s;border-bottom:2px solid #2a2a3e;font-family:monospace}.controls button:active{transform:translateY(3px);box-shadow:0 0 0 #0a0a12;background:#2a2a4e}.file-label{background:#1a1a2e;color:#889;padding:10px 20px;border-radius:25px;font-size:.9rem;cursor:pointer;border:2px dashed #2a2a4e;text-align:center;width:100%;max-width:280px;transition:background .2s}.file-label:hover{background:#22223e}.file-label input{display:none}#status{color:#667;font-size:.8rem;min-height:1.2em;text-align:center;font-family:monospace}.key-hint{color:#445;font-size:.65rem;text-align:center;max-width:400px;line-height:1.4;padding:0 8px}.key-hint span{color:#556}</style>
<div class="container"><canvas id="c" width="64" height="32"></canvas><div class="controls" id="kb"><button data-k="0x1">1</button><button data-k="0x2">2</button><button data-k="0x3">3</button><button data-k="0xC">C</button><button data-k="0x4">4</button><button data-k="0x5">5</button><button data-k="0x6">6</button><button data-k="0xD">D</button><button data-k="0x7">7</button><button data-k="0x8">8</button><button data-k="0x9">9</button><button data-k="0xE">E</button><button data-k="0xA">A</button><button data-k="0x0">0</button><button data-k="0xB">B</button><button data-k="0xF">F</button></div><label class="file-label" id="loadBtn">📁 Load ROM<input type="file" id="romInput" accept=".ch8,.rom"></label><div id="status">Load a CHIP-8 ROM</div><div class="key-hint"><span>Keyboard: 1-4=1-4, QWER=4-D, ASDF=7-E, ZXCV=A-F</span></div></div>
<script>(function(){'use strict';const canvas=document.getElementById('c');const ctx=canvas.getContext('2d');const statusEl=document.getElementById('status');const mem=new Uint8Array(4096);const V=new Uint8Array(16);let I=0;let pc=0x200;const stack=new Uint16Array(16);let sp=0;let dt=0;let st=0;const display=new Uint8Array(64*32);const keys=new Uint8Array(16);let draw=true;const font=[0xF0,0x90,0x90,0x90,0xF0,0x20,0x60,0x20,0x20,0x70,0xF0,0x10,0xF0,0x80,0xF0,0xF0,0x10,0xF0,0x10,0xF0,0x90,0x90,0xF0,0x10,0x10,0xF0,0x80,0xF0,0x10,0xF0,0xF0,0x80,0xF0,0x90,0xF0,0xF0,0x10,0x20,0x40,0x40,0xF0,0x90,0xF0,0x90,0xF0,0xF0,0x90,0xF0,0x10,0xF0,0xF0,0x90,0xF0,0x90,0x90,0xE0,0x90,0xE0,0x90,0xE0,0xF0,0x80,0x80,0x80,0xF0,0xE0,0x90,0x90,0x90,0xE0,0xF0,0x80,0xF0,0x80,0xF0,0xF0,0x80,0xF0,0x80,0x80];for(let i=0;i<80;i++)mem[i]=font[i];function setStatus(msg,ok){statusEl.textContent=msg;statusEl.style.color=ok?'#6a6':'#667'}function loadROM(buffer){const rom=new Uint8Array(buffer);if(rom.length>4096-0x200){setStatus('ROM too large',false);return false}pc=0x200;sp=0;I=0;V.fill(0);display.fill(0);dt=st=0;mem.fill(0,0x200);mem.set(rom,0x200);draw=true;setStatus('ROM loaded ✓',true);return true}function drawDisplay(){const img=ctx.createImageData(64,32);const d=img.data;for(let i=0;i<64*32;i++){const v=display[i]?255:0;const idx=i*4;d[idx]=v;d[idx+1]=v;d[idx+2]=v;d[idx+3]=255}ctx.putImageData(img,0,0)}function exec(){const op=(mem[pc]<<8)|mem[pc+1];pc+=2;const x=(op&0x0F00)>>8;const y=(op&0x00F0)>>4;const n=op&0x000F;const nn=op&0x00FF;const nnn=op&0x0FFF;switch(op&0xF000){case 0x0000:if(nn===0xE0){display.fill(0);draw=true}else if(nn===0xEE){pc=stack[--sp]}break;case 0x1000:pc=nnn;break;case 0x2000:stack[sp++]=pc;pc=nnn;break;case 0x3000:if(V[x]===nn)pc+=2;break;case 0x4000:if(V[x]!==nn)pc+=2;break;case 0x5000:if(V[x]===V[y])pc+=2;break;case 0x6000:V[x]=nn;break;case 0x7000:V[x]=(V[x]+nn)&0xFF;break;case 0x8000:switch(n){case 0x0:V[x]=V[y];break;case 0x1:V[x]|=V[y];break;case 0x2:V[x]&=V[y];break;case 0x3:V[x]^=V[y];break;case 0x4:V[0xF]=(V[x]+V[y]>0xFF)?1:0;V[x]=(V[x]+V[y])&0xFF;break;case 0x5:V[0xF]=(V[x]>V[y])?1:0;V[x]=(V[x]-V[y])&0xFF;break;case 0x6:V[0xF]=V[x]&0x1;V[x]>>=1;break;case 0x7:V[0xF]=(V[y]>V[x])?1:0;V[x]=(V[y]-V[x])&0xFF;break;case 0xE:V[0xF]=(V[x]&0x80)>>7;V[x]=(V[x]<<1)&0xFF;break}break;case 0x9000:if(V[x]!==V[y])pc+=2;break;case 0xA000:I=nnn;break;case 0xB000:pc=nnn+V[0];break;case 0xC000:V[x]=(Math.random()*256)&nn;break;case 0xD000:{const h=n;let xPos=V[x]&63;let yPos=V[y]&31;V[0xF]=0;for(let row=0;row<h;row++){const sprite=mem[I+row];for(let col=0;col<8;col++){if(sprite&(0x80>>col)){const idx=(xPos+col)+(yPos+row)*64;if(idx<64*32){if(display[idx])V[0xF]=1;display[idx]^=1}}}}draw=true;break}case 0xE000:if(nn===0x9E){if(keys[V[x]])pc+=2}else if(nn===0xA1){if(!keys[V[x]])pc+=2}break;case 0xF000:switch(nn){case 0x07:V[x]=dt;break;case 0x0A:{let pressed=-1;for(let i=0;i<16;i++)if(keys[i]){pressed=i;break}if(pressed===-1)pc-=2;else V[x]=pressed;break}case 0x15:dt=V[x];break;case 0x18:st=V[x];break;case 0x1E:I=(I+V[x])&0xFFFF;break;case 0x29:I=V[x]*5;break;case 0x33:{const val=V[x];mem[I]=Math.floor(val/100);mem[I+1]=Math.floor((val%100)/10);mem[I+2]=val%10;break}case 0x55:for(let i=0;i<=x;i++)mem[I+i]=V[i];break;case 0x65:for(let i=0;i<=x;i++)V[i]=mem[I+i];break}break}}let running=false;function loop(){if(!running)return;for(let i=0;i<10;i++)exec();if(dt>0)dt--;if(st>0)st--;if(draw){drawDisplay();draw=false}requestAnimationFrame(loop)}function keyDown(k){if(k>=0&&k<16)keys[k]=1}function keyUp(k){if(k>=0&&k<16)keys[k]=0}document.querySelectorAll('#kb button[data-k]').forEach(btn=>{const k=parseInt(btn.dataset.k,16);btn.addEventListener('touchstart',e=>{e.preventDefault();keyDown(k)});btn.addEventListener('touchend',e=>{e.preventDefault();keyUp(k)});btn.addEventListener('touchcancel',e=>{keyUp(k)});btn.addEventListener('mousedown',e=>{e.preventDefault();keyDown(k)});btn.addEventListener('mouseup',e=>{keyUp(k)});btn.addEventListener('mouseleave',e=>{keyUp(k)})});const keyMap={'1':0x1,'2':0x2,'3':0x3,'4':0xC,'q':0x4,'w':0x5,'e':0x6,'r':0xD,'a':0x7,'s':0x8,'d':0x9,'f':0xE,'z':0xA,'x':0x0,'c':0xB,'v':0xF};document.addEventListener('keydown',e=>{const k=e.key.toLowerCase();if(k in keyMap){e.preventDefault();keyDown(keyMap[k])}});document.addEventListener('keyup',e=>{const k=e.key.toLowerCase();if(k in keyMap){e.preventDefault();keyUp(keyMap[k])}});document.getElementById('romInput').addEventListener('change',function(e){if(this.files&&this.files[0]){const reader=new FileReader();reader.onload=function(e){if(loadROM(e.target.result)){if(!running){running=true;loop()}}};reader.readAsArrayBuffer(this.files[0])}this.value=''});document.querySelector('.container').addEventListener('dragover',e=>e.preventDefault());document.querySelector('.container').addEventListener('drop',e=>{e.preventDefault();const f=e.dataTransfer.files[0];if(f){const reader=new FileReader();reader.onload=function(e){if(loadROM(e.target.result)){if(!running){running=true;loop()}}};reader.readAsArrayBuffer(f)}});running=true;loop();drawDisplay();setStatus('Load a CHIP-8 ROM',false)})();</script>
CUSTOMHTML-END