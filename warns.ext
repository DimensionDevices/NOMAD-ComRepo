{
  "description": "Header banner warning when LoRa duty cycle or file storage usage gets close to their limits",
  "target": "header",
  "html": "<div id='nmdWarnBanner' style='display:none;padding:10px 16px;margin:8px 0;font-size:14px;font-weight:600;text-align:center;'></div>",
  "css": ".nmd-warn-caution{background:#fff3cd;color:#856404;} .nmd-warn-danger{background:#f8d7da;color:#721c24;}",
  "js": "(function(){var DUTY_CAUTION=70;var DUTY_DANGER=90;var STORAGE_CAUTION=70;var STORAGE_DANGER=90;var POLL_MS=10000;var testOverride=null;function pct(used,total){if(!total)return 0;return used/total*100}function applyStatus(t){var banner=document.getElementById('nmdWarnBanner');if(!banner)return;var msgs=[];var level=0;var duty=t.dutyCycle||0;if(duty>=DUTY_DANGER){msgs.push('⚠️ LoRa duty cycle at '+duty.toFixed(1)+'% - near transmit limit');level=Math.max(level,2)}else if(duty>=DUTY_CAUTION){msgs.push('LoRa duty cycle at '+duty.toFixed(1)+'%');level=Math.max(level,1)}var s=t.storage||{};if(!s.error&&s.totalKB){var used=s.usedKB||0;var total=s.totalKB||0;var p=pct(used,total);if(p>=STORAGE_DANGER){msgs.push('⚠️ Storage at '+p.toFixed(0)+'% ('+used+'/'+total+' kB) - nearly full');level=Math.max(level,2)}else if(p>=STORAGE_CAUTION){msgs.push('Storage at '+p.toFixed(0)+'% ('+used+'/'+total+' kB)');level=Math.max(level,1)}}if(msgs.length===0){banner.style.display='none';banner.className='';return}banner.className=level>=2?'nmd-warn-danger':'nmd-warn-caution';banner.innerHTML=msgs.join('&nbsp;&nbsp;|&nbsp;&nbsp;');banner.style.display='block'}function render(){if(testOverride){applyStatus(testOverride);return}fetch('/api/status').then(function(r){if(!r.ok)throw new Error('bad status');return r.json()}).then(applyStatus).catch(function(){})}window.nmdTestWarnBanner=function(opts){opts=opts||{};if(opts.clear){testOverride=null;render();console.log('[nmdTestWarnBanner] cleared override, resumed live /api/status polling');return}testOverride={dutyCycle:opts.dutyCycle!==undefined?opts.dutyCycle:0,storage:{error:false,usedKB:opts.usedKB!==undefined?opts.usedKB:0,totalKB:opts.totalKB!==undefined?opts.totalKB:100,availableKB:(opts.totalKB!==undefined?opts.totalKB:100)-(opts.usedKB!==undefined?opts.usedKB:0)}};render();console.log('[nmdTestWarnBanner] applied mock status:',testOverride,'(call nmdTestWarnBanner({clear:true}) to resume live polling)')};render();setInterval(render,POLL_MS)})();"
}
