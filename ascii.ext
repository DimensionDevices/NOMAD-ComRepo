{"html":"<style>.figlet-container{background:transparent;border-radius:12px;padding:12px 16px;margin-bottom:12px;text-align:center;position:relative}.figlet-display{font-family:'Courier New',monospace;font-size:.55em;line-height:1.1;color:var(--text);white-space:pre;overflow-x:auto;padding:8px 0;min-height:40px;display:flex;align-items:center;justify-content:center}.figlet-display .empty{color:var(--text-dim);font-size:1.2em;font-family:sans-serif}.figlet-display .text-fallback{font-size:2em;font-weight:700}.figlet-controls{display:none;gap:8px;align-items:center;justify-content:center;flex-wrap:wrap;margin-top:8px;padding:12px;background:var(--surface);border-radius:8px;border:1px solid var(--border)}.figlet-controls.show{display:flex}.figlet-controls select,.figlet-controls input[type=color]{background:var(--bg);border:1px solid var(--border);color:var(--text);padding:6px 12px;border-radius:6px;font-size:.85em;cursor:pointer}.figlet-controls select:focus,.figlet-controls input[type=color]:focus{outline:none;border-color:var(--accent)}.figlet-controls input[type=text]{background:var(--bg);border:1px solid var(--border);color:var(--text);padding:6px 12px;border-radius:6px;font-size:.85em;flex:1;min-width:120px;max-width:200px}.figlet-controls input[type=text]:focus{outline:none;border-color:var(--accent)}.figlet-controls .btn{background:var(--accent);color:#fff;border:none;padding:6px 16px;border-radius:6px;cursor:pointer;font-size:.85em;transition:all .2s}.figlet-controls .btn:hover{opacity:.85;transform:scale(1.02)}.figlet-controls .btn-secondary{background:var(--border);color:var(--text)}.figlet-controls .btn-small{padding:4px 10px;font-size:.75em}.figlet-cog{position:absolute;top:0px;right:1px;cursor:pointer;color:var(--text-dim);font-size:1.2em;transition:all .3s;background:transparent;border:none;padding:4px 8px;border-radius:4px}.figlet-cog:hover{color:var(--text);background:var(--surface);transform:rotate(90deg)}.figlet-color-row{display:flex;gap:6px;align-items:center;flex-wrap:wrap}</style><div class=figlet-container><button class=figlet-cog id=figletCog>⚙</button><div class=figlet-display id=figletDisplay><span class=empty>No text set</span></div><div class=figlet-controls id=figletControls><input type=text id=figletInput placeholder=\"Type here...\" maxlength=9><select id=figletFont><option value=standard selected>Standard</option></select><div class=figlet-color-row><input type=color id=figletColor value=#4CAF50><label style=font-size:.7em;color:var(--text-dim)>color</label></div><button class=btn id=figletRenderBtn>Render</button><button class=\"btn btn-secondary\" id=figletResetBtn>✕</button></div></div>","css":"","js":"var figletLib={fonts:{standard:{A:['  A  ',' A A ','AAAAA','A   A','A   A'],B:['BBBB ','B   B','BBBB ','B   B','BBBB '],C:[' CCC ','C   C','C    ','C   C',' CCC '],D:['DDDD ','D   D','D   D','D   D','DDDD '],E:['EEEEE','E    ','EEE  ','E    ','EEEEE'],F:['FFFFF','F    ','FFF  ','F    ','F    '],G:[' GGG ','G   G','G    ','G  GG',' GGG '],H:['H   H','H   H','HHHHH','H   H','H   H'],I:['IIIII','  I  ','  I  ','  I  ','IIIII'],J:['JJJJJ','    J','    J','J   J',' JJJ '],K:['K   K','K  K ','KKK  ','K  K ','K   K'],L:['L    ','L    ','L    ','L    ','LLLLL'],M:['M   M','MM MM','M M M','M   M','M   M'],N:['N   N','NN  N','N N N','N  NN','N   N'],O:[' OOO ','O   O','O   O','O   O',' OOO '],P:['PPPP ','P   P','PPPP ','P    ','P    '],Q:[' QQQ ','Q   Q','Q   Q','Q  QQ',' QQQQ'],R:['RRRR ','R   R','RRRR ','R  R ','R   R'],S:[' SSS ','S   S',' SSS ','    S',' SSS '],T:['TTTTT','  T  ','  T  ','  T  ','  T  '],U:['U   U','U   U','U   U','U   U',' UUU '],V:['V   V','V   V',' V V ',' V V ','  V  '],W:['W   W','W   W','W W W','WW WW','W   W'],X:['X   X',' X X ','  X  ',' X X ','X   X'],Y:['Y   Y',' Y Y ','  Y  ','  Y  ','  Y  '],Z:['ZZZZZ','   Z ','  Z  ',' Z   ','ZZZZZ'],'0':[' 000 ','0   0','0   0','0   0',' 000 '],'1':['  1  ',' 11  ','  1  ','  1  ','11111'],'2':[' 222 ','2   2','   2 ','  2  ','22222'],'3':['3333 ','    3',' 333 ','    3','3333 '],'4':['  4  ',' 44  ','4 4  ','44444','  4  '],'5':['55555','5    ','5555 ','    5','5555 '],'6':[' 666 ','6    ','6666 ','6   6',' 666 '],'7':['77777','   7 ','  7  ',' 7   ','7    '],'8':[' 888 ','8   8',' 888 ','8   8',' 888 '],'9':[' 999 ','9   9',' 999 ','    9',' 999 '],'!':['  !  ','  !  ','  !  ','     ','  !  '],'?':[' ??? ','?   ?','   ? ','  ?  ','     '],'.':['     ','     ','     ','     ','  .  '],'-':['     ','     ','-----','     ','     '],' ':['     ','     ','     ','     ','     ']}},render:function(text,font){font=font||'standard';var chars=text.toUpperCase().split('');var lines=['','','','',''];for(var i=0;i<chars.length;i++){var c=chars[i];var charData=this.fonts[font]&&this.fonts[font][c]?this.fonts[font][c]:this.fonts[font][' '];for(var j=0;j<5;j++){lines[j]+=charData[j]+'  '}}return lines.join('\\n')}};var display=document.getElementById('figletDisplay');var input=document.getElementById('figletInput');var fontSelect=document.getElementById('figletFont');var colorPicker=document.getElementById('figletColor');var renderBtn=document.getElementById('figletRenderBtn');var resetBtn=document.getElementById('figletResetBtn');var controls=document.getElementById('figletControls');var cog=document.getElementById('figletCog');var controlsVisible=false;cog.addEventListener('click',function(){controlsVisible=!controlsVisible;controls.classList.toggle('show',controlsVisible);localStorage.setItem('figletControlsVisible',controlsVisible?'true':'false')});function renderTitle(text){if(!text||text.trim()===''){display.innerHTML='<span class=empty>No text set</span>';return}try{var font=fontSelect.value;var color=colorPicker.value;var result=figletLib.render(text.trim(),font);var lines=result.split('\\n');var html='';for(var i=0;i<lines.length;i++){if(lines[i].trim()){html+=lines[i]+'\\n'}}display.textContent=html;display.style.color=color;if(!html.trim()){display.innerHTML='<span class=text-fallback style=color:'+color+'>'+text.toUpperCase()+'</span>'}}catch(e){display.innerHTML='<span class=text-fallback style=color:'+colorPicker.value+'>'+text.toUpperCase()+'</span>'}}function saveSettings(){var settings={text:input.value.trim(),font:fontSelect.value,color:colorPicker.value,controlsVisible:controlsVisible};localStorage.setItem('figletSettings',JSON.stringify(settings))}function loadSettings(){var saved=localStorage.getItem('figletSettings');if(saved){try{var settings=JSON.parse(saved);if(settings.text){input.value=settings.text;renderTitle(settings.text)}if(settings.font){fontSelect.value=settings.font}if(settings.color){colorPicker.value=settings.color;display.style.color=settings.color}if(settings.controlsVisible){controlsVisible=settings.controlsVisible;controls.classList.toggle('show',controlsVisible)}}catch(e){}}}renderBtn.addEventListener('click',function(){var text=input.value.trim();if(text){renderTitle(text);saveSettings()}});input.addEventListener('keypress',function(e){if(e.key==='Enter'){var text=input.value.trim();if(text){renderTitle(text);saveSettings()}}});resetBtn.addEventListener('click',function(){input.value='';localStorage.removeItem('figletSettings');display.innerHTML='<span class=empty>⚡ Enter text below</span>';display.style.color='';input.focus()});fontSelect.addEventListener('change',function(){var text=input.value.trim();if(text){renderTitle(text);saveSettings()}});colorPicker.addEventListener('input',function(){var text=input.value.trim();if(text){renderTitle(text);saveSettings()}});loadSettings();setInterval(function(){var current=input.value.trim();var saved=localStorage.getItem('figletSettings');if(saved){try{var settings=JSON.parse(saved);if(current!==settings.text&&current){renderTitle(current);saveSettings()}}catch(e){}}},3000);controls.classList.remove('show');controlsVisible=false;localStorage.removeItem('figletControlsVisible');","target":"header"}