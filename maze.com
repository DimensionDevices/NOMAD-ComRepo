CUSTOMHTML-START
<style>body{padding:0 !important;margin:0;overflow:hidden;font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif}#info{position:absolute;top:20px;left:20px;color:#fff;background:rgb(0 0 0 / .6);padding:12px 24px;border-radius:8px;pointer-events:none;user-select:none;backdrop-filter:blur(4px);border-left:4px solid #fa4;box-shadow:0 4px 20px rgb(0 0 0 / .5);z-index:10}#info h1{margin:0;font-size:1.4rem;font-weight:400;letter-spacing:1px}#info h1 span{color:#fa4;font-weight:600}#info p{margin:6px 0 0 0;font-size:.85rem;opacity:.8}#hud{position:absolute;top:20px;right:20px;color:#fff;background:rgb(0 0 0 / .6);padding:12px 20px;border-radius:8px;backdrop-filter:blur(4px);border-left:4px solid #fa4;box-shadow:0 4px 20px rgb(0 0 0 / .5);z-index:10;pointer-events:none;user-select:none;text-align:right;min-width:120px}#hud div{margin:2px 0;font-size:1.1rem;letter-spacing:.5px}#hud .score{color:gold;font-weight:700}#hud .timer{color:#8df}#controls{position:absolute;bottom:30px;left:50%;transform:translateX(-50%);color:#fff;background:rgb(20 20 30 / .75);padding:12px 28px;border-radius:60px;backdrop-filter:blur(6px);border:1px solid rgb(255 255 255 / .15);display:flex;gap:36px;font-size:.9rem;letter-spacing:.5px;box-shadow:0 4px 30px rgb(0 0 0 / .6);z-index:10;pointer-events:none}#controls kbd{background:#2a2a3a;padding:4px 12px;border-radius:30px;margin:0 6px;border:1px solid #555;font-weight:600;color:#fa4}#win-message{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:rgb(0 0 0 / .85);color:gold;padding:40px 60px;border-radius:20px;backdrop-filter:blur(8px);border:2px solid gold;box-shadow:0 0 60px rgb(255 215 0 / .3);display:none;z-index:20;text-shadow:0 0 20px #fa0;text-align:center;min-width:280px}#win-message h2{font-size:2.8rem;margin:0 0 8px 0;font-weight:700;letter-spacing:4px}#win-message p{font-size:1.1rem;font-weight:300;color:#ccc;margin:8px 0 20px 0;letter-spacing:1px}#win-message .final-score{color:gold;font-weight:700;font-size:1.3rem}#restart-btn{background:#fa4;color:#1a1a2a;border:none;padding:12px 36px;font-size:1.2rem;font-weight:700;border-radius:60px;cursor:pointer;transition:all 0.2s;letter-spacing:1px;box-shadow:0 4px 20px rgb(255 170 68 / .3)}#restart-btn:hover{transform:scale(1.05);background:#fb5;box-shadow:0 6px 30px rgb(255 170 68 / .5)}#click-prompt{position:absolute;bottom:100px;left:50%;transform:translateX(-50%);color:rgb(255 255 255 / .7);background:rgb(0 0 0 / .5);padding:10px 24px;border-radius:30px;font-size:.9rem;backdrop-filter:blur(4px);border:1px solid rgb(255 255 255 / .1);z-index:10;animation:pulse 2s ease-in-out infinite;pointer-events:none}@keyframes pulse{0%,100%{opacity:.6}50%{opacity:1}}@media (max-width:700px){#info{top:12px;left:12px;padding:8px 16px}#info h1{font-size:1rem}#hud{top:12px;right:12px;padding:8px 14px;min-width:80px}#hud div{font-size:.9rem}#controls{gap:12px;flex-wrap:wrap;justify-content:center;padding:10px 18px;bottom:16px;font-size:.75rem}#click-prompt{bottom:80px;font-size:.75rem;padding:8px 16px}#win-message{padding:24px 30px;min-width:200px}#win-message h2{font-size:2rem}#restart-btn{padding:10px 24px;font-size:1rem}}#touch-controls{display:none;position:fixed;inset:0;z-index:15;touch-action:none}body.touch-device #touch-controls{display:block}body.touch-device #controls,body.touch-device #click-prompt{display:none!important}#joystick-zone{position:absolute;left:0;bottom:0;width:45vw;height:55vh;max-width:320px;pointer-events:auto;z-index:2}#look-zone{position:absolute;right:0;top:0;width:100vw;height:100vh;pointer-events:auto;z-index:1}#joystick-base{position:absolute;left:36px;bottom:36px;width:120px;height:120px;border-radius:50%;background:rgb(255 255 255 / .08);border:2px solid rgb(255 255 255 / .25);backdrop-filter:blur(4px);box-shadow:0 4px 20px rgb(0 0 0 / .4)}#joystick-thumb{position:absolute;top:50%;left:50%;width:54px;height:54px;margin:-27px 0 0 -27px;border-radius:50%;background:rgb(255 170 68 / .85);box-shadow:0 2px 12px rgb(255 170 68 / .5);transition:background 0.15s}body.joystick-active #joystick-thumb{background:rgb(255 170 68)}</style>
