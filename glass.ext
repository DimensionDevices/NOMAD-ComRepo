{
  "html": "",
  "css": ":root{--bg:#fdfaf1;--bg-gradient:linear-gradient(145deg,#fdfaf1 0%,#f5f0e1 100%);--surface:rgba(255,255,255,0.65);--border:rgba(84,117,64,0.15);--text:#2c3e2d;--text-dim:#5c6e5d;--accent:#547540;--accent-hover:#456334;--card-bg:rgba(84,117,64,0.05);--stat-val:#1b3012;--danger:#b0413e;--shadow:0 4px 20px rgba(0,0,0,0.08);--glass-bg:rgba(255,255,255,0.25);--glass-border:rgba(255,255,255,0.3);--glass-blur:6px;--glass-radius:4px;--glass-shadow:0 8px 32px rgba(0,0,0,0.08);--glass-hover:rgba(255,255,255,0.35);--glass-padding:15px 20px}*{margin:0;padding:0;box-sizing:border-box;tap-highlight-color:transparent;-webkit-tap-highlight-color:transparent;-webkit-touch-callout:none}body{background:url(https://images.unsplash.com/photo-1781049941247-0d00f7351e1e?q=80&w=687);background-attachment:fixed;background-size:cover;font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif;color:var(--text);line-height:1.6;transition:background .3s,color .3s;min-height:100vh;position:relative}body::before{content:\"\";position:fixed;top:0;left:0;right:0;bottom:0;z-index:0;pointer-events:none}body>*{position:relative;z-index:1}.container{max-width:800px;margin:0 auto;display:block;flex-wrap:wrap;gap:12px;padding-top:4px}.glass,.header,.section,.stat-card,.node-card,.file-list,.file-item,.file-folder,.file-card,.transfer-item,.upload-area{background:var(--glass-bg);backdrop-filter:blur(var(--glass-blur));-webkit-backdrop-filter:blur(var(--glass-blur));border:1px solid var(--glass-border);border-radius:var(--glass-radius);box-shadow:var(--glass-shadow);transition:all .3s cubic-bezier(.4,0,.2,1)}.glass:hover,.header:hover,.section:hover,.stat-card:hover,.node-card:hover,.file-item:hover,.file-card:hover{background:var(--glass-hover);box-shadow:0 12px 48px rgba(0,0,0,.12)}.stat-card,.node-card,.file-list,.file-item,.file-folder,.file-card,.transfer-item,.upload-area,.btn-icon,.reorder-btn,.modal-content,#customModal .modal-content{backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px)}.header{padding:16px 15px;margin-bottom:4px;position:relative;flex:1 1 100%}.header h1{font-size:1.8rem;font-weight:800}.header .subtitle{font-size:.65rem;opacity:.9;font-weight:400}.header .status-bar>.btn{grid-column:1/-1}.status-bar{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:15px}.stat-card{padding:12px;border-radius:var(--glass-radius)}.stat-label{font-size:.7rem;text-transform:uppercase;opacity:.8;font-weight:600;margin-bottom:4px}.stat-value{font-size:1.1rem;font-weight:700}.unit{font-size:.75rem;opacity:.7;font-weight:400}.section{flex:1 1 calc(50% - 6px);min-width:300px;padding:var(--glass-padding);margin-bottom:4px;overflow:hidden;animation:fadeIn .4s ease-out}.section-hidden{display:none!important}.section summary{background:0 0!important;backdrop-filter:none!important;-webkit-backdrop-filter:none!important;border:none!important;border-radius:0!important;cursor:pointer!important;transition:none!important;padding:0!important;margin:calc(-1 * var(--glass-padding))!important;font-weight:700;user-select:none;list-style:none;display:flex;align-items:center;justify-content:space-between;gap:10px}.section summary::-webkit-details-marker{display:none}.section summary:hover{background:0 0!important;border:none!important;transform:none!important}.section summary h2{margin:0;flex:1;font-size:1.1rem}.section summary h2 span{opacity:.3;margin-right:.25em}.section summary .refresh-btn{flex-shrink:0;background:0 0;border:none;cursor:pointer;padding:4px;display:flex;align-items:center;justify-content:center;opacity:.7;transition:opacity .2s,transform .2s}.section summary .refresh-btn:hover{opacity:1;transform:scale(1.1)}.refresh-btn svg{width:20px;height:20px}.section>div:not(.glass):not(.section):not(.file-folder):not(.file-item):not(.stat-card),.section>div>div:not(.glass):not(.section):not(.file-folder):not(.file-item):not(.stat-card),.glass>div:not(.glass):not(.section):not(.file-folder):not(.file-item):not(.stat-card),.glass>div>div:not(.glass):not(.section):not(.file-folder):not(.file-item):not(.stat-card),.content,.main-content,.page-content,.body-content,.app-content,.wrapper,.container,.panel,.card,.box,.widget,.module,.component{background:0 0!important;backdrop-filter:none!important;-webkit-backdrop-filter:none!important;border:none!important;box-shadow:none!important;border-radius:0!important}details{transition:all .3s ease;overflow:hidden;width:98%;margin-left:1%;}details[open]{padding-bottom:10px}details>summary{list-style:none;cursor:pointer;user-select:none;display:flex;align-items:center;justify-content:space-between;gap:10px}details>:not(summary){opacity:0;transform:translateY(-10px);transition:opacity .3s ease,transform .3s ease;visibility:hidden;height:0;overflow:hidden}details[open]>:not(summary){opacity:1;transform:translateY(0);visibility:visible;height:auto}details[open]>summary:not(:has(button)) h2,details[open]>summary h2:only-child{margin-bottom:1em}.empty-state{text-align:center;padding:30px;color:var(--text-dim)}.node-card{padding:15px;border-radius:var(--glass-radius);margin-bottom:12px}.node-card:first-child{margin-top:1em}.node-header{display:flex;justify-content:space-between;align-items:center}.badge{padding:4px 10px;border-radius:20px;font-size:.7rem;font-weight:800;text-transform:uppercase;color:#fff}.signal-excellent{background:#2e7d32}.signal-good{background:#689f38}.signal-fair{background:#f57c00}.signal-weak{background:#c62828}.node-info{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}.node-field-label{font-size:.6rem;text-transform:uppercase;color:var(--text-dim);font-weight:700}.node-field-value{font-size:.9rem;font-weight:600;color:var(--stat-val)}.node-actions{display:flex;gap:8px;flex-wrap:wrap}.file-list{margin-top:10px;padding:10px;border-radius:var(--glass-radius)}.file-list h4{font-size:.85rem;color:var(--text-dim);margin-bottom:8px}.file-item{padding:8px;border-radius:var(--glass-radius);display:flex;justify-content:space-between;align-items:center;margin-bottom:6px}.file-info{display:flex;align-items:center;gap:10px}.file-name{font-weight:600;font-size:.9rem;color:var(--text)}.file-size{font-size:.75rem;color:var(--text-dim)}.file-item-buttons .btn{float:right;margin-right:6px}.file-item-buttons .btn:first-child{float:none;margin-right:0}.file-description{font-size:.75rem;color:#666;margin-top:6px;font-style:italic;line-height:1.3;max-width:90%;overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}#fileSearch{width:100%;padding:10px;margin:10px 0;border-radius:var(--glass-radius);border:1px solid var(--glass-border);background:rgba(255,255,255,.2);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);color:var(--text);outline:0;transition:all .3s cubic-bezier(.4,0,.2,1)}#fileSearch:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(84,117,64,.1);background:rgba(255,255,255,.3)}.upload-area{border:2px dashed var(--glass-border);padding:15px;text-align:center;font-size:.9rem;font-weight:500;cursor:pointer}.upload-area:hover{border-color:var(--accent);background:rgba(255,255,255,.3)}.file-folder{margin-bottom:12px;border-radius:var(--glass-radius);overflow:hidden}.folder-header{display:flex;align-items:center;padding:12px 16px;cursor:pointer;background:rgba(255,255,255,.1);transition:background .2s;gap:10px}.folder-header:hover{background:rgba(255,255,255,.2)}.folder-icon{font-size:18px}.folder-name{flex:1;font-weight:600}.folder-size{font-size:13px;opacity:.7}.folder-toggle{font-size:12px;transition:transform .2s}.folder-content{padding:8px;background:rgba(255,255,255,.05)}.file-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px;padding:4px}.file-card{padding:12px;text-align:center;display:flex;flex-direction:column;gap:8px;border-radius:var(--glass-radius)}.file-card:hover{border-color:var(--accent)}.file-card-icon{font-size:32px;padding:12px;background:rgba(255,255,255,.15);border-radius:var(--glass-radius);font-weight:700;color:var(--accent)}.file-card-name{font-weight:600;font-size:13px;word-break:break-word;min-height:32px;display:flex;align-items:center;justify-content:center}.file-card-info{font-size:11px;opacity:.7;margin:4px 0}.file-card-actions{display:flex;gap:4px;justify-content:center;flex-wrap:wrap}.file-card-actions .btn{padding:6px 8px;font-size:16px}.category-badge{position:static;margin-left:auto;margin-right:0;align-self:center;font-size:.7rem;padding:2px 8px;border-radius:var(--glass-radius);font-weight:500;z-index:1}.category-badge.game{background:#8B5CF6;color:#fff}.category-badge.app{background:#3B82F6;color:#fff}.category-badge.info{background:#10B981;color:#fff}.category-badge.other{background:#6B7280;color:#fff}.btn{background:var(--accent);color:#fff;border:none;padding:8px 14px;border-radius:var(--glass-radius);font-size:.8rem;font-weight:600;cursor:pointer;transition:all .2s cubic-bezier(.4,0,.2,1);white-space:nowrap}.btn:hover{background:var(--accent-hover);transform:translateY(-1px);box-shadow:0 4px 12px rgba(84,117,64,.2)}.btn-danger{background:var(--danger)}.btn-danger:hover{background:#8a3532}.btn-small{padding:4px 8px;font-size:1rem}.btn-success{background:#2e7d32}.btn-success:hover{background:#1b5e20}.btn-icon{padding:4px 8px;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.15);border:1px solid var(--glass-border);color:var(--accent);min-width:32px;height:32px;border-radius:var(--glass-radius);transition:all .2s cubic-bezier(.4,0,.2,1)}.btn-icon:hover{background:rgba(255,255,255,.3);border-color:var(--accent);color:var(--accent-hover);transform:translateY(-1px)}.star-btn{color:var(--text);font-size:1.4em;cursor:pointer;border:none;background:0 0!important;padding:4px 8px!important;transition:all .2s}.star-btn:hover{transform:scale(1.1)}.starred{color:#fbc02d}.transfer-item{padding:12px;border-radius:var(--glass-radius);margin-top:8px}.progress-bar{height:6px;background:rgba(0,0,0,.1);border-radius:var(--glass-radius);overflow:hidden;margin-top:8px}.progress-fill{height:100%;background:var(--accent);transition:width .3s}.modal{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(253,250,241,.7);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);display:none;z-index:100000;will-change:opacity}.modal-close{padding:0;border:0;background:0 0;font-size:2em;color:#000!important;cursor:pointer;transition:transform .2s}.modal-close:hover{transform:scale(1.1)}.modal-content{margin:0 auto;width:100vw;height:100vh;max-width:none;max-height:none;display:flex;flex-direction:column;overflow:hidden;color:var(--text);background:rgba(255,255,255,.3);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);will-change:transform}.modal-header{display:flex;justify-content:space-between;align-items:center;padding:15px 20px;border-bottom:1px solid var(--glass-border)}.modal-body{padding:20px;overflow-y:auto;flex:1}#previewModal .modal-body,#fileModal .modal-body{background:var(--bg)}#previewModal iframe,#fileModal iframe{display:block;width:100%;height:80vh;border:none;background:#fff;border-radius:var(--glass-radius)}#customModal .modal-content{width:90%!important;max-width:400px!important;height:auto!important;margin:50vh auto 0!important;transform:translateY(-50%);padding:20px;background:rgba(255,255,255,.4);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-radius:var(--glass-radius);border:1px solid var(--glass-border)}#customModal .modal-content *{text-align:center!important}.modal-buttons button:first-child{margin-right:1em}textarea#fileContent{width:100%;height:300px;color:var(--text);border:1px solid var(--glass-border);border-radius:var(--glass-radius);padding:12px;font-family:'SF Mono',Menlo,Monaco,monospace;font-size:.9rem;line-height:1.5;background:rgba(255,255,255,.2);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px)}textarea#fileContent:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(84,117,64,.1);outline:0}.md-render{color:var(--text);line-height:1.6}.md-render h1{font-size:1.75em;line-height:1.2em}.md-render h2{font-size:1.3em;line-height:1.2em}.md-render h1,.md-render h2{color:var(--accent);border-bottom:1px solid var(--glass-border);padding-bottom:.3em;margin:.5em 0}.md-render code{background:rgba(255,255,255,.15);padding:.2em .4em;border-radius:var(--glass-radius);font-family:monospace}.md-render pre{background:rgba(255,255,255,.15);padding:12px;border-radius:var(--glass-radius);overflow-x:auto;margin:1em 0;border:1px solid var(--glass-border)}.md-render table{border-collapse:collapse;width:100%;margin:1em 0}.md-render th,.md-render td{border:1px solid var(--glass-border);padding:8px 12px}.md-render img{transition:none!important;opacity:.7}.md-render ol,.md-render ul{margin-left:20px}.status-overlay{box-shadow:-10px 0 22px rgba(0,0,0,.3);background:rgba(255,255,255,.2);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);position:fixed;bottom:0;left:0;padding:15px;width:100%;transition:transform .3s ease;transform:translateY(150%);z-index:1100}.status-overlay.visible{transform:translateY(0)}.status-btn{position:absolute;top:10px;right:10px;border:0;background:0 0;font-size:1.2em;cursor:pointer}#fileInput{display:none}#configFilesList .file-card{transition:transform .2s,box-shadow .2s}#configFilesList .file-card:hover{box-shadow:0 4px 12px rgba(0,0,0,.3)}#configFilesList .empty-state{text-align:center;padding:40px;color:rgba(255,255,255,.6);font-size:14px}.btn:hover,.node-card:hover,.file-item:hover{will-change:transform}#favoritesList{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}#favoritesList .file-item{min-width:0}@keyframes fadeIn{from{opacity:0}to{opacity:1}}.directory-actions{display:flex;align-items:center;gap:8px;margin-left:auto}#upload-area{display:none}.chat-broadcast{background:rgba(84,117,64,.15)!important;border-left:3px solid #ff9800!important}.chat-broadcast-mine{border-right:3px solid #ff9800!important;border-left:3px solid #ff9800!important}#messageNode{padding:.5em;font-size:1.1em;border:1px solid var(--glass-border);background:rgba(255,255,255,.2);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);border-radius:var(--glass-radius)}#messageNodeContent{border:1px solid var(--glass-border);min-height:100px;height:100px;max-height:150px;font-size:1.1em;padding:.5em;background:rgba(255,255,255,.1);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);border-radius:var(--glass-radius)}#sendMessage{padding:.5em;font-size:1.1em;border:1px solid var(--glass-border);background:rgba(80,120,80,.3);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);border-radius:var(--glass-radius);color:var(--text)}#chatTargetNode{padding:.5em;border:1px solid var(--glass-border);background:rgba(255,255,255,.2);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);border-radius:var(--glass-radius);color:var(--text)}#chatTargetNode option[value=null]{color:#888;font-style:italic;font-weight:400}.chat-fullscreen{position:fixed!important;top:0!important;left:0!important;right:0!important;bottom:0!important;width:100vw!important;height:100vh!important;max-width:none!important;margin:0!important;padding:20px!important;background:var(--bg-gradient,#1a1a2e)!important;z-index:9999!important;overflow-y:auto!important}.chat-fullscreen summary{position:sticky;top:0;background:inherit;z-index:10}body.chat-fullscreen-active{overflow:hidden}.chat-fullscreen #chatWindow{height:68vh!important}.circular-menu{position:fixed;bottom:1em;right:1em;z-index:999}.circular-menu .floating-btn{display:flex;align-items:center;justify-content:center;width:3.5em;height:3.5em;border-radius:50%;background-color:#c6bbac;box-shadow:0 2px 5px 0 rgba(0,0,0,.26);color:#fff;cursor:pointer;outline:0;text-decoration:none;transition:transform .2s}.circular-menu.active .floating-btn{box-shadow:inset 0 0 3px rgba(0,0,0,.3);background-color:var(--bg);color:var(--text);transform:rotate(45deg)}.circular-menu .floating-btn:active{box-shadow:0 4px 8px 0 rgba(0,0,0,.4)}.circular-menu .floating-btn span{font-size:1.3em;line-height:1;display:inline-block;transition:none}.circular-menu:after{display:block;content:' ';width:3.5em;height:3.5em;border-radius:50%;position:absolute;top:0;right:0;z-index:-2;background-color:#b8ab9a;transition:all .3s ease}.circular-menu.active:after{transform:scale3d(5.5,5.5,1);transition-timing-function:cubic-bezier(.68,1.55,.265,1)}.circular-menu .items-wrapper{padding:0;margin:0}.circular-menu .menu-item{position:absolute;top:.2em;right:.2em;z-index:-1;display:block;text-decoration:none;color:#fff;font-size:1em;width:3em;height:3em;border-radius:50%;text-align:center;line-height:3;transition:transform .3s ease,background .2s ease}.circular-menu .menu-item:hover{cursor:pointer}.circular-menu.active .menu-item{transition-timing-function:cubic-bezier(.175,.885,.32,1.275)}.circular-menu.active .menu-item:nth-child(1){transform:translate3d(1em,-7em,0)}.circular-menu.active .menu-item:nth-child(1):hover{transform:translate3d(1em,-7em,0) scale(1.25)}.circular-menu.active .menu-item:nth-child(2){transform:translate3d(-2em,-6.8em,0)}.circular-menu.active .menu-item:nth-child(2):hover{transform:translate3d(-2em,-6.8em,0) scale(1.25)}.circular-menu.active .menu-item:nth-child(3){transform:translate3d(-5em,-5em,0)}.circular-menu.active .menu-item:nth-child(3):hover{transform:translate3d(-5em,-5em,0) scale(1.25)}.circular-menu.active .menu-item:nth-child(4){transform:translate3d(-6.8em,-2em,0)}.circular-menu.active .menu-item:nth-child(4):hover{transform:translate3d(-6.8em,-2em,0) scale(1.25)}.circular-menu.active .menu-item:nth-child(5){transform:translate3d(-7em,1em,0)}.circular-menu.active .menu-item:nth-child(5):hover{transform:translate3d(-7em,1em,0) scale(1.25)}.switch{position:relative;display:inline-block;width:52px;height:28px}.switch input{opacity:0;width:0;height:0}.slider{position:absolute;cursor:pointer;top:0;left:0;right:0;bottom:0;background-color:#ccc;transition:.3s;border-radius:28px}.slider:before{position:absolute;content:\"\";height:24px;width:24px;left:2px;bottom:2px;background-color:#fff;transition:.3s;border-radius:50%}input:checked+.slider{background-color:#547540}input:checked+.slider:before{transform:translateX(24px)}.reorder-btn-group{display:flex;gap:8px;margin-top:8px;flex-wrap:wrap}.reorder-btn{background:rgba(255,255,255,.15);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);border:1px solid var(--glass-border);padding:6px 12px;border-radius:var(--glass-radius);cursor:pointer;font-size:.8rem;transition:all .2s}.reorder-btn:hover{background:var(--accent);color:#fff;border-color:var(--accent);transform:translateY(-1px)}.isInBeacon{display:inline-flex;align-items:center;justify-content:center;height:28px;margin-right:6px;color:var(--accent);flex-shrink:0;position:absolute;right:0;top:0}.darkmode-overlay{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:500000;transition:opacity .3s ease;display:none}body.darkmode-active .darkmode-overlay{display:block;background:#fff;mix-blend-mode:difference}body.darkmode-active #theTemp span,body.darkmode-active #heapIndicator,body.darkmode-active #modalContent img{filter:invert(1)!important}.circular-menu:after,.circular-menu .floating-btn{background-color:#fff;color:#000;backdrop-filter:blur(1px);}h1,h2{color:var(--bg);text-shadow: 1px 1px 2px #0000008f;}svg{filter:invert(1) !important;}.menu-item svg{filter:invert(1) !important;}.empty-state{color:var(--bg);}btn{color:var(--bg) !important;}.circular-menu.active .floating-btn{background-color:#fff;box-shadow:none;}.modal{background-color:rgb(248 248 248 / 37%);backdrop-filter:blur(6px);.modal-header h2{color:var(--text);}.header summary svg{filter:invert(0) !important}",
  "js": "setTimeout(function(){document.body.style.backgroundAttachment='scroll';document.body.style.backgroundSize='200% auto';document.body.style.animation='bg 240s linear infinite';const s=document.createElement('style');s.textContent='@keyframes bg{0%{background-position:0%}to{background-position:100%}}';document.head.appendChild(s);},350)",
  "target": ""
}