<style>body{padding:0 !important;}.game-container{display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif;background:#faf8ef;border-radius:12px;padding:20px;margin:0;min-height:100vh;box-sizing:border-box}.score-panel{display:flex;justify-content:space-between;width:100%;max-width:400px;margin-bottom:20px;gap:16px}.score-box,.best-box{background:#bbada0;padding:12px 20px;border-radius:8px;text-align:center;flex:1}.score-label{font-size:.8rem;color:#eee4da;letter-spacing:1px}.score-value{font-size:1.8rem;font-weight:700;color:#fff;line-height:1}.grid-container{position:relative;background:#bbada0;border-radius:12px;padding:12px;width:min(85vw,85vh,400px);height:min(85vw,85vh,400px);touch-action:none;overflow:hidden}.grid{position:relative;width:100%;height:100%;display:grid;grid-template-columns:repeat(4,1fr);grid-template-rows:repeat(4,1fr);gap:10px;margin:0!important}.cell{background:#cdc1b4;border-radius:8px}.tile-container{position:absolute;top:12px;left:12px;right:12px;bottom:12px}.tile{position:absolute;background:#eee4da;border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:700;transition:left 0.05s ease,top 0.05s ease,transform 0.1s cubic-bezier(.34,1.56,.64,1),opacity 0.1s ease;z-index:10;box-sizing:border-box;will-change:transform,left,top}.tile.merge-pop{animation:pop .15s cubic-bezier(.34,1.56,.64,1)}@keyframes pop{0%{transform:scale(1)}50%{transform:scale(1.3)}100%{transform:scale(1)}}.tile.new-tile{animation:appear .12s ease-out}@keyframes appear{0%{transform:scale(0);opacity:0}100%{transform:scale(1);opacity:1}}.particle{position:absolute;border-radius:50%;pointer-events:none;z-index:15;animation:particleFly .6s ease-out forwards}@keyframes particleFly{0%{transform:translate(0,0) scale(1);opacity:1}100%{transform:translate(var(--tx),var(--ty)) scale(0);opacity:0}}.tile[data-value="2"]{background:#eee4da;color:#776e65}.tile[data-v