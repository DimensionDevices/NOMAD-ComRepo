{
  "description": "Pin (embed) any website or content in an iframe with customizable height",
  "html": "<details class='section' id='fembedSection'><summary><h2><svg style='position:relative;top:6px' width='24px' height='24px' viewBox='0 0 24 24' fill='none' stroke='var(--text)' stroke-width='2'><rect x='2' y='3' width='20' height='14' rx='2' ry='2'></rect><line x1='8' y1='21' x2='16' y2='21'></line><line x1='12' y1='17' x2='12' y2='21'></line></svg>&nbsp;Pinned</h2></summary><div style='padding:0px;'><div style='display:flex;justify-content:space-between;align-items:center;margin-bottom:15px;'><button onclick='window.openEmbedModal()' class='btn btn-primary' style='padding:8px 16px;background:var(--accent);color:var(--bg);border:none;border-radius:4px;cursor:pointer;font-weight:bold;'>⚙</button></div><div id='iframeContainer' style='width:100%;'><div id='noIframeMessage' style='text-align:center;padding:40px 20px;color:var(--text-dim);border:2px dashed var(--border);border-radius:8px;'><div style='font-size:48px;margin-bottom:10px;'>🖥️</div><p>No content configured yet.</p><p style='font-size:13px;margin-top:5px;'>Click the Configure button above to set up your pinned content.</p></div><iframe id='embeddedFrame' style='display:none;width:100%;border:1px solid var(--border);border-radius:8px;background:var(--bg);' sandbox='allow-scripts allow-same-origin allow-forms allow-popups allow-modals'></iframe></div></div></details><div id='embedModal' style='display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:9999;justify-content:center;align-items:center;'><div style='background:var(--bg);border-radius:12px;padding:25px;max-width:500px;width:90%;max-height:90vh;overflow-y:auto;box-shadow:0 10px 40px rgba(0,0,0,0.3);border:1px solid var(--border);'><h3 style='margin-top:0;color:var(--text);'>⚙</h3><div style='margin-bottom:15px;'><label style='display:block;margin-bottom:5px;color:var(--text-dim);font-size:13px;font-weight:bold;'>Source Type</label><div style='display:flex;gap:10px;'><button onclick='window.setSourceType(\"url\")' id='urlTypeBtn' style='flex:1;padding:8px;background:var(--accent);color:var(--bg);border:none;border-radius:4px;cursor:pointer;font-weight:bold;'>🌐 URL</button><button onclick='window.setSourceType(\"file\")' id='fileTypeBtn' style='flex:1;padding:8px;background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:4px;cursor:pointer;font-weight:bold;'>📁 File</button></div></div><div id='urlInputGroup'><div style='margin-bottom:15px;'><label style='display:block;margin-bottom:5px;color:var(--text-dim);font-size:13px;font-weight:bold;'>URL</label><input type='url' id='embedUrl' placeholder='https://example.com' style='width:100%;background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:8px;'></div></div><div id='fileInputGroup' style='display:none;'><div style='margin-bottom:15px;'><label style='display:block;margin-bottom:5px;color:var(--text-dim);font-size:13px;font-weight:bold;'>Select File</label><select id='fileSelect' style='width:100%;background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:8px;'><option value=''>Loading files...</option></select><div id='fileStatus' style='margin-top:5px;font-size:12px;color:var(--text-dim);'></div></div></div><div style='margin-bottom:15px;'><label style='display:block;margin-bottom:5px;color:var(--text-dim);font-size:13px;font-weight:bold;'>Height (px)</label><input type='number' id='embedHeight' placeholder='400' value='400' min='100' max='2000' style='width:100%;background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:4px;padding:8px;'></div><div style='display:flex;gap:10px;flex-wrap:wrap;'><button onclick='window.saveEmbedConfig()' class='btn btn-primary' style='flex:1;padding:10px;background:var(--accent);color:var(--bg);border:none;border-radius:4px;cursor:pointer;font-weight:bold;min-width:80px;'>💾 Save</button><button onclick='window.removeEmbed()' style='flex:1;padding:10px;background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:4px;cursor:pointer;min-width:80px;'>🗑️ Remove</button><button onclick='window.closeEmbedModal()' style='flex:1;padding:10px;background:var(--surface);color:var(--text);border:1px solid var(--border);border-radius:4px;cursor:pointer;min-width:80px;'>Cancel</button></div></div></div>",
  "css": "#iframeContainer { position:relative; } #embeddedFrame { transition: height 0.3s ease; } .embed-controls { display:flex; gap:10px; flex-wrap:wrap; } .source-btn-active { background:var(--accent) !important; color:var(--bg) !important; border:none !important; } .source-btn-inactive { background:var(--surface) !important; color:var(--text) !important; border:1px solid var(--border) !important; }",
  "js": "var embedConfig = JSON.parse(localStorage.getItem('fembedConfig') || 'null');var fileList = [];var sourceType = 'url';function loadEmbedConfig() { if (embedConfig) { var iframe = document.getElementById('embeddedFrame'); var noMsg = document.getElementById('noIframeMessage'); if (embedConfig.url && embedConfig.url.trim()) { iframe.src = embedConfig.url; iframe.style.display = 'block'; iframe.style.height = (embedConfig.height || 400) + 'px'; if (noMsg) noMsg.style.display = 'none'; } else { iframe.style.display = 'none'; if (noMsg) noMsg.style.display = 'block'; } } }window.openEmbedModal = function() { var urlInput = document.getElementById('embedUrl'); var heightInput = document.getElementById('embedHeight'); var fileSelect = document.getElementById('fileSelect'); if (embedConfig) { urlInput.value = embedConfig.url || ''; heightInput.value = embedConfig.height || 400; if (embedConfig.sourceType === 'file') { window.setSourceType('file'); var found = false; for (var i = 0; i < fileSelect.options.length; i++) { if (fileSelect.options[i].value === embedConfig.url) { fileSelect.selectedIndex = i; found = true; break; } } } else { window.setSourceType('url'); } } else { urlInput.value = ''; heightInput.value = 400; window.setSourceType('url'); } document.getElementById('embedModal').style.display = 'flex'; fetchFiles(); };window.closeEmbedModal = function() { document.getElementById('embedModal').style.display = 'none'; };window.setSourceType = function(type) { sourceType = type; var urlGroup = document.getElementById('urlInputGroup'); var fileGroup = document.getElementById('fileInputGroup'); var urlBtn = document.getElementById('urlTypeBtn'); var fileBtn = document.getElementById('fileTypeBtn'); if (type === 'url') { urlGroup.style.display = 'block'; fileGroup.style.display = 'none'; urlBtn.className = 'source-btn-active'; fileBtn.className = 'source-btn-inactive'; } else { urlGroup.style.display = 'none'; fileGroup.style.display = 'block'; urlBtn.className = 'source-btn-inactive'; fileBtn.className = 'source-btn-active'; } };function fetchFiles() { var fileSelect = document.getElementById('fileSelect'); var fileStatus = document.getElementById('fileStatus'); fileStatus.textContent = 'Loading files...'; fetch('/api/files').then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); }).then(function(data) { fileList = data.files || []; fileSelect.innerHTML = '<option value=\"\">Select a file...</option>'; var hasFiles = false; fileList.forEach(function(file) { if (file.name) { var option = document.createElement('option'); option.value = file.name; option.textContent = file.name + ' (' + (file.size || 0) + ' bytes)'; fileSelect.appendChild(option); hasFiles = true; } }); if (!hasFiles) { fileSelect.innerHTML = '<option value=\"\">No files available</option>'; fileStatus.textContent = 'No files found on device'; } else { fileStatus.textContent = 'Loaded ' + fileList.length + ' files'; } if (embedConfig && embedConfig.sourceType === 'file' && embedConfig.url) { for (var i = 0; i < fileSelect.options.length; i++) { if (fileSelect.options[i].value === embedConfig.url) { fileSelect.selectedIndex = i; break; } } } }).catch(function(err) { console.error('Error fetching files:', err); fileSelect.innerHTML = '<option value=\"\">Error loading files</option>'; fileStatus.textContent = 'Error: Could not load file list'; }); }window.saveEmbedConfig = function() { var urlInput = document.getElementById('embedUrl'); var heightInput = document.getElementById('embedHeight'); var fileSelect = document.getElementById('fileSelect'); var height = parseInt(heightInput.value) || 400; var targetUrl = ''; if (sourceType === 'url') { targetUrl = urlInput.value.trim(); if (!targetUrl) { alert('Please enter a valid URL.'); return; } } else { var selectedFile = fileSelect.value; if (!selectedFile) { alert('Please select a file from the list.'); return; } targetUrl = '/view?file=' + encodeURIComponent(selectedFile); } if (height < 100) { alert('Height must be at least 100px.'); return; } if (height > 2000) { alert('Height cannot exceed 2000px.'); return; } embedConfig = { url: targetUrl, height: height, sourceType: sourceType, fileName: (sourceType === 'file' ? fileSelect.value : null) }; localStorage.setItem('fembedConfig', JSON.stringify(embedConfig)); var iframe = document.getElementById('embeddedFrame'); var noMsg = document.getElementById('noIframeMessage'); iframe.src = targetUrl; iframe.style.display = 'block'; iframe.style.height = height + 'px'; if (noMsg) noMsg.style.display = 'none'; window.closeEmbedModal(); };window.removeEmbed = function() { if (confirm('Remove embedded content?')) { embedConfig = null; localStorage.removeItem('fembedConfig'); var iframe = document.getElementById('embeddedFrame'); var noMsg = document.getElementById('noIframeMessage'); iframe.src = ''; iframe.style.display = 'none'; if (noMsg) noMsg.style.display = 'block'; window.closeEmbedModal(); } };function initEmbed() { loadEmbedConfig(); }if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', initEmbed); } else { initEmbed(); }document.addEventListener('click', function(e) { var modal = document.getElementById('embedModal'); if (e.target === modal) { window.closeEmbedModal(); } });",
  "target": "footer"
}