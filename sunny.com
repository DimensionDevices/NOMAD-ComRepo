<style>*{margin:0;padding:0;box-sizing:border-box;font-family:'Segoe UI',Roboto,system-ui,-apple-system,sans-serif}html,body{height:100%;overflow:hidden;background:#0a101d}body{display:flex;justify-content:center;align-items:center;background:#0a101d;padding:0}.c{background:linear-gradient(145deg,#101b2e,#070d18);width:100%;max-width:480px;height:100vh;max-height:820px;display:flex;flex-direction:column;box-shadow:none;border:0;border-radius:0;margin:0 auto;padding:14px 18px 12px;position:relative}.c::after{content:'';position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse at 20% 20%,rgba(255,215,100,0.07)0%,transparent 60%)}.h{display:flex;justify-content:space-between;align-items:center;padding-bottom:10px;border-bottom:1px solid rgba(255,215,120,0.08);flex-shrink:0;position:relative;z-index:2}.h h1{font-weight:300;font-size:1.3rem;letter-spacing:1px;color:#eef4fc;display:flex;align-items:center;gap:8px}.h h1 .si{display:inline-block;width:26px;height:26px;background:radial-gradient(circle at 30% 30%,#fce47a,#e8a817);border-radius:50%;box-shadow:0 0 28px rgba(249,217,118,0.25);flex-shrink:0}.h .b{font-size:0.65rem;color:rgba(200,215,240,0.25);letter-spacing:0.8px;font-weight:300}.s{width:85%;background:rgba(255,255,255,0.05);border-radius:60px;padding:3px;border:1px solid rgba(255,215,100,0.08);transition:0.2s;flex-shrink:0;margin-top:8px;backdrop-filter:blur(4px);position:relative;z-index:2}.s:focus-within{background:rgba(255,255,255,0.08);border-color:#f9d976;box-shadow:0 0 0 3px rgba(249,217,118,0.12)}.s input{width:65%;flex:1;background:transparent;border:none;padding:12px 18px;font-size:0.95rem;color:#f0f7ff;outline:none;min-width:0;font-weight:300;letter-spacing:0.2px}.s input::placeholder{color:rgba(200,215,240,0.3);font-weight:300;letter-spacing:0.4px;font-size:0.85rem}.s button{float:right;background:#f9d976;border:none;border-radius:60px;padding:10px 22px;font-weight:600;font-size:0.85rem;color:#0b1a2e;cursor:pointer;transition:0.15s;display:flex;align-items:center;gap:6px;letter-spacing:0.4px;flex-shrink:0;box-shadow:0 4px 12px rgba(249,217,118,0.15)}.s button:active{transform:scale(0.95)}.w{flex:1;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:4px 0;min-height:0;position:relative;z-index:2;width:100%}.wc{display:flex;flex-direction:column;align-items:center;justify-content:center;width:100%;flex:1;gap:1px}.cr{display:flex;align-items:baseline;justify-content:center;gap:8px;flex-wrap:wrap;margin-bottom:0px;width:100%}.cn{font-size:1.9rem;font-weight:500;color:#eef6ff;letter-spacing:-0.5px;text-shadow:0 2px 12px rgba(0,0,0,0.3);text-align:center}.cn .cy{font-size:0.8rem;font-weight:300;color:rgba(182,208,232,0.5);background:rgba(255,255,255,0.04);padding:2px 14px;border-radius:40px;margin-left:6px;border:1px solid rgba(255,255,255,0.04)}.wm{display:flex;align-items:center;justify-content:center;gap:16px;margin:2px 0 0px;width:100%}.wi{width:68px;height:68px;flex-shrink:0;display:flex;align-items:center;justify-content:center;filter:drop-shadow(0 6px 18px rgba(0,0,0,0.5))}.wi svg{width:64px;height:64px}.tg{display:flex;align-items:baseline;gap:2px}.t{font-size:3.8rem;font-weight:300;color:#eef6ff;letter-spacing:-2px;line-height:1;text-shadow:0 2px 16px rgba(0,0,0,0.2)}.t .dg{font-size:1.8rem;font-weight:300;color:rgba(255,255,255,0.4);margin-left:2px}.d{margin:2px 0 4px;font-size:1rem;text-transform:capitalize;color:rgba(220,235,255,0.7);background:rgba(255,215,100,0.06);padding:4px 24px;border-radius:60px;display:inline-block;border:1px solid rgba(255,215,100,0.08);backdrop-filter:blur(4px);letter-spacing:0.2px;font-weight:300;text-align:center}.e{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-top:auto;background:rgba(0,0,0,0.25);border-radius:16px;padding:10px 6px;backdrop-filter:blur(6px);border:1px solid rgba(255,215,100,0.04);flex-shrink:0;margin-bottom:0px;width:100%}.di{text-align:center;display:flex;flex-direction:column;align-items:center;gap:1px}.di .iw{width:24px;height:24px;display:flex;align-items:center;justify-content:center;margin-bottom:1px;opacity:0.8}.di .iw svg{width:18px;height:18px;fill:none;stroke:#f9d976;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;filter:drop-shadow(0 0 6px rgba(249,217,118,0.1))}.di .l{font-size:0.5rem;text-transform:uppercase;letter-spacing:0.6px;color:rgba(170,195,219,0.45);font-weight:400}.di .v{font-size:0.9rem;font-weight:500;color:#eef6ff;line-height:1.2;letter-spacing:-0.1px}.e2{background:rgba(255,70,70,0.12);border-left:3px solid #ff6b6b;padding:8px 14px;border-radius:14px;margin:6px 0 2px;color:#ffd6d6;font-weight:300;font-size:0.85rem;display:none;backdrop-filter:blur(4px);flex-shrink:0;align-items:center;gap:8px;width:100%}.e2.s{display:flex}.l{text-align:center;color:rgba(182,208,232,0.5);font-weight:300;padding:4px 0;font-size:0.85rem;display:none;flex-shrink:0;letter-spacing:0.3px;width:100%}.l.s{display:block}.l .sp{display:inline-block;width:20px;height:20px;border:2px solid rgba(255,255,255,0.06);border-top:2px solid #f9d976;border-radius:50%;animation:spin 0.7s linear infinite;vertical-align:middle;margin-right:10px}@keyframes spin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}.f{text-align:center;font-size:0.5rem;color:rgba(255,255,255,0.08);letter-spacing:0.8px;padding-top:6px;flex-shrink:0;margin-top:0px}.fa{transition:all 0.1s ease}.st{display:flex;justify-content:space-around;width:100%;margin:2px 0;gap:8px;flex-shrink:0}.si{display:flex;align-items:center;gap:6px;background:rgba(0,0,0,0.15);padding:2px 12px;border-radius:20px;border:1px solid rgba(255,215,100,0.04)}.si .sii{font-size:0.9rem;opacity:0.6}.si .sit{font-size:0.7rem;color:rgba(220,235,255,0.6);font-weight:300;letter-spacing:0.3px}.wm2{display:flex;justify-content:space-between;width:100%;padding:0 4px;flex-shrink:0;gap:4px}.mi{color:rgba(170,195,219,0.3);letter-spacing:0.3px;font-weight:300}.mi span{color:rgba(200,215,240,0.5)}@media(max-height:640px){.c{padding:10px 14px 8px;max-height:100%}.cn{font-size:1.5rem}.t{font-size:3rem}.t .dg{font-size:1.4rem}.wi{width:54px;height:54px}.wi svg{width:50px;height:50px}.e{padding:8px 4px;gap:4px}.di .v{font-size:0.8rem}.s input{padding:8px 14px;font-size:0.8rem}.s button{padding:8px 16px;font-size:0.8rem}.s{margin-top:-3px}.d{font-size:0.85rem;padding:3px 18px}.di .l{font-size:0.45rem}.si .sit{font-size:0.6rem}.si .sii{font-size:0.75rem}}@media(max-height:500px){.c{padding:6px 10px 6px}.cn{font-size:1.2rem}.t{font-size:2.4rem}.t .dg{font-size:1.1rem}.wi{width:44px;height:44px}.wi svg{width:40px;height:40px}.e{gap:3px;padding:5px 3px}.di .v{font-size:0.7rem}.s input{padding:6px 10px;font-size:0.7rem}.s button{padding:5px 12px;font-size:0.7rem}.s{margin-top:-3px}.d{font-size:0.7rem;padding:2px 14px}.wm{gap:8px}.di .l{font-size:0.4rem}.si .sit{font-size:1.25rem}.si .sii{font-size:0.65rem}}
</style>
<div class="c"><div class="s"><input type="text" id="i" placeholder="City name, e.g. London" value="London"><button id="b"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>Search</button></div><div id="l2" class="l"><span class="sp"></span>Loading weather...</div><div id="e3" class="e2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ff6b6b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><span id="et">City not found</span></div><div id="w2" class="w"><div id="wc2" class="wc"><div class="cr"><span class="cn" id="cn2">London<span class="cy" id="cy2">GB</span></span></div><div class="wm"><div class="wi" id="wi2"><svg viewBox="0 0 64 64" fill="none" stroke="#eef6ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="32" cy="32" r="14" fill="#f9d976" stroke="none"/><circle cx="32" cy="32" r="18" stroke="#f9d976" stroke-width="1.8" fill="none" opacity="0.3"/><path d="M32 6 L32 14 M32 50 L32 58 M6 32 L14 32 M50 32 L58 32 M12 12 L18 18 M46 46 L52 52 M12 52 L18 46 M46 18 L52 12" stroke="#f9d976" stroke-width="2" opacity="0.5"/></svg></div><div class="tg"><span class="t" id="t2">12<span class="dg">°C</span></span></div></div><div class="d" id="d2">overcast clouds</div></div><div class="st"><div class="si"><span class="sii">🌅</span><span class="sit" id="sit2">--:--</span></div><div class="si"><span class="sii">🌇</span><span class="sit" id="sit3">--:--</span></div></div><div class="e"><div class="di"><div class="iw"><svg viewBox="0 0 24 24"><path d="M12 2v6M12 16v6"/><path d="M4 12h6M14 12h6"/><circle cx="12" cy="12" r="3" fill="#f9d976" stroke="none"/><circle cx="12" cy="12" r="8" stroke="#f9d976" stroke-width="1.5" fill=