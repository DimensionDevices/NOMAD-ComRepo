{
  "html": "<details class='section' id='networkDetails'>\n  <summary>\n    <h2>\n      <svg style='position:relative;top:6px' width='24px' height='24px' viewBox='0 0 24 24' fill='none' stroke='var(--text)' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>\n        <path d='M5 12.55a11 11 0 0 1 14.08 0'></path>\n        <path d='M1.42 9a16 16 0 0 1 21.16 0'></path>\n        <path d='M8.53 16.11a6 6 0 0 1 6.94 0'></path>\n        <line x1='12' y1='20' x2='12.01' y2='20'></line>\n      </svg>\n      &nbsp;Network\n    </h2>\n  </summary>\n  <div style='padding:12px 0;'>\n    <div style='display:grid;grid-template-columns:1fr 1fr;gap:10px;'>\n      <div style='background:var(--bg);border-radius:8px;padding:12px;border:1px solid var(--border);'>\n        <div style='font-size:0.7rem;opacity:0.7;'>WiFi</div>\n        <div id='netWifi' style='font-size:1.1rem;font-weight:bold;'>--</div>\n      </div>\n      <div style='background:var(--bg);border-radius:8px;padding:12px;border:1px solid var(--border);'>\n        <div style='font-size:0.7rem;opacity:0.7;'>Signal</div>\n        <div id='netSignal' style='font-size:1.1rem;font-weight:bold;'>--</div>\n      </div>\n      <div style='background:var(--bg);border-radius:8px;padding:12px;border:1px solid var(--border);'>\n        <div style='font-size:0.7rem;opacity:0.7;'>IP Address</div>\n        <div id='netIP' style='font-size:0.85rem;font-weight:bold;word-break:break-all;'>--</div>\n      </div>\n      <div style='background:var(--bg);border-radius:8px;padding:12px;border:1px solid var(--border);'>\n        <div style='font-size:0.7rem;opacity:0.7;'>mDNS</div>\n        <div id='netMDNS' style='font-size:0.85rem;font-weight:bold;'>--</div>\n      </div>\n    </div>\n  </div>\n</details>",

  "css": "",
  "js": "function updateNetwork(){var e=document.getElementById('netWifi');var t=document.getElementById('netSignal');var n=document.getElementById('netIP');var o=document.getElementById('netMDNS');fetch('/api/status').then(function(e){return e.json()}).then(function(l){if(e){e.textContent=l.staIP&&l.staIP!=='0.0.0.0'?'Connected':'AP Only'}if(t){t.textContent=l.staIP&&l.staIP!=='0.0.0.0'?'Good':'N/A'}if(n){n.textContent=l.staIP||l.apIP||'--'}if(o){o.textContent=window.location.hostname||'--'}})['catch'](function(e){})}setInterval(updateNetwork,10000);if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',updateNetwork)}else{updateNetwork()}",

  "target": "header"
}