{
  "description": "System Lockdown - Fully dynamic DOM destruction protocol",
  "html": "<details class='section' id='lockdownExtension'><summary><h2><svg style='position:relative;top:6px' width='24px' height='24px' viewBox='0 0 24 24' fill='none' stroke='var(--text)' stroke-width='2'><rect x='3' y='11' width='18' height='11' rx='2' ry='2'></rect><path d='M7 11V7a5 5 0 0 1 10 0v4'></path></svg>&nbsp;System Lockdown</h2></summary><div style='padding:15px;text-align:center;'><p style='color:var(--text-dim);font-family:monospace;font-size:0.85em;'>⚠️ SECURITY PROTOCOL 0x7F: LOCKDOWN ACTIVE</p><div style='background:var(--surface);padding:12px;border-radius:4px;border:1px solid var(--danger);margin-top:10px;'><span style='color:var(--danger);font-family:monospace;font-size:0.9em;'>STATUS: DESTRUCTIVE LOCKDOWN</span></div></div></details>",
  "css": "",
  "js": "(function(){console.log('⚠️ SECURITY PROTOCOL 0x7F: INITIATING DYNAMIC LOCKDOWN...');console.log('⚠️ INJECTING LOCKDOWN ASSETS...');var lockdownCSS=document.createElement('style');lockdownCSS.id='lockdownStyles';lockdownCSS.textContent='#lockdownOverlay{position:fixed;top:0;left:0;width:100vw;height:100vh;background:var(--bg);z-index:99999;display:flex;align-items:center;justify-content:center;flex-direction:column;font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif;pointer-events:all;}#lockdownOverlay .lockdown-content{text-align:center;padding:40px;max-width:600px;width:90%;position:relative;z-index:2;}#lockdownOverlay .nomad-title-tech{font-size:3em;font-weight:800;color:var(--text);letter-spacing:4px;margin-bottom:5px;text-transform:uppercase;}#lockdownOverlay .nomad-sub{font-size:0.8em;color:var(--text-dim);letter-spacing:1px;margin-bottom:30px;text-transform:uppercase;font-weight:500;}#lockdownOverlay .cursor-blink{display:inline-block;width:8px;height:1.2em;background:var(--danger);margin-left:4px;animation:blink 1s step-end infinite;vertical-align:text-bottom;}#lockdownOverlay .vignette{position:fixed;top:0;left:0;width:100%;height:100%;background:radial-gradient(ellipse at center,transparent 60%,rgba(0,0,0,0.1) 100%);pointer-events:none;z-index:0;}#lockdownOverlay::after{content:\"\";position:fixed;top:0;left:0;width:100%;height:100%;background:repeating-linear-gradient(0deg,transparent 0px,transparent 2px,rgba(0,0,0,0.02) 2px,rgba(0,0,0,0.02) 4px);pointer-events:none;z-index:1;}@keyframes blink{0%,100%{opacity:1;}50%{opacity:0;}}';document.head.appendChild(lockdownCSS);console.log('✅ CSS injected');var overlayHTML='<div class=\"vignette\"></div><div class=\"lockdown-content\"><div class=\"nomad-title-tech\">NOMAD</div><div class=\"nomad-sub\">Network for Open Messaging and Data<br><br><sup>[ Lockdown Sequence Active ]</sup></div></div>';var overlay=document.createElement('div');overlay.id='lockdownOverlay';overlay.innerHTML=overlayHTML;document.body.appendChild(overlay);console.log('✅ Lockdown overlay created and added to DOM');function purgeDOM(){var removed=0;var children=document.body.childNodes;var toRemove=[];for(var i=0;i<children.length;i++){var node=children[i];if(node.nodeType===1){if(node.id!=='lockdownOverlay'){toRemove.push(node);}}}for(var j=0;j<toRemove.length;j++){var el=toRemove[j];try{if(el.parentNode){el.parentNode.removeChild(el);removed++;}}catch(e){}}var headElements=document.head.querySelectorAll('script, link, style');for(var k=0;k<headElements.length;k++){try{if(headElements[k].parentNode&&headElements[k].id!=='lockdownStyles'){headElements[k].parentNode.removeChild(headElements[k]);removed++;}}catch(e){}}console.log('🗑️ Removed '+removed+' DOM elements');return removed;}var totalRemoved=purgeDOM();console.log('✅ Initial purge complete: '+totalRemoved+' elements removed');var observer=new MutationObserver(function(mutations){var removed=0;mutations.forEach(function(mutation){if(mutation.type==='childList'&&mutation.addedNodes.length>0){for(var i=0;i<mutation.addedNodes.length;i++){var node=mutation.addedNodes[i];if(node.nodeType===1&&node.id!=='lockdownOverlay'){try{if(node.parentNode){node.parentNode.removeChild(node);removed++;}}catch(e){}}}}});if(removed>0){console.log('🗑️ Removed '+removed+' new elements');}});observer.observe(document.documentElement,{childList:true,subtree:true});function blockAll(e){e.preventDefault();e.stopPropagation();return false;}var events=['keydown','keyup','keypress','click','mousedown','mouseup','contextmenu','touchstart','touchend','touchmove','scroll','wheel','focus','blur','select','change','submit'];for(var i=0;i<events.length;i++){document.addEventListener(events[i],blockAll,true);window.addEventListener(events[i],blockAll,true);}window.scrollTo(0,0);document.body.style.overflow='hidden';document.documentElement.style.overflow='hidden';setInterval(function(){var scripts=document.querySelectorAll('script:not([data-keep])');for(var i=0;i<scripts.length;i++){try{if(scripts[i].parentNode&&scripts[i].id!=='lockdownOverlay'&&scripts[i].id!=='lockdownStyles'){scripts[i].parentNode.removeChild(scripts[i]);}}catch(e){}}var styles=document.querySelectorAll('style:not([data-keep])');for(var j=0;j<styles.length;j++){try{if(styles[j].parentNode&&styles[j].id!=='lockdownOverlay'&&styles[j].id!=='lockdownStyles'){styles[j].parentNode.removeChild(styles[j]);}}catch(e){}}},100);console.log('🔒 DESTRUCTIVE LOCKDOWN ACTIVE - All assets injected, DOM purged');console.log('⚠️ This extension injected CSS + HTML via JavaScript, then removed everything else');})();"
}