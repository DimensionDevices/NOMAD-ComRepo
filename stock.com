PAGE: Stock Manager
COLOR: #1e293b
AUTHOR: NOMAD User
DATE: 2026-06-23
DESCRIPTION: Professional inventory manager – sharp, minimal, dense

STYLE-START
*{box-sizing:border-box;margin:0;padding:0}body{background:#f1f5f9;font-family:system-ui,-apple-system,'Segoe UI',Roboto,sans-serif;padding:10px 8px 80px;color:#0f172a;min-height:100vh}.app-card{max-width:720px;margin:0 auto;background:#ffffff;border-radius:0;box-shadow:0 1px 3px rgba(0,0,0,.04);padding:12px 12px 20px}.bigheader{font-size:24px;font-weight:600;letter-spacing:-.3px;color:#0f172a;display:flex;align-items:center;gap:8px;margin-bottom:6px}.divider{height:1px;background:#e2e8f0;margin:12px 0}.header{font-size:14px;font-weight:600;color:#1e293b;margin-bottom:6px;display:flex;align-items:center;gap:6px;text-transform:uppercase;letter-spacing:.3px}.summary-grid{display:flex;gap:10px;flex-wrap:wrap;background:#f8fafc;padding:8px 12px;border:1px solid #e2e8f0;margin-bottom:4px}.summary-item{font-size:13px;font-weight:500}.summary-item strong{color:#1e293b;font-weight:600}.summary-item span{color:#0f172a;font-weight:600;margin-left:4px}.toast-container{position:fixed;top:10px;left:50%;transform:translateX(-50%);width:92%;max-width:400px;z-index:9999;display:flex;flex-direction:column;gap:6px;pointer-events:none}.toast{pointer-events:auto;padding:10px 16px;border-radius:0;font-weight:500;font-size:14px;color:#fff;box-shadow:0 4px 12px rgba(0,0,0,.10);animation:slideDown 0.2s ease;display:flex;align-items:center;gap:8px;border-left:4px solid rgba(255,255,255,.3)}.toast.success{background:#10b981}.toast.warning{background:#f59e0b}.toast.error{background:#ef4444}.toast.info{background:#3b82f6}@keyframes slideDown{0%{opacity:0;transform:translateY(-16px)}100%{opacity:1;transform:translateY(0)}}.search-box{width:100%;padding:8px 12px;border:1px solid #e2e8f0;font-size:14px;background:#fff;margin-bottom:6px;transition:0.1s}.search-box:focus{border-color:#0f172a;outline:none;box-shadow:0 0 0 2px rgba(15,23,42,.08)}.card-grid{display:flex;flex-direction:column;gap:6px;margin:4px 0 2px}.inventory-card{background:#ffffff;border:1px solid #e2e8f0;padding:8px 12px;display:flex;flex-wrap:wrap;align-items:center;gap:6px 12px;transition:0.1s}.inventory-card .item-name{font-weight:600;font-size:15px;color:#0f172a;display:flex;align-items:center;gap:6px;min-width:100px}.inventory-card .loc-badge{font-size:12px;background:#f1f5f9;padding:1px 10px;color:#475569;border:1px solid #e2e8f0;font-weight:500;white-space:nowrap}.inventory-card .qty-section{display:flex;align-items:center;gap:4px;flex-wrap:wrap;margin-left:auto}.inventory-card .qty-section>span{font-size:12px;font-weight:500;color:#64748b;margin-right:2px}.inventory-card .qty-input{width:48px;padding:4px 2px;border:1px solid #cbd5e1;border-radius:0;text-align:center;font-weight:600;font-size:14px;background:#fff;transition:0.1s;height:28px}.inventory-card .qty-input:focus{border-color:#0f172a;outline:none;box-shadow:0 0 0 2px rgba(15,23,42,.1)}.inventory-card .qty-actions{display:flex;gap:2px}.inventory-card .qty-btn{background:#f1f5f9;border:1px solid #e2e8f0;border-radius:0;width:26px;height:26px;font-size:13px;font-weight:600;color:#1e293b;display:inline-flex;align-items:center;justify-content:center;cursor:pointer;transition:0.05s;line-height:1}.inventory-card .qty-btn:active{background:#e2e8f0;transform:none}.inventory-card .status-badge{display:inline-block;padding:2px 10px;font-size:12px;font-weight:600;background:#f1f5f9;color:#1e293b;border:1px solid #e2e8f0;white-space:nowrap}.inventory-card .status-badge.low{background:#fef2f2;color:#b91c1c;border-color:#fecaca}.inventory-card .status-badge.ok{background:#ecfdf5;color:#065f46;border-color:#a7f3d0}.inventory-card .delete-btn{background:#fee2e2;border:1px solid #fecaca;border-radius:0;width:26px;height:26px;font-size:14px;font-weight:700;color:#b91c1c;display:inline-flex;align-items:center;justify-content:center;cursor:pointer;transition:0.05s;line-height:1;margin-left:2px}.inventory-card .delete-btn:active{background:#fecaca;transform:none}.empty-state{text-align:center;padding:28px 10px;color:#94a3b8;font-weight:500;background:#f8fafc;border:1px solid #e2e8f0;font-size:14px}.empty-state i{font-size:24px;opacity:0.5;display:block;margin-bottom:6px}.fab{position:fixed;bottom:18px;right:18px;width:52px;height:52px;border-radius:0;background:#0f172a;border:1px solid #1e293b;color:#fff;font-size:28px;font-weight:300;box-shadow:0 4px 12px rgba(0,0,0,.12);cursor:pointer;transition:0.1s;display:flex;align-items:center;justify-content:center;z-index:1000;touch-action:manipulation}.fab:active{background:#1e293b;transform:scale(.96)}.modal-overlay{position:fixed;inset:0;background:rgba(15,23,42,.4);display:flex;align-items:center;justify-content:center;z-index:2000;padding:16px;opacity:0;visibility:hidden;transition:0.15s}.modal-overlay.active{opacity:1;visibility:visible}.modal-card{background:#fff;max-width:380px;width:100%;padding:24px 20px 28px;box-shadow:0 20px 40px rgba(0,0,0,.15);transform:scale(.96);transition:0.15s;border:1px solid #e2e8f0}.modal-overlay.active .modal-card{transform:scale(1)}.modal-card h2{font-weight:600;font-size:18px;margin-bottom:16px;color:#0f172a;display:flex;align-items:center;gap:8px}.modal-field{margin-bottom:14px}.modal-field label{display:block;font-weight:500;font-size:12px;color:#475569;margin-bottom:3px;text-transform:uppercase;letter-spacing:.3px}.modal-field input{width:100%;padding:10px 12px;border:1px solid #cbd5e1;border-radius:0;font-size:15px;background:#fff;transition:0.1s}.modal-field input:focus{border-color:#0f172a;outline:none;box-shadow:0 0 0 2px rgba(15,23,42,.1)}.modal-actions{display:flex;gap:8px;margin-top:18px}.modal-actions button{flex:1;padding:10px 0;border:1px solid #e2e8f0;border-radius:0;font-weight:600;font-size:14px;cursor:pointer;transition:0.05s;background:#fff}.modal-actions .btn-primary{background:#0f172a;color:#fff;border-color:#0f172a}.modal-actions .btn-primary:active{background:#1e293b}.modal-actions .btn-secondary{background:#fff;color:#1e293b}.modal-actions .btn-secondary:active{background:#f1f5f9}.clear-btn{background:#fff;border:1px solid #e2e8f0;padding:6px 16px;font-size:12px;color:#475569;display:inline-flex;align-items:center;gap:6px;cursor:pointer;transition:0.05s;font-weight:500;height:32px}.clear-btn:active{background:#f1f5f9}.settings-row{display:flex;flex-wrap:wrap;gap:6px;margin:2px 0 0}.text-muted{color:#64748b;font-size:13px}.mt-1{margin-top:4px}.mb-1{margin-bottom:4px}@media (max-width:500px){.inventory-card{flex-direction:column;align-items:stretch;gap:6px;padding:10px}.inventory-card .qty-section{margin-left:0;justify-content:space-between}.inventory-card .item-name{min-width:auto}.app-card{padding:10px 6px 16px}.bigheader{font-size:20px}}
#confirmModal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgb(0 0 0 / .5);z-index:1000;justify-content:center;align-items:center}#confirmModal.active{display:flex}#confirmModal .modal-content{background:#fff;padding:2rem;border-radius:12px;max-width:400px;width:90%;box-shadow:0 10px 30px rgb(0 0 0 / .2);animation:slideIn 0.3s ease}@keyframes slideIn{from{transform:translateY(-30px);opacity:0}to{transform:translateY(0);opacity:1}}#confirmModal h2{margin:0 0 .5rem 0;color:#333}#confirmModal p{margin:0 0 1.5rem 0;color:#666}#confirmModal .modal-actions{display:flex;gap:.75rem;justify-content:flex-end}#confirmModal .btn-secondary,#confirmModal .btn-primary{padding:.5rem 1.5rem;border:none;border-radius:6px;font-size:.9rem;cursor:pointer;transition:all 0.2s}#confirmModal .btn-secondary{background:#e0e0e0;color:#333}#confirmModal .btn-secondary:hover{background:#d0d0d0}#confirmModal .btn-primary{background:#dc3545;color:#fff}#confirmModal .btn-primary:hover{background:#c82333}
STYLE-END

CUSTOMHTML-START
<div class="toast-container" id="toastContainer"></div>
<div class="app-card">
  <div class="bigheader">Stock Manager</div>
  <div class="summary-grid">
    <div class="summary-item"><strong>Total:</strong><span id="totalItems">0</span></div>
    <div class="summary-item"><strong>Low:</strong><span id="lowStockCount">0</span></div>
  </div>
  <div class="divider"></div>
  <div class="header">Inventory</div>
  <input type="text" class="search-box" id="searchBox" placeholder="Search items..." autocomplete="off" />
  <div id="cardContainer" class="card-grid"></div>
  <div class="divider"></div>
  <div class="header">Settings</div>
  <div class="settings-row">
    <button class="clear-btn" id="clearAllBtn">Clear All</button>
  </div>
</div>
<button class="fab" id="fabAddBtn">+</button>
<div class="modal-overlay" id="addModal">
  <div class="modal-card">
    <h2>New Item</h2>
    <div class="modal-field"><label>Item name</label><input type="text" id="modalItemName" placeholder="e.g. Notebook" /></div>
    <div class="modal-field"><label>Quantity</label><input type="number" id="modalItemQty" placeholder="0" min="0" value="1" /></div>
    <div class="modal-field"><label>Location (optional)</label><input type="text" id="modalItemLoc" placeholder="Warehouse A" /></div>
    <div class="modal-actions">
      <button class="btn-secondary" id="modalCancelBtn">Cancel</button>
      <button class="btn-primary" id="modalAddBtn">+ Add</button>
    </div>
  </div>
</div>
CUSTOMHTML-END

SCRIPT-START
