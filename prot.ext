{"description":"A basic file scanner to detect potential unwanted actions from .ext files. A new button is added to the bottom of the main screen.","html":"<button class=scan-all-btn id=scanAllBtn><span id=scanBtnText>Scan</span> <span class=badge id=scanBadge>0</span></button><div class=scan-progress id=scanProgress><div style=font-size:.8em;font-weight:600 id=scanStatus>Initializing...</div><div class=bar><div class=bar-fill id=scanBar style=width:0%></div></div><div class=stats><span id=scanCount>0/0</span><span id=scanIssues>⚠️0</span></div><div id=scanResults style=max-height:150px;overflow-y:auto;margin-top:6px></div></div><div class=report-modal id=reportModal><div class=header><h2>🔍 Report</h2><button class=close-btn onclick=\"document.getElementById('reportModal').classList.remove('show')\">✕</button></div><p style='font-size:.7em;padding-bottom:1em;'>This scan checks for potentially unwanted behavior in files - it is <u>not</u> a virus or malware scanner.</p><div class=content id=reportContent></div></div>","css":".scan-all-btn{position:fixed;bottom:20px;right:79px;padding:12px 16px;z-index:999;background:var(--accent);color:#fff;border:none;border-radius:50px;cursor:pointer;font-size:.9em;box-shadow:0 4px 12px rgba(0,0,0,.3);transition:all .3s;display:flex;align-items:center;gap:8px}.scan-all-btn:hover{transform:scale(1.05);box-shadow:0 6px 20px rgba(0,0,0,.4)}.scan-all-btn.scanning{background:#f39c12;animation:pulse 1s infinite;cursor:wait}.scan-all-btn.done{background:#4CAF50}.scan-all-btn .badge{background:rgba(255,255,255,.2);border-radius:50%;padding:2px 8px;font-size:.7em;font-weight:700}.scan-progress{position:fixed;bottom:70px;right:79px;z-index:998;background:#fff;border:1px solid var(--border);border-radius:12px;padding:12px 16px;min-width:250px;max-width:350px;box-shadow:0 4px 20px rgba(0,0,0,.3);display:none}.scan-progress.show{display:block}.scan-progress .bar{background:var(--bg);height:6px;border-radius:3px;overflow:hidden;margin-top:6px}.scan-progress .bar-fill{height:100%;background:linear-gradient(90deg,#4CAF50,#8BC34A);transition:width .3s;border-radius:3px}.scan-progress .stats{display:flex;justify-content:space-between;font-size:.7em;color:var(--text-dim);margin-top:4px}.scan-result-item{padding:2px 0;font-size:.75em;border-bottom:1px solid var(--border);display:flex;justify-content:space-between}.scan-result-item:last-child{border-bottom:none}.scan-result-item .status{font-weight:600}.scan-result-item .status.safe{color:#4CAF50}.scan-result-item .status.warning{color:#FF9800}.scan-result-item .status.danger{color:#F44336}@keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}.report-modal{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:9999;background:#fff;border:1px solid var(--border);border-radius:16px;padding:20px;max-width:90vw;max-height:90vh;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.5);display:none}.report-modal.show{display:block}.report-modal .header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;padding-bottom:12px;border-bottom:2px solid var(--border)}.report-modal .header h2{margin:0;font-size:1.2em}.report-modal .close-btn{background:var(--border);border:none;color:var(--text);padding:4px 12px;border-radius:6px;cursor:pointer;font-size:1.2em}.report-modal .close-btn:hover{background:#f44336;color:#fff}.report-modal .content{overflow-y:auto;max-height:70vh}.report-modal table{width:100%;border-collapse:collapse;font-size:.85em}.report-modal th{background:var(--bg);color:var(--text);padding:8px 12px;text-align:left;border-bottom:2px solid var(--border);position:sticky;top:0;z-index:1}.report-modal td{padding:6px 12px;border-bottom:1px solid var(--border);vertical-align:top}.report-modal .summary{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:16px}.report-modal .summary-item{background:var(--bg);padding:8px 12px;border-radius:8px;text-align:center}.report-modal .summary-item .num{font-size:1.4em;font-weight:700}.report-modal .summary-item .label{font-size:.7em;color:var(--text-dim)}.report-modal .summary-item.danger .num{color:#f44336}.report-modal .summary-item.warning .num{color:#ff9800}.report-modal .summary-item.safe .num{color:#4caf50}.report-modal .status-badge{display:inline-block;padding:2px 10px;border-radius:12px;font-size:.7em;font-weight:600}.report-modal .status-badge.danger{background:#f4433620;color:#f44336}.report-modal .status-badge.warning{background:#ff980020;color:#ff9800}.report-modal .status-badge.safe{background:#4caf5020;color:#4caf50}.report-modal .issues-list{margin:2px 0;padding-left:16px;font-size:.85em}.report-modal .issues-list li{list-style:none;margin:1px 0}.report-modal .issues-list .danger-item{color:#f44336}.report-modal .issues-list .warning-item{color:#ff9800}.report-modal .code-snippet{font-family:monospace;font-size:.7em;background:var(--bg);padding:3px 8px;border-radius:3px;display:block;margin:2px 0;max-width:100%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;border-left:3px solid var(--border)}.report-modal .code-snippet.danger-line{border-left-color:#f44336}.report-modal .code-snippet.warning-line{border-left-color:#ff9800}.report-modal .issue-details{margin-top:2px;padding-left:16px}.report-modal .timestamp{text-align:center;font-size:.7em;color:var(--text-dim);margin-top:12px;padding-top:8px;border-top:1px solid var(--border)}","js":"document.addEventListener('DOMContentLoaded',function(){var s=false,results=[];function b64(b){try{var a=atob(b),c=new Uint8Array(a.length);for(var i=0;i<a.length;i++)c[i]=a.charCodeAt(i);return c}catch(e){return null}}function isGz(b){return b&&b.length>=2&&b[0]===31&&b[1]===139}function decomp(b){return new Promise(function(r,j){try{if(typeof DecompressionStream!=='undefined'){var ds=new DecompressionStream('gzip'),w=ds.writable.getWriter();w.write(b);w.close();var rd=ds.readable.getReader(),chunks=[];function read(){rd.read().then(function(res){if(res.done){var tl=0;chunks.forEach(function(c){tl+=c.length});var m=new Uint8Array(tl),o=0;chunks.forEach(function(c){m.set(c,o);o+=c.length});r(m)}else{chunks.push(res.value);read()}}).catch(j)}read()}else{j(new Error('No DecompressionStream'))}}catch(e){j(e)}})}function dec(b){return new Promise(function(r){try{var bytes=b64(b);if(!bytes){r('');return}if(isGz(bytes)){decomp(bytes).then(function(d){try{r(new TextDecoder('utf-8').decode(d))}catch(e){r('')}}).catch(function(){try{r(new TextDecoder('utf-8').decode(bytes))}catch(e){r('')}})}else{try{r(new TextDecoder('utf-8').decode(bytes))}catch(e){r('')}}}catch(e){r('')}})}function getFile(f){return new Promise(function(r){fetch('/api/view-file?filename='+encodeURIComponent(f)).then(function(resp){if(!resp.ok)return r('');return resp.text()}).then(function(data){if(data&&data.length>0){dec(data).then(function(t){r(t)}).catch(function(){r('')})}else{r('')}}).catch(function(){r('')})})}function findSnippet(c,m){var lines=c.split('\\n');for(var i=0;i<lines.length;i++){if(lines[i].toLowerCase().indexOf(m.toLowerCase())!==-1){var s=Math.max(0,i-1),e=Math.min(lines.length-1,i+1),a=[];for(var j=s;j<=e;j++){a.push((j===i?'> ':'  ')+lines[j].trim())}return a.join('\\n')}}return m}function scan(c){var I=[],W=[],D=[];if(!c||c.length===0)return{I:I,W:W,D:D,H:false,G:false};var C=[{n:'eval()',t:function(c){var m=c.match(/eval\\s*\\(/gi);if(m&&!c.match(/eval\\s*\\(\\s*['\"][^'\"]*['\"]\\s*\\)/gi))return m;return null},se:'danger'},{n:'Function()',t:function(c){return c.match(/new\\s+Function\\s*\\(/gi)},se:'danger'},{n:'setTimeout(string)',t:function(c){var m=c.match(/setTimeout\\s*\\(\\s*['\"][^'\"]*['\"]\\s*\\)/gi);if(m&&!m.some(function(s){return s.includes('function')||s.includes('=>')}))return m;return null},se:'danger'},{n:'setInterval(string)',t:function(c){var m=c.match(/setInterval\\s*\\(\\s*['\"][^'\"]*['\"]\\s*\\)/gi);if(m&&!m.some(function(s){return s.includes('function')||s.includes('=>')}))return m;return null},se:'danger'},{n:'External fetch',t:function(c){var m=c.match(/fetch\\s*\\(\\s*['\"](https?:\\/\\/[^'\"]+)['\"]/gi);if(m){var f=m.filter(function(u){return!u.includes('/api/')&&!u.includes('localhost')&&!u.includes('127.0.0.1')});return f.length>0?f:null}return null},se:'danger'},{n:'XHR external',t:function(c){var m=c.match(/xhr\\.open\\s*\\([^,]+,\\s*['\"]([^'\"]+)['\"]/gi);if(m){var f=m.filter(function(u){return!u.includes('/api/')&&!u.includes('localhost')&&!u.includes('127.0.0.1')});return f.length>0?f:null}return null},se:'danger'},{n:'WebSocket external',t:function(c){var m=c.match(/new\\s+WebSocket\\s*\\(\\s*['\"](wss?:\\/\\/[^'\"]+)['\"]/gi);if(m){var f=m.filter(function(u){return!u.includes('localhost')&&!u.includes('127.0.0.1')});return f.length>0?f:null}return null},se:'danger'},{n:'EventSource external',t:function(c){var m=c.match(/new\\s+EventSource\\s*\\(\\s*['\"](https?:\\/\\/[^'\"]+)['\"]/gi);if(m){var f=m.filter(function(u){return!u.includes('/api/')&&!u.includes('localhost')&&!u.includes('127.0.0.1')});return f.length>0?f:null}return null},se:'danger'},{n:'sendBeacon external',t:function(c){var m=c.match(/navigator\\.sendBeacon\\s*\\(\\s*['\"](https?:\\/\\/[^'\"]+)['\"]/gi);if(m){var f=m.filter(function(u){return!u.includes('/api/')&&!u.includes('localhost')&&!u.includes('127.0.0.1')});return f.length>0?f:null}return null},se:'danger'},{n:'External script',t:function(c){var m=c.match(/<script[^>]*src\\s*=\\s*['\"](https?:\\/\\/[^'\"]+)['\"]/gi);return m?m:null},se:'danger'},{n:'iframe external',t:function(c){var m=c.match(/<iframe[^>]*src\\s*=\\s*['\"](https?:\\/\\/[^'\"]+)['\"]/gi);if(m&&!c.match(/<iframe[^>]*src\\s*=\\s*['\"]\\//gi))return m;return null},se:'danger'},{n:'object/embed external',t:function(c){var m=c.match(/<(object|embed)[^>]*(data|src)\\s*=\\s*['\"](https?:\\/\\/[^'\"]+)['\"]/gi);return m?m:null},se:'danger'},{n:'API call /api/',t:function(c){var m=c.match(/fetch\\s*\\(\\s*['\"](\\/api\\/[^'\"]+)['\"]/gi);if(m){var d=m.filter(function(u){return u.includes('/api/files')||u.includes('/api/delete')||u.includes('/api/upload')||u.includes('/api/rename')||u.includes('/api/move')||u.includes('/api/exec')||u.includes('/api/shell')});return d.length>0?d:null}return null},se:'warning'},{n:'Clipboard access',t:function(c){var m=c.match(/navigator\\.clipboard\\.(readText|writeText|read|write)\\s*\\(/gi)||c.match(/document\\.execCommand\\s*\\(\\s*['\"]copy['\"]\\s*\\)/gi);return m?m:null},se:'warning'},{n:'Screen capture',t:function(c){var m=c.match(/getDisplayMedia\\s*\\(/gi)||c.match(/mediaDevices\\.getDisplayMedia/gi);return m?m:null},se:'danger'},{n:'Camera access',t:function(c){var m=c.match(/getUserMedia\\s*\\(/gi)||c.match(/mediaDevices\\.getUserMedia\\s*\\(/gi);return m?m:null},se:'warning'},{n:'Microphone access',t:function(c){var m=c.match(/getUserMedia\\s*\\(\\s*{[^}]*audio\\s*:\\s*true/gi)||c.match(/mediaDevices\\.getUserMedia\\s*\\(\\s*{[^}]*audio\\s*:\\s*true/gi);return m?m:null},se:'warning'},{n:'atob() decode',t:function(c){var m=c.match(/atob\\s*\\(/gi);if(m&&c.match(/[A-Za-z0-9+\\/]{20,}={0,2}/))return m;return null},se:'warning'},{n:'btoa() encode',t:function(c){var m=c.match(/btoa\\s*\\(/gi);return m?m:null},se:'warning'},{n:'localStorage',t:function(c){var m=c.match(/localStorage\\s*\\.\\s*(setItem|getItem|removeItem|clear)\\s*\\(/gi);return m?m:null},se:'warning'},{n:'sessionStorage',t:function(c){var m=c.match(/sessionStorage\\s*\\.\\s*(setItem|getItem|removeItem|clear)\\s*\\(/gi);return m?m:null},se:'warning'},{n:'document.cookie',t:function(c){var m=c.match(/document\\s*\\.\\s*cookie\\s*=/gi)||c.match(/document\\s*\\.\\s*cookie\\s*[^=]/gi);if(m)return c.match(/document\\s*\\.\\s*cookie/gi);return null},se:'warning'},{n:'Child process',t:function(c){var m=c.match(/(?:child_process|require\\s*\\(\\s*['\"]child_process['\"]\\s*\\))/gi);if(m){var sp=c.match(/\\.(exec|spawn|fork|execFile)\\s*\\(/gi);return sp?m.concat(sp):m}return null},se:'danger'},{n:'fs.writeFile',t:function(c){var m=c.match(/(?:fs\\.writeFile|fs\\.writeFileSync|fs\\.appendFile|fs\\.createWriteStream)\\s*\\(/gi);if(m){var p=c.match(/['\"][^'\"]*['\"]\\s*[,)]/g);if(p){var d=p.some(function(x){return x.includes('..')||x.includes('/etc/')||x.includes('/passwd')||x.includes('/shadow')});if(d)return m}}return null},se:'danger'},{n:'fs.unlink',t:function(c){var m=c.match(/(?:fs\\.unlink|fs\\.unlinkSync|fs\\.rmdir|fs\\.rmSync)\\s*\\(/gi);if(m){var p=c.match(/['\"][^'\"]*['\"]\\s*[,)]/g);if(p){var d=p.some(function(x){return x.includes('..')||x.includes('/etc/')||x.includes('/passwd')||x.includes('/shadow')});if(d)return m}}return null},se:'danger'},{n:'Path traversal',t:function(c){var m=c.match(/(?:readFile|readFileSync|createReadStream|writeFile|unlink|rmdir|exec|spawn)\\s*\\([^)]*\\.\\.\\//gi);return m?m:null},se:'danger'},{n:'Large base64 payload',t:function(c){var m=c.match(/[A-Za-z0-9+\\/]{80,}={0,2}/g);return m&&m.length>0?m:null},se:'warning'},{n:'import/require dangerous modules',t:function(c){var m=c.match(/(?:import\\s+['\"]?(?:child_process|fs|net|http|https|os|vm|util)['\"]?|require\\s*\\(\\s*['\"]?(?:child_process|fs|net|http|https|os|vm|util)['\"]?\\s*\\))/gi);return m?m:null},se:'danger'},{n:'process.env access',t:function(c){var m=c.match(/process\\s*\\.\\s*env\\s*[\\[.]/gi);if(m)return c.match(/process\\s*\\.\\s*env/gi);return null},se:'danger'},{n:'crypto module usage',t:function(c){var m=c.match(/(?:import\\s+['\"]?crypto['\"]?|require\\s*\\(\\s*['\"]?crypto['\"]?\\s*\\)|crypto\\.(?:createHash|createCipher|createDecipher|createSign|createVerify|randomBytes|randomInt|pbkdf2|scrypt)\\s*\\(|new\\s+crypto\\.)/gi);if(m){var d=c.match(/crypto\\.(?:createCipher|createDecipher|createSign|createVerify|randomBytes|randomInt|pbkdf2|scrypt)\\s*\\(/gi);return d?d:m}return null},se:'warning'},{n:'document.domain manipulation',t:function(c){var m=c.match(/document\\s*\\.\\s*domain\\s*=\\s*['\"]/gi);if(m)return c.match(/document\\s*\\.\\s*domain/gi);return null},se:'danger'}];C.forEach(function(ch){var r=ch.t(c);if(r&&r.length>0){var sev=ch.se,label=ch.n,matches=[];if(Array.isArray(r)){var matchStr=r[0];if(matchStr){var snippet=findSnippet(c,matchStr);if(snippet)matches.push({snippet:snippet})}}if(matches.length===0){var simpleMatch=c.match(new RegExp(ch.n.replace(/[.*+?^${}()|[\\]\\\\]/g,'\\\\$&'),'i'));if(simpleMatch){var snippet=findSnippet(c,simpleMatch[0]);if(snippet)matches.push({snippet:snippet})}}if(matches.length===0){var words=ch.n.split(' ');for(var i=0;i<words.length&&matches.length===0;i++){if(words[i].length>3){var snippet=findSnippet(c,words[i]);if(snippet)matches.push({snippet:snippet})}}}D.push({name:label,severity:sev,count:r.length,matches:matches});if(sev==='danger')I.push(label+' (x'+r.length+')');else if(sev==='warning')W.push(label+' (x'+r.length+')')}});return{I:I,W:W,D:D,H:I.length>0,G:W.length>0}}function getFileList(){return new Promise(function(r){fetch('/api/files').then(function(resp){if(!resp.ok)return r([]);return resp.json()}).then(function(data){if(data&&data.files&&Array.isArray(data.files)){var names=data.files.map(function(f){return f.name});r(names)}else{r([])}}).catch(function(){r([])})})}function updProg(cur,tot,st){var p=tot>0?Math.round(cur/tot*100):0;var bar=document.getElementById('scanBar'),cnt=document.getElementById('scanCount'),stEl=document.getElementById('scanStatus');if(bar)bar.style.width=p+'%';if(cnt)cnt.textContent=cur+' / '+tot;if(stEl)stEl.textContent=st}function addRes(fn,res){var el=document.getElementById('scanResults');if(!el)return;var d=document.createElement('div');d.className='scan-result-item';var st='✅ Safe',cls='safe';if(res.H){st='🚨 '+res.I.length;cls='danger'}else if(res.G){st='⚠️ '+res.W.length;cls='warning'}d.innerHTML='<span style=overflow:hidden;text-overflow:ellipsis;max-width:150px;font-size:.7em>'+fn+'</span><span class=status '+cls+'>'+st+'</span>';el.appendChild(d);el.scrollTop=el.scrollHeight}function showReport(){var content=document.getElementById('reportContent'),total=results.length,dangerCount=0,warningCount=0,safeCount=0;results.forEach(function(r){if(r.result.H)dangerCount++;else if(r.result.G)warningCount++;else safeCount++});var html='<div class=summary><div class=summary-item><div class=num>'+total+'</div><div class=label>📁 Total Files</div></div><div class=summary-item danger><div class=num>'+dangerCount+'</div><div class=label>🚨 Critical</div></div><div class=summary-item warning><div class=num>'+warningCount+'</div><div class=label>⚠️ Warnings</div></div><div class=summary-item safe><div class=num>'+safeCount+'</div><div class=label>✅ Safe</div></div></div>';results.sort(function(a,b){if(a.result.H&&!b.result.H)return -1;if(!a.result.H&&b.result.H)return 1;if(a.result.G&&!b.result.G)return -1;if(!a.result.G&&b.result.G)return 1;return 0});if(results.length>0){html+='<table><thead><tr><th style=width:20%>Filename</th><th style=width:12%>Status</th><th style=width:68%>Findings</th></tr></thead><tbody>';results.forEach(function(r){var cls='safe',st='✅ Safe';if(r.result.H){cls='danger';st='🚨 '+r.result.I.length+' issue(s)'}else if(r.result.G){cls='warning';st='⚠️ '+r.result.W.length+' warning(s)'}html+='<tr><td style=font-weight:500;font-size:.85em>'+r.filename+'</td><td><span class=\"status-badge '+cls+'\">'+st+'</span></td><td>';var hasFindings=false;if(r.result.D&&r.result.D.length>0){r.result.D.forEach(function(detail){if(detail.matches&&detail.matches.length>0){hasFindings=true;var lineClass=(detail.severity==='danger')?'danger-line':'warning-line';html+='<div style=margin:4px 0;font-weight:600;>'+detail.name+'</div>';html+='<div class=issue-details>';detail.matches.forEach(function(match){html+='<div class=\"code-snippet '+lineClass+'\">'+escapeHtml(match.snippet)+'</div>'});html+='</div>'}})}if(!hasFindings&&r.result.H){html+='<ul class=issues-list>';r.result.I.forEach(function(i){html+='<li class=danger-item>❌ '+i+'</li>'});html+='</ul>'}if(!hasFindings&&r.result.G&&!r.result.H){html+='<ul class=issues-list>';r.result.W.forEach(function(w){html+='<li class=warning-item>⚠️ '+w+'</li>'});html+='</ul>'}if(!r.result.H&&!r.result.G){html+='<span style=color:#4CAF50;font-size:.85em>✓ No issues detected</span>'}html+='</td></tr>'});html+='</tbody></table>'}else{html+='<div style=text-align:center;padding:30px;color:var(--text-dim)>No files scanned</div>'}html+='<div class=timestamp>Scan completed at '+new Date().toLocaleString()+'</div>';content.innerHTML=html;document.getElementById('reportModal').classList.add('show')}function escapeHtml(str){if(!str)return'';return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;')}function scanAll(){if(s)return;s=true;results=[];var btn=document.getElementById('scanAllBtn'),prog=document.getElementById('scanProgress'),res=document.getElementById('scanResults');if(res)res.innerHTML='';if(btn){btn.classList.add('scanning');document.getElementById('scanBtnText').textContent='Scanning...';document.getElementById('scanBadge').textContent='...'}if(prog)prog.classList.add('show');getFileList().then(function(files){if(files.length===0){alert('No files found');reset();return}var total=files.length,cur=0,totIssues=0,totWarnings=0;updProg(0,total,'Starting...');files.forEach(function(fn,idx){setTimeout(function(){getFile(fn).then(function(c){cur++;var res=scan(c);if(res.H)totIssues++;if(res.G)totWarnings++;results.push({filename:fn,result:res});addRes(fn,res);updProg(cur,total,'Scanning: '+fn);var el=document.getElementById('scanIssues');if(el)el.textContent='⚠️ '+(totIssues+totWarnings);if(cur===total){setTimeout(function(){showReport();reset()},500)}}).catch(function(){cur++;updProg(cur,total,'Error: '+fn);addRes(fn,{I:[],W:[],D:[],H:false,G:false});if(cur===total){showReport();reset()}})},idx*300)})}).catch(function(){alert('Failed to fetch file list');reset()})}function reset(){s=false;var btn=document.getElementById('scanAllBtn');if(btn){btn.classList.remove('scanning');btn.classList.add('done');document.getElementById('scanBtnText').textContent='Scan';document.getElementById('scanBadge').textContent=results.length;setTimeout(function(){btn.classList.remove('done');var prog=document.getElementById('scanProgress');if(prog)prog.classList.remove('show')},3000)}}document.getElementById('scanAllBtn').onclick=scanAll})","target":"directory"}