{
  "description": "Multi-timezone display widget for NOMAD",
  "html": "<details class='section' id='timezoneSection'><summary><h2><svg style='position:relative;top:6px' width='24px' height='24px' viewBox='0 0 24 24' fill='none' stroke='var(--text)' stroke-width='2'><circle cx='12' cy='12' r='10'/><polyline points='12 6 12 12 16 14'/></svg>&nbsp;Global Timezones</h2></summary><div id='timezoneDisplay' style='padding:10px;display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;'></div></details>",
  "css": ".timezone-card { background: var(--surface); padding: 14px 16px; border-radius: 10px; border: 1px solid var(--border); text-align: center; transition: all 0.2s; } .timezone-card:hover { border-color: var(--accent); transform: translateY(-2px); } .timezone-name { font-size: 13px; color: var(--text-dim); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; } .timezone-time { font-size: 26px; font-weight: bold; color: var(--text); font-variant-numeric: tabular-nums; } .timezone-offset { font-size: 13px; color: var(--text-dim); margin-top: 4px; } .timezone-date { font-size: 12px; color: var(--text-dim); margin-top: 2px; }",
  "js": "// Timezone configuration - customize these\nvar timezones = [\n  { name: 'UTC', offset: 0 },\n  { name: 'London', offset: 1 },\n  { name: 'New York', offset: -4 },\n  { name: 'Tokyo', offset: 9 },\n  { name: 'Sydney', offset: 10 },\n  { name: 'Dubai', offset: 4 },\n  { name: 'Singapore', offset: 8 },\n  { name: 'Los Angeles', offset: -7 }\n];\n\nfunction updateTimezones() {\n  var container = document.getElementById('timezoneDisplay');\n  if (!container) return;\n  \n  var now = new Date();\n  var utcTime = now.getTime() + (now.getTimezoneOffset() * 60000);\n  var html = '';\n  \n  timezones.forEach(function(tz) {\n    var localTime = new Date(utcTime + (tz.offset * 3600000));\n    var hours = String(localTime.getHours()).padStart(2, '0');\n    var minutes = String(localTime.getMinutes()).padStart(2, '0');\n    var seconds = String(localTime.getSeconds()).padStart(2, '0');\n    \n    var day = String(localTime.getDate()).padStart(2, '0');\n    var month = String(localTime.getMonth() + 1).padStart(2, '0');\n    var year = localTime.getFullYear();\n    var shortYear = String(year).slice(-2);\n    \n    var offsetStr = (tz.offset >= 0 ? '+' : '') + tz.offset;\n    \n    html += '<div class=\"timezone-card\">';\n    html += '  <div class=\"timezone-name\">' + tz.name + '</div>';\n    html += '  <div class=\"timezone-time\">' + hours + ':' + minutes + ':' + seconds + '</div>';\n    html += '  <div class=\"timezone-offset\">GMT' + offsetStr + '</div>';\n    html += '  <div class=\"timezone-date\">' + day + '/' + month + '/' + shortYear + '</div>';\n    html += '</div>';\n  });\n  \n  container.innerHTML = html;\n}\n\n// Update immediately and then every second\nupdateTimezones();\nsetInterval(updateTimezones, 1000);",
  "target": "footer"
}