{
  "description": "Change the password below from 1337 to something else",
  "target": "footer",
  "html": "<div id='nmdLock' style='position:fixed;inset:0;z-index:999999;background:var(--bg);display:flex;align-items:center;justify-content:center;flex-direction:column;'><div style='background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:32px;max-width:280px;width:90%;text-align:center;'><div style='font-size:32px;margin-bottom:12px;'>🔒</div><div style='color:var(--text);font-weight:600;margin-bottom:16px;'>Locked</div><input id='nmdLockInput' type='password' inputmode='numeric' autocomplete='off' placeholder='Enter code' style='width:100%;box-sizing:border-box;padding:10px;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--text);text-align:center;font-size:16px;letter-spacing:2px;'/><div id='nmdLockMsg' style='color:#f44336;font-size:13px;margin-top:10px;min-height:16px;'></div></div></div>",
  "css": "html.nmd-locked, html.nmd-locked body{overflow:hidden !important;} body.nmd-locked{visibility:hidden !important;} #nmdLock{visibility:visible !important;}",
  "js": "(function(){var CODE='1337';var MAX_ATTEMPTS=5;var LOCKOUT_MS=30000;var ATTEMPT_KEY='nmd_lock_attempts';var LOCKOUT_UNTIL_KEY='nmd_lock_until';var unlocked=false;function getAttempts(){return parseInt(sessionStorage.getItem(ATTEMPT_KEY)||'0',10)}function setAttempts(n){sessionStorage.setItem(ATTEMPT_KEY,String(n))}function getLockoutUntil(){return parseInt(sessionStorage.getItem(LOCKOUT_UNTIL_KEY)||'0',10)}function setLockoutUntil(ts){sessionStorage.setItem(LOCKOUT_UNTIL_KEY,String(ts))}function lockBody(){document.documentElement.classList.add('nmd-locked');document.body.classList.add('nmd-locked')}function unlockBody(){unlocked=true;document.documentElement.classList.remove('nmd-locked');document.body.classList.remove('nmd-locked');var el=document.getElementById('nmdLock');if(el)el.style.display='none'}function msg(text){var m=document.getElementById('nmdLockMsg');if(m)m.textContent=text}function updateLockoutMsg(){var remain=getLockoutUntil()-Date.now();var input=document.getElementById('nmdLockInput');if(remain>0){var s=Math.ceil(remain/1000);msg('Too many attempts. Try again in '+s+'s');if(input)input.disabled=true;return true}if(input&&input.disabled){input.disabled=false;input.value='';msg('')}return false}function checkValue(){if(updateLockoutMsg())return;var input=document.getElementById('nmdLockInput');if(!input)return;var val=input.value;if(val===CODE){setAttempts(0);setLockoutUntil(0);unlockBody();return}if(val.length>=CODE.length){var n=getAttempts()+1;setAttempts(n);input.value='';if(n>=MAX_ATTEMPTS){var until=Date.now()+LOCKOUT_MS;setLockoutUntil(until);setAttempts(0);updateLockoutMsg()}else{msg('Incorrect code ('+(MAX_ATTEMPTS-n)+' attempts left)')}}}function attach(){var input=document.getElementById('nmdLockInput');if(!input)return;input.addEventListener('input',checkValue)}lockBody();updateLockoutMsg();attach();setInterval(function(){if(!unlocked){lockBody();var el=document.getElementById('nmdLock');if(el&&el.style.display==='none')el.style.display='flex';updateLockoutMsg()}},400)})();"
}
