CUSTOMHTML-START
<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no"/><title>// DECK //</title><style>*{margin:0;padding:0;box-sizing:border-box}@import url('https://fonts.googleapis.com/css2?family=VT323&family=Share+Tech+Mono&display=swap');:root{--chassis-bg:#181a1c;--pcb-green:#1e3a2a;--pcb-dark:#0f1a12;--pcb-copper:#b8863a;--pcb-gold:#d4a84a;--screen-bg:#0a0f0a;--green:#33ff77;--green-dim:#1a4a2a;--amber:#ffb066;--cyan:#66ccff;--magenta:#ff66cc}html{padding:0!important}html,body{background:#080a0c;min-height:100vh;display:flex;justify-content:center;align-items:center;padding:0;width:100vw;font-family:'Share Tech Mono','VT323',monospace;margin:0;height:100%;overflow:hidden}.chassis{width:100%;height:98vh;max-height:700px;border:3px solid #2a2e32;padding:8px 8px 6px;box-shadow:0 20px 60px rgba(0,0,0,0.9),inset 0 0 30px rgba(0,0,0,0.5);background:var(--chassis-bg);display:flex;flex-direction:column;position:relative}.chassis::before{content:'';position:absolute;inset:0;z-index:0;opacity:0.2;pointer-events:none;background-image:linear-gradient(90deg,rgba(184,134,58,0.10) 1px,transparent 1px),linear-gradient(0deg,rgba(184,134,58,0.08) 1px,transparent 1px),radial-gradient(circle at 15% 25%,rgba(212,168,74,0.15) 3px,transparent 3px),radial-gradient(circle at 85% 75%,rgba(212,168,74,0.15) 3px,transparent 3px);background-size:30px 30px,30px 30px,60px 60px,60px 60px}.chassis>*{position:relative;z-index:1}.crt{background:#0e1012;border:4px solid #1f2328;padding:8px 8px 6px;box-shadow:inset 0 0 40px rgba(0,0,0,0.8);border-radius:2px;flex:1;display:flex;flex-direction:column;position:relative;min-height:0}.crt::after{content:'';position:absolute;top:0;left:0;width:100%;height:100%;background:repeating-linear-gradient(0deg,rgba(0,0,0,0) 0px,rgba(0,0,0,0) 3px,rgba(0,20,0,0.12) 3px,rgba(0,20,0,0.12) 5px);pointer-events:none;z-index:5}.crt .vignette{position:absolute;top:0;left:0;width:100%;height:100%;background:radial-gradient(ellipse at center,transparent 50%,rgba(0,0,0,0.7) 100%);pointer-events:none;z-index:5}.screen-grid{display:flex;gap:6px;flex:1;min-height:0;background:var(--screen-bg);padding:3px;border:2px solid #1a2a1a;position:relative;z-index:2;box-shadow:inset 0 0 20px rgba(0,0,0,0.6)}.terminal-panel{flex:2.2;display:flex;flex-direction:column;gap:3px;background:#050805;padding:3px;border:1px solid #1a2a1a;min-width:0;height:100%;min-height:0;overflow:hidden}.term-window{overflow-y:auto;padding:3px 5px;font-size:0.65rem;line-height:1.5;color:var(--green);scrollbar-width:thin;scrollbar-color:#1a2a1a transparent;background:rgba(0,0,0,0.4);border-bottom:1px solid #0a150a;font-family:'Share Tech Mono',monospace;flex-shrink:0;overflow-x:hidden}.term-window:last-child{border-bottom:none;flex:1}.term-window::-webkit-scrollbar{width:3px}.term-window::-webkit-scrollbar-thumb{background:#1a2a1a}.term-window .line .prompt{color:var(--green)}.term-window .line .cmd{color:var(--cyan)}.term-window .line .output{color:#4a8a5a;white-space:pre-wrap;word-break:break-all}.term-window .line .highlight{color:var(--amber)}#syslog{height:70px;min-height:70px;max-height:70px;flex-shrink:0}#shell{flex:1;min-height:0;border-bottom:none}.cursor-blink{display:inline-block;width:8px;height:1.1em;background:var(--green);animation:blink 0.9s step-end infinite;vertical-align:text-bottom;margin-left:2px}@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}.hardware-panel{flex:1;background:#050805;border:1px solid #1a2a1a;padding:4px 6px;display:flex;flex-direction:column;gap:2px;font-size:0.5rem;color:var(--green);min-width:90px;overflow:hidden}.hw-section{border-bottom:1px solid #0a150a;padding-bottom:2px}.hw-section:last-child{border-bottom:none}.hw-label{color:#2a5a3a;letter-spacing:1px;font-size:0.5rem;display:block;margin-bottom:1px}.hw-row{display:flex;justify-content:space-between;padding:1px 0;color:#4a8a5a;font-size:0.5rem}.hw-row .val{color:var(--green);font-weight:700}.hw-row .val.amber{color:var(--amber)}.hw-row .val.cyan{color:var(--cyan)}.hw-row .val.magenta{color:var(--magenta)}.ascii-bar{display:flex;align-items:center;gap:3px;font-size:0.5rem;color:var(--green)}.ascii-bar .track{flex:1;background:#0a150a;padding:0 2px;border:1px solid #1a2a1a;letter-spacing:1px;white-space:pre;font-family:'Share Tech Mono',monospace;color:var(--green);font-size:0.45rem}.ascii-bar .track .fill{color:var(--green)}.ascii-bar .track .empty{color:#1a2a1a}.ascii-bar .pct{min-width:28px;text-align:right;color:#4a8a5a;font-size:0.45rem}.deck-header{display:flex;justify-content:space-between;align-items:center;background:#0e1012;padding:2px 10px;border-bottom:2px solid #1a2a1a;margin-bottom:6px;font-size:0.6rem;color:#3a5a3a;flex-shrink:0}.deck-header .title{font-family:'VT323',monospace;font-size:1.2rem;color:var(--green);text-shadow:0 0 10px rgba(0,255,100,0.2);letter-spacing:1px}.deck-header .title .cursor{animation:blink 0.9s step-end infinite}.deck-header .status{display:flex;gap:10px;font-size:0.5rem;color:#2a5a3a}.deck-header .status .item{display:flex;align-items:center;gap:3px}.deck-header .status .dot-green{width:5px;height:5px;background:var(--green);display:inline-block;box-shadow:0 0 6px var(--green)}.led-power{display:inline-block;width:8px;height:8px;background:var(--green);box-shadow:0 0 12px var(--green);margin-right:4px;animation:pulse-led 1.5s infinite}@keyframes pulse-led{0%,100%{opacity:1}50%{opacity:0.3}}.scanlines{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:999;background:repeating-linear-gradient(0deg,rgba(0,0,0,0) 0px,rgba(0,0,0,0) 3px,rgba(0,20,0,0.08) 3px,rgba(0,20,0,0.08) 5px)}@media(max-width:800px){.screen-grid{flex-direction:row;gap:4px}.terminal-panel{flex:2}.hardware-panel{flex:1;min-width:70px;padding:3px 4px}.term-window{font-size:0.5rem;padding:2px 4px;line-height:1.4}#syslog{height:55px;min-height:55px;max-height:55px}#shell{min-height:0}.hw-row{font-size:0.45rem}.hw-label{font-size:0.45rem}.ascii-bar{font-size:0.45rem}.ascii-bar .track{font-size:0.4rem}.deck-header .title{font-size:1rem}.deck-header .status{font-size:0.45rem;gap:6px}.chassis{padding:4px;max-height:100vh;height:100vh}.crt{padding:4px}}@media(max-width:600px){.hardware-panel{display:none}.terminal-panel{flex:1}.term-window{font-size:0.55rem}.deck-header .title{font-size:0.9rem}}#hidden-input{position:absolute;opacity:0;width:1px;height:1px;pointer-events:none}</style></head><body><div class="scanlines"></div><div class="chassis"><div class="deck-header"><div class="title"><span class="led-power"></span> CYBERDECK <span class="cursor">█</span></div><div class="status"><span class="item"><span class="dot-green"></span> LINK</span><span class="item" id="uptime">⏱ 00:00:00</span><span class="item">TEMP: 46°C</span></div></div><div class="crt"><div class="vignette"></div><div class="screen-grid"><div class="terminal-panel" id="terminal-panel"><div class="term-window" id="syslog"><div class="line"><span class="prompt">[</span><span class="highlight">SYS</span><span class="prompt">]</span> <span class="output">booting kernel 6.8.0-cyber</span></div><div class="line"><span class="prompt">[</span><span class="highlight">SYS</span><span class="prompt">]</span> <span class="output">mem: 64GB | cores: 16</span></div><div class="line"><span class="prompt">[</span><span class="highlight">NET</span><span class="prompt">]</span> <span class="output">eth0: 10.0.0.42/24</span></div><div class="line"><span class="prompt">[</span><span class="highlight">SYS</span><span class="prompt">]</span> <span class="output">daemon: cyberd started (pid 1024)</span></div><div class="line"><span class="prompt">➜</span> <span class="cmd">_</span><span class="cursor-blink"></span></div></div><div class="term-window" id="shell"><div class="line"><span class="prompt">user@deck:~$</span> <span class="cmd">./scan --net</span></div><div class="line"><span class="output">  scanning 10.0.0.0/24 ... 3 hosts up</span></div><div class="line"><span class="output">  10.0.0.1 (gateway) latency 0.4ms</span></div><div class="line"><span class="output">  10.0.0.42 (self) latency 0.0ms</span></div><div class="line"><span class="output"><br><br><u>Use in landscape for best experience...</u></span></div><div class="line"><span class="prompt">user@deck:~$</span> <span class="cmd">_</span><span class="cursor-blink"></span></div></div></div><div class="hardware-panel"><div class="hw-section"><span class="hw-label">// REGISTERS</span><div class="hw-row"><span>RAX</span><span class="val cyan" id="reg-rax">0x7FFF0000</span></div><div class="hw-row"><span>RBX</span><span class="val magenta" id="reg-rbx">0x0000FF00</span></div><div class="hw-row"><span>RCX</span><span class="val" id="reg-rcx">0xDEADBEEF</span></div><div class="hw-row"><span>RDX</span><span class="val amber" id="reg-rdx">0xCAFEBABE</span></div></div><div class="hw-section"><span class="hw-label">// RESOURCES</span><div class="ascii-bar"><span>CPU</span><span class="track"><span class="fill" id="cpu-fill">=====</span><span class="empty" id="cpu-empty">-----</span></span><span class="pct" id="cpu-pct">0%</span></div><div class="ascii-bar"><span>RAM</span><span class="track"><span class="fill" id="ram-fill">=====</span><span class="empty" id="ram-empty">-----</span></span><span class="pct" id="ram-pct">0%</span></div><div class="ascii-bar"><span>DISK</span><span class="track"><span class="fill" id="disk-fill">=====</span><span class="empty" id="disk-empty">-----</span></span><span class="pct" id="disk-pct">0%</span></div><div class="ascii-bar"><span>NET</span><span class="track"><span class="fill" id="net-fill">=====</span><span class="empty" id="net-empty">-----</span></span><span class="pct" id="net-pct">0 Mbps</span></div></div><div class="hw-section" style="flex:1;"><span class="hw-label">// CONNECTIONS</span><div id="netlist" style="font-size:0.45rem;color:#2a5a3a;display:flex;flex-direction:column;gap:1px;"><div class="entry" style="display:flex;justify-content:space-between;"><span style="color:var(--cyan);">TCP</span><span style="color:var(--green);">10.0.0.42:443</span><span style="color:var(--amber);">EST</span></div><div class="entry" style="display:flex;justify-content:space-between;"><span style="color:var(--cyan);">UDP</span><span style="color:var(--green);">10.0.0.42:53</span><span style="color:var(--amber);">ACT</span></div><div class="entry" style="display:flex;justify-content:space-between;"><span style="color:var(--cyan);">ICMP</span><span style="color:var(--green);">10.0.0.1</span><span style="color:var(--amber);">ECHO</span></div></div></div></div></div></div></div><input id="hidden-input" type="text" autofocus/><script>(function(){"use strict";const syslog=document.getElementById("syslog");const shell=document.getElementById("shell");const netlist=document.getElementById("netlist");const uptimeEl=document.getElementById("uptime");const hiddenInput=document.getElementById("hidden-input");const regEls={rax:document.getElementById("reg-rax"),rbx:document.getElementById("reg-rbx"),rcx:document.getElementById("reg-rcx"),rdx:document.getElementById("reg-rdx")};const cpuFill=document.getElementById("cpu-fill");const cpuEmpty=document.getElementById("cpu-empty");const cpuPct=document.getElementById("cpu-pct");const ramFill=document.getElementById("ram-fill");const ramEmpty=document.getElementById("ram-empty");const ramPct=document.getElementById("ram-pct");const diskFill=document.getElementById("disk-fill");const diskEmpty=document.getElementById("disk-empty");const diskPct=document.getElementById("disk-pct");const netFill=document.getElementById("net-fill");const netEmpty=document.getElementById("net-empty");const netPct=document.getElementById("net-pct");let startTime=Date.now();function updateUptime(){const diff=Math.floor((Date.now()-startTime)/1000);const h=String(Math.floor(diff/3600)).padStart(2,"0");const m=String(Math.floor((diff%3600)/60)).padStart(2,"0");const s=String(diff%60).padStart(2,"0");uptimeEl.textContent="⏱ "+h+":"+m+":"+s}setInterval(updateUptime,1e3);updateUptime();function updateBar(fillEl,emptyEl,pctEl,value,max,suffix){const pct=Math.min(100,Math.round(value/max*100));const filled=Math.round(pct/100*10);const empty=10-filled;fillEl.textContent="=".repeat(filled);emptyEl.textContent="-".repeat(empty);pctEl.textContent=suffix==="mbps"?value+" Mbps":pct+"%"}function getCPU(){if(window.performance&&performance.now){const load=performance.now()%100;return Math.min(95,Math.max(5,Math.round(load*.7+10)))}return Math.round(20+Math.random()*60)}function getRAM(){if(performance.memory){const used=performance.memory.usedJSHeapSize;const total=performance.memory.jsHeapSizeLimit;return Math.min(95,Math.round(used/total*100))}return Math.round(30+Math.random()*60)}function getDisk(){return Math.round(35+Math.random()*50)}function getNet(){return Math.round(Math.random()*480)}function updateStats(){const cpu=getCPU();updateBar(cpuFill,cpuEmpty,cpuPct,cpu,100,"%");const ram=getRAM();updateBar(ramFill,ramEmpty,ramPct,ram,100,"%");const disk=getDisk();updateBar(diskFill,diskEmpty,diskPct,disk,100,"%");const net=getNet();updateBar(netFill,netEmpty,netPct,net,480,"mbps");const randHex=()=>"0x"+Math.floor(Math.random()*4294967295).toString(16).toUpperCase().padStart(8,"0");regEls.rax.textContent=randHex();regEls.rbx.textContent=randHex();regEls.rcx.textContent=randHex();regEls.rdx.textContent=randHex()}let shellHistory=[];let shellIdx=0;function appendToShell(text,cls="output"){const div=document.createElement("div");div.className="line";div.innerHTML='<span class="'+cls+'">'+text+"</span>";shell.appendChild(div);shell.scrollTop=shell.scrollHeight;while(shell.children.length>30)shell.removeChild(shell.children[0])}function appendPrompt(){const div=document.createElement("div");div.className="line";div.innerHTML='<span class="prompt">user@deck:~$</span> <span class="cmd" contenteditable="false">_</span><span class="cursor-blink"></span>';shell.appendChild(div);shell.scrollTop=shell.scrollHeight;return div}function getCurrentInput(){const lines=shell.querySelectorAll(".line");for(let i=lines.length-1;i>=0;i--){const line=lines[i];const cmdSpan=line.querySelector(".cmd");if(cmdSpan){const text=cmdSpan.textContent.replace("_","").trim();return{line,cmdSpan,text}}}return null}function setPromptText(text){const cur=getCurrentInput();if(cur){cur.cmdSpan.textContent=text+"_";const blink=cur.line.querySelector(".cursor-blink");if(blink)blink.style.display="inline-block"}}function executeCommand(cmd){const cur=getCurrentInput();if(cur){const blink=cur.line.querySelector(".cursor-blink");if(blink)blink.style.display="none";cur.cmdSpan.textContent=cmd}let response="";const lower=cmd.toLowerCase().trim();if(lower===""){response=""}else if(lower==="help"){response="Available: help, uptime, stats, echo, whoami, date, clear, ls, ps, netstat"}else if(lower==="uptime"){const diff=Math.floor((Date.now()-startTime)/1e3);const h=String(Math.floor(diff/3600)).padStart(2,"0");const m=String(Math.floor(diff%3600/60)).padStart(2,"0");const s=String(diff%60).padStart(2,"0");response="uptime: "+h+":"+m+":"+s}else if(lower==="stats"){const cpu=getCPU();const ram=getRAM();const disk=getDisk();const net=getNet();response="CPU: "+cpu+"%  RAM: "+ram+"%  DISK: "+disk+"%  NET: "+net+" Mbps"}else if(lower==="whoami"){response="user@deck"}else if(lower==="date"){response=new Date().toString()}else if(lower==="clear"){while(shell.children.length>0)shell.removeChild(shell.children[0]);appendPrompt();return}else if(lower==="ls"){response="bin/  boot/  dev/  etc/  home/  lib/  proc/  sys/  usr/"}else if(lower==="ps"){response="  PID  PPID  CMD\n  1024  1     cyberd\n  2048  1024  shell\n  4096  1     systemd"}else if(lower==="netstat"){response="Proto  Local Address          State\nTCP    10.0.0.42:443         ESTABLISHED\nUDP    10.0.0.42:53          ACTIVE\nICMP   10.0.0.1              ECHO"}else if(lower.startsWith("echo ")){response=cmd.substring(5)}else{response="command not found: "+cmd}if(response){appendToShell(response,"output")}appendPrompt();shell.scrollTop=shell.scrollHeight}hiddenInput.addEventListener("focus",()=>{});hiddenInput.addEventListener("blur",()=>{setTimeout(()=>hiddenInput.focus(),10)});hiddenInput.addEventListener("keydown",(e)=>{e.preventDefault();const key=e.key;const cur=getCurrentInput();if(key==="Enter"){if(cur){const cmd=cur.text;executeCommand(cmd);if(cmd)shellHistory.push(cmd);shellIdx=shellHistory.length}return}if(key==="Backspace"){if(cur){const text=cur.text;if(text.length>0){setPromptText(text.slice(0,-1))}}return}if(key==="ArrowUp"){if(shellHistory.length>0){shellIdx=Math.max(0,shellIdx-1);setPromptText(shellHistory[shellIdx]||"")}return}if(key==="ArrowDown"){if(shellHistory.length>0){shellIdx=Math.min(shellHistory.length,shellIdx+1);setPromptText(shellHistory[shellIdx]||"")}return}if(key.length===1&&key.charCodeAt(0)>=32){if(cur){setPromptText(cur.text+key)}}});const sysLines=["[SYS]  load: 0.51, 0.44, 0.39","[NET]  packet: 128KB/s received","[SYS]  daemon: cyberd memory 2.1%","[NET]  ping to 8.8.8.8: 12ms","[SYS]  thermal: 46°C (nominal)","[SEC]  firewall: 12 rules loaded","[SYS]  uptime: 1d 4h 32m","[NET]  connection established 10.0.0.1"];let sysIdx=0;function addSysLog(){const children=syslog.children;if(children.length>0){const last=children[children.length-1];if(last.querySelector(".cursor-blink")){syslog.removeChild(last)}}while(syslog.children.length>15){syslog.removeChild(syslog.children[0])}const data=sysLines[sysIdx%sysLines.length];const div=document.createElement("div");div.className="line";const tag=data.split(" ")[0].replace("[","").replace("]","");const msg=data.substring(data.indexOf(" ")+1);div.innerHTML='<span class="prompt">[</span><span class="highlight">'+tag+'</span><span class="prompt">]</span> <span class="output">'+msg+"</span>";syslog.appendChild(div);const cursor=document.createElement("div");cursor.className="line";cursor.innerHTML='<span class="prompt">➜</span> <span class="cmd">_</span><span class="cursor-blink"></span>';syslog.appendChild(cursor);syslog.scrollTop=syslog.scrollHeight;sysIdx++}const netEntries=[["TCP","10.0.0.42:443","EST"],["UDP","10.0.0.42:53","ACT"],["ICMP","10.0.0.1","ECHO"],["TCP","10.0.0.42:22","LIS"],["TCP","10.0.0.42:8080","SYN"],["UDP","10.0.0.42:67","BCAST"]];let netIdx=0;function rotateNetlist(){const entries=netlist.querySelectorAll(".entry");if(entries.length>0)netlist.removeChild(entries[0]);const data=netEntries[netIdx%netEntries.length];const div=document.createElement("div");div.className="entry";div.style.display="flex";div.style.justifyContent="space-between";div.innerHTML='<span style="color:var(--cyan);">'+data[0]+'</span><span style="color:var(--green);">'+data[1]+'</span><span style="color:var(--amber);">'+data[2]+"</span>";netlist.appendChild(div);netIdx++}setTimeout(()=>hiddenInput.focus(),100);updateStats();setInterval(updateStats,1500);setInterval(addSysLog,7e3);setInterval(rotateNetlist,4e3);setTimeout(addSysLog,600);document.querySelector(".terminal-panel").addEventListener("click",()=>{hiddenInput.focus()});console.log("// CYBERDECK TERMINAL //")})();</script></body></html>
CUSTOMHTML-END