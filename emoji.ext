{
  "description":"Adds an emoji picker to the LoRa messenger input.",
  "html": "<div id='emojiPluginContainer' style='display:flex;gap:6px;align-items:flex-end;padding:4px 0;'>\n  <button id='emojiToggleBtn' onclick='openEmojiModal()' style='background:none;border:1px solid var(--border);border-radius:8px;padding:8px 10px;cursor:pointer;font-size:18px;line-height:1;transition:all 0.2s;color:var(--text);height:40px;display:flex;align-items:center;gap:4px;flex-shrink:0;'>\n    <span>😊</span>\n    <span style='font-size:10px;opacity:0.6;'>▼</span>\n  </button>\n</div>\n\n<div id='emojiModal' style='display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.6);backdrop-filter:blur(6px);z-index:99999;align-items:center;justify-content:center;'>\n  <div style='background:var(--bg);border-radius:20px;padding:20px;max-width:440px;width:92%;max-height:85vh;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,0.5);border:1px solid var(--border);'>\n    <div style='display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;flex-shrink:0;'>\n      <h3 style='margin:0;font-size:1.1rem;'>Choose an emoji</h3>\n      <button onclick='closeEmojiModal()' style='background:none;border:none;font-size:28px;cursor:pointer;color:var(--text);padding:0 8px;line-height:1;'>&times;</button>\n    </div>\n    <div style='display:grid;grid-template-columns:repeat(8,1fr);gap:4px;overflow-y:auto;flex:1;padding:4px 2px;'>\n      <button class='emoji-btn' onclick='insertEmoji(\"😊\")'>😊</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"😂\")'>😂</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🤣\")'>🤣</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"❤️\")'>❤️</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🔥\")'>🔥</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"👍\")'>👍</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"👎\")'>👎</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"💀\")'>💀</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"😍\")'>😍</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"😭\")'>😭</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"😎\")'>😎</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🤔\")'>🤔</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"😴\")'>😴</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"😈\")'>😈</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"👀\")'>👀</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"💯\")'>💯</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"✅\")'>✅</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"❌\")'>❌</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"⚠️\")'>⚠️</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🎉\")'>🎉</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"✨\")'>✨</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🌟\")'>🌟</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"⭐\")'>⭐</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🌙\")'>🌙</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"☀️\")'>☀️</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🌈\")'>🌈</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🍕\")'>🍕</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🍺\")'>🍺</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"☕\")'>☕</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🧠\")'>🧠</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"💡\")'>💡</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🔒\")'>🔒</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🔓\")'>🔓</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🤖\")'>🤖</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"👾\")'>👾</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🎮\")'>🎮</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"📡\")'>📡</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"📶\")'>📶</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🚀\")'>🚀</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🛸\")'>🛸</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🌍\")'>🌍</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🌎\")'>🌎</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🌏\")'>🌏</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🌊\")'>🌊</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"💧\")'>💧</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"⚡\")'>⚡</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"❄️\")'>❄️</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🌹\")'>🌹</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🌺\")'>🌺</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🌸\")'>🌸</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🌻\")'>🌻</button>\n      <button class='emoji-btn' onclick='insertEmoji(\"🌷\")'>🌷</button>\n    </div>\n    <div style='margin-top:12px;padding-top:10px;border-top:1px solid var(--border);text-align:center;font-size:0.7rem;opacity:0.5;flex-shrink:0;'>Tap an emoji to insert it into your message</div>\n  </div>\n</div>",

  "css": "#emojiPluginContainer { display: flex; gap: 6px; align-items: flex-end; padding: 4px 0; }\n#emojiToggleBtn { background: none; border: 1px solid var(--border); border-radius: 8px; padding: 8px 10px; cursor: pointer; font-size: 18px; line-height: 1; transition: all 0.2s; color: var(--text); height: 40px; display: flex; align-items: center; gap: 4px; flex-shrink: 0; }\n#emojiToggleBtn:hover { background: var(--accent-light); border-color: var(--accent); }\n#emojiToggleBtn:active { transform: scale(0.95); }\n#emojiModal { animation: fadeIn 0.2s ease; }\n@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }\n.emoji-btn { background: none; border: none; cursor: pointer; font-size: 28px; padding: 8px 4px; border-radius: 8px; transition: all 0.15s; }\n.emoji-btn:hover { background: var(--accent-light); }\n.emoji-btn:active { transform: scale(0.85); }\n@media (max-width: 400px) { #emojiModal > div { padding: 16px; } }",

  "js": "function openEmojiModal() { var e=document.getElementById('emojiModal'); if(e){e.style.display='flex';document.body.style.overflow='hidden'}}function closeEmojiModal(){var e=document.getElementById('emojiModal');if(e){e.style.display='none';document.body.style.overflow=''}}function insertEmoji(e){var t=document.getElementById('chatInput');if(!t)return;var n=t.selectionStart||0;var o=t.selectionEnd||0;var l=t.value.substring(0,n)+e+t.value.substring(o);t.value=l;t.focus();var s=n+e.length;t.setSelectionRange(s,s);t.dispatchEvent(new Event('input'));closeEmojiModal()}document.addEventListener('keydown',function(e){if(e.key==='Escape'){closeEmojiModal()}});function initEmojiPlugin(){var e=document.getElementById('chatInput');var t=document.getElementById('emojiPluginContainer');if(e&&t){var n=e.parentElement;if(n){var o=n.querySelector('.btn-primary');var l=n.querySelector('textarea');if(l&&o){var s=document.createElement('div');s.style.cssText='display:flex;gap:6px;align-items:flex-end;width:100%;';var r=t.parentNode;if(r){r.removeChild(t)}s.appendChild(t);var i=document.createElement('div');i.style.cssText='flex:1;display:flex;flex-direction:column;';var a=l.parentNode;if(a){a.removeChild(l)}i.appendChild(l);s.appendChild(i);var c=o.parentNode;if(c){c.removeChild(o)}s.appendChild(o);n.appendChild(s)}}}}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',initEmojiPlugin)}else{initEmojiPlugin()}",

  "target": "footer"
}