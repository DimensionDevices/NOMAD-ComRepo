{
  "description":"A sidebar style user interface replacement.",
  "html": "<style>#sidebar-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:var(--bg);z-index:9998;display:flex;overflow:hidden}.sidebar{width:64px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;height:100%;overflow-y:auto;padding-top:12px}.sidebar-item{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:12px 4px;cursor:pointer;transition:all .2s ease;border-left:3px solid transparent;color:var(--text);text-decoration:none;gap:2px;min-height:56px;position:relative}.sidebar-item:hover{background:var(--bg);border-left-color:var(--accent)}.sidebar-item.active{background:var(--bg);border-left-color:var(--accent)}.sidebar-item .icon{font-size:22px;line-height:1}.sidebar-item .label{font-size:.5rem;opacity:.6;text-align:center;font-weight:500}.sidebar-item .badge{position:absolute;top:6px;right:6px;background:var(--accent);color:#fff;border-radius:50%;font-size:.45rem;padding:1px 6px;min-width:14px;text-align:center;font-weight:600}.sidebar-item.disabled{opacity:0.3;cursor:default;pointer-events:none}.sidebar-item.disabled:hover{background:transparent;border-left-color:transparent}.sidebar-footer{margin-top:auto;padding:16px 4px;text-align:center;font-size:.5rem;opacity:.4;border-top:1px solid var(--border);flex-shrink:0}.content-area{flex:1;display:flex;flex-direction:column;padding:10px 24px;overflow-y:auto;height:100%;box-sizing:border-box}.content-area .page-title{font-size:1.2rem;font-weight:600;margin-bottom:16px;color:var(--text)}.content-area .page-content{flex:1;overflow-y:auto}.stat-card{border-radius:0px !important;}.content-area .empty-state{text-align:center;padding:40px;color:var(--text-dim);font-size:.9rem}.sidebar-back{display:none}.modal-overlay{position:fixed;top:0;left:0;width:100%;height:100%;z-index:10000;display:none;align-items:center;justify-content:center;background:rgba(0,0,0,0.5)}.modal-overlay.active{display:flex}.modal-box{background:var(--bg);border-radius:12px;padding:30px;max-width:90%;max-height:90%;width:600px;overflow-y:auto;border:1px solid var(--border);position:relative}.modal-box .close{position:absolute;top:12px;right:16px;background:transparent;border:none;font-size:24px;cursor:pointer;color:var(--text)}.modal-box .close:hover{opacity:0.7}</style><div id='sidebar-overlay'><div class=sidebar id=sidebarNav><div id=sidebarItems></div><div class=sidebar-footer>NOMAD v1.0</div></div><div class=content-area id=contentArea><div id=pageTitle class=page-title>NOMAD</div><div id=pageContent class=page-content><div class=empty-state></div></div></div><div class=modal-overlay id=sidebarModal><div class=modal-box id=sidebarModalBox><button class=close onclick='document.getElementById(\"sidebarModal\").classList.remove(\"active\")'>✕</button><div id=sidebarModalContent></div></div></div></div>",
  "css": ".modal{left:64px !important;background:transparent !important;backdrop-filter:none !important;}.modal-content{border:0 !important;background:var(--bg) !important;width:calc(100vw - 64px) !important;}#chatWindow{height:63vh !important;}.content-area{padding:10px !important;}#modalMessage,.modal-buttons{text-align:left !important;}",
  "js": "(function(){var overlay=document.getElementById('sidebar-overlay');if(!overlay){overlay=document.createElement('div');overlay.id='sidebar-overlay';document.body.appendChild(overlay);var style=document.createElement('style');style.textContent='#sidebar-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:var(--bg);z-index:9998;display:flex;overflow:hidden}.sidebar{width:64px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;height:100%;overflow-y:auto;padding-top:12px}.sidebar-item{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:12px 4px;cursor:pointer;transition:all .2s ease;border-left:3px solid transparent;color:var(--text);text-decoration:none;gap:2px;min-height:56px;position:relative}.sidebar-item:hover{background:var(--bg);border-left-color:var(--accent)}.sidebar-item.active{background:var(--bg);border-left-color:var(--accent)}.sidebar-item .icon{font-size:22px;line-height:1}.sidebar-item .label{font-size:.5rem;opacity:.6;text-align:center;font-weight:500}.sidebar-item .badge{position:absolute;top:6px;right:6px;background:var(--accent);color:#fff;border-radius:50%;font-size:.45rem;padding:1px 6px;min-width:14px;text-align:center;font-weight:600}.sidebar-item.disabled{opacity:0.3;cursor:default;pointer-events:none}.sidebar-item.disabled:hover{background:transparent;border-left-color:transparent}.sidebar-footer{margin-top:auto;padding:16px 4px;text-align:center;font-size:.5rem;opacity:.4;border-top:1px solid var(--border);flex-shrink:0}.content-area{flex:1;display:flex;flex-direction:column;padding:10px 24px;overflow-y:auto;height:100%;box-sizing:border-box}.content-area .page-title{font-size:1.2rem;font-weight:600;margin-bottom:16px;color:var(--text)}.content-area .page-content{flex:1;overflow-y:auto}.stat-card{border-radius:0px !important;}.content-area .empty-state{text-align:center;padding:40px;color:var(--text-dim);font-size:.9rem}.sidebar-back{display:none}.modal-overlay{position:fixed;top:0;left:0;width:100%;height:100%;z-index:10000;display:none;align-items:center;justify-content:center;background:rgba(0,0,0,0.5)}.modal-overlay.active{display:flex}.modal-box{background:var(--bg);border-radius:12px;padding:30px;max-width:90%;max-height:90%;width:600px;overflow-y:auto;border:1px solid var(--border);position:relative}.modal-box .close{position:absolute;top:12px;right:16px;background:transparent;border:none;font-size:24px;cursor:pointer;color:var(--text)}.modal-box .close:hover{opacity:0.7}';document.head.appendChild(style);overlay.innerHTML='<div class=sidebar id=sidebarNav><div id=sidebarItems></div><div class=sidebar-footer>NOMAD v1.0</div></div><div class=content-area id=contentArea><div id=pageTitle class=page-title>NOMAD</div><div id=pageContent class=page-content><div class=empty-state>Select an item from the sidebar</div></div></div><div class=modal-overlay id=sidebarModal><div class=modal-box id=sidebarModalBox><button class=close onclick=\"document.getElementById(\\'sidebarModal\\').classList.remove(\\'active\\')\">✕</button><div id=sidebarModalContent></div></div></div>';}function hideOpenModals(){var helpModal=document.getElementById('helpModal');if(helpModal)helpModal.style.display='none';var createModal=document.getElementById('createFileModal');if(createModal)createModal.style.display='none';}function showSidebarModal(title,content){var modal=document.getElementById('sidebarModal');var contentEl=document.getElementById('sidebarModalContent');contentEl.innerHTML='<h2 style=margin-top:0;margin-bottom:16px;>'+title+'</h2>'+content;modal.classList.add('active');}var sidebar=document.getElementById('sidebarItems');var contentArea=document.getElementById('pageContent');var titleArea=document.getElementById('pageTitle');function stripBadges(html){var temp=document.createElement('div');temp.innerHTML=html;temp.querySelectorAll('.category-badge').forEach(function(el){el.remove();});return temp.innerHTML;}function renderSidebar(){sidebar.innerHTML='';var favList=document.getElementById('favoritesList');var favs=favList?favList.querySelectorAll('.file-item'):[];var extList=document.getElementById('extFileList');var extCount=extList?extList.querySelectorAll('.file-item').length:0;var items=[{id:'headerDetails',label:'Status',icon:'📊'},{id:'filesDetails',label:'Files',icon:'📁'},{id:'nodesDetails',label:'Nodes',icon:'📡'},{id:'loraMessengerDetails',label:'Chat',icon:'💬'},{id:'bookmarks',label:'Bookmarks',icon:'⭐',count:favs.length},{id:'extensions',label:'Ext',icon:'🧩',count:extCount},{id:'createFile',label:'New',icon:'➕'},{id:'fileInput',label:'Upload',icon:'📤'},{id:'helpModalBtn',label:'Settings',icon:'⚙️'}];items.forEach(function(item){var div=document.createElement('div');div.className='sidebar-item';if(item.id==='extensions'&&extCount===0)div.classList.add('disabled');if(item.id==='bookmarks'&&favs.length===0)div.classList.add('disabled');var badge='';if(item.count&&item.count>0)badge='<span class=badge>'+item.count+'</span>';div.innerHTML='<span class=icon>'+item.icon+'</span><span class=label>'+item.label+'</span>'+badge;if(item.id==='createFile'){div.onclick=function(e){e.stopPropagation();hideOpenModals();if(typeof openCreateFileModal==='function'){openCreateFileModal();}else if(window.openCreateFileModal){window.openCreateFileModal();}else{var btn=document.getElementById('createFileBtn');if(btn)btn.click();}};}else if(item.id==='fileInput'){div.onclick=function(e){e.stopPropagation();hideOpenModals();var input=document.getElementById('fileInput');if(input)input.click();};}else if(item.id==='helpModalBtn'){div.onclick=function(e){e.stopPropagation();hideOpenModals();var btn=document.getElementById('helpModalBtn');if(btn)btn.click();};}else if(item.id==='filesDetails'){div.onclick=function(e){e.stopPropagation();hideOpenModals();var list=document.getElementById('fileList');if(list){var content=list.cloneNode(true);titleArea.textContent='Files';contentArea.innerHTML=stripBadges(content.innerHTML);}};div.classList.add('active');}else if(item.id==='nodesDetails'){div.onclick=function(e){e.stopPropagation();hideOpenModals();var nodes=document.getElementById('nodeList');if(nodes){var content=nodes.cloneNode(true);titleArea.textContent='Nodes';contentArea.innerHTML=stripBadges(content.innerHTML);}};}else if(item.id==='loraMessengerDetails'){div.onclick=function(e){e.stopPropagation();hideOpenModals();var chat=document.getElementById('chatWindow');if(chat){var parent=chat.parentNode;var clone=parent.cloneNode(true);titleArea.textContent='Chat';contentArea.innerHTML=stripBadges(clone.innerHTML);}};}else if(item.id==='headerDetails'){div.onclick=function(e){e.stopPropagation();hideOpenModals();var status=document.querySelector('.status-bar');if(status){var content=status.cloneNode(true);titleArea.textContent='Status';contentArea.innerHTML=stripBadges(content.innerHTML);}};}else if(item.id==='extensions'){div.onclick=function(e){e.stopPropagation();hideOpenModals();if(extCount===0){titleArea.textContent='Extensions';contentArea.innerHTML='<div class=empty-state>No extensions installed</div>';return;}var extList=document.getElementById('extFileList');if(extList){var content=extList.cloneNode(true);titleArea.textContent='Extensions';contentArea.innerHTML=stripBadges(content.innerHTML);}};}else if(item.id==='bookmarks'){div.onclick=function(e){e.stopPropagation();hideOpenModals();if(favs.length===0){titleArea.textContent='Bookmarks';contentArea.innerHTML='<div class=empty-state>No bookmarks yet</div>';return;}var html='<div style=display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:12px;>';favs.forEach(function(li){var nameEl=li.querySelector('.file-name strong');if(nameEl){var name=nameEl.textContent.trim();html+='<div style=\"background:var(--surface);border-radius:8px;padding:16px;text-align:center;cursor:pointer;border:1px solid var(--border);transition:all .2s;\" onclick=\"(function(){if(typeof viewFile===\\'function\\'){viewFile(\\''+name+'\\')}else if(window.viewFile){window.viewFile(\\''+name+'\\')}})()\"><div style=font-size:28px;>⭐</div><div style=font-size:.7rem;margin-top:4px;>'+name+'</div></div>';}});html+='</div>';titleArea.textContent='Bookmarks';contentArea.innerHTML=html;}};sidebar.appendChild(div);});}renderSidebar();var favObserver=new MutationObserver(function(){renderSidebar();});var favList=document.getElementById('favoritesList');if(favList){favObserver.observe(favList,{childList:true,subtree:true});}var extObserver=new MutationObserver(function(){renderSidebar();});var extList=document.getElementById('extFileList');if(extList){extObserver.observe(extList,{childList:true,subtree:true});}var header=document.querySelector('.header summary');if(header){var newHeader=header.cloneNode(true);header.parentNode.replaceChild(newHeader,header);newHeader.onclick=function(e){e.preventDefault();e.stopPropagation();var overlay=document.getElementById('sidebar-overlay');if(overlay.style.display==='none'||overlay.style.display===''){overlay.style.display='flex';}else{overlay.style.display='none';}};}overlay.style.display='flex';})();",
  "target": "header"
}