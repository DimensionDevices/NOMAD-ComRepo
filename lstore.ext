{"description":"A localStorage management area, where you can delete NOMAD program/app/extension storage at will.","html":"<details class='section' id='storageManagerSection'><summary><h2>🗃️&nbsp;Storage Manager</h2></summary><div style='padding:8px 0;'><div style='display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;'><button class='btn btn-small' id='smRefresh' style='background:var(--accent);color:white;'>🔄</button><button class='btn btn-small btn-danger' id='smClearAll' style='background:#e74c3c;color:white;'>🗑️</button><button class='btn btn-small' id='smExport' style='background:#3498db;color:white;'>📤</button><button class='btn btn-small' id='smImport' style='background:#2ecc71;color:white;'>📥</button><input type='file' id='smImportFile' accept='.json' style='display:none;'><span style='margin-left:auto;font-size:0.85em;opacity:0.7;' id='smStats'>0 items</span></div><div style='background:var(--surface);border:1px solid var(--border);border-radius:8px;max-height:400px;overflow-y:auto;'><div id='smKeyList' style='padding:8px;'></div></div></div></details>","css":"#storageManagerSection .section { margin-bottom: 12px; } #storageManagerSection summary h2 { display: flex; align-items: center; gap: 8px; } .sm-key-item { display: flex; align-items: center; gap: 8px; padding: 6px 8px; border-bottom: 1px solid var(--border); font-size: 0.85rem; transition: background 0.15s ease; } .sm-key-item:hover { background: var(--bg); } .sm-key-name { flex: 1; font-weight: 500; word-break: break-all; cursor: pointer; } .sm-key-size { font-size: 0.75rem; opacity: 0.6; white-space: nowrap; margin-right: 8px; } .sm-key-actions { display: flex; gap: 4px; flex-shrink: 0; } .sm-key-actions button { padding: 2px 8px; font-size: 0.75rem; border-radius: 4px; border: 1px solid var(--border); background: var(--surface); cursor: pointer; transition: all 0.15s ease; } .sm-key-actions button:hover { transform: scale(1.05); } .sm-key-actions .sm-view-btn { background: #3498db; color: white; border-color: #3498db; } .sm-key-actions .sm-delete-btn { background: #e74c3c; color: white; border-color: #e74c3c; } .sm-key-actions .sm-delete-btn:hover { background: #c0392b; } .sm-key-actions .sm-view-btn:hover { background: #2980b9; } .sm-empty { text-align: center; padding: 30px; opacity: 0.6; } .sm-modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 9999; display: none; align-items: center; justify-content: center; } .sm-modal-content { background: var(--bg); border: 1px solid var(--border); border-radius: 12px; max-width: 600px; width: 90%; max-height: 80vh; display: flex; flex-direction: column; box-shadow: 0 8px 32px rgba(0,0,0,0.3); } .sm-modal-header { display: flex; justify-content: space-between; align-items: center; padding: 12px 20px; border-bottom: 1px solid var(--border); } .sm-modal-header h3 { margin: 0; font-size: 1rem; } .sm-modal-close { background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text); opacity: 0.6; } .sm-modal-close:hover { opacity: 1; } .sm-modal-body { padding: 16px 20px; overflow-y: auto; flex: 1; } .sm-modal-body pre { background: var(--surface); padding: 12px; border-radius: 6px; overflow: auto; max-height: 300px; font-size: 0.8rem; white-space: pre-wrap; word-break: break-all; border: 1px solid var(--border); } .sm-modal-footer { padding: 12px 20px; border-top: 1px solid var(--border); display: flex; gap: 8px; justify-content: flex-end; } .sm-badge { display: inline-block; padding: 1px 8px; border-radius: 10px; font-size: 0.7rem; font-weight: bold; background: var(--accent); color: white; }","js":"(function(){'use strict';var STORAGE_PREFIX='sm_';var smData={};function init(){renderKeyList();setupEventListeners();updateStats()}function getKeys(){var keys=[];for(var i=0;i<localStorage.length;i++){var key=localStorage.key(i);if(key&&!key.startsWith(STORAGE_PREFIX)){keys.push(key)}}return keys.sort()}function getItemSize(key){try{var val=localStorage.getItem(key);return val?new Blob([val]).size:0}catch(e){return 0}}function formatSize(bytes){if(bytes<1024)return bytes+' B';if(bytes<1048576)return (bytes/1024).toFixed(1)+' KB';return (bytes/1048576).toFixed(1)+' MB'}function renderKeyList(){var container=document.getElementById('smKeyList');if(!container)return;var keys=getKeys();if(keys.length===0){container.innerHTML='<div class=\"sm-empty\">📭 No localStorage items found</div>';return}var html='';var totalSize=0;keys.forEach(function(key){var size=getItemSize(key);totalSize+=size;var val=localStorage.getItem(key);var preview='';try{var parsed=JSON.parse(val);preview=JSON.stringify(parsed).substring(0,100)}catch(e){preview=val.substring(0,100)}if(preview.length>100)preview+='...';html+='<div class=\"sm-key-item\">';html+='<span class=\"sm-key-name\" data-key=\"'+escapeHtml(key)+'\">'+escapeHtml(key)+'</span>';html+='<span class=\"sm-key-size\">'+formatSize(size)+'</span>';html+='<div class=\"sm-key-actions\">';html+='<button class=\"sm-view-btn\" data-key=\"'+escapeHtml(key)+'\">📄</button>';html+='<button class=\"sm-delete-btn\" data-key=\"'+escapeHtml(key)+'\">🗑️</button>';html+='</div></div>'});container.innerHTML=html;document.getElementById('smStats').textContent=keys.length+' items ('+formatSize(totalSize)+')';document.querySelectorAll('.sm-view-btn').forEach(function(btn){btn.addEventListener('click',function(e){e.stopPropagation();var key=this.dataset.key;viewKey(key)})});document.querySelectorAll('.sm-delete-btn').forEach(function(btn){btn.addEventListener('click',function(e){e.stopPropagation();var key=this.dataset.key;deleteKey(key)})});document.querySelectorAll('.sm-key-name').forEach(function(el){el.addEventListener('click',function(){var key=this.dataset.key;viewKey(key)})})}function viewKey(key){var val=localStorage.getItem(key);if(val===null){alert('Key no longer exists');return}var formatted=val;try{var parsed=JSON.parse(val);formatted=JSON.stringify(parsed,null,2)}catch(e){}var modal=document.createElement('div');modal.className='sm-modal';modal.style.display='flex';modal.innerHTML='<div class=\"sm-modal-content\">'+'<div class=\"sm-modal-header\"><h3>📄 '+escapeHtml(key)+'</h3><button class=\"sm-modal-close\">×</button></div>'+'<div class=\"sm-modal-body\"><pre>'+escapeHtml(formatted)+'</pre></div>'+'<div class=\"sm-modal-footer\">'+'<button class=\"btn btn-small btn-primary\" id=\"smCopyBtn\">📋 Copy</button>'+'<button class=\"btn btn-small btn-danger\" id=\"smDeleteFromModal\">🗑️ Delete</button>'+'<button class=\"btn btn-small\" id=\"smCloseModal\">Close</button>'+'</div></div>';document.body.appendChild(modal);modal.querySelector('.sm-modal-close').addEventListener('click',function(){modal.remove()});modal.querySelector('#smCloseModal').addEventListener('click',function(){modal.remove()});modal.querySelector('#smCopyBtn').addEventListener('click',function(){navigator.clipboard.writeText(val).then(function(){alert('Copied to clipboard!')})['catch'](function(){var textarea=document.createElement('textarea');textarea.value=val;document.body.appendChild(textarea);textarea.select();document.execCommand('copy');document.body.removeChild(textarea);alert('Copied to clipboard!')})});modal.querySelector('#smDeleteFromModal').addEventListener('click',function(){if(confirm('Delete key \"'+key+'\"?')){localStorage.removeItem(key);modal.remove();renderKeyList();updateStats()}});modal.addEventListener('click',function(e){if(e.target===modal)modal.remove()})}function deleteKey(key){if(confirm('Delete key \"'+key+'\"?')){localStorage.removeItem(key);renderKeyList();updateStats()}}function clearAll(){var keys=getKeys();if(keys.length===0){alert('No items to clear');return}if(confirm('Delete ALL '+keys.length+' localStorage items? This cannot be undone!')){keys.forEach(function(key){localStorage.removeItem(key)});renderKeyList();updateStats();alert('Cleared '+keys.length+' items')}}function exportData(){var keys=getKeys();if(keys.length===0){alert('No data to export');return}var data={};keys.forEach(function(key){data[key]=localStorage.getItem(key)});var json=JSON.stringify(data,null,2);var blob=new Blob([json],{type:'application/json'});var url=URL.createObjectURL(blob);var a=document.createElement('a');a.href=url;a.download='localstorage-export-'+new Date().toISOString().slice(0,10)+'.json';document.body.appendChild(a);a.click();document.body.removeChild(a);URL.revokeObjectURL(url)}function importData(){document.getElementById('smImportFile').click()}function handleImport(file){var reader=new FileReader();reader.onload=function(e){try{var data=JSON.parse(e.target.result);if(typeof data!=='object'||data===null){alert('Invalid JSON format');return}var count=0;for(var key in data){if(data.hasOwnProperty(key)){localStorage.setItem(key,data[key]);count++}}renderKeyList();updateStats();alert('Imported '+count+' items')}catch(err){alert('Failed to parse JSON: '+err.message)}};reader.readAsText(file)}function setupEventListeners(){document.getElementById('smRefresh').addEventListener('click',function(){renderKeyList();updateStats()});document.getElementById('smClearAll').addEventListener('click',clearAll);document.getElementById('smExport').addEventListener('click',exportData);document.getElementById('smImport').addEventListener('click',importData);document.getElementById('smImportFile').addEventListener('change',function(e){if(this.files&&this.files[0]){handleImport(this.files[0]);this.value=''}});document.addEventListener('keydown',function(e){if(e.key==='Escape'){document.querySelectorAll('.sm-modal').forEach(function(m){m.remove()})}})}function updateStats(){var keys=getKeys();document.getElementById('smStats').textContent=keys.length+' items'}function escapeHtml(str){if(!str)return'';var div=document.createElement('div');div.textContent=str;return div.innerHTML}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',init)}else{init()}})();",
  "target": "footer"}