{
  "html": "<details class='section' id='notesSection'>\n  <summary><h2><svg style='margin-right:6px;'width='24px' height='24px' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'><g id='SVGRepo_bgCarrier' stroke-width='0'/><g id='SVGRepo_tracerCarrier' stroke-linecap='round' stroke-linejoin='round'/><g id='SVGRepo_iconCarrier'> <path d='M2.75458 14.716L3.27222 16.6479C3.87647 18.9029 4.17859 20.0305 4.86351 20.7618C5.40432 21.3392 6.10421 21.7433 6.87466 21.9229C7.85044 22.1504 8.97798 21.8483 11.2331 21.244C13.4881 20.6398 14.6157 20.3377 15.347 19.6528C15.4077 19.5959 15.4664 19.5373 15.5233 19.477C15.1891 19.449 14.852 19.3952 14.5094 19.3271C13.8133 19.1887 12.9862 18.967 12.008 18.7049L11.9012 18.6763L11.8764 18.6697C10.8121 18.3845 9.92281 18.1457 9.21277 17.8892C8.46607 17.6195 7.7876 17.287 7.21148 16.7474C6.41753 16.0038 5.86193 15.0414 5.61491 13.982C5.43567 13.2133 5.48691 12.4594 5.62666 11.6779C5.76058 10.929 6.00109 10.0315 6.28926 8.95613L6.28926 8.95611L6.82365 6.96174L6.84245 6.8916C4.9219 7.40896 3.91101 7.71505 3.23687 8.34646C2.65945 8.88726 2.25537 9.58715 2.07573 10.3576C1.84821 11.3334 2.15033 12.4609 2.75458 14.716Z' fill='var(--text)'/> <path fill-rule='evenodd' clip-rule='evenodd' d='M20.8293 10.7154L20.3116 12.6473C19.7074 14.9024 19.4052 16.0299 18.7203 16.7612C18.1795 17.3386 17.4796 17.7427 16.7092 17.9223C16.6129 17.9448 16.5152 17.9621 16.415 17.9744C15.4999 18.0873 14.3834 17.7881 12.3508 17.2435C10.0957 16.6392 8.96815 16.3371 8.23687 15.6522C7.65945 15.1114 7.25537 14.4115 7.07573 13.641C6.84821 12.6652 7.15033 11.5377 7.75458 9.28263L8.27222 7.35077C8.3591 7.02654 8.43979 6.7254 8.51621 6.44561C8.97128 4.77957 9.27709 3.86298 9.86351 3.23687C10.4043 2.65945 11.1042 2.25537 11.8747 2.07573C12.8504 1.84821 13.978 2.15033 16.2331 2.75458C18.4881 3.35883 19.6157 3.66095 20.347 4.34587C20.9244 4.88668 21.3285 5.58657 21.5081 6.35703C21.7356 7.3328 21.4335 8.46034 20.8293 10.7154ZM11.0524 9.80589C11.1596 9.40579 11.5709 9.16835 11.971 9.27556L16.8006 10.5697C17.2007 10.6769 17.4381 11.0881 17.3309 11.4882C17.2237 11.8883 16.8125 12.1257 16.4124 12.0185L11.5827 10.7244C11.1826 10.6172 10.9452 10.206 11.0524 9.80589ZM10.2756 12.7033C10.3828 12.3032 10.794 12.0658 11.1941 12.173L14.0919 12.9495C14.492 13.0567 14.7294 13.4679 14.6222 13.868C14.515 14.2681 14.1038 14.5056 13.7037 14.3984L10.8059 13.6219C10.4058 13.5147 10.1683 13.1034 10.2756 12.7033Z' fill='var(--text)'/> </g></svg>&nbsp;Notes <span id='noteCount' style='font-weight:normal;font-size:0.85rem;opacity:0.6;'></span></h2></summary>\n  <div style='padding:0.75rem 0 0.25rem 0;'>\n    <div style='display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;'>\n      <input type='text' id='noteInput' placeholder='Write a note...' style='flex:1;min-width:150px;padding:8px 12px;border:1px solid var(--border-color, #e2e8f0);border-radius:var(--radius, 8px);font-size:0.9rem;background:var(--bg-secondary, #fafbfc);color:var(--text-primary, #1e293b);transition:all 0.15s;'>\n      <button id='addNoteBtn' style='padding:8px 16px;background:var(--accent, #c6bbac);color:var(--text-on-accent, #0f172a);border:none;border-radius:var(--radius, 8px);font-weight:600;cursor:pointer;transition:all 0.15s;font-size:0.9rem;'>Add</button>\n      <button id='clearNotesBtn' style='padding:8px 12px;background:transparent;border:1px solid var(--border-color, #e2e8f0);border-radius:var(--radius, 8px);cursor:pointer;font-size:0.85rem;color:var(--text-secondary, #64748b);transition:all 0.15s;'>Clear All</button>\n    </div>\n    <div id='notesList' style='display:flex;flex-direction:column;gap:6px;max-height:300px;overflow-y:auto;'></div>\n  </div>\n</details>",

  "css": "#notesSection {padding: 0.5rem 1rem;\n  transition: all 0.2s;\n  color: var(--text-primary, #1e293b);\n#notesSection summary {\n  cursor: pointer;\n  font-weight: 600;\n  font-size: 1.05rem;\n  padding: 0.25rem 0;\n  color: var(--text-primary, #0f172a);\n  user-select: none;\n  list-style: none;\n  display: flex;\n  align-items: center;\n  gap: 6px;\n}\n#notesSection summary::-webkit-details-marker {\n  display: none;\n}\n#notesSection summary::before {\n  content: '▶';\n  display: inline-block;\n  font-size: 0.75rem;\n  transition: transform 0.2s;\n  color: var(--text-secondary, #64748b);\n  margin-right: 4px;\n}\n#notesSection[open] summary::before {\n  transform: rotate(90deg);\n}\n#noteInput:focus {\n  outline: none;\n  border-color: var(--accent, #c6bbac);\n  box-shadow: 0 0 0 3px var(--accent-light, rgba(198, 187, 172, 0.15));\n}\n#addNoteBtn:hover {\n  background: var(--accent-hover, #b5a899);\n  transform: scale(1.02);\n}\n#addNoteBtn:active {\n  transform: scale(0.96);\n}\n#clearNotesBtn:hover {\n  background: var(--bg-hover, #f1f5f9);\n  border-color: var(--border-hover, #cbd5e1);\n}\n.note-item {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n  gap: 10px;\n  padding: 8px 12px;\n  background: var(--bg-card, #ffffff);\n  border-radius: var(--radius, 8px);\n  border: 1px solid var(--border-color, #e2e8f0);\n  transition: all 0.15s;\n  animation: noteSlideIn 0.2s ease;\n}\n.note-item:hover {\n  border-color: var(--border-hover, #cbd5e1);\n  box-shadow: 0 1px 4px var(--shadow-color, rgba(0,0,0,0.04));\n}\n.note-item .note-text {\n  flex: 1;\n  word-break: break-word;\n  line-height: 1.4;\n  font-size: 0.92rem;\n  color: var(--text-primary, #1e293b);\n}\n.note-item .note-time {\n  font-size: 0.7rem;\n  color: var(--text-secondary, #94a3b8);\n  white-space: nowrap;\n  margin-top: 2px;\n  flex-shrink: 0;\n}\n.note-item .delete-btn {\n  background: none;\n  border: none;\n  color: var(--text-secondary, #94a3b8);\n  cursor: pointer;\n  font-size: 1rem;\n  padding: 2px 6px;\n  border-radius: 4px;\n  transition: all 0.15s;\n  line-height: 1;\n  flex-shrink: 0;\n}\n.note-item .delete-btn:hover {\n  color: var(--danger, #ef4444);\n  background: var(--danger-bg, #fef2f2);\n}\n.note-item .delete-btn:active {\n  transform: scale(0.85);\n}\n.empty-notes {\n  color: var(--text-secondary, #94a3b8);\n  font-style: italic;\n  padding: 1rem 0;\n  text-align: center;\n  font-size: 0.9rem;\n}\n@keyframes noteSlideIn {\n  from {\n    opacity: 0;\n    transform: translateY(-6px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n#notesList::-webkit-scrollbar {\n  width: 4px;\n}\n#notesList::-webkit-scrollbar-track {\n  background: transparent;\n}\n#notesList::-webkit-scrollbar-thumb {\n  background: var(--border-color, #cbd5e1);\n  border-radius: 10px;\n}\n#notesList {\n  scrollbar-width: thin;\n  scrollbar-color: var(--border-color, #cbd5e1) transparent;\n}\n\n/* Dark theme support */\n@media (prefers-color-scheme: dark) {\n  #notesSection {\n    --bg-secondary: #1e293b;\n    --bg-card: #2d3748;\n    --bg-hover: #374151;\n    --text-primary: #e2e8f0;\n    --text-secondary: #94a3b8;\n    --border-color: #374151;\n    --border-hover: #4a5568;\n    --shadow-color: rgba(0,0,0,0.2);\n    --accent: #8a7e72;\n    --accent-hover: #9a8e82;\n    --accent-light: rgba(138, 126, 114, 0.25);\n    --text-on-accent: #f1f5f9;\n    --danger: #f87171;\n    --danger-bg: rgba(248, 113, 113, 0.15);\n  }\n}\n\n/* Light theme default */\n#notesSection {\n  --bg-secondary: #f8fafc;\n  --bg-card: #ffffff;\n  --bg-hover: #f1f5f9;\n  --text-primary: #1e293b;\n  --text-secondary: #64748b;\n  --border-color: #e2e8f0;\n  --border-hover: #cbd5e1;\n  --shadow-color: rgba(0,0,0,0.04);\n  --accent: #c6bbac;\n  --accent-hover: #b5a899;\n  --accent-light: rgba(198, 187, 172, 0.15);\n  --text-on-accent: #0f172a;\n  --danger: #ef4444;\n  --danger-bg: #fef2f2;\n  --radius: 8px;\n}",

  "js": "(function() {\n  'use strict';\n\n  const STORAGE_KEY = 'notesApp_notes';\n  let notes = [];\n  let noteInput, addBtn, clearBtn, notesList, noteCount, notesSection;\n\n  function getElements() {\n    noteInput = document.getElementById('noteInput');\n    addBtn = document.getElementById('addNoteBtn');\n    clearBtn = document.getElementById('clearNotesBtn');\n    notesList = document.getElementById('notesList');\n    noteCount = document.getElementById('noteCount');\n    notesSection = document.getElementById('notesSection');\n  }\n\n  function loadNotes() {\n    try {\n      const stored = localStorage.getItem(STORAGE_KEY);\n      if (stored) {\n        notes = JSON.parse(stored);\n        if (!Array.isArray(notes)) notes = [];\n      } else {\n        notes = [];\n      }\n    } catch (e) {\n      notes = [];\n    }\n    return notes;\n  }\n\n  function saveNotes() {\n    try {\n      localStorage.setItem(STORAGE_KEY, JSON.stringify(notes));\n    } catch (e) {\n      // Silently fail\n    }\n    updateCount();\n  }\n\n  function renderNotes() {\n    if (!notesList) return;\n\n    if (notes.length === 0) {\n      notesList.innerHTML = '<div class=\"empty-notes\">No notes yet</div>';\n      return;\n    }\n\n    const sorted = [...notes].reverse();\n    let html = '';\n    for (let i = 0; i < sorted.length; i++) {\n      const note = sorted[i];\n      const time = note.timestamp ? new Date(note.timestamp).toLocaleString() : '';\n      const id = note.id || i;\n      const text = escapeHtml(note.text);\n      html += `\n        <div class=\"note-item\" data-id=\"${id}\">\n          <span class=\"note-text\">${text}</span>\n          <span class=\"note-time\">${time}</span>\n          <button class=\"delete-btn\" data-id=\"${id}\" title=\"Delete note\">✕</button>\n        </div>\n      `;\n    }\n    notesList.innerHTML = html;\n\n    const deleteBtns = notesList.querySelectorAll('.delete-btn');\n    for (let i = 0; i < deleteBtns.length; i++) {\n      const btn = deleteBtns[i];\n      btn.addEventListener('click', function(e) {\n        e.stopPropagation();\n        const id = this.dataset.id;\n        deleteNote(id);\n      });\n    }\n  }\n\n  function escapeHtml(text) {\n    const div = document.createElement('div');\n    div.textContent = text;\n    return div.innerHTML;\n  }\n\n  function updateCount() {\n    if (noteCount) {\n      noteCount.textContent = notes.length ? '(' + notes.length + ')' : '';\n    }\n  }\n\n  function addNote(text) {\n    text = text.trim();\n    if (!text) return false;\n\n    const note = {\n      id: Date.now() + '_' + Math.random().toString(36).slice(2, 6),\n      text: text,\n      timestamp: Date.now()\n    };\n    notes.push(note);\n    saveNotes();\n    renderNotes();\n    return true;\n  }\n\n  function deleteNote(id) {\n    notes = notes.filter(function(n) { return String(n.id) !== String(id); });\n    saveNotes();\n    renderNotes();\n  }\n\n  function clearAllNotes() {\n    if (notes.length === 0) return;\n    if (confirm('Delete all notes?')) {\n      notes = [];\n      saveNotes();\n      renderNotes();\n    }\n  }\n\n  function bindEvents() {\n    if (!addBtn || !noteInput || !clearBtn) return;\n\n    addBtn.addEventListener('click', function() {\n      const text = noteInput.value;\n      if (addNote(text)) {\n        noteInput.value = '';\n        noteInput.focus();\n        if (notesSection && !notesSection.open) {\n          notesSection.open = true;\n        }\n      }\n    });\n\n    noteInput.addEventListener('keypress', function(e) {\n      if (e.key === 'Enter') {\n        e.preventDefault();\n        addBtn.click();\n      }\n    });\n\n    clearBtn.addEventListener('click', clearAllNotes);\n  }\n\n  function init() {\n    getElements();\n    if (!notesList) {\n      setTimeout(function() {\n        getElements();\n        if (notesList) {\n          loadNotes();\n          renderNotes();\n          bindEvents();\n        }\n      }, 100);\n      return;\n    }\n    loadNotes();\n    renderNotes();\n    bindEvents();\n  }\n\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', init);\n  } else {\n    init();\n  }\n\n  window.addEventListener('beforeunload', function() {\n    saveNotes();\n  });\n\n})();",

  "target": "footer"
}