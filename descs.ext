{
  "description": "Adds custom descriptions to files stored in localStorage",
  "css": ".file-desc-container{display:inline-flex;align-items:center;margin-left:auto;}.file-desc-btn{background:0 0;border:none;color:var(--text-dim);cursor:pointer;padding:2px 6px;border-radius:4px;font-size:.9em;opacity:.5;transition:opacity .2s;display:inline-flex;align-items:center;height:100%;}.file-desc-btn:hover{opacity:1;background:var(--border)}.file-desc-text-wrapper{display:block;width:100%;margin-top:4px;padding:4px 8px;font-size:.8em;color:var(--text-dim);background:var(--surface);border-radius:4px;word-break:break-word;box-sizing:border-box;}",
  "html": "<div id=\"fileDescExt_container\" style=\"display:none;\"></div>",
  "js": "(function(){'use strict';var STORAGE_KEY='file_descriptions';var currentEditingFile=null;function getDescriptions(){try{var data=localStorage.getItem(STORAGE_KEY);return data?JSON.parse(data):{}}catch(e){return{}}}function saveDescriptions(descs){try{localStorage.setItem(STORAGE_KEY,JSON.stringify(descs))}catch(e){console.error('Failed to save descriptions:',e)}}function getDescription(filename){var descs=getDescriptions();return descs[filename]||''}function setDescription(filename,text){var descs=getDescriptions();if(text&&text.trim()){descs[filename]=text.trim()}else{delete descs[filename]}saveDescriptions(descs)}function escapeHtml(text){var div=document.createElement('div');div.textContent=text;return div.innerHTML}function renderDescription(fileItem,filename){var desc=getDescription(filename);var hasDesc=desc&&desc.trim().length>0;var escapedFilename=escapeHtml(filename).replace(/\\\\/g,'\\\\\\\\').replace(/'/g,\"\\\\'\");var buttonsContainer=fileItem.querySelector('.file-item-buttons');if(!buttonsContainer)return;var existingContainer=buttonsContainer.querySelector('.file-desc-container');if(existingContainer){buttonsContainer.removeChild(existingContainer)}var existingTextWrapper=fileItem.querySelector('.file-desc-text-wrapper');if(existingTextWrapper){fileItem.removeChild(existingTextWrapper)}var descContainer=document.createElement('span');descContainer.className='file-desc-container';descContainer.dataset.filename=filename;var btnHtml='<button class=\"file-desc-btn\" onclick=\"event.stopPropagation();window.__fileDescEdit(\\''+escapedFilename+'\\')\" title=\"'+(hasDesc?'Edit':'Add')+' description\">✏️</button>';descContainer.innerHTML=btnHtml;descContainer.addEventListener('click',function(e){e.stopPropagation();e.stopImmediatePropagation();return false});var isInBeacon=buttonsContainer.querySelector('.isInBeacon');if(isInBeacon){isInBeacon.after(descContainer)}else{buttonsContainer.appendChild(descContainer)}if(hasDesc){var textWrapper=document.createElement('div');textWrapper.className='file-desc-text-wrapper';textWrapper.textContent=desc;textWrapper.addEventListener('click',function(e){e.stopPropagation();return false});fileItem.appendChild(textWrapper)}}function injectDescriptions(){var fileList=document.getElementById('fileList');if(!fileList){setTimeout(injectDescriptions,500);return}var fileItems=fileList.querySelectorAll('.file-item');var foundAny=false;fileItems.forEach(function(item){var nameSpan=item.querySelector('.file-name strong');if(!nameSpan)return;var filename=nameSpan.textContent;renderDescription(item,filename);foundAny=true});if(!foundAny){setTimeout(injectDescriptions,1000)}}function editDescription(filename){currentEditingFile=filename;var currentDesc=getDescription(filename);var modalHtml='<div style=\"padding:10px;\"><h3 style=\"margin:0 0 10px 0;color:var(--text);\">Description for <strong>'+escapeHtml(filename)+'</strong></h3><input type=\"text\" id=\"descInput\" value=\"'+escapeHtml(currentDesc)+'\" placeholder=\"Enter description...\" style=\"width:100%;background:var(--bg);border:1px solid var(--border);color:var(--text);padding:8px 12px;border-radius:4px;font-size:.95em;font-family:inherit;outline:0;box-sizing:border-box;\"></div>';showCustomModal(modalHtml);var input=document.getElementById('descInput');if(input){input.focus();input.select();input.addEventListener('input',function(){var newDesc=this.value.trim();if(currentEditingFile){setDescription(currentEditingFile,newDesc);var fileItems=document.querySelectorAll('.file-item');fileItems.forEach(function(item){var nameSpan=item.querySelector('.file-name strong');if(nameSpan&&nameSpan.textContent===currentEditingFile){renderDescription(item,currentEditingFile)}})}});input.addEventListener('keydown',function(e){if(e.key==='Escape'){closeCustomModal()}})}};window.__fileDescEdit=editDescription;window.fileDesc={get:getDescription,set:setDescription,getAll:getDescriptions,refresh:injectDescriptions};var observer=null;function setupObserver(){if(observer){observer.disconnect()}var fileList=document.getElementById('fileList');if(!fileList){setTimeout(setupObserver,1000);return}observer=new MutationObserver(function(mutations){var shouldRefresh=false;mutations.forEach(function(mutation){if(mutation.type==='childList'){mutation.addedNodes.forEach(function(node){if(node.nodeType===Node.ELEMENT_NODE){if(node.classList&&node.classList.contains('file-item')){shouldRefresh=true}if(node.querySelectorAll){var items=node.querySelectorAll('.file-item');if(items.length>0)shouldRefresh=true}}})}});if(shouldRefresh){setTimeout(injectDescriptions,100)}});observer.observe(fileList,{childList:true,subtree:true})}function init(){if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',function(){setTimeout(injectDescriptions,300);setTimeout(setupObserver,400)})}else{setTimeout(injectDescriptions,300);setTimeout(setupObserver,400)}var originalRefreshFiles=window.refreshFiles;if(originalRefreshFiles){window.refreshFiles=function(){var result=originalRefreshFiles.apply(this,arguments);setTimeout(injectDescriptions,300);return result}}}init()})();",
  "target": "footer"
}