CUSTOMHTML-START
<style>.tz-card{background:#faf5ff;border-radius:16px;padding:16px;margin-bottom:16px;}.tz-label{font-size:12px;color:#6b7280;margin-bottom:4px;}.tz-select{width:100%;padding:10px;border-radius:10px;border:1px solid #e9d5ff;background:white;font-size:14px;margin-bottom:12px;}.tz-input{width:100%;padding:10px;border-radius:10px;border:1px solid #e9d5ff;font-size:14px;box-sizing:border-box;}.convert-btn{width:100%;padding:12px;background:#8b5cf6;color:white;border:none;border-radius:12px;font-size:16px;font-weight:bold;margin:8px 0;cursor:pointer;}.result-box{background:white;border-radius:12px;padding:16px;text-align:center;border:2px solid #e9d5ff;}.result-big{font-size:24px;font-weight:bold;color:#6b21a5;}.result-small{font-size:12px;color:#9ca3af;margin-top:8px;}.swap-btn{background:#f3e8ff;border:none;padding:6px 12px;border-radius:20px;font-size:12px;cursor:pointer;margin-bottom:12px;}</style> <div class="tz-card"> <div class="tz-label">From</div> <select id="fromTz" class="tz-select"> <option value="UTC">UTC</option> <option value="America/New_York">New York (EST)</option> <option value="America/Chicago">Chicago (CST)</option> <option value="America/Denver">Denver (MST)</option> <option value="America/Los_Angeles">Los Angeles (PST)</option> <option value="Europe/London">London</option> <option value="Europe/Paris">Paris</option> <option value="Europe/Berlin">Berlin</option> <option value="Asia/Dubai">Dubai</option> <option value="Asia/Kolkata">Mumbai</option> <option value="Asia/Tokyo">Tokyo</option> <option value="Asia/Shanghai">Shanghai</option> <option value="Australia/Sydney">Sydney</option> </select> <input type="datetime-local" id="inputTime" class="tz-input"> <button class="swap-btn" onclick="swapTimezones()">Swap</button> <div class="tz-label">To</div> <select id="toTz" class="tz-select"> <option value="America/Los_Angeles">Los Angeles (PST)</option> <option value="America/New_York">New York (EST)</option> <option value="America/Chicago">Chicago (CST)</option> <option value="America/Denver">Denver (MST)</option> <option value="Europe/London">London</option> <option value="Europe/Paris">Paris</option> <option value="Europe/Berlin">Berlin</option> <option value="Asia/Dubai">Dubai</option> <option value="Asia/Kolkata">Mumbai</option> <option value="Asia/Tokyo">Tokyo</option> <option value="Asia/Shanghai">Shanghai</option> <option value="Australia/Sydney">Sydney</option> <option value="UTC">UTC</option> </select> <button class="convert-btn" onclick="convertTime()">Convert</button> <div class="result-box" id="result"> <div class="result-small">Converted Time</div> <div class="result-big" id="convertedTime">--:-- --</div> <div class="result-small" id="timeDiff"></div> </div> </div> <script>function formatTime(date,tz){return date.toLocaleTimeString('en-US',{timeZone: tz,hour: '2-digit',minute: '2-digit',hour12: true});}function formatDate(date,tz){return date.toLocaleDateString('en-US',{timeZone: tz,month: 'short',day: 'numeric',year: 'numeric'});}function getOffset(tz){try{let date=new Date();let tzDate=new Date(date.toLocaleString('en-US',{timeZone: tz}));let offset=(tzDate.getTime()-date.getTime())/(1000*60*60);return offset;}catch(e){return 0;}}function convertTime(){let fromTz=document.getElementById('fromTz').value;let toTz=document.getElementById('toTz').value;let inputDateTime=document.getElementById('inputTime').value;if(!inputDateTime){let now=new Date();let localIso=now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0')+'-'+String(now.getDate()).padStart(2,'0')+'T'+String(now.getHours()).padStart(2,'0')+':'+String(now.getMinutes()).padStart(2,'0');document.getElementById('inputTime').value=localIso;inputDateTime=localIso;}let sourceDate=new Date(inputDateTime);let sourceStr=sourceDate.toLocaleString('en-US',{timeZone: fromTz});let sourceMoment=new Date(sourceStr);let targetStr=sourceMoment.toLocaleString('en-US',{timeZone: toTz});let targetDate=new Date(targetStr);let formattedTime=formatTime(targetDate,toTz);let formattedDate=formatDate(targetDate,toTz);document.getElementById('convertedTime').innerHTML=formattedTime;document.getElementById('timeDiff').innerHTML=formattedDate;let fromOffset=getOffset(fromTz);let toOffset=getOffset(toTz);let diff=toOffset-fromOffset;if(diff!==0){let diffText=diff>0 ? '+'+diff : diff;document.getElementById('timeDiff').innerHTML+='('+diffText+'h)';}}function swapTimezones(){let from=document.getElementById('fromTz').value;let to=document.getElementById('toTz').value;document.getElementById('fromTz').value=to;document.getElementById('toTz').value=from;convertTime();}window.onload=function(){let now=new Date();let localIso=now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0')+'-'+String(now.getDate()).padStart(2,'0')+'T'+String(now.getHours()).padStart(2,'0')+':'+String(now.getMinutes()).padStart(2,'0');document.getElementById('inputTime').value=localIso;convertTime();};</script>
