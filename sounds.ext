{
  "html": "<details class='section' id='soundsSection'>\n  <summary><h2><svg style='margin-right:6px;' width='32px' height='32px' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'><path d='M3 10L7 10L11 6L11 18L7 14L3 14L3 10Z' stroke='var(--text)' stroke-width='2' stroke-linejoin='round'/><path d='M15 9C16.5 10.5 16.5 13.5 15 15' stroke='var(--text)' stroke-width='2' stroke-linecap='round'/><path d='M17 6C19.5 8.5 19.5 15.5 17 18' stroke='var(--text)' stroke-width='2' stroke-linecap='round'/></svg><span style='opacity:1;position:relative;top:-0.5em;'>Sounds</span></h2></summary>\n  <div style='padding:0.75rem 0 0.25rem 0;'>\n    <div style='display:flex;gap:10px;margin-bottom:12px;flex-wrap:wrap;align-items:center;'>\n      <label style='display:flex;align-items:center;gap:6px;font-size:0.85rem;cursor:pointer;'>\n        <input type='checkbox' id='soundEnabled' checked> Enabled\n      </label>\n      <label style='display:flex;align-items:center;gap:6px;font-size:0.85rem;cursor:pointer;'>\n        <input type='checkbox' id='soundNodeDiscover' checked> Node Found\n      </label>\n      <label style='display:flex;align-items:center;gap:6px;font-size:0.85rem;cursor:pointer;'>\n        <input type='checkbox' id='soundNodeLost'> Node Lost\n      </label>\n      <label style='display:flex;align-items:center;gap:6px;font-size:0.85rem;cursor:pointer;'>\n        <input type='checkbox' id='soundMessageReceive' checked> Message In\n      </label>\n      <label style='display:flex;align-items:center;gap:6px;font-size:0.85rem;cursor:pointer;'>\n        <input type='checkbox' id='soundMessageSent'> Message Out\n      </label>\n      <label style='display:flex;align-items:center;gap:6px;font-size:0.85rem;cursor:pointer;'>\n        <input type='checkbox' id='soundFileChange'> File Changed\n      </label>\n      <label style='display:flex;align-items:center;gap:6px;font-size:0.85rem;cursor:pointer;'>\n        <input type='checkbox' id='soundTransferComplete'> Transfer Done\n      </label>\n      <label style='display:flex;align-items:center;gap:6px;font-size:0.85rem;cursor:pointer;'>\n        <input type='checkbox' id='soundWarning'> Warnings\n      </label>\n    </div>\n    <div style='display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;'>\n      <button class='sound-test-btn' onclick='testAllSounds()' style='padding:4px 12px;border:1px solid var(--border-color);border-radius:var(--radius,6px);background:var(--bg-secondary);cursor:pointer;font-size:0.75rem;'>Test All</button>\n      <button class='sound-test-btn' onclick='clearSoundLog()' style='padding:4px 12px;border:1px solid var(--border-color);border-radius:var(--radius,6px);background:var(--bg-secondary);cursor:pointer;font-size:0.75rem;'>Clear Log</button>\n    </div>\n    <div id='soundEventLog' style='font-size:0.78rem;color:var(--text-secondary);padding:6px 10px;background:var(--bg-secondary);border-radius:var(--radius,6px);max-height:100px;overflow-y:auto;font-family:monospace;display:none;border:1px solid var(--border-color);'></div>\n  </div>\n</details>",

  "css": "#soundsSection {padding:0.5rem 1rem;transition:all 0.2s;color:var(--text-primary,#1e293b);}#soundsSection summary::-webkit-details-marker{display:none;}#soundsSection[open] summary::before{transform:rotate(90deg);}.sound-test-btn{transition:all 0.15s;color:var(--text-primary,#1e293b);}.sound-test-btn:hover{background:var(--accent,#c6bbac);color:var(--text-on-accent,#0f172a);}.sound-test-btn:active{transform:scale(0.95);}#soundEventLog::-webkit-scrollbar{width:4px;}#soundEventLog::-webkit-scrollbar-track{background:transparent;}#soundEventLog::-webkit-scrollbar-thumb{background:var(--border-color,#cbd5e1);border-radius:10px;}#soundEventLog{scrollbar-width:thin;scrollbar-color:var(--border-color,#cbd5e1) transparent;}@media(prefers-color-scheme:dark){#soundsSection{--bg-secondary:#1e293b;--bg-card:#2d3748;--bg-hover:#374151;--text-primary:#e2e8f0;--text-secondary:#94a3b8;--border-color:#374151;--border-hover:#4a5568;--shadow-color:rgba(0,0,0,0.2);--accent:#8a7e72;--accent-hover:#9a8e82;--accent-light:rgba(138,126,114,0.25);--text-on-accent:#f1f5f9;--danger:#f87171;--danger-bg:rgba(248,113,113,0.15);}}#soundsSection{--bg-secondary:#f8fafc;--bg-card:#ffffff;--bg-hover:#f1f5f9;--text-primary:#1e293b;--text-secondary:#64748b;--border-color:#e2e8f0;--border-hover:#cbd5e1;--shadow-color:rgba(0,0,0,0.04);--accent:#c6bbac;--accent-hover:#b5a899;--accent-light:rgba(198,187,172,0.15);--text-on-accent:#0f172a;--danger:#ef4444;--danger-bg:#fef2f2;--radius:8px;}",

  "js": "(function(){'use strict';var SOUND_KEY='nomad_sound_settings_v2';var defaults={enabled:true,nodeDiscover:true,nodeLost:false,messageReceive:true,messageSent:false,fileChange:false,transferComplete:false,warning:false};var settings={};var audioCtx=null;var logEntries=[];var MAX_LOG=60;var lastNodeCount=0;var knownNodes={};var lastFileSignature='';var soundEnabledEl,soundNodeEl,soundNodeLostEl,soundMsgEl,soundMsgSentEl,soundFileEl,soundTransferEl,soundWarnEl,logEl,badgeEl,sectionEl;function getSettings(){try{var stored=localStorage.getItem(SOUND_KEY);if(stored){var parsed=JSON.parse(stored);for(var k in defaults){if(defaults.hasOwnProperty(k)&&typeof parsed[k]!=='undefined'){settings[k]=parsed[k];}else{settings[k]=defaults[k];}}}else{settings=Object.assign({},defaults);}}catch(e){settings=Object.assign({},defaults);}return settings;}function saveSettings(){try{localStorage.setItem(SOUND_KEY,JSON.stringify(settings));}catch(e){}}function getEls(){soundEnabledEl=document.getElementById('soundEnabled');soundNodeEl=document.getElementById('soundNodeDiscover');soundNodeLostEl=document.getElementById('soundNodeLost');soundMsgEl=document.getElementById('soundMessageReceive');soundMsgSentEl=document.getElementById('soundMessageSent');soundFileEl=document.getElementById('soundFileChange');soundTransferEl=document.getElementById('soundTransferComplete');soundWarnEl=document.getElementById('soundWarning');logEl=document.getElementById('soundEventLog');sectionEl=document.getElementById('soundsSection');}function initAudio(){try{if(!audioCtx){audioCtx=new(window.AudioContext||window.webkitAudioContext)();if(audioCtx.state==='suspended'){audioCtx.resume();}}}catch(e){}}function playTone(freq,duration,type,volume){try{initAudio();if(!audioCtx||!settings.enabled)return;var osc=audioCtx.createOscillator();var gain=audioCtx.createGain();osc.type=type||'sine';osc.frequency.value=freq||440;gain.gain.setValueAtTime((volume||0.12),audioCtx.currentTime);gain.gain.exponentialRampToValueAtTime(0.001,audioCtx.currentTime+(duration||0.15));osc.connect(gain);gain.connect(audioCtx.destination);osc.start();osc.stop(audioCtx.currentTime+(duration||0.15));}catch(e){}}function playChord(freqs,duration,volume){try{initAudio();if(!audioCtx||!settings.enabled)return;for(var i=0;i<freqs.length;i++){var osc=audioCtx.createOscillator();var gain=audioCtx.createGain();osc.type='sine';osc.frequency.value=freqs[i];gain.gain.setValueAtTime((volume||0.08),audioCtx.currentTime);gain.gain.exponentialRampToValueAtTime(0.001,audioCtx.currentTime+(duration||0.2));osc.connect(gain);gain.connect(audioCtx.destination);osc.start(audioCtx.currentTime+(i*0.05));osc.stop(audioCtx.currentTime+(duration||0.2));}}catch(e){}}function playNodeSound(){if(!settings.nodeDiscover)return;playChord([523,659,784],0.15,0.10);}function playNodeLostSound(){if(!settings.nodeLost)return;playChord([440,370,330],0.2,0.08);}function playMessageSound(){if(!settings.messageReceive)return;playChord([440,554,659],0.12,0.10);}function playMessageSentSound(){if(!settings.messageSent)return;playTone(880,0.06,'sine',0.08);setTimeout(function(){playTone(1100,0.06,'sine',0.06);},80);}function playFileSound(){if(!settings.fileChange)return;playChord([330,415,523],0.10,0.06);}function playTransferSound(){if(!settings.transferComplete)return;playChord([440,554,659,880],0.2,0.10);}function playWarningSound(){if(!settings.warning)return;playTone(600,0.2,'square',0.08);setTimeout(function(){playTone(600,0.2,'square',0.08);},250);}function addLog(icon,msg){var now=new Date();var time=now.toLocaleTimeString();logEntries.push({time:time,icon:icon,msg:msg});if(logEntries.length>MAX_LOG){logEntries.shift();}renderLog();}function renderLog(){if(!logEl)return;if(logEntries.length===0){logEl.style.display='none';return;}logEl.style.display='block';var html='';for(var i=logEntries.length-1;i>=0;i--){var e=logEntries[i];html+='<div style=\"padding:2px 0;border-bottom:1px solid var(--border-color);opacity:0.8;\"><span style=\"color:var(--text-secondary);margin-right:6px;\">'+e.time+'</span><span>'+e.icon+'</span> '+e.msg+'</div>';}logEl.innerHTML=html;}function clearSoundLog(){logEntries=[];renderLog();}function testAllSounds(){initAudio();addLog('🔊','Testing all sounds...');playMessageSound();setTimeout(function(){playNodeSound();},400);setTimeout(function(){playMessageSentSound();},700);setTimeout(function(){playFileSound();},1000);setTimeout(function(){playTransferSound();},1300);setTimeout(function(){playWarningSound();},1600);setTimeout(function(){playNodeLostSound();},1900);}function bindUI(){if(!soundEnabledEl||!soundNodeEl||!soundNodeLostEl||!soundMsgEl||!soundMsgSentEl||!soundFileEl||!soundTransferEl||!soundWarnEl)return;soundEnabledEl.checked=settings.enabled;soundNodeEl.checked=settings.nodeDiscover;soundNodeLostEl.checked=settings.nodeLost;soundMsgEl.checked=settings.messageReceive;soundMsgSentEl.checked=settings.messageSent;soundFileEl.checked=settings.fileChange;soundTransferEl.checked=settings.transferComplete;soundWarnEl.checked=settings.warning;soundEnabledEl.addEventListener('change',function(){settings.enabled=this.checked;saveSettings();if(!settings.enabled&&audioCtx){try{audioCtx.suspend();}catch(e){}}});soundNodeEl.addEventListener('change',function(){settings.nodeDiscover=this.checked;saveSettings();});soundNodeLostEl.addEventListener('change',function(){settings.nodeLost=this.checked;saveSettings();});soundMsgEl.addEventListener('change',function(){settings.messageReceive=this.checked;saveSettings();});soundMsgSentEl.addEventListener('change',function(){settings.messageSent=this.checked;saveSettings();});soundFileEl.addEventListener('change',function(){settings.fileChange=this.checked;saveSettings();});soundTransferEl.addEventListener('change',function(){settings.transferComplete=this.checked;saveSettings();});soundWarnEl.addEventListener('change',function(){settings.warning=this.checked;saveSettings();});}function getFileSignature(files){if(!files||!files.length)return '';var names=[];for(var i=0;i<files.length;i++){names.push(files[i].name+':'+files[i].size+':'+files[i].timestamp);}names.sort();return names.join('|');}function setupNodeObserver(){var origRenderNodes=window.renderNodes;if(origRenderNodes){window.renderNodes=function(nodes){var currentIds={};var count=nodes?nodes.length:0;if(nodes){for(var i=0;i<nodes.length;i++){currentIds[nodes[i].id]=true;}}if(count>lastNodeCount&&lastNodeCount>0){playNodeSound();addLog('🟢','Node discovered ('+count+' total)');}if(count<lastNodeCount){var lostCount=lastNodeCount-count;playNodeLostSound();addLog('🔴',lostCount+' node(s) lost');}lastNodeCount=count;origRenderNodes(nodes);};}}function setupMessageObserver(){var origAppendChat=window.appendChatMessages;if(origAppendChat){window.appendChatMessages=function(messages){if(messages&&messages.length>0){var hasNew=false;var isMine=false;for(var i=0;i<messages.length;i++){if(!messages[i].mine){hasNew=true;}else{isMine=true;}}if(hasNew){playMessageSound();addLog('💬','Message received');}else if(isMine&&settings.messageSent){playMessageSentSound();addLog('📤','Message sent');}}origAppendChat(messages);};}}function setupFileObserver(){setInterval(function(){try{if(typeof cachedFilesData!=='undefined'&&cachedFilesData&&cachedFilesData.length>0){var sig=getFileSignature(cachedFilesData);if(lastFileSignature!==''&&lastFileSignature!==sig){playFileSound();addLog('📁','File changed');}lastFileSignature=sig;}}catch(e){}},5000);}function setupTransferObserver(){var origStatusUpdate=window.updateStatusOverlay||function(){};window.updateStatusOverlay=function(title,msg,progress){if(progress===100&&title&&title.toLowerCase().indexOf('transfer')!==-1){playTransferSound();addLog('✅','Transfer complete');}origStatusUpdate(title,msg,progress);};var origShowStatus=window.showStatusOverlay||function(){};window.showStatusOverlay=function(title,msg,progress){if(title&&title.toLowerCase().indexOf('transfer')!==-1&&progress===0){addLog('📥','Transfer started');}origShowStatus(title,msg,progress);};}function setupWarningObserver(){var origAlert=window.alert;window.alert=function(msg){if(msg&&(msg.toLowerCase().indexOf('warning')!==-1||msg.toLowerCase().indexOf('error')!==-1||msg.toLowerCase().indexOf('low')!==-1||msg.toLowerCase().indexOf('full')!==-1||msg.toLowerCase().indexOf('failed')!==-1)){playWarningSound();addLog('⚠️','Warning: '+msg.substring(0,30)+(msg.length>30?'...':''));}origAlert(msg);};}function init(){getEls();getSettings();bindUI();setupNodeObserver();setupMessageObserver();setupFileObserver();setupTransferObserver();setupWarningObserver();if(sectionEl){sectionEl.addEventListener('toggle',function(){if(this.open&&audioCtx&&audioCtx.state==='suspended'){audioCtx.resume();}});}document.addEventListener('click',function(){if(audioCtx&&audioCtx.state==='suspended'){audioCtx.resume();}});setTimeout(function(){addLog('🔊','Sounds ready');},1000);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',init);}else{init();}window.testAllSounds=testAllSounds;window.clearSoundLog=clearSoundLog;window.playTone=playTone;window.playChord=playChord;})();",

  "target": "header"
}