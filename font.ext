{
"description": "Custom font. Use: hellogreg.github.io/woff2base to convert a woff2 font to a base64 font and replace the src below",
"html": "",
"css": "@font-face{font-family:'CustomFont';src:url('data:font/woff2;base64,') format('woff2');font-weight:normal;font-style:normal;font-display:swap;}*,*::before,*::after{font-family:'CustomFont',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif !important;}body,body *:not(.fa):not(.fas):not(.far):not(.fal):not(.fab):not([class*=\"icon-\"]):not(svg):not(.material-icons):not(.emoji):not(.symbol),div,p,span,a,h1,h2,h3,h4,h5,h6,li,ul,ol,table,tr,td,th,section,article,aside,header,footer,nav,main,form,input,textarea,button,label,select,option,strong,b,i,em,u,small,big,sub,sup,mark,del,ins,q,cite,blockquote,pre,code,kbd,samp,var,abbr,address,time,figure,figcaption,details,summary,menu,menuitem,dl,dt,dd,fieldset,legend,datalist,output,progress,meter,iframe,object,embed,canvas,audio,video,map,area,template,slot,div[class],span[class],*[style*=\"font-family\"]{font-family:'CustomFont',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif !important;}:root,:host,html{font-family:'CustomFont',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif !important;}input,textarea,button,select,option{font-family:'CustomFont',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif !important;}",
"js": "console.log('✅ Custom font applied via data URL extension');(function(){var style=document.createElement('style');style.textContent='*,*::before,*::after{font-family:\"CustomFont\",-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,sans-serif !important;}body,body *{font-family:\"CustomFont\",-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,sans-serif !important;}';document.head.appendChild(style);var els=document.querySelectorAll('*');for(var i=0;i<els.length;i++){if(els[i].style){els[i].style.setProperty('font-family','CustomFont, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif','important');}}document.fonts.load('1em CustomFont').then(function(){console.log('✅ Custom font loaded successfully');}).catch(function(err){console.warn('⚠️ Custom font failed to load:',err);});})();",
"target": "header"
}