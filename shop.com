<script>
function filterTables(){const e=document.getElementById("searchBox").value.toLowerCase().trim(),t=document.querySelectorAll("table"),n=document.createElement("div");n.className="no-results",n.id="noResults";const o=document.getElementById("noResults");if(o&&o.remove(),""===e)return void t.forEach(e=>{e.querySelectorAll("tbody tr").forEach(e=>{e.style.display="",e.innerHTML=e.innerHTML.replace(/<span class="highlight">(.*?)<\/span>/g,"$1")})});let r=!1;if(t.forEach(t=>{const n=t.querySelectorAll("tbody tr");let o=!1;n.forEach(t=>{if(t.textContent.toLowerCase().includes(e)){t.style.display="";t.querySelectorAll("td").forEach(t=>{const n=t.textContent,o=new RegExp(`(${e.replace(/[.*+?^${}()|[\]\\]/g,"\\$&")})`,"gi");n.toLowerCase().includes(e)&&(t.innerHTML=n.replace(o,'<span class="highlight">$1</span>'))}),r=!0,o=!0}else t.style.display="none"})}),!r&&""!==e){const t=document.querySelector(".search-container"),n=document.createElement("div");n.className="no-results",n.id="noResults",n.innerHTML=`🔍 No items found matching "<strong>${e}</strong>"<br><small>Try searching for produce, pantry items, or trade goods.</small>`,t.parentNode.insertBefore(n,t.nextSibling)}}let timeoutId;document.addEventListener("DOMContentLoaded",function(){document.getElementById("searchBox").addEventListener("input",function(){clearTimeout(timeoutId),timeoutId=setTimeout(filterTables,150)})});
</script>
