d>Compost, manure</td><td>Spring</td></tr><tr><td>Pepper Seedling</td><td>Compost, manure</td><td>Spring</td></tr><tr><td>Basil Seedling</td><td>Candles, soap</td><td>Spring</td></tr><tr><td>Mint Seedling</td><td>Candles, soap</td><td>Spring</td></tr></tbody></table><hr><div class="h">📍 Find Us</div><div class="card"><b>Location</b><br>127 Ridge Road<br>Local Valley, ST 12345<br><br><b>Directions</b><br>Turn off Hwy 9 at yellow mailbox. 2 miles past pond.</div><div class="card"><b>Contact</b><br>Radio Ch 7 (10am-12pm)<br>📞 (555) 987-6543<br>📧 hillside@offgrid.com<br><br><b>Hours</b><br>Weekdays: 8am-6pm<br>Weekends: 9am-4pm</div><hr><div class="q">"Bring what you have, take what you need."</div><div class="alert alert-success">New items weekly!</div><div class="text"><em>No pesticides. Rainwater collection. Solar cold storage. Bring containers. All trades negotiable.</em></div></div>
<script>
const D={Kale:5,"Swiss Chard":3,Lettuce:8,Garlic:12,Onions:10,Potatoes:20,Carrots:15,Beets:12,Apples:30,Pears:20,Honey:4,Eggs:18,Pickles:8,"Sourdough Starter":2,Tomato:10,Pepper:8,Basil:6,Mint:6};function F(){return location.pathname.split("/").pop()||"shop.com"}async function G(k){const r=`/api/db/get?filename=${F()}`+(k?`&key=${k}`:"");return(await fetch(r)).json()}async function S(d){return(await fetch("/api/db/set",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({filename:F(),data:d})})).json()}function H(s){let h=0;for(let i=0;i<s.length;i++){h=((h<<5)-h)+s.charCodeAt(i);h=h&h}return h.toString(16).padStart(8,"0")}let stock={};function get(k){return stock[k]??0}function badge(n){return n>2?'<span class="badge in">✓</span>':n>0?'<span class="badge low">⚠</span>':'<span class="badge out">✗</span>'}function upd(){document.querySelectorAll(".sd").forEach(el=>{const k=el.dataset.i,n=get(k);el.textContent=n;const td=el.closest("td");if(td){td.innerHTML=n+" "+badge(n);const e=td.querySelector(".sd");e&&(e.dataset.i=k)}})}function M(html){const e=document.createElement("div");e.className="mo",e.id="mo",e.innerHTML=`<div class="mb">${html}</div>`,document.body.appendChild(e),e.addEventListener("click",t=>{t.target===e&&C()})}function C(){const e=document.getElementById("mo");e&&e.remove()}function A(t,m,msg){const icons={e:"❌",s:"✅",w:"⚠️",i:"ℹ️"};M(`<button class="close" onclick="C()">×</button><div class="am ${t}"><h4>${icons[t]||""} ${m}</h4><p>${msg}</p></div><div style="margin-top:16px;text-align:right"><button class="btn" onclick="C()">OK</button></div>`)}async function setup(){const items=Object.keys(D).sort().map(k=>`<div class="si"><label>${k}</label><input type="number" id="s_${k.replace(/\s/g,"_")}" value="${D[k]}" min="0" step="1"></div>`).join("");M(`<button class="close" onclick="C()">×</button><h2>🏪 Welcome!</h2><p>Set password & stock.</p><div class="ps"><label>Password</label><input type="password" id="p1" placeholder="Password"><label>Confirm</label><input type="password" id="p2" placeholder="Confirm"></div><label>Stock</label><div class="sg">${items}</div><div style="margin-top:16px;text-align:right"><button class="btn" onclick="saveSetup()">Save</button></div>`)}async function saveSetup(){const p=document.getElementById("p1").value,c=document.getElementById("p2").value;if(!p||p.length<4)return A("e","Error","Password min 4 chars");if(p!==c)return A("e","Error","Passwords don't match");const s={};Object.keys(D).forEach(k=>{const e=document.getElementById(`s_${k.replace(/\s/g,"_")}`);s[k]=parseInt(e.value)||0});const h=H(p),r=await S({password:h,stock:s});r.success?(C(),A("s","Done","Reloading..."),setTimeout(()=>location.reload(),1200)):A("e","Error",r.error||"unknown")}async function pw(){const r=await G("password");r.success&&r.data?M(`<button class="close" onclick="C()">×</button><h2>🔐 Login</h2><label>Password</label><input type="password" id="ap" placeholder="Password" onkeydown="if(event.key==='Enter')login()"><div style="margin-top:16px;text-align:right"><button class="btn" onclick="login()">Login</button></div>`):await setup()}async function login(){const el=document.getElementById("ap"),v=el.value;if(!v)return;const r=await G("password");if(!r.success||!r.data)return A("e","Error","No password set"),void setTimeout(C,1000);if(H(v)===r.data){C();admin()}else{A("e","Error","Wrong password");el.value="";setTimeout(()=>el.focus(),100)}}async function admin(){const r=await G("stock");r.success&&r.data&&(stock=r.data,upd());const items=Object.keys(stock).sort().map(k=>`<div class="sr" data-i="${k}"><span class="nm">${k}</span><span class="sv" id="a_${k.replace(/\s/g,"_")}">${stock[k]}</span><div class="sbtns"><button class="m" onclick="adj('${k}',-1)">−</button><button class="p" onclick="adj('${k}',1)">+</button><button class="s" onclick="setP('${k}')">Set</button></div></div>`).join("");M(`<button class="close" onclick="C()">×</button><h2>📦 Stock</h2><input type="text" class="ss" id="sf" placeholder="🔍 Filter..." onkeyup="filter()"><div id="sl">${items}</div><div class="ps"><label>Change Password</label><div style="display:flex;gap:8px;flex-wrap:wrap"><input type="password" id="np" placeholder="New" style="flex:1;min-width:120px"><input type="password" id="cp" placeholder="Confirm" style="flex:1;min-width:120px"><button class="btn" onclick="chPw()">Update</button></div></div><div style="margin-top:16px;text-align:right"><button class="btn btn-s" onclick="C()">Close</button></div>`)}function filter(){const q=document.getElementById("sf").value.toLowerCase();document.querySelectorAll(".sr").forEach(el=>{el.style.display=el.dataset.i.toLowerCase().includes(q)?"":"none"})}async function adj(k,d){const n=Math.max(0,(stock[k]||0)+d);stock[k]=n;const el=document.getElementById(`a_${k.replace(/\s/g,"_")}`);el&&(el.textContent=n),await save(),upd()}async function setP(k){const cur=stock[k]||0;M(`<button class="close" onclick="C()">×</button><h2>Set ${k}</h2><label>Current: ${cur}</label><input type="number" id="si2" value="${cur}" min="0" step="1" style="margin-top:8px"><div style="margin-top:16px;text-align:right"><button class="btn btn-s" onclick="C()">Cancel</button><button class="btn" onclick="setC('${k}')">Set</button></div>`)}async function setC(k){const el=document.getElementById("si2");if(!el)return;const n=parseInt(el.value);if(isNaN(n)||n<0)return A("e","Error","Invalid number");stock[k]=n;const e=document.getElementById(`a_${k.replace(/\s/g,"_")}`);e&&(e.textContent=n),C(),await save(),upd()}async function save(){const r=await S({stock});r.success||A("e","Error",r.error||"unknown")}async function chPw(){const n=document.getElementById("np").value,c=document.getElementById("cp").value;if(!n||n.length<4)return A("e","Error","Min 4 chars");if(n!==c)return A("e","Error","Passwords don't match");const h=H(n),r=await S({password:h});r.success?(A("s","Success","Password updated"),document.getElementById("np").value="",document.getElementById("cp").value=""):A("e","Error",r.error||"unknown")}async function init(){const r=await G("password");if(!r.success||!r.data)return await setup();const s=await G("stock");s.success&&s.data?stock=s.data:(stock={...D},await save()),upd()}window.pw=pw;document.addEventListener("DOMContentLoaded",init);
</script>
