<style>*{box-sizing:border-box}body{background:#f7f2eb;color:#3d3228;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif;line-height:1.7;padding:1em;margin:0}.bh{font-size:2.2em;font-weight:700;color:#3d2c1e;text-shadow:0 2px 4px rgb(93 64 55/.08);letter-spacing:-.5px;border-bottom:3px solid #d4c5b2;padding-bottom:12px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:center}.st{font-size:1.15em;color:#7a6b5a;font-weight:400;letter-spacing:1px;margin-top:-4px;margin-bottom:20px}.h{font-size:1.5em;font-weight:600;color:#4a3728;margin-top:28px;margin-bottom:14px;border-left:4px solid #8b7355;padding-left:14px}.card{background:#fcf9f4;border:1px solid #e6ddd0;border-radius:12px;padding:20px 24px;margin:12px 0;box-shadow:0 2px 8px rgb(93 64 55/.06)}table{width:100%;border-collapse:collapse;background:#fcf9f4;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgb(93 64 55/.06);margin:12px 0;font-size:.95em}th{background:#5d4037;color:#f5efe8;font-weight:600;padding:12px 16px;text-align:left}td{padding:10px 16px;border-bottom:1px solid #ece5db;color:#4a3d30}tr:last-child td{border-bottom:none}ul{list-style:none;padding:0;margin:12px 0}li{padding:8px 12px 8px 36px;background:#fcf9f4;border-radius:8px;margin-bottom:6px;position:relative;border:1px solid #ece5db}li::before{content:"•";position:absolute;left:14px;top:8px;color:#8b7355;font-size:1.3em}.alert{border-radius:10px;padding:14px 18px;margin:16px 0;font-weight:500}.alert-info{background:#eef3ea;border-left:4px solid #7a9b6d;color:#3d5a34}.alert-warning{background:#fcf3e0;border-left:4px solid #d4a85a;color:#7a6438}.alert-success{background:#e8f0e0;border-left:4px solid #6d8f5e;color:#3a5a2e}.q{font-size:1.15em;font-style:italic;color:#5d4037;padding:16px 24px;background:#fcf9f4;border-radius:12px;border:1px solid #e6ddd0;margin:20px 0;text-align:center}.q::before{content:"\201C";font-size:1.8em;color:#b8a68b;margin-right:6px}.q::after{content:"\201D";font-size:1.8em;color:#b8a68b;margin-left:6px}.text{color:#4a3d30;line-height:1.8;padding:4px 0}.text em{color:#6d5f4e;font-style:italic}hr{border:none;height:2px;background:linear-gradient(to right,transparent,#d4c5b2,transparent);margin:28px 0}.badge{display:inline-block;padding:2px 10px;border-radius:12px;font-size:.8em;font-weight:600;margin-left:8px}.in{background:#d4edda;color:#155724}.low{background:#fff3cd;color:#856404}.out{background:#f8d7da;color:#721c24}.mo{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;z-index:1000;padding:20px;animation:fadeIn .3s}.mb{background:#fcf9f4;border-radius:16px;padding:30px;max-width:600px;width:100%;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.3)}.mb h2{margin-top:0;color:#3d2c1e;border-bottom:2px solid #d4c5b2;padding-bottom:12px}.mb label{display:block;margin:12px 0 4px;font-weight:600;color:#4a3728}.mb input[type="password"],.mb input[type="number"],.mb input[type="text"]{width:100%;padding:10px 14px;border:2px solid #d4c5b2;border-radius:8px;font-size:1em;background:#fff;box-sizing:border-box}.mb input:focus{border-color:#5d4037;outline:none}.btn{background:#5d4037;color:#f5efe8;border:none;padding:10px 24px;border-radius:8px;font-size:1em;font-weight:600;cursor:pointer;margin:8px 6px 0 0}.btn:hover{background:#4a3228}.btn-s{background:#d4c5b2;color:#3d3228}.btn-s:hover{background:#c4b5a2}.btn-d{background:#c0392b;color:#fff}.btn-d:hover{background:#a93226}.close{float:right;background:none;border:none;font-size:1.8em;cursor:pointer;color:#8b7355;padding:0 6px}.close:hover{color:#5d4037}.sr{display:flex;align-items:center;padding:6px 0;border-bottom:1px solid #ece5db}.sr:last-child{border-bottom:none}.sr .nm{flex:1;font-weight:500}.sr .sv{width:50px;text-align:center;font-weight:600}.sr .sbtns{display:flex;gap:4px}.sr .sbtns button{width:32px;height:32px;border:none;border-radius:6px;font-size:1.1em;font-weight:700;cursor:pointer}.sr .sbtns .m{background:#f8d7da;color:#721c24}.sr .sbtns .m:hover{background:#f5c6cb}.sr .sbtns .p{background:#d4edda;color:#155724}.sr .sbtns .p:hover{background:#c3e6cb}.sr .sbtns .s{background:#d4c5b2;color:#3d3228;width:auto;padding:0 12px}.sr .sbtns .s:hover{background:#c4b5a2}.ss{width:100%;padding:10px 14px;border:2px solid #d4c5b2;border-radius:8px;font-size:1em;margin-bottom:16px;background:#fff;box-sizing:border-box}.ss:focus{border-color:#5d4037;outline:none}.sg{display:grid;grid-template-columns:1fr 1fr;gap:8px 16px;max-height:300px;overflow-y:auto;padding:4px 0}.si{display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:1px solid #ece5db}.si label{font-weight:400;margin:0}.si input{width:60px;padding:4px 6px;border:1px solid #d4c5b2;border-radius:4px;text-align:center}.ps{border:1px solid #e6ddd0;border-radius:8px;padding:16px;margin:16px 0;background:#fcf9f4}.ps label{margin-top:0}.am{background:#f8f9fa;border-radius:8px;padding:16px 20px;margin:12px 0;border-left:4px solid #5d4037}.am.e{border-left-color:#c0392b;background:#fdf2f2}.am.s{border-left-color:#27ae60;background:#f0faf4}.am.i{border-left-color:#2980b9;background:#f0f7fc}.am.w{border-left-color:#f39c12;background:#fdf8f0}.am h4{margin:0 0 4px 0;color:#3d3228}.am p{margin:0;color:#4a3d30}@keyframes fadeIn{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:translateY(0)}}@media (max-width:600px){.bh{font-size:1.7em;flex-wrap:wrap}.h{font-size:1.3em}table{font-size:.85em}th,td{padding:8px 10px}.card{padding:16px 18px}.q{font-size:1em;padding:14px 16px}.sg{grid-template-columns:1fr}.mb{padding:20px}.sr{flex-wrap:wrap;gap:4px}.sr .nm{flex:1 1 100%}}</style>
<div id="app"><div class="bh">Homestead Shop <span style="font-size:0.5em;cursor:pointer;color:#8b7355;position:absolute;left:3px;top:1px" onclick="window.pw()">⚙️</span></div><div class="st">Off-Grid • Local • Trade Only</div><hr><div class="alert alert-info">📍 Located at 127 Ridge Road</div><hr><div class="h">🧺 Available This Week</div><table><thead><tr><th>Category</th><th>Item</th><th>Stock</th><th>Trade For</th></tr></thead><tbody><tr><td>Produce</td><td>Kale</td><td><span class="sd" data-i="Kale">-</span></td><td>Honey, eggs, candles</td></tr><tr><td>Produce</td><td>Swiss Chard</td><td><span class="sd" data-i="Swiss Chard">-</span></td><td>Honey, eggs, candles</td></tr><tr><td>Produce</td><td>Lettuce</td><td><span class="sd" data-i="Lettuce">-</span></td><td>Eggs, herbs</td></tr><tr><td>Produce</td><td>Garlic</td><td><span class="sd" data-i="Garlic">-</span></td><td>Candles, firewood</td></tr><tr><td>Produce</td><td>Onions</td><td><span class="sd" data-i="Onions">-</span></td><td>Candles, firewood</td></tr><tr><td>Produce</td><td>Potatoes</td><td><span class="sd" data-i="Potatoes">-</span></td><td>Beans, dried meat</td></tr><tr><td>Produce</td><td>Carrots</td><td><span class="sd" data-i="Carrots">-</span></td><td>Pickles, candles</td></tr><tr><td>Produce</td><td>Beets</td><td><span class="sd" data-i="Beets">-</span></td><td>Pickles, candles</td></tr><tr><td>Pantry</td><td>Apples</td><td><span class="sd" data-i="Apples">-</span></td><td>Honey, dried fruit</td></tr><tr><td>Pantry</td><td>Pears</td><td><span class="sd" data-i="Pears">-</span></td><td>Honey, dried fruit</td></tr><tr><td>Pantry</td><td>Honey</td><td><span class="sd" data-i="Honey">-</span></td><td>Beans, dried meat, firewood</td></tr><tr><td>Pantry</td><td>Eggs</td><td><span class="sd" data-i="Eggs">-</span></td><td>Firewood, dried beans</td></tr><tr><td>Pantry</td><td>Pickles</td><td><span class="sd" data-i="Pickles">-</span></td><td>Beans, candles</td></tr><tr><td>Pantry</td><td>Sourdough Starter