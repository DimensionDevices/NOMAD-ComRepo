{
  "description": "Child-friendly view-only UI. Hides all standard <details> sections off-screen and replaces the body with a calm, simple file list.",
  "target": "footer",
  "html": "<div id='nmdChildRoot'><div id='nmdChildHeader'><span id='nmdChildTitle'>Files</span></div><div id='nmdChildList'><div id='nmdChildEmpty' style='display:none;'>No files yet.</div></div></div>",
  "css": "body.nmd-child-active > details{position:absolute !important;left:-9999px !important;top:-9999px !important;width:1px !important;height:1px !important;overflow:hidden !important;} body.nmd-child-active > .container > details{position:absolute !important;left:-9999px !important;top:-9999px !important;width:1px !important;height:1px !important;overflow:hidden !important;} #nmdChildRoot{display:none;} body.nmd-child-active #nmdChildRoot{display:block;position:fixed;inset:0;z-index:500000;background:#f7f6f2;overflow-y:auto;font-family:inherit;} #nmdChildHeader{padding:22px 20px;background:#eef2ee;border-bottom:1px solid #dfe4de;} #nmdChildTitle{font-size:1.5em;font-weight:600;color:#3a4a3d;} #nmdChildList{padding:18px;display:flex;flex-direction:column;gap:14px;} .nmd-child-item{display:flex;align-items:center;gap:14px;background:#ffffff;border:1px solid #e2e6e0;border-radius:14px;padding:16px 18px;cursor:pointer;transition:background 0.15s;} .nmd-child-item:active{background:#eef2ee;} .nmd-child-icon{font-size:1.8em;flex-shrink:0;} .nmd-child-name{font-size:1.15em;color:#3a4a3d;font-weight:500;word-break:break-word;} #nmdChildEmpty{text-align:center;color:#8a9086;padding:40px 20px;font-size:1.1em;} body.nmd-child-active #fileModal{z-index:500001;}img{filter:blur(14px) !important}",
  "js": "(function(){function escapeHtml(str){var d=document.createElement('div');d.textContent=str==null?'':String(str);return d.innerHTML}function iconFor(name){var l=name.substring(name.lastIndexOf('.'));if(l==='.txt')return '📝';if(l==='.md')return '📋';if(l==='.com')return '🌐';if(l==='.img'||l==='.avif'||l==='.jpg'||l==='.jpeg'||l==='.png'||l==='.gif')return '🖼️';return '📄'}function activate(){document.body.classList.add('nmd-child-active');loadFiles()}function deactivate(){document.body.classList.remove('nmd-child-active')}async function loadFiles(){var list=document.getElementById('nmdChildList');var empty=document.getElementById('nmdChildEmpty');try{var r=await fetch('/api/files');var data=await r.json();var files=(data.files||[]).filter(function(f){var n=f.name.toLowerCase();return !n.endsWith('.ext')&&!n.endsWith('.thm')});list.innerHTML='';if(files.length===0){list.appendChild(empty);empty.style.display='block';return}files.forEach(function(f){var item=document.createElement('div');item.className='nmd-child-item';item.innerHTML='<span class=\"nmd-child-icon\">'+iconFor(f.name)+'</span><span class=\"nmd-child-name\">'+escapeHtml(f.name)+'</span>';item.addEventListener('click',function(){openFile(f.name)});list.appendChild(item)})}catch(e){list.innerHTML='<div id=\"nmdChildEmpty\">Could not load files.</div>'}}function openFile(name){if(typeof window.viewFile==='function'){window.viewFile(name)}}function attach(){document.addEventListener('click',function(e){var closeBtn=e.target.closest && e.target.closest('#fileModal .modal-close');if(closeBtn){var modal=document.getElementById('fileModal');if(modal)modal.style.display='none'}})}window.nmdChildMode=function(on){if(on===false){deactivate();return}activate()};attach();activate()})();"
}
