PAGE: TRON CYBER
COLOR: #00f3ff
AUTHOR: NOMAD
DATE: 2026-06-05
DESCRIPTION: Tron light cycles - surround your opponent. AI controlled, mobile friendly!
CUSTOMHTML-START
<style>*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}body{background:#050510;min-height:100vh;display:flex;justify-content:center;align-items:center;font-family:'Courier New','VT323',monospace;margin:0;padding:6px;touch-action:manipulation;}.game-wrapper{background:#000;border-radius:16px;padding:4px;box-shadow:0 0 0 1px #00f3ff,0 0 15px rgba(0,243,255,0.3);max-width:100%;}canvas{display:block;border-radius:8px;width:100%;height:auto;cursor:pointer;}.hud{margin-top:8px;display:flex;justify-content:space-between;background:#0a0a1a;padding:6px 12px;border-radius:20px;color:#0ff;font-weight:bold;font-size:12px;font-family:monospace;flex-wrap:wrap;gap:6px;}.hud span{color:#f0f;font-size:16px;}.tip{color:#0fa;font-size:9px;background:#0a0a1aaa;padding:4px 8px;border-radius:16px;margin-top:6px;text-align:center;}.touch-controls{display:flex;flex-direction:column;align-items:center;margin-top:10px;gap:8px;}.dpad-row{display:flex;justify-content:center;gap:12px;}.ctrl-btn{background:#1a1a3a;border:1.5px solid #0ff;color:#0ff;font-size:28px;width:60px;height:60px;border-radius:40px;display:flex;align-items:center;justify-content:center;cursor:pointer;touch-action:manipulation;user-select:none;font-weight:bold;box-shadow:0 0 8px rgba(0,255,255,0.3);transition:0.03s linear;}.ctrl-btn:active{transform:scale(0.92);background:#0ff;color:#000;}.restart-btn{background:#330000;border-color:#f33;color:#f66;font-size:14px;padding:6px 20px;width:auto;min-width:100px;}.restart-btn:active{background:#f33;color:#fff;}@media (max-width:550px){.ctrl-btn{width:50px;height:50px;font-size:24px;}.restart-btn{width:auto;padding:6px 16px;}}</style> <div class="game-wrapper"> <canvas id="gameCanvas" width="700" height="700"></canvas> <div class="hud"> <div>🟦 PLAYER: <span id="playerScore">0</span></div> <div class="status" id="gameStatus">▶ PRESS START</div> <div>🟥 AI: <span id="aiScore">0</span></div> </div> <div class="touch-controls"> <div class="dpad-row"> <div class="ctrl-btn" data-dir="up">▲</div> </div> <div class="dpad-row"> <div class="ctrl-btn" data-dir="left">◀</div> <button id="restartButton" class="ctrl-btn restart-btn">!</button> <div class="ctrl-btn" data-dir="right">▶</div> </div> <div class="dpad-row"> <div class="ctrl-btn" data-dir="down">▼</div> </div> </div> </div> <script>(function(){const canvas=document.getElementById('gameCanvas');const ctx=canvas.getContext('2d');let GRID_SIZE=35;let CELL_SIZE=canvas.width/GRID_SIZE;let gameRunning=true;let playerScore=0;let aiScore=0;let gameLoopId=null;let animationFrameId=null;let grid=Array(GRID_SIZE).fill().map(()=>Array(GRID_SIZE).fill(0));let player={x: 5,y: 17,dir: 'right',trail: [],alive: true,color: '#33ccff'};let ai={x: GRID_SIZE-6,y: 17,dir: 'left',trail: [],alive: true,color: '#ff3366'};const dirMap={'up':{dx: 0,dy:-1,opposite: 'down'},'down':{dx: 0,dy: 1,opposite: 'up'},'left':{dx:-1,dy: 0,opposite: 'right'},'right':{dx: 1,dy: 0,opposite: 'left'}};const dirOrder=['up','right','down','left'];function isValidMove(x,y){if(x<0 || x>=GRID_SIZE || y<0 || y>=GRID_SIZE)return false;return grid[x][y]===0;}function resetGame(){for(let i=0;i<GRID_SIZE;i++){for(let j=0;j<GRID_SIZE;j++){grid[i][j]=0;}}player={x: 5,y: Math.floor(GRID_SIZE/2),dir: 'right',trail: [{x: 5,y: Math.floor(GRID_SIZE/2)}],alive: true,color: '#33ccff'};ai={x: GRID_SIZE-6,y: Math.floor(GRID_SIZE/2),dir: 'left',trail: [{x: GRID_SIZE-6,y: Math.floor(GRID_SIZE/2)}],alive: true,color: '#ff3366'};grid[player.x][player.y]=1;grid[ai.x][ai.y]=2;gameRunning=true;pendingDir=null;document.getElementById('gameStatus').innerHTML='🏁 RACING';document.getElementById('gameStatus').style.color='#0ff';}function getAIMove(){if(!ai.alive)return ai.dir;let possibleMoves=[];for(let d of dirOrder){if(d===dirMap[ai.dir].opposite)continue;let nd=dirMap[d];let newX=ai.x+nd.dx;let newY=ai.y+nd.dy;if(isValidMove(newX,newY)){possibleMoves.push(d);}}if(possibleMoves.length===0)return ai.dir;let bestMove=possibleMoves[0];let bestScore=-Infinity;for(let move of possibleMoves){let nd=dirMap[move];let newX=ai.x+nd.dx;let newY=ai.y+nd.dy;let distToPlayer=Math.abs(newX-player.x)+Math.abs(newY-player.y);let chaseScore=(GRID_SIZE*2)-distToPlayer;let futureSafe=0;let nd2=dirMap[move];let step2X=newX+nd2.dx;let step2Y=newY+nd2.dy;if(isValidMove(step2X,step2Y))futureSafe+=3;let playerNearby=Math.abs(newX-player.x)<=2 && Math.abs(newY-player.y)<=2;let aggressiveBonus=playerNearby ? 15 : 0;let score=chaseScore+futureSafe+aggressiveBonus;if(score>bestScore){bestScore=score;bestMove=move;}}return bestMove;}function updateAI(){if(!ai.alive ||!gameRunning)return;let newDir=getAIMove();let move=dirMap[newDir];let newX=ai.x+move.dx;let newY=ai.y+move.dy;if(!isValidMove(newX,newY)){ai.alive=false;gameRunning=false;playerScore++;document.getElementById('playerScore').innerText=playerScore;document.getElementById('gameStatus').innerHTML='🎉 PLAYER WINS!';document.getElementById('gameStatus').style.color='#3f3';return;}ai.dir=newDir;ai.x=newX;ai.y=newY;ai.trail.push({x: ai.x,y: ai.y});grid[ai.x][ai.y]=2;if(ai.trail.length>GRID_SIZE*GRID_SIZE)ai.trail.shift();}let pendingDir=null;function updatePlayer(){if(!player.alive ||!gameRunning)return;let newDir=player.dir;if(pendingDir!==null && pendingDir!==dirMap[player.dir].opposite){newDir=pendingDir;}let move=dirMap[newDir];let newX=player.x+move.dx;let newY=player.y+move.dy;if(!isValidMove(newX,newY)){player.alive=false;gameRunning=false;aiScore++;document.getElementById('aiScore').innerText=aiScore;document.getElementById('gameStatus').innerHTML='💀 AI WINS!';document.getElementById('gameStatus').style.color='#f66';return;}player.dir=newDir;player.x=newX;player.y=newY;player.trail.push({x: player.x,y: player.y});grid[player.x][player.y]=1;if(player.trail.length>GRID_SIZE*GRID_SIZE)player.trail.shift();}function gameTick(){if(gameRunning){updatePlayer();updateAI();if(gameRunning &&(!player.alive ||!ai.alive)){gameRunning=false;if(!player.alive &&!ai.alive){document.getElementById('gameStatus').innerHTML='⚔️ DOUBLE KO!';document.getElementById('gameStatus').style.color='#ff0';}else if(!player.alive){aiScore++;document.getElementById('aiScore').innerText=aiScore;}else if(!ai.alive){playerScore++;document.getElementById('playerScore').innerText=playerScore;}}}}function draw(){CELL_SIZE=canvas.width/GRID_SIZE;ctx.clearRect(0,0,canvas.width,canvas.height);ctx.fillStyle='#050510';ctx.fillRect(0,0,canvas.width,canvas.height);ctx.strokeStyle='#0a2a3a';ctx.lineWidth=0.8;for(let i=0;i<=GRID_SIZE;i++){ctx.beginPath();ctx.moveTo(i*CELL_SIZE,0);ctx.lineTo(i*CELL_SIZE,canvas.height);ctx.stroke();ctx.moveTo(0,i*CELL_SIZE);ctx.lineTo(canvas.width,i*CELL_SIZE);ctx.stroke();}for(let i=0;i<player.trail.length;i++){let seg=player.trail[i];let intensity=0.3+(i/Math.max(1,player.trail.length))*0.7;ctx.fillStyle=`rgba(51,204,255,${intensity*0.85})`;ctx.fillRect(seg.x*CELL_SIZE,seg.y*CELL_SIZE,CELL_SIZE-1,CELL_SIZE-1);if(i===player.trail.length-1){ctx.fillStyle='#aaffff';ctx.fillRect(seg.x*CELL_SIZE,seg.y*CELL_SIZE,CELL_SIZE-1,CELL_SIZE-1);}}for(let i=0;i<ai.trail.length;i++){let seg=ai.trail[i];let intensity=0.3+(i/Math.max(1,ai.trail.length))*0.7;ctx.fillStyle=`rgba(255,51,102,${intensity*0.85})`;ctx.fillRect(seg.x*CELL_SIZE,seg.y*CELL_SIZE,CELL_SIZE-1,CELL_SIZE-1);if(i===ai.trail.length-1){ctx.fillStyle='#ffaacc';ctx.fillRect(seg.x*CELL_SIZE,seg.y*CELL_SIZE,CELL_SIZE-1,CELL_SIZE-1);}}ctx.shadowBlur=12;ctx.shadowColor='#0ff';ctx.fillStyle='#ffffff';ctx.fillRect(player.x*CELL_SIZE,player.y*CELL_SIZE,CELL_SIZE-1,CELL_SIZE-1);ctx.fillStyle=player.color;ctx.fillRect(player.x*CELL_SIZE+2,player.y*CELL_SIZE+2,CELL_SIZE-5,CELL_SIZE-5);ctx.shadowColor='#f0f';ctx.fillStyle='#ffffff';ctx.fillRect(ai.x*CELL_SIZE,ai.y*CELL_SIZE,CELL_SIZE-1,CELL_SIZE-1);ctx.fillStyle=ai.color;ctx.fillRect(ai.x*CELL_SIZE+2,ai.y*CELL_SIZE+2,CELL_SIZE-5,CELL_SIZE-5);ctx.shadowBlur=0;ctx.fillStyle="#fff";ctx.font=`bold ${Math.max(12,CELL_SIZE*0.5)}px monospace`;let arrow="→";if(player.dir==='up')arrow="↑";else if(player.dir==='down')arrow="↓";else if(player.dir==='left')arrow="←";else arrow="→";ctx.fillText(arrow,player.x*CELL_SIZE+CELL_SIZE*0.3,player.y*CELL_SIZE+CELL_SIZE*0.7);if(!gameRunning){ctx.font=`bold ${Math.max(18,CELL_SIZE*1.2)}px monospace`;ctx.fillStyle="#ffff00";ctx.shadowBlur=6;ctx.shadowColor="#000";let msg="";if(!player.alive &&!ai.alive)msg="⚡ DOUBLE KO ⚡";else if(!player.alive)msg="GAME OVER";else if(!ai.alive)msg="VICTORY!";ctx.fillText(msg,canvas.width/2-ctx.measureText(msg).width/2,canvas.height/2);}}function setPlayerDirection(dir){if(!gameRunning)return;if(dir==='up' && player.dir!=='down')pendingDir='up';else if(dir==='down' && player.dir!=='up')pendingDir='down';else if(dir==='left' && player.dir!=='right')pendingDir='left';else if(dir==='right' && player.dir!=='left')pendingDir='right';}window.addEventListener('keydown',(e)=>{const key=e.code;if(['ArrowUp','ArrowDown','ArrowLeft','ArrowRight','KeyW','KeyS','KeyA','KeyD','Space'].includes(key)){e.preventDefault();}if(key==='ArrowUp' || key==='KeyW')setPlayerDirection('up');if(key==='ArrowDown' || key==='KeyS')setPlayerDirection('down');if(key==='ArrowLeft' || key==='KeyA')setPlayerDirection('left');if(key==='ArrowRight' || key==='KeyD')setPlayerDirection('right');if(key==='Space'){resetGame();}});document.querySelectorAll('[data-dir]').forEach(btn=>{btn.addEventListener('click',(e)=>{e.preventDefault();e.stopPropagation();setPlayerDirection(btn.dataset.dir);});btn.addEventListener('touchstart',(e)=>{e.preventDefault();e.stopPropagation();setPlayerDirection(btn.dataset.dir);});});const restartBtn=document.getElementById('restartButton');if(restartBtn){restartBtn.addEventListener('click',(e)=>{e.preventDefault();e.stopPropagation();resetGame();});restartBtn.addEventListener('touchstart',(e)=>{e.preventDefault();e.stopPropagation();resetGame();});}let touchStart=null;canvas.addEventListener('touchstart',(e)=>{e.preventDefault();const rect=canvas.getBoundingClientRect();const scaleX=canvas.width/rect.width;const scaleY=canvas.height/rect.height;touchStart={x:(e.touches[0].clientX-rect.left)*scaleX,y:(e.touches[0].clientY-rect.top)*scaleY};});canvas.addEventListener('touchend',(e)=>{if(!touchStart)return;e.preventDefault();const rect=canvas.getBoundingClientRect();const scaleX=canvas.width/rect.width;const scaleY=canvas.height/rect.height;const endX=(e.changedTouches[0].clientX-rect.left)*scaleX;const endY=(e.changedTouches[0].clientY-rect.top)*scaleY;const dx=endX-touchStart.x;const dy=endY-touchStart.y;if(Math.abs(dx)<15 && Math.abs(dy)<15)return;if(Math.abs(dx)>Math.abs(dy)){if(dx>0)setPlayerDirection('right');else setPlayerDirection('left');}else{if(dy>0)setPlayerDirection('down');else setPlayerDirection('up');}touchStart=null;});canvas.addEventListener('touchcancel',(e)=>{touchStart=null;});let lastTick=0;const TICK_INTERVAL=110;let accumulator=0;function gameLoop(now){animationFrameId=requestAnimationFrame(gameLoop);let delta=Math.min(100,now-lastTick);if(delta>0){accumulator+=delta;while(accumulator>=TICK_INTERVAL && gameRunning){gameTick();accumulator-=TICK_INTERVAL;}draw();}lastTick=now;}function handleResize(){let size=Math.min(window.innerWidth-20,700);canvas.style.width=`${size}px`;canvas.style.height=`${size}px`;canvas.width=size;canvas.height=size;CELL_SIZE=canvas.width/GRID_SIZE;draw();}window.addEventListener('resize',handleResize);handleResize();resetGame();lastTick=performance.now();gameLoop(lastTick);})();</script>
CUSTOMHTML-END