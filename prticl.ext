{
  "description": "Dynamic particle overlay with blend mode cycling",
  "html": "<canvas id='particleCanvas' style='position:fixed;top:0;left:0;width:100%;opacity:0.5;height:100%;pointer-events:none;z-index:9999;mix-blend-mode:multiply;'></canvas><div id='blendCog' style='position:fixed;bottom:0px;left:10px;z-index:10000;cursor:pointer;pointer-events:auto;font-size:28px;color:var(--text-dim);opacity:0.25;transition:opacity 0.3s;' onmouseover='this.style.opacity=1' onmouseout='this.style.opacity=0.4' onclick='cycleBlendMode()'>⚙</div>",
  "css": "",
  "js": "(function(){var canvas=document.getElementById('particleCanvas');if(!canvas)return;var ctx=canvas.getContext('2d');var particles=[];var mouseX=-1000;var mouseY=-1000;var W,H;var blendModes=['multiply','screen','overlay','hard-light'];var currentBlendIndex=0;function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight;}window.addEventListener('resize',resize);resize();document.addEventListener('mousemove',function(e){mouseX=e.clientX;mouseY=e.clientY;});window.cycleBlendMode=function(){currentBlendIndex=(currentBlendIndex+1)%blendModes.length;canvas.style.mixBlendMode=blendModes[currentBlendIndex];var cog=document.getElementById('blendCog');if(cog){cog.style.transform='rotate('+(currentBlendIndex*90)+'deg)';cog.style.transition='transform 0.4s ease';}};function Particle(){this.x=Math.random()*W;this.y=Math.random()*H;this.size=Math.random()*3+1;this.speedX=(Math.random()-0.5)*1.5;this.speedY=(Math.random()-0.5)*1.5;this.opacity=Math.random()*0.5+0.3;}Particle.prototype.update=function(){var dx=mouseX-this.x;var dy=mouseY-this.y;var dist=Math.sqrt(dx*dx+dy*dy);if(dist<200&&dist>0){var force=(200-dist)/200*1.5;this.speedX+=(dx/dist)*force*0.05;this.speedY+=(dy/dist)*force*0.05;}this.x+=this.speedX;this.y+=this.speedY;this.speedX*=0.995;this.speedY*=0.995;if(this.x<0||this.x>W)this.speedX*=-1;if(this.y<0||this.y>H)this.speedY*=-1;this.x=Math.max(0,Math.min(W,this.x));this.y=Math.max(0,Math.min(H,this.y));};Particle.prototype.draw=function(){ctx.beginPath();ctx.arc(this.x,this.y,this.size,0,Math.PI*2);var r=44/255;var g=62/255;var b=45/255;ctx.fillStyle='rgba('+Math.round(r*255)+','+Math.round(g*255)+','+Math.round(b*255)+','+this.opacity+')';ctx.fill();};for(var i=0;i<80;i++){particles.push(new Particle());}function drawConnections(){for(var i=0;i<particles.length;i++){for(var j=i+1;j<particles.length;j++){var dx=particles[i].x-particles[j].x;var dy=particles[i].y-particles[j].y;var dist=Math.sqrt(dx*dx+dy*dy);if(dist<150){var opacity=(150-dist)/150*0.3;ctx.beginPath();ctx.moveTo(particles[i].x,particles[i].y);ctx.lineTo(particles[j].x,particles[j].y);var r=44/255;var g=62/255;var b=45/255;ctx.strokeStyle='rgba('+Math.round(r*255)+','+Math.round(g*255)+','+Math.round(b*255)+','+opacity+')';ctx.lineWidth=0.5;ctx.stroke();}}}}function drawMouseGlow(){if(mouseX>0&&mouseY>0){var gradient=ctx.createRadialGradient(mouseX,mouseY,0,mouseX,mouseY,150);var r=44/255;var g=62/255;var b=45/255;gradient.addColorStop(0,'rgba('+Math.round(r*255)+','+Math.round(g*255)+','+Math.round(b*255)+',0.08)');gradient.addColorStop(1,'rgba('+Math.round(r*255)+','+Math.round(g*255)+','+Math.round(b*255)+',0)');ctx.fillStyle=gradient;ctx.fillRect(mouseX-150,mouseY-150,300,300);}}function animate(){ctx.clearRect(0,0,W,H);drawMouseGlow();for(var i=0;i<particles.length;i++){particles[i].update();particles[i].draw();}drawConnections();requestAnimationFrame(animate);}animate();var resizeTimeout;window.addEventListener('resize',function(){clearTimeout(resizeTimeout);resizeTimeout=setTimeout(resize,100);});})();",
  "target": "footer"
}