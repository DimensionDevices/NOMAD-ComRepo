{
  "description": "Kiosk / wall-display mode. Hides all interactive UI and cycles full-screen status slides with smooth transitions, tap-to-advance, and a theme picker (dark, light, high contrast, warm, neon).",
  "target": "footer",
  "html": "<div id='nmdKiosk' data-theme='dark'><div id='nmdKioskBg'></div><button id='nmdKioskThemeBtn' aria-label='Theme'></button><div id='nmdKioskThemePopup'><div class='nmd-kiosk-theme-opt' data-theme-choice='dark'><span class='nmd-kiosk-swatch' data-swatch='dark'></span>Dark</div><div class='nmd-kiosk-theme-opt' data-theme-choice='light'><span class='nmd-kiosk-swatch' data-swatch='light'></span>Light</div><div class='nmd-kiosk-theme-opt' data-theme-choice='contrast'><span class='nmd-kiosk-swatch' data-swatch='contrast'></span>High Contrast</div><div class='nmd-kiosk-theme-opt' data-theme-choice='warm'><span class='nmd-kiosk-swatch' data-swatch='warm'></span>Warm</div><div class='nmd-kiosk-theme-opt' data-theme-choice='neon'><span class='nmd-kiosk-swatch' data-swatch='neon'></span>Neon</div></div><div id='nmdKioskSlideWrap'><div id='nmdKioskSlide'><div id='nmdKioskIcon'></div><div id='nmdKioskLabel'></div><div id='nmdKioskValue'></div><div id='nmdKioskSub'></div></div></div><div id='nmdKioskProgress'></div><div id='nmdKioskHint'>Tap to continue</div></div>",
  "css": "body.nmd-kiosk-active > details{position:absolute !important;left:-9999px !important;top:-9999px !important;width:1px !important;height:1px !important;overflow:hidden !important;} body.nmd-kiosk-active > .container > details{position:absolute !important;left:-9999px !important;top:-9999px !important;width:1px !important;height:1px !important;overflow:hidden !important;} body.nmd-kiosk-active #circularMenu{display:none !important;} #nmdKiosk{display:none;--k-bg1:#2c332d;--k-bg2:#181c19;--k-bg3:#101310;--k-text:#f5f6f3;--k-value-grad1:#ffffff;--k-value-grad2:#c9d6c9;--k-accent:#8bc98b;--k-bar-track:rgba(255,255,255,0.15);--k-bar-done:rgba(255,255,255,0.4);--k-popup-bg:#22271f;--k-popup-border:rgba(255,255,255,0.12);} body.nmd-kiosk-active #nmdKiosk{display:flex;position:fixed;inset:0;z-index:600000;color:var(--k-text);flex-direction:column;align-items:center;justify-content:center;font-family:inherit;text-align:center;overflow:hidden;cursor:pointer;user-select:none;-webkit-user-select:none;} #nmdKiosk[data-theme='light']{--k-bg1:#f7f6f2;--k-bg2:#e9e8e2;--k-bg3:#dedcd4;--k-text:#2c332d;--k-value-grad1:#2c332d;--k-value-grad2:#547540;--k-accent:#547540;--k-bar-track:rgba(0,0,0,0.12);--k-bar-done:rgba(0,0,0,0.3);--k-popup-bg:#ffffff;--k-popup-border:rgba(0,0,0,0.1);} #nmdKiosk[data-theme='contrast']{--k-bg1:#000000;--k-bg2:#000000;--k-bg3:#000000;--k-text:#ffffff;--k-value-grad1:#ffff00;--k-value-grad2:#ffff00;--k-accent:#ffff00;--k-bar-track:rgba(255,255,255,0.25);--k-bar-done:#ffff00;--k-popup-bg:#000000;--k-popup-border:#ffff00;} #nmdKiosk[data-theme='warm']{--k-bg1:#3d2b1f;--k-bg2:#2a1c13;--k-bg3:#1c110a;--k-text:#f4e3d0;--k-value-grad1:#ffd9a0;--k-value-grad2:#e8a15c;--k-accent:#e8a15c;--k-bar-track:rgba(255,217,160,0.15);--k-bar-done:rgba(255,217,160,0.4);--k-popup-bg:#2a1c13;--k-popup-border:rgba(255,217,160,0.2);} #nmdKiosk[data-theme='neon']{--k-bg1:#1a0b2e;--k-bg2:#10081f;--k-bg3:#05030c;--k-text:#e8e6ff;--k-value-grad1:#ff2fd4;--k-value-grad2:#5df1ff;--k-accent:#5df1ff;--k-bar-track:rgba(93,241,255,0.15);--k-bar-done:#ff2fd4;--k-popup-bg:#150826;--k-popup-border:rgba(93,241,255,0.3);} #nmdKioskBg{position:absolute;inset:-10%;background:radial-gradient(circle at 30% 20%,var(--k-bg1) 0%,var(--k-bg2) 55%,var(--k-bg3) 100%);transition:background 0.4s ease;z-index:0;} #nmdKioskSlideWrap{position:relative;z-index:1;width:100%;max-width:640px;padding:0 32px;perspective:800px;} #nmdKioskSlide{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;opacity:0;transform:translateY(18px) scale(0.97);transition:opacity 0.5s cubic-bezier(.22,.61,.36,1),transform 0.5s cubic-bezier(.22,.61,.36,1);} #nmdKioskSlide.nmd-kiosk-in{opacity:1;transform:translateY(0) scale(1);} #nmdKioskIcon{font-size:3em;opacity:0.9;filter:drop-shadow(0 4px 12px rgba(0,0,0,0.35));} #nmdKioskLabel{font-size:1.15em;letter-spacing:3px;text-transform:uppercase;opacity:0.55;font-weight:600;} #nmdKioskValue{font-size:5.5em;font-weight:800;line-height:1;letter-spacing:-1px;background:linear-gradient(180deg,var(--k-value-grad1),var(--k-value-grad2));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;transition:font-size 0.3s ease,background 0.4s ease;} #nmdKioskValue.nmd-kiosk-value-sm{font-size:2.4em;letter-spacing:0;} #nmdKioskSub{font-size:1.2em;opacity:0.6;font-weight:500;} #nmdKioskProgress{position:absolute;bottom:44px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:1;} .nmd-kiosk-bar{width:34px;height:4px;border-radius:2px;background:var(--k-bar-track);overflow:hidden;position:relative;} .nmd-kiosk-bar-fill{position:absolute;left:0;top:0;bottom:0;width:0%;background:var(--k-accent);border-radius:2px;} .nmd-kiosk-bar.nmd-kiosk-done .nmd-kiosk-bar-fill{width:100%;background:var(--k-bar-done);} #nmdKioskHint{position:absolute;bottom:16px;left:50%;transform:translateX(-50%);font-size:0.75em;opacity:0.3;letter-spacing:1px;text-transform:uppercase;z-index:1;} #nmdKioskThemeBtn{position:absolute;top:18px;right:18px;width:26px;height:26px;border-radius:6px;border:1.5px solid var(--k-popup-border);background:var(--k-accent);opacity:0.55;cursor:pointer;z-index:3;padding:0;transition:opacity 0.2s ease;} #nmdKioskThemeBtn:hover{opacity:0.9;} #nmdKioskThemePopup{position:absolute;top:52px;right:18px;z-index:4;background:var(--k-popup-bg);border:1px solid var(--k-popup-border);border-radius:12px;padding:8px;display:none;flex-direction:column;gap:2px;min-width:170px;box-shadow:0 8px 24px rgba(0,0,0,0.4);text-align:left;} #nmdKioskThemePopup.nmd-kiosk-popup-open{display:flex;} .nmd-kiosk-theme-opt{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;font-size:0.85em;color:var(--k-text);cursor:pointer;} .nmd-kiosk-theme-opt:hover{background:rgba(128,128,128,0.15);} .nmd-kiosk-theme-opt.nmd-kiosk-theme-active{background:rgba(128,128,128,0.25);font-weight:700;} .nmd-kiosk-swatch{width:16px;height:16px;border-radius:4px;flex-shrink:0;border:1px solid rgba(128,128,128,0.4);} .nmd-kiosk-swatch[data-swatch='dark']{background:linear-gradient(135deg,#2c332d,#101310);} .nmd-kiosk-swatch[data-swatch='light']{background:linear-gradient(135deg,#f7f6f2,#dedcd4);} .nmd-kiosk-swatch[data-swatch='contrast']{background:#000;box-shadow:inset 0 0 0 2px #ffff00;} .nmd-kiosk-swatch[data-swatch='warm']{background:linear-gradient(135deg,#ffd9a0,#3d2b1f);} .nmd-kiosk-swatch[data-swatch='neon']{background:linear-gradient(135deg,#ff2fd4,#5df1ff);}",
  "js": "(function(){var SLIDE_MS=6000;var POLL_MS=10000;var THEME_KEY='nmd_kiosk_theme';var idx=0;var latestStatus=null;var timer=null;var slides=[];var ICONS={'Duty Cycle':'📡','Storage':'💾','Free Memory':'🧠','Nearby Nodes':'🛰️','Local Files':'🗂️','Temperature':'🌡️','LoRa Config':'📶','Network':'🌐'};function readStatCard(label){var cards=document.querySelectorAll('.stat-card');for(var i=0;i<cards.length;i++){var lab=cards[i].querySelector('.stat-label');if(lab&&lab.textContent.trim()===label){var val=cards[i].querySelector('.stat-value');return val?val.textContent.trim():null}}return null}function mdnsHostFromNodeId(nodeId){if(!nodeId||nodeId.length<=4)return null;return 'NMD'+nodeId.substring(4)+'.local'}function tempColorSub(t){if(t<40)return 'cool and steady';if(t<50)return 'normal range';if(t<60)return 'warm, keep an eye on it';if(t<70)return 'running hot';if(t<80)return 'high \u2014 check ventilation';return 'critical \u2014 needs attention'}function slidesFromData(){var s=[];if(!latestStatus)return s;s.push({label:'Duty Cycle',value:(latestStatus.dutyCycle||0).toFixed(1)+'%',sub:'LoRa transmit usage'});if(latestStatus.storage&&!latestStatus.storage.error&&latestStatus.storage.totalKB){var p=((latestStatus.storage.usedKB||0)/latestStatus.storage.totalKB*100).toFixed(0);s.push({label:'Storage',value:p+'%',sub:(latestStatus.storage.usedKB||0)+' / '+latestStatus.storage.totalKB+' kB used'})}if(latestStatus.freeHeap!==undefined){s.push({label:'Free Memory',value:Math.round(latestStatus.freeHeap/1024)+' kB',sub:'available heap'})}if(latestStatus.temperature!==undefined){s.push({label:'Temperature',value:latestStatus.temperature.toFixed(1)+'\u00b0C',sub:tempColorSub(latestStatus.temperature)})}var freq=readStatCard('LoRa Frequency');var sf=readStatCard('Spreading Factor');if(freq||sf){s.push({label:'LoRa Config',value:(freq||'\u2013'),sub:(sf?sf:'')+(freq&&sf?' \u00b7 ':'')+'radio settings'})}s.push({label:'Nearby Nodes',value:String(latestStatus.nodeCount||0),sub:'devices in range'});s.push({label:'Local Files',value:String(latestStatus.fileCount||0),sub:'stored on device'});var mdnsHost=mdnsHostFromNodeId(latestStatus.nodeId);var netSub=[];if(latestStatus.staIP)netSub.push('IP '+latestStatus.staIP);if(mdnsHost)netSub.push(mdnsHost);s.push({label:'Network',value:latestStatus.nodeId||'\u2013',sub:netSub.length?netSub.join(' \u00b7 '):'not connected to a router'});return s}function renderProgress(){var wrap=document.getElementById('nmdKioskProgress');if(!wrap)return;wrap.innerHTML='';slides.forEach(function(_,i){var bar=document.createElement('div');bar.className='nmd-kiosk-bar'+(i<idx?' nmd-kiosk-done':'');var fill=document.createElement('div');fill.className='nmd-kiosk-bar-fill';fill.id='nmd-kiosk-fill-'+i;bar.appendChild(fill);wrap.appendChild(bar)})}function animateCurrentBar(){var fill=document.getElementById('nmd-kiosk-fill-'+idx);if(!fill)return;fill.style.transition='none';fill.style.width='0%';void fill.offsetWidth;fill.style.transition='width '+SLIDE_MS+'ms linear';fill.style.width='100%'}function showSlide(){if(slides.length===0)return;if(idx>=slides.length)idx=0;if(idx<0)idx=slides.length-1;var s=slides[idx];var icon=document.getElementById('nmdKioskIcon');var lab=document.getElementById('nmdKioskLabel');var val=document.getElementById('nmdKioskValue');var sub=document.getElementById('nmdKioskSub');var slide=document.getElementById('nmdKioskSlide');if(!lab||!val||!sub||!slide||!icon)return;slide.classList.remove('nmd-kiosk-in');setTimeout(function(){icon.textContent=ICONS[s.label]||'✨';lab.textContent=s.label;val.textContent=s.value;val.classList.toggle('nmd-kiosk-value-sm',s.label==='Network');sub.textContent=s.sub;renderProgress();animateCurrentBar();requestAnimationFrame(function(){requestAnimationFrame(function(){slide.classList.add('nmd-kiosk-in')})})},260)}function resetTimer(){if(timer)clearInterval(timer);timer=setInterval(advance,SLIDE_MS)}function advance(){idx++;showSlide()}function goNext(){advance();resetTimer()}async function poll(){try{var r=await fetch('/api/status');if(r.ok){latestStatus=await r.json();var wasEmpty=slides.length===0;slides=slidesFromData();if(wasEmpty&&slides.length>0){showSlide();resetTimer()}}}catch(e){}}function getSavedTheme(){try{return localStorage.getItem(THEME_KEY)||'dark'}catch(e){return 'dark'}}function saveTheme(name){try{localStorage.setItem(THEME_KEY,name)}catch(e){}}function applyTheme(name){var el=document.getElementById('nmdKiosk');if(!el)return;el.setAttribute('data-theme',name);document.querySelectorAll('.nmd-kiosk-theme-opt').forEach(function(opt){opt.classList.toggle('nmd-kiosk-theme-active',opt.getAttribute('data-theme-choice')===name)})}function togglePopup(force){var popup=document.getElementById('nmdKioskThemePopup');if(!popup)return;if(force===false){popup.classList.remove('nmd-kiosk-popup-open');return}popup.classList.toggle('nmd-kiosk-popup-open')}function onTap(e){if(e.target.closest('#nmdKioskThemeBtn')){e.stopPropagation();togglePopup();return}if(e.target.closest('#nmdKioskThemePopup')){e.stopPropagation();var opt=e.target.closest('.nmd-kiosk-theme-opt');if(opt){var choice=opt.getAttribute('data-theme-choice');applyTheme(choice);saveTheme(choice);togglePopup(false)}return}togglePopup(false);goNext()}function activate(){document.body.classList.add('nmd-kiosk-active');applyTheme(getSavedTheme());poll();setInterval(poll,POLL_MS);var el=document.getElementById('nmdKiosk');if(el)el.addEventListener('click',onTap)}function deactivate(){document.body.classList.remove('nmd-kiosk-active');if(timer){clearInterval(timer);timer=null}var el=document.getElementById('nmdKiosk');if(el)el.removeEventListener('click',onTap)}window.nmdKioskMode=function(on){if(on===false){deactivate();return}activate()};activate()})();"
}