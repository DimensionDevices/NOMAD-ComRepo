{
  "description": "Kiosk / wall-display mode. Hides all interactive UI and cycles full-screen status slides (nodes, storage, duty cycle, memory, files) with a smooth transition, auto-advance progress bar, and tap-to-advance.",
  "target": "footer",
  "html": "<div id='nmdKiosk'><div id='nmdKioskBg'></div><div id='nmdKioskSlideWrap'><div id='nmdKioskSlide'><div id='nmdKioskIcon'></div><div id='nmdKioskLabel'></div><div id='nmdKioskValue'></div><div id='nmdKioskSub'></div></div></div><div id='nmdKioskProgress'></div><div id='nmdKioskHint'>Tap to continue</div></div>",
  "css": "body.nmd-kiosk-active > details{position:absolute !important;left:-9999px !important;top:-9999px !important;width:1px !important;height:1px !important;overflow:hidden !important;} body.nmd-kiosk-active > .container > details{position:absolute !important;left:-9999px !important;top:-9999px !important;width:1px !important;height:1px !important;overflow:hidden !important;} body.nmd-kiosk-active #circularMenu{display:none !important;} #nmdKiosk{display:none;} body.nmd-kiosk-active #nmdKiosk{display:flex;position:fixed;inset:0;z-index:600000;color:#f5f6f3;flex-direction:column;align-items:center;justify-content:center;font-family:inherit;text-align:center;overflow:hidden;cursor:pointer;user-select:none;-webkit-user-select:none;} #nmdKioskBg{position:absolute;inset:-10%;background:radial-gradient(circle at 30% 20%,#2c332d 0%,#181c19 55%,#101310 100%);transition:filter 0.5s ease;z-index:0;} #nmdKioskSlideWrap{position:relative;z-index:1;width:100%;max-width:640px;padding:0 32px;perspective:800px;} #nmdKioskSlide{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;opacity:0;transform:translateY(18px) scale(0.97);transition:opacity 0.5s cubic-bezier(.22,.61,.36,1),transform 0.5s cubic-bezier(.22,.61,.36,1);} #nmdKioskSlide.nmd-kiosk-in{opacity:1;transform:translateY(0) scale(1);} #nmdKioskIcon{font-size:3em;opacity:0.9;filter:drop-shadow(0 4px 12px rgba(0,0,0,0.35));} #nmdKioskLabel{font-size:1.15em;letter-spacing:3px;text-transform:uppercase;opacity:0.55;font-weight:600;} #nmdKioskValue{font-size:5.5em;font-weight:800;line-height:1;letter-spacing:-1px;background:linear-gradient(180deg,#ffffff,#c9d6c9);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;transition:font-size 0.3s ease;} #nmdKioskValue.nmd-kiosk-value-sm{font-size:2.4em;letter-spacing:0;} #nmdKioskSub{font-size:1.2em;opacity:0.6;font-weight:500;} #nmdKioskProgress{position:absolute;bottom:44px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:1;} .nmd-kiosk-bar{width:34px;height:4px;border-radius:2px;background:rgba(255,255,255,0.15);overflow:hidden;position:relative;} .nmd-kiosk-bar-fill{position:absolute;left:0;top:0;bottom:0;width:0%;background:#8bc98b;border-radius:2px;} .nmd-kiosk-bar.nmd-kiosk-done .nmd-kiosk-bar-fill{width:100%;background:rgba(255,255,255,0.4);} #nmdKioskHint{position:absolute;bottom:16px;left:50%;transform:translateX(-50%);font-size:0.75em;opacity:0.3;letter-spacing:1px;text-transform:uppercase;z-index:1;}",
  "js": "(function(){var SLIDE_MS=6000;var POLL_MS=10000;var idx=0;var latestStatus=null;var timer=null;var barTimer=null;var barStart=0;var slides=[];var ICONS={'Duty Cycle':'📡','Storage':'💾','Free Memory':'🧠','Nearby Nodes':'🛰️','Local Files':'🗂️','Temperature':'🌡️','LoRa Config':'📶','Network':'🌐'};function readStatCard(label){var cards=document.querySelectorAll('.stat-card');for(var i=0;i<cards.length;i++){var lab=cards[i].querySelector('.stat-label');if(lab&&lab.textContent.trim()===label){var val=cards[i].querySelector('.stat-value');return val?val.textContent.trim():null}}return null}function mdnsHostFromNodeId(nodeId){if(!nodeId||nodeId.length<=4)return null;return 'NMD'+nodeId.substring(4)+'.local'}function tempColorSub(t){if(t<40)return 'cool and steady';if(t<50)return 'normal range';if(t<60)return 'warm, keep an eye on it';if(t<70)return 'running hot';if(t<80)return 'high \u2014 check ventilation';return 'critical \u2014 needs attention'}function slidesFromData(){var s=[];if(!latestStatus)return s;s.push({label:'Duty Cycle',value:(latestStatus.dutyCycle||0).toFixed(1)+'%',sub:'LoRa transmit usage'});if(latestStatus.storage&&!latestStatus.storage.error&&latestStatus.storage.totalKB){var p=((latestStatus.storage.usedKB||0)/latestStatus.storage.totalKB*100).toFixed(0);s.push({label:'Storage',value:p+'%',sub:(latestStatus.storage.usedKB||0)+' / '+latestStatus.storage.totalKB+' kB used'})}if(latestStatus.freeHeap!==undefined){s.push({label:'Free Memory',value:Math.round(latestStatus.freeHeap/1024)+' kB',sub:'available heap'})}if(latestStatus.temperature!==undefined){s.push({label:'Temperature',value:latestStatus.temperature.toFixed(1)+'\u00b0C',sub:tempColorSub(latestStatus.temperature)})}var freq=readStatCard('LoRa Frequency');var sf=readStatCard('Spreading Factor');if(freq||sf){s.push({label:'LoRa Config',value:(freq||'\u2013'),sub:(sf?sf:'')+(freq&&sf?' \u00b7 ':'')+'radio settings'})}s.push({label:'Nearby Nodes',value:String(latestStatus.nodeCount||0),sub:'devices in range'});s.push({label:'Local Files',value:String(latestStatus.fileCount||0),sub:'stored on device'});var mdnsHost=mdnsHostFromNodeId(latestStatus.nodeId);var netSub=[];if(latestStatus.staIP)netSub.push('IP '+latestStatus.staIP);if(mdnsHost)netSub.push(mdnsHost);s.push({label:'Network',value:latestStatus.nodeId||'\u2013',sub:netSub.length?netSub.join(' \u00b7 '):'not connected to a router'});return s}function renderProgress(){var wrap=document.getElementById('nmdKioskProgress');if(!wrap)return;wrap.innerHTML='';slides.forEach(function(_,i){var bar=document.createElement('div');bar.className='nmd-kiosk-bar'+(i<idx?' nmd-kiosk-done':'');var fill=document.createElement('div');fill.className='nmd-kiosk-bar-fill';fill.id='nmd-kiosk-fill-'+i;bar.appendChild(fill);wrap.appendChild(bar)})}function animateCurrentBar(){var fill=document.getElementById('nmd-kiosk-fill-'+idx);if(!fill)return;fill.style.transition='none';fill.style.width='0%';void fill.offsetWidth;fill.style.transition='width '+SLIDE_MS+'ms linear';fill.style.width='100%'}function showSlide(){if(slides.length===0)return;if(idx>=slides.length)idx=0;if(idx<0)idx=slides.length-1;var s=slides[idx];var icon=document.getElementById('nmdKioskIcon');var lab=document.getElementById('nmdKioskLabel');var val=document.getElementById('nmdKioskValue');var sub=document.getElementById('nmdKioskSub');var slide=document.getElementById('nmdKioskSlide');if(!lab||!val||!sub||!slide||!icon)return;slide.classList.remove('nmd-kiosk-in');setTimeout(function(){icon.textContent=ICONS[s.label]||'✨';lab.textContent=s.label;val.textContent=s.value;val.classList.toggle('nmd-kiosk-value-sm',s.label==='Network');sub.textContent=s.sub;renderProgress();animateCurrentBar();requestAnimationFrame(function(){requestAnimationFrame(function(){slide.classList.add('nmd-kiosk-in')})})},260)}function resetTimer(){if(timer)clearInterval(timer);timer=setInterval(advance,SLIDE_MS)}function advance(){idx++;showSlide()}function goNext(){advance();resetTimer()}async function poll(){try{var r=await fetch('/api/status');if(r.ok){latestStatus=await r.json();var wasEmpty=slides.length===0;slides=slidesFromData();if(wasEmpty&&slides.length>0){showSlide();resetTimer()}}}catch(e){}}function onTap(e){goNext()}function activate(){document.body.classList.add('nmd-kiosk-active');poll();setInterval(poll,POLL_MS);var el=document.getElementById('nmdKiosk');if(el)el.addEventListener('click',onTap)}function deactivate(){document.body.classList.remove('nmd-kiosk-active');if(timer){clearInterval(timer);timer=null}var el=document.getElementById('nmdKiosk');if(el)el.removeEventListener('click',onTap)}window.nmdKioskMode=function(on){if(on===false){deactivate();return}activate()};activate()})();"
}
