{
  "description":"Adds a simple customisable clock to the main screen, change the font/colours/size.",
  "html": "<details class='section' id='clockDetails' open>\n  <summary>\n    <h2 style='opacity:1;margin-right:0;'>\n      <svg style='position:relative;top:6px' width='24px' height='24px' viewBox='0 0 24 24' fill='none' stroke='var(--text)' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>\n        <circle cx='12' cy='12' r='10'></circle>\n        <polyline points='12 6 12 12 16 14'></polyline>\n      </svg>\n      &nbsp;<span id='clockDisplay' style='font-size:1.25em;'>--:--:--</span>\n      <span style='font-size:0.7rem;font-weight:normal;opacity:0.5;margin-left:8px;' id='clockDate'></span>\n    </h2>\n  </summary>\n  <div style='padding:0;display:flex;justify-content:center;align-items:center;flex-direction:column;'>\n    <div id='clockFace' style='font-size:3.5rem;font-weight:300;letter-spacing:2px;font-family:monospace;text-align:center;padding:12px 0;padding-bottom:0;'>\n      <span id='clockHours'>00</span><span id='clockColon'>:</span><span id='clockMinutes'>00</span><span id='clockSecondsDisplay'>:<span id='clockSeconds'>00</span></span>\n    </div>\n    <div id='clockDateDisplay' style='font-size:0.9rem;opacity:0.6;letter-spacing:1px;'></div>\n  </div>\n    <button onclick='event.stopPropagation();openClockSettings()' style='opacity:0.3;background:none;border:none;cursor:pointer;font-size:16px;margin-left:auto;' title='Clock Settings'>\n      <svg width='18px' height='18px' viewBox='0 0 24 24' fill='none' stroke='var(--text)' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>\n        <circle cx='12' cy='12' r='3'></circle>\n        <path d='M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z'></path>\n      </svg>\n    </button>\n</details>\n\n<div id='clockSettingsModal' style='display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.6);backdrop-filter:blur(4px);z-index:9999;align-items:center;justify-content:center;'>\n  <div style='background:var(--surface);border-radius:16px;padding:24px;max-width:420px;width:90%;box-shadow:0 8px 32px rgba(0,0,0,0.3);border:1px solid var(--border);'>\n    <div style='display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;'>\n      <h3 style='margin:0;'>Clock Settings</h3>\n      <button onclick='closeClockSettings()' style='background:none;border:none;font-size:24px;cursor:pointer;color:var(--text);'>&times;</button>\n    </div>\n    \n    <div style='margin-bottom:14px;'>\n      <label style='display:block;font-size:0.8rem;font-weight:600;margin-bottom:4px;'>Font Family</label>\n      <select id='clockFontSelect' style='width:100%;padding:8px 12px;border:1px solid var(--border);border-radius:8px;background:var(--bg);color:var(--text);font-size:0.9rem;'>\n        <option value='monospace'>Monospace</option>\n        <option value='serif'>Serif</option>\n        <option value='sans-serif'>Sans-serif</option>\n        <option value='\"Courier New\",monospace'>Courier New</option>\n        <option value='\"Georgia\",serif'>Georgia</option>\n        <option value='\"Arial\",sans-serif'>Arial</option>\n        <option value='\"Impact\",sans-serif'>Impact</option>\n        <option value='\"Times New Roman\",serif'>Times New Roman</option>\n      </select>\n    </div>\n\n    <div style='margin-bottom:14px;'>\n      <label style='display:block;font-size:0.8rem;font-weight:600;margin-bottom:4px;'>Font Size</label>\n      <input type='range' id='clockSizeSlider' min='2' max='6' step='0.25' value='3.5' style='width:100%;'>\n      <div style='display:flex;justify-content:space-between;font-size:0.7rem;opacity:0.6;'>\n        <span>2rem</span>\n        <span id='clockSizeLabel'>3.5rem</span>\n        <span>6rem</span>\n      </div>\n    </div>\n\n    <div style='margin-bottom:14px;'>\n      <label style='display:block;font-size:0.8rem;font-weight:600;margin-bottom:4px;'>Color</label>\n      <input type='color' id='clockColorPicker' value='#547540' style='width:100%;height:40px;border:1px solid var(--border);border-radius:8px;cursor:pointer;'>\n    </div>\n\n    <div style='margin-bottom:14px;'>\n      <label style='display:block;font-size:0.8rem;font-weight:600;margin-bottom:4px;'>Clock Format</label>\n      <select id='clockFormatSelect' style='width:100%;padding:8px 12px;border:1px solid var(--border);border-radius:8px;background:var(--bg);color:var(--text);font-size:0.9rem;'>\n        <option value='24h'>24-hour (HH:MM:SS)</option>\n        <option value='12h'>12-hour (HH:MM:SS AM/PM)</option>\n        <option value='24h-no-sec'>24-hour (HH:MM)</option>\n        <option value='12h-no-sec'>12-hour (HH:MM AM/PM)</option>\n      </select>\n    </div>\n\n    <div style='margin-bottom:16px;'>\n      <label style='display:flex;align-items:center;gap:10px;cursor:pointer;'>\n        <input type='checkbox' id='clockShowDate' checked> \n        <span style='font-size:0.9rem;'>Show date</span>\n      </label>\n      <label style='display:flex;align-items:center;gap:10px;cursor:pointer;margin-top:6px;'>\n        <input type='checkbox' id='clockShowSeconds' checked> \n        <span style='font-size:0.9rem;'>Show seconds</span>\n      </label>\n    </div>\n\n    <button onclick='saveClockSettings()' style='width:100%;padding:10px;background:var(--accent);color:white;border:none;border-radius:8px;font-weight:600;cursor:pointer;'>\n      Apply Settings\n    </button>\n  </div>\n</div>",

  "css": "#clockFace { transition: all 0.3s ease; user-select: none; }\n#clockDetails summary h2 { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }\n#clockDetails summary { display: flex; align-items: center; justify-content: space-between; }\n#clockDetails .clock-preview { font-size: 0.8rem; opacity: 0.7; margin-left: 6px; }\n#clockSettingsModal input[type='color']::-webkit-color-swatch-wrapper { padding: 2px; }\n#clockSettingsModal input[type='color']::-webkit-color-swatch { border: none; border-radius: 4px; }#clockDetails summary {display: none;}",

  "js": "var clockInterval=null;var clockSettings={font:'monospace',size:'3.5',color:'#547540',format:'24h',showDate:true,showSeconds:true};function loadClockSettings(){try{var e=localStorage.getItem('clockSettings');if(e){var t=JSON.parse(e);Object.assign(clockSettings,t)}}catch(e){console.warn('Failed to load clock settings:',e)}applyClockSettings()}function applyClockSettings(){var e=document.getElementById('clockFace');if(!e)return;e.style.fontFamily=clockSettings.font;e.style.fontSize=clockSettings.size+'rem';e.style.color=clockSettings.color;var t=document.getElementById('clockColorPicker');if(t)t.value=clockSettings.color;var n=document.getElementById('clockFontSelect');if(n)n.value=clockSettings.font;var o=document.getElementById('clockSizeSlider');if(o)o.value=clockSettings.size;var l=document.getElementById('clockSizeLabel');if(l)l.textContent=clockSettings.size+'rem';var s=document.getElementById('clockFormatSelect');if(s)s.value=clockSettings.format;var r=document.getElementById('clockShowDate');if(r)r.checked=clockSettings.showDate;var i=document.getElementById('clockShowSeconds');if(i)i.checked=clockSettings.showSeconds}function updateClock(){var e=new Date;var t=clockSettings.format;var n=clockSettings.showDate;var o=clockSettings.showSeconds;var l=document.getElementById('clockHours');var s=document.getElementById('clockMinutes');var r=document.getElementById('clockSeconds');var i=document.getElementById('clockColon');var a=document.getElementById('clockSecondsDisplay');var c=document.getElementById('clockDateDisplay');var d=document.getElementById('clockDisplay');var u=document.getElementById('clockDate');var p=document.getElementById('clockFace');if(!l||!s||!r||!p)return;var m=e.getHours();var h=e.getMinutes();var v=e.getSeconds();var f='';var g='';if(t.startsWith('12h')){var y=m%12||12;g=m>=12?' PM':' AM';f=y.toString().padStart(2,'0')}else{f=m.toString().padStart(2,'0')}l.textContent=f;s.textContent=h.toString().padStart(2,'0');r.textContent=v.toString().padStart(2,'0');if(t.includes('no-sec')){a.style.display='none';i.style.display='none';if(d){d.textContent=f+':'+h.toString().padStart(2,'0')+g}}else{a.style.display='';i.style.display='';if(d){d.textContent=f+':'+h.toString().padStart(2,'0')+':'+v.toString().padStart(2,'0')+g}}if(d&&t.startsWith('12h')){d.textContent+=g}if(n){var b=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];var w=['January','February','March','April','May','June','July','August','September','October','November','December'];var C=b[e.getDay()];var S=e.getDate();var k=w[e.getMonth()];var A=e.getFullYear();var M=C+', '+S+' '+k+' '+A;if(c)c.textContent=M;if(u)u.textContent=M}else{if(c)c.textContent='';if(u)u.textContent=''}}function openClockSettings(){var e=document.getElementById('clockSettingsModal');if(e){e.style.display='flex';document.body.style.overflow='hidden';applyClockSettings()}}function closeClockSettings(){var e=document.getElementById('clockSettingsModal');if(e){e.style.display='none';document.body.style.overflow=''}}function saveClockSettings(){var e=document.getElementById('clockFontSelect');var t=document.getElementById('clockSizeSlider');var n=document.getElementById('clockColorPicker');var o=document.getElementById('clockFormatSelect');var l=document.getElementById('clockShowDate');var s=document.getElementById('clockShowSeconds');if(e)clockSettings.font=e.value;if(t){clockSettings.size=t.value;var r=document.getElementById('clockSizeLabel');if(r)r.textContent=t.value+'rem'}if(n)clockSettings.color=n.value;if(o)clockSettings.format=o.value;if(l)clockSettings.showDate=l.checked;if(s)clockSettings.showSeconds=s.checked;localStorage.setItem('clockSettings',JSON.stringify(clockSettings));applyClockSettings();closeClockSettings();updateClock();if(clockInterval){clearInterval(clockInterval);clockInterval=null}clockInterval=setInterval(updateClock,1e3)}function initClock(){loadClockSettings();updateClock();if(!clockInterval){clockInterval=setInterval(updateClock,1e3)}var e=document.getElementById('clockSizeSlider');if(e){e.addEventListener('input',function(){var t=document.getElementById('clockSizeLabel');if(t)t.textContent=this.value+'rem'})}}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',initClock)}else{initClock()}window.addEventListener('keydown',function(e){if(e.key==='Escape'){closeClockSettings()}})",

  "target": "header"
}