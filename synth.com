CUSTOMHTML-START
<style>
*{margin:0;padding:0;box-sizing:border-box}body{font-family:"Courier New",Courier,"Lucida Sans Typewriter",monospace;background:#f0ede8;color:#1e1c19;padding:16px 16px 100px;min-height:100vh;line-height:1.5}.header{border-bottom:2px solid #1e1c19;padding-bottom:10px;margin-bottom:20px;display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:8px}.header h1{font-size:26px;font-weight:700;letter-spacing:-.5px;text-transform:uppercase}.header .meta{font-size:13px;color:#5a5550}.btn{font-family:"Courier New",monospace;background:0 0;border:2px solid #1e1c19;padding:6px 14px;font-size:13px;font-weight:600;color:#1e1c19;cursor:pointer;transition:background .15s,color .15s;touch-action:manipulation;text-transform:uppercase;letter-spacing:.3px}.btn:active{background:#1e1c19;color:#f0ede8}.btn.primary{background:#1e1c19;color:#f0ede8}.btn.primary:active{background:#3a3632}.btn.danger{border-color:#8f3f3a;color:#8f3f3a}.btn.danger:active{background:#8f3f3a;color:#f0ede8}.btn.small{padding:4px 10px;font-size:11px}.row{display:flex;gap:8px;flex-wrap:wrap;align-items:center}.mb-8{margin-bottom:8px}.mb-12{margin-bottom:12px}.mb-16{margin-bottom:16px}.mt-8{margin-top:8px}.flex-between{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:6px}.piano{display:flex;width:100%;height:140px;margin:12px 0 16px;border:2px solid #1e1c19;background:#d6d0c6;position:relative;overflow:hidden}.key{flex:1;display:flex;align-items:flex-end;justify-content:center;padding-bottom:8px;font-size:10px;font-weight:700;cursor:pointer;touch-action:manipulation;user-select:none;transition:background .08s;border-right:1px solid #b0aaa0;background:#fcfaf7;color:#1e1c19;font-family:"Courier New",monospace;text-transform:uppercase;position:relative;z-index:1}.key:active,.key.active{background:#d4c8b8;transform:scale(.98)}.key:last-child{border-right:none}.key.black{background:#1e1c19;color:#f0ede8;border-right:1px solid #3a3632;flex:.65;margin-left:-12px;margin-right:-12px;z-index:2;height:62%;align-self:flex-start;padding-bottom:4px;font-size:9px;border-bottom:2px solid #1e1c19}.key.black:active,.key.black.active{background:#3a3632;transform:scale(.96)}.key .note-label{font-size:9px;opacity:.6;pointer-events:none}.key.black .note-label{opacity:.7;font-size:8px}.controls-panel{border:2px solid #1e1c19;padding:12px;background:#fcfaf7;margin-bottom:14px;display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px}.control-group{display:flex;flex-direction:column;gap:4px;font-size:11px;font-weight:700;text-transform:uppercase;color:#5a5550}.control-group span{font-size:10px;color:#7a756e;margin-left:4px}.control-group input[type=range]{-webkit-appearance:none;appearance:none;width:100%;background:#ede9e2;border:1px solid #b0aaa0;height:6px;outline:none}.control-group input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:12px;height:14px;background:#1e1c19;cursor:pointer;border:none}.control-group select{font-family:"Courier New",monospace;font-size:11px;font-weight:600;padding:4px;border:2px solid #1e1c19;background:#fcfaf7;outline:none;text-transform:uppercase}.sequencer{border:2px solid #1e1c19;padding:14px 12px;background:#fcfaf7;margin-bottom:14px;overflow-x:auto}.seq-controls{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:10px}.seq-grid{display:grid;grid-template-columns:54px repeat(16,1fr);gap:2px;min-width:460px}.seq-grid .step-label{font-size:10px;font-weight:700;text-transform:uppercase;color:#5a5550;display:flex;align-items:center;padding-right:4px;justify-content:flex-end}.seq-step{background:#ede9e2;border:1px solid #d6d0c6;aspect-ratio:1;min-height:24px;cursor:pointer;touch-action:manipulation;transition:background .1s;display:flex;align-items:center;justify-content:center;font-size:8px;color:#b0aaa0}.seq-step.active{background:#6a4c9c;border-color:#6a4c9c}.seq-step.active.current{background:#8b6cb0;border-color:#8b6cb0;box-shadow:inset 0 0 0 2px #f0ede8}.seq-step.current{background:#d6d0c6;border-color:#b0aaa0}.seq-step.playing{background:#4a7c59;border-color:#4a7c59}.seq-step.playing.current{background:#5a9c6e;border-color:#5a9c6e;box-shadow:inset 0 0 0 2px #f0ede8}.tune-list{border:2px solid #1e1c19;padding:12px 14px;background:#fcfaf7;margin-top:12px}.tune-item{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid #e0dad2;flex-wrap:wrap;gap:6px}.tune-item:last-child{border-bottom:none}.tune-item .name{font-weight:600;font-size:14px}.tune-item .info{font-size:12px;color:#5a5550}.empty-state{text-align:center;padding:24px 10px;color:#7a756e;font-size:14px}.toast{position:fixed;bottom:88px;left:50%;transform:translateX(-50%);background:#1e1c19;color:#f0ede8;padding:10px 24px;font-size:13px;font-family:"Courier New",monospace;border:2px solid #1e1c19;opacity:0;transition:opacity .25s;pointer-events:none;z-index:200;text-align:center;white-space:nowrap}.toast.show{opacity:1}@media(max-width:600px){.piano{height:100px}.key{font-size:8px;padding-bottom:4px}.key.black{height:55%;font-size:7px;margin-left:-8px;margin-right:-8px}.seq-grid{min-width:360px;grid-template-columns:42px repeat(16,1fr)}.seq-step{min-height:20px}.header h1{font-size:20px}}@media(max-width:420px){.piano{height:80px}.key{font-size:7px}.key.black{height:50%;font-size:6px;margin-left:-6px;margin-right:-6px}.seq-grid{min-width:300px;grid-template-columns:36px repeat(16,1fr)}.seq-step{min-height:16px;font-size:6px}}
</style>
<div class="header"><div><h1>🎹 Melody Studio</h1><div class="meta">polyphonic programmable synthesizer & engine matrix</div></div></div><div class="row mb-12" style="background:#fcfaf7;border:2px solid #1e1c19;padding:8px 12px;display:inline-flex;align-items:center"><span style="font-size:11px;font-weight:700;text-transform:uppercase;color:#5a5550;margin-right:8px">Piano Octave Range:</span><button class="btn small" id="octDownBtn" style="padding:2px 8px">-</button><span id="octDisplay" style="font-family:monospace;font-weight:700;font-size:14px;margin:0 12px">4</span><button class="btn small" id="octUpBtn" style="padding:2px 8px">+</button></div><div class="piano" id="piano"></div><div class="controls-panel"><div class="control-group"><label>Waveform</label><select id="waveSelect"><option value="sine">Sine (Soft)</option><option value="triangle" selected="selected">Triangle (Warm)</option><option value="sawtooth">Sawtooth (Bright)</option><option value="square">Square (Retro)</option></select></div><div class="control-group"><label>Tempo:<span id="bpmVal">120</span>BPM</label><input type="range" id="bpmSlider" min="50" max="220" value="120"></div><div class="control-group"><label>Filter Cutoff:<span id="cutoffVal">20000Hz</span></label><input type="range" id="cutoffSlider" min="100" max="20000" step="100" value="20000"></div><div class="control-group"><label>Resonance:<span id="qVal">0.1</span></label><input type="range" id="qSlider" min="0.1" max="12" step="0.1" value="0.1"></div><div class="control-group"><label>Attack:<span id="attackVal">0.02s</span></label><input type="range" id="attackSlider" min="0.001" max="0.4" step="0.01" value="0.02"></div><div class="control-group"><label>Release:<span id="releaseVal">0.20s</span></label><input type="range" id="releaseSlider" min="0.05" max="1.5" step="0.05" value="0.20"></div><div class="control-group"><label>Space Delay:<span id="delayMixVal">0%</span></label><input type="range" id="delayMixSlider" min="0" max="0.75" step="0.05" value="0"></div></div><div class="sequencer"><div class="seq-controls"><button class="btn primary small" id="playBtn">▶ Play</button><button class="btn small" id="stopBtn">■ Stop</button><button class="btn small" id="clearSeqBtn">✕ Clear Grid</button><div style="flex:1;min-width:20px"></div><span style="font-size:12px;color:#5a5550;font-weight:700" id="stepDisplay">Step: 1/16</span><button class="btn small" id="saveTuneBtn">💾 Save Matrix</button></div><div class="seq-grid" id="seqGrid"></div></div><div class="tune-list"><div class="flex-between mb-8"><strong style="font-size:14px;text-transform:uppercase;letter-spacing:.5px">Stored Presets</strong><span style="font-size:12px;color:#5a5550" id="tuneCount">0 tunes</span></div><div id="tuneContainer"><div class="empty-state">No saved tunes yet.</div></div></div><div id="toast" class="toast"></div>
