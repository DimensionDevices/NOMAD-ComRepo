{
  "html": "<details class='section' id='statsTracker'><summary><h2><svg style='position:relative;top:6px' width='24px' height='24px' viewBox='0 0 24 24' fill='none' stroke='var(--text)' stroke-width='2'><path d='M21 12v-2a5 5 0 0 0-5-5H8a5 5 0 0 0-5 5v2'/><circle cx='12' cy='16' r='5'/><path d='M12 11v5'/><path d='M9 13l3 3 3-3'/></svg>&nbsp;Stats Tracker</h2></summary><div style='padding:12px 0;'><div style='display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px;margin-bottom:12px;'><div style='background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;'><div style='font-size:.6em;text-transform:uppercase;color:var(--text-dim);letter-spacing:.3px;'>Total Uptime</div><div style='font-size:1.2em;font-weight:700;' id='statUptime'>0h</div></div><div style='background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;'><div style='font-size:.6em;text-transform:uppercase;color:var(--text-dim);letter-spacing:.3px;'>Total Uptime (All Time)</div><div style='font-size:1.2em;font-weight:700;' id='statTotalUptime'>0h</div></div><div style='background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;'><div style='font-size:.6em;text-transform:uppercase;color:var(--text-dim);letter-spacing:.3px;'>Sessions</div><div style='font-size:1.2em;font-weight:700;' id='statSessions'>0</div></div><div style='background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;'><div style='font-size:.6em;text-transform:uppercase;color:var(--text-dim);letter-spacing:.3px;'>Longest Session</div><div style='font-size:1.2em;font-weight:700;' id='statLongestSession'>0h</div></div><div style='background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;'><div style='font-size:.6em;text-transform:uppercase;color:var(--text-dim);letter-spacing:.3px;'>Files Created</div><div style='font-size:1.2em;font-weight:700;' id='statFilesCreated'>0</div></div><div style='background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;'><div style='font-size:.6em;text-transform:uppercase;color:var(--text-dim);letter-spacing:.3px;'>Files Uploaded</div><div style='font-size:1.2em;font-weight:700;' id='statFilesUploaded'>0</div></div><div style='background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;'><div style='font-size:.6em;text-transform:uppercase;color:var(--text-dim);letter-spacing:.3px;'>Files Deleted</div><div style='font-size:1.2em;font-weight:700;' id='statFilesDeleted'>0</div></div><div style='background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;'><div style='font-size:.6em;text-transform:uppercase;color:var(--text-dim);letter-spacing:.3px;'>Files Downloaded</div><div style='font-size:1.2em;font-weight:700;' id='statFilesDownloaded'>0</div></div><div style='background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;'><div style='font-size:.6em;text-transform:uppercase;color:var(--text-dim);letter-spacing:.3px;'>Messages Sent</div><div style='font-size:1.2em;font-weight:700;' id='statMessagesSent'>0</div></div><div style='background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;'><div style='font-size:.6em;text-transform:uppercase;color:var(--text-dim);letter-spacing:.3px;'>Messages Received</div><div style='font-size:1.2em;font-weight:700;' id='statMessagesReceived'>0</div></div><div style='background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;'><div style='font-size:.6em;text-transform:uppercase;color:var(--text-dim);letter-spacing:.3px;'>Nodes Discovered</div><div style='font-size:1.2em;font-weight:700;' id='statNodesDiscovered'>0</div></div><div style='background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;'><div style='font-size:.6em;text-transform:uppercase;color:var(--text-dim);letter-spacing:.3px;'>Peak Nodes</div><div style='font-size:1.2em;font-weight:700;' id='statPeakNodes'>0</div></div><div style='background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;'><div style='font-size:.6em;text-transform:uppercase;color:var(--text-dim);letter-spacing:.3px;'>Lowest Memory</div><div style='font-size:1.2em;font-weight:700;' id='statLowestMemory'>0kB</div></div><div style='background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;'><div style='font-size:.6em;text-transform:uppercase;color:var(--text-dim);letter-spacing:.3px;'>Highest Temp</div><div style='font-size:1.2em;font-weight:700;' id='statHighestTemp'>0°C</div></div></div><div style='display:flex;gap:8px;justify-content:center;flex-wrap:wrap;'><button class='btn btn-small' id='resetStatsBtn' style='background:#f44336;color:#fff;border:none;padding:6px 16px;border-radius:6px;cursor:pointer;'>Reset All Stats</button><button class='btn btn-small' id='exportStatsBtn' style='background:var(--accent);color:#fff;border:none;padding:6px 16px;border-radius:6px;cursor:pointer;'>Export Stats</button></div></div></details>",
  "css": "#statsTracker .section { margin-bottom: 12px; } #statsTracker summary h2 { display: flex; align-items: center; gap: 8px; }",
  "js": "(function(){'use strict';var STATS_KEY='nomad_stats_tracker';var SESSION_KEY='nomad_session_start';function getStats(){try{var data=localStorage.getItem(STATS_KEY);if(data){return JSON.parse(data)}}catch(e){}return{uptime:0,totalUptime:0,sessions:0,longestSession:0,filesCreated:0,filesUploaded:0,filesDeleted:0,filesDownloaded:0,messagesSent:0,messagesReceived:0,nodesDiscovered:0,peakNodes:0,lowestMemory:999999,highestTemp:0}}function saveStats(stats){try{localStorage.setItem(STATS_KEY,JSON.stringify(stats))}catch(e){}}function updateUptime(){var stats=getStats();var sessionStart=parseInt(localStorage.getItem(SESSION_KEY)||Date.now());var sessionSeconds=Math.floor((Date.now()-sessionStart)/1000);stats.uptime=sessionSeconds;saveStats(stats);renderStats()}function formatTime(seconds){if(seconds<60)return seconds+'s';if(seconds<3600)return Math.floor(seconds/60)+'m';if(seconds<86400)return Math.floor(seconds/3600)+'h';return Math.floor(seconds/86400)+'d'}function renderStats(){var stats=getStats();var uptime=document.getElementById('statUptime');var totalUptime=document.getElementById('statTotalUptime');var sessions=document.getElementById('statSessions');var longest=document.getElementById('statLongestSession');var filesCreated=document.getElementById('statFilesCreated');var filesUploaded=document.getElementById('statFilesUploaded');var filesDeleted=document.getElementById('statFilesDeleted');var filesDownloaded=document.getElementById('statFilesDownloaded');var messagesSent=document.getElementById('statMessagesSent');var messagesReceived=document.getElementById('statMessagesReceived');var nodesDiscovered=document.getElementById('statNodesDiscovered');var peakNodes=document.getElementById('statPeakNodes');var lowestMemory=document.getElementById('statLowestMemory');var highestTemp=document.getElementById('statHighestTemp');if(uptime)uptime.textContent=formatTime(stats.uptime);if(totalUptime)totalUptime.textContent=formatTime(stats.totalUptime);if(sessions)sessions.textContent=stats.sessions;if(longest)longest.textContent=formatTime(stats.longestSession);if(filesCreated)filesCreated.textContent=stats.filesCreated;if(filesUploaded)filesUploaded.textContent=stats.filesUploaded;if(filesDeleted)filesDeleted.textContent=stats.filesDeleted;if(filesDownloaded)filesDownloaded.textContent=stats.filesDownloaded;if(messagesSent)messagesSent.textContent=stats.messagesSent;if(messagesReceived)messagesReceived.textContent=stats.messagesReceived;if(nodesDiscovered)nodesDiscovered.textContent=stats.nodesDiscovered;if(peakNodes)peakNodes.textContent=stats.peakNodes;if(lowestMemory)lowestMemory.textContent=(stats.lowestMemory===999999?'N/A':stats.lowestMemory+'kB');if(highestTemp)highestTemp.textContent=(stats.highestTemp===0?'N/A':stats.highestTemp.toFixed(1)+'°C')}function incrementStat(key,amount){amount=amount||1;var stats=getStats();if(stats[key]!==undefined){stats[key]+=amount;saveStats(stats);renderStats()}}function trackSession(){var sessionStart=parseInt(localStorage.getItem(SESSION_KEY));if(!sessionStart||sessionStart===0){localStorage.setItem(SESSION_KEY,String(Date.now()));var stats=getStats();stats.sessions++;saveStats(stats);renderStats();return}var now=Date.now();var sessionSeconds=Math.floor((now-sessionStart)/1000);if(sessionSeconds>0){var stats=getStats();stats.totalUptime+=sessionSeconds;if(sessionSeconds>stats.longestSession){stats.longestSession=sessionSeconds}saveStats(stats)}localStorage.setItem(SESSION_KEY,String(now))}function prePopulateStats(){var stats=getStats();var needsSave=false;fetch('/api/files').then(function(r){return r.json()}).then(function(data){if(data&&data.files){var count=data.files.length;if(stats.filesCreated===0&&stats.filesUploaded===0){stats.filesCreated=count;stats.filesUploaded=count;needsSave=true}}if(needsSave){saveStats(stats);renderStats()}}).catch(function(){});var nodeCountEl=document.getElementById('nodeCount');if(nodeCountEl){var count=parseInt(nodeCountEl.textContent)||0;if(count>0&&stats.nodesDiscovered===0){stats.nodesDiscovered=count;stats.peakNodes=count;needsSave=true;saveStats(stats);renderStats()}}var freeHeapEl=document.getElementById('freeHeap');if(freeHeapEl){var text=freeHeapEl.textContent;var match=text.match(/(\\d+)/);if(match){var kb=parseInt(match[1]);if(kb>0&&kb<stats.lowestMemory){stats.lowestMemory=kb;needsSave=true;saveStats(stats);renderStats()}}}var tempEl=document.getElementById('theTemp');if(tempEl){var tempText=tempEl.textContent;var match=tempText.match(/(\\d+\\.?\\d*)/);if(match){var temp=parseFloat(match[1]);if(temp>0&&temp>stats.highestTemp){stats.highestTemp=temp;needsSave=true;saveStats(stats);renderStats()}}}if(needsSave){saveStats(stats);renderStats()}}function hookFunctions(){var origUpload=window.uploadFile;if(origUpload){window.uploadFile=function(e){var result=origUpload(e);incrementStat('filesUploaded');return result}}var origDeleteFile=window.deleteFile;if(origDeleteFile){window.deleteFile=function(e){var result=origDeleteFile(e);if(result!==undefined&&result!==false){incrementStat('filesDeleted')}return result}}var origCreateFile=window.createFile;if(origCreateFile){window.createFile=function(){var result=origCreateFile.apply(this,arguments);if(result&&result!==false){incrementStat('filesCreated')}return result}}var origDownload=window.downloadFile;if(origDownload){window.downloadFile=function(e){var result=origDownload(e);incrementStat('filesDownloaded');return result}}var origSend=window.sendChatMessage;if(origSend){window.sendChatMessage=function(){var result=origSend.apply(this,arguments);incrementStat('messagesSent');return result}}var origPoll=window.pollChatMessages;if(origPoll){window.pollChatMessages=function(){var result=origPoll.apply(this,arguments);var msgs=document.querySelectorAll('#chatWindow .chat-msg:not(.processed)');msgs.forEach(function(el){el.classList.add('processed');incrementStat('messagesReceived')});return result}}var origRenderNodes=window.renderNodes;if(origRenderNodes){window.renderNodes=function(e){var result=origRenderNodes(e);if(e&&e.length>0){var count=e.length;var stats=getStats();if(count>stats.peakNodes){stats.peakNodes=count;saveStats(stats)}if(count>stats.nodesDiscovered){stats.nodesDiscovered=count;saveStats(stats)}renderStats()}return result}}var origRefreshStatus=window.refreshStatus;if(origRefreshStatus){window.refreshStatus=function(){var result=origRefreshStatus.apply(this,arguments);setTimeout(function(){var freeHeapEl=document.getElementById('freeHeap');if(freeHeapEl){var text=freeHeapEl.textContent;var match=text.match(/(\\d+)/);if(match){var kb=parseInt(match[1]);if(kb>0){var stats=getStats();if(kb<stats.lowestMemory){stats.lowestMemory=kb;saveStats(stats);renderStats()}}}}} ,100);var tempEl=document.getElementById('theTemp');if(tempEl){var tempText=tempEl.textContent;var match=tempText.match(/(\\d+\\.?\\d*)/);if(match){var temp=parseFloat(match[1]);if(temp>0){var stats=getStats();if(temp>stats.highestTemp){stats.highestTemp=temp;saveStats(stats);renderStats()}}}}return result}}}
function resetStats(){if(confirm('Reset all statistics? This cannot be undone.')){localStorage.removeItem(STATS_KEY);localStorage.removeItem(SESSION_KEY);trackSession();prePopulateStats();renderStats()}}function exportStats(){var stats=getStats();var text='NOMAD Stats Export\\n';text+='==================\\n\\n';text+='Total Uptime: '+formatTime(stats.totalUptime)+'\\n';text+='Current Session: '+formatTime(stats.uptime)+'\\n';text+='Sessions: '+stats.sessions+'\\n';text+='Longest Session: '+formatTime(stats.longestSession)+'\\n\\n';text+='Files Created: '+stats.filesCreated+'\\n';text+='Files Uploaded: '+stats.filesUploaded+'\\n';text+='Files Deleted: '+stats.filesDeleted+'\\n';text+='Files Downloaded: '+stats.filesDownloaded+'\\n\\n';text+='Messages Sent: '+stats.messagesSent+'\\n';text+='Messages Received: '+stats.messagesReceived+'\\n\\n';text+='Nodes Discovered: '+stats.nodesDiscovered+'\\n';text+='Peak Nodes: '+stats.peakNodes+'\\n';text+='Lowest Memory: '+(stats.lowestMemory===999999?'N/A':stats.lowestMemory+'kB')+'\\n';text+='Highest Temp: '+(stats.highestTemp===0?'N/A':stats.highestTemp.toFixed(1)+'°C')+'\\n\\n';text+='Exported: '+new Date().toLocaleString();var blob=new Blob([text],{type:'text/plain'});var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='nomad_stats_'+Date.now()+'.txt';document.body.appendChild(a);a.click();document.body.removeChild(a);URL.revokeObjectURL(a.href)}function init(){trackSession();renderStats();prePopulateStats();hookFunctions();setInterval(function(){trackSession();updateUptime();renderStats()},30000);setInterval(function(){var stats=getStats();var tempEl=document.getElementById('theTemp');if(tempEl){var tempText=tempEl.textContent;var match=tempText.match(/(\\d+\\.?\\d*)/);if(match){var temp=parseFloat(match[1]);if(temp>0&&temp>stats.highestTemp){stats.highestTemp=temp;saveStats(stats);renderStats()}}}var freeHeapEl=document.getElementById('freeHeap');if(freeHeapEl){var text=freeHeapEl.textContent;var match=text.match(/(\\d+)/);if(match){var kb=parseInt(match[1]);if(kb>0&&kb<stats.lowestMemory){stats.lowestMemory=kb;saveStats(stats);renderStats()}}}},10000);var resetBtn=document.getElementById('resetStatsBtn');if(resetBtn)resetBtn.addEventListener('click',resetStats);var exportBtn=document.getElementById('exportStatsBtn');if(exportBtn)exportBtn.addEventListener('click',exportStats)}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',init)}else{init()}})();",
  "target": "footer"
}